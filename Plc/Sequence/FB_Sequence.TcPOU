      <Declaration><![CDATA[PROPERTY P_nCount : UINT]]></Declaration>
      <Get Name="Get" Id="{9150198e-4488-4c86-ac46-7d4532fad654}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nCount := fbStepList.P_nCount;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_nId" Id="{e547e7f2-fb5a-429b-b4a4-fee4174c089d}">
      <Declaration><![CDATA[PROPERTY P_nId : UDINT]]></Declaration>
      <Get Name="Get" Id="{ad6c8f77-ea12-426b-9d39-1966d8345f16}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nId := nId;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{3e63581d-45bf-4273-8fd6-fa523cef5298}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[nId := P_nId;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="P_nProgress" Id="{53f88210-c8db-45b4-9126-ea9ac38d495a}">
      <Declaration><![CDATA[PROPERTY P_nProgress : UINT]]></Declaration>
      <Get Name="Get" Id="{27be711f-2187-419c-883b-e3e8ef2c6a07}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[//Gibt den Fortschritt in % an (momentan auf Anzahl abgearbeiteter Schritte bezogen)
P_nProgress := 100 * nStepsReady / fbStepList.P_nCount;
]]></ST>
        </Implementation>
      </Get>
    </Property>
