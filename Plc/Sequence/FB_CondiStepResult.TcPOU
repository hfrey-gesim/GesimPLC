<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4022.10">
  <POU Name="FB_CondiStepResult" Id="{72836e5d-189d-419c-a7fd-efb986e596ad}" SpecialFunc="None">
    <Declaration><![CDATA[{attribute 'enable_dynamic_creation'}
FUNCTION_BLOCK FB_CondiStepResult EXTENDS FB_CondiBase
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	pStep 			: POINTER TO ST_Step;
	eCompareOperator: E_CompOperator;
	nCompareValue 	: DINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
