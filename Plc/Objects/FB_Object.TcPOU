    <Method Name="M_RemoveChild" Id="{a4fdd1a9-85af-4d60-804f-2b95973c7db4}">
      <Declaration><![CDATA[METHOD M_RemoveChild : ERRORID
VAR_INPUT
	pObject	: POINTER TO FB_Object;
END_VAR

VAR
	iter : FB_ObjCollectIterator;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Das Objekt in der Collection suchen (flach)
pObjCollectNode^.nodes.M_GetIterator(iter);
WHILE iter.pNode > 0 DO
	IF iter.pNode^.P_pObject = pObject THEN
		//Falls Object an einem Slot, von diesem entfernen
		IF pObject^.P_pParentSlot > 0 THEN
			pObject^.P_pParentSlot^.P_pChild := 0;
		END_IF
		pObjCollectNode^.nodes.M_RemoveNode(iter.pNode);
		pObject^.M_UpdateParent();
		EXIT;
	END_IF
	iter.M_Increment();
END_WHILE

IF iter.pNode = 0 THEN
	M_RemoveChild := E_ErrorIdObjMgmt.ERRORID_ObjectNotInCollection;
END_IF]]></ST>
      </Implementation>
    </Method>
