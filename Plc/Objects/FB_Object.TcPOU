    <Method Name="M_GetSlotFromChild" Id="{8851af2f-0e6f-4d0a-81d3-b945a799be53}">
      <Declaration><![CDATA[METHOD M_GetSlotFromChild : POINTER TO FB_Slot
VAR_INPUT
	pObject : POINTER TO FB_Object;
END_VAR]]></Declaration>
