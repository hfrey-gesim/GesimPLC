	pObjCollectNode		: POINTER TO FB_ObjCollectionNode;
	pParentSlot			: POINTER TO FB_Slot;
	nNoOfProps			: UINT;
	wChecksum			: WORD;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[//Basisklasse für alle Objekte]]></ST>
    </Implementation>
