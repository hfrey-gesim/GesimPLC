          <ST><![CDATA[IF pObjCollectNode > 0 AND_THEN pObjCollectNode^.pOwnerColl > 0 AND_THEN pObjCollectNode^.pOwnerColl^.pOwnerNode > 0 THEN
	P_pParentObject := pObjCollectNode^.pOwnerColl^.pOwnerNode^.P_pObject;
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
