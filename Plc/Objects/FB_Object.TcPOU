]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_bHasChilds := pObjCollectNode > 0 and_then pObjCollectNode^.nodes.nCount > 0;]]></ST>
        </Implementation>
      </Get>
    </Property>
