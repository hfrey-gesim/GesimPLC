    <Method Name="M_RemoveListEntry" Id="{5dced78b-fb65-4483-8dc5-f4c70eb42ea3}">
      <Declaration><![CDATA[METHOD M_RemoveListEntry : BOOL
VAR_INPUT
	nSearchValue	: E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[getPosPtr := 0;(* start from first node element *)
fbList.A_FindNext( hList := hList, putPosPtr := getPosPtr, putValue := nSearchValue, getValue=>getValue, getPosPtr=>getPosPtr );
IF fbList.bOk THEN	//Eintrag wurde gefunden
	fbList.A_RemoveValueAtPosPtr(hList:= hList,	putPosPtr:= getPosPtr);
	IF fbList.bOk THEN
		M_RemoveListEntry := TRUE;
	END_IF
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Reset" Id="{e230c62a-0142-4b1f-8e24-d4e5fa14f7b8}">
      <Declaration><![CDATA[METHOD M_Reset
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bBusy := TRUE;
bFlagA_ResetBase := TRUE;
eCurrentState := E_MachineState.MACHINESTATE_Reset;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetAllProps" Id="{374f7038-b5aa-4675-ae03-134893e7892b}">
      <Declaration><![CDATA[METHOD M_SetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR

VAR
	nMzToolObjId		: UINT;
	nParentMzToolObjId	: UINT;
	i 					: UINT;
	pSlot 				: POINTER TO FB_Slot;
	stTempPos 			: ST_3DPoint;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[
//RelPos setzen
stRelPos.X:= DINT_TO_REAL(refCmdData.n32Data[2]);
stRelPos.Y:= DINT_TO_REAL(refCmdData.n32Data[3]);
stRelPos.Z:= DINT_TO_REAL(refCmdData.n32Data[4]);
//Offset setzen
stOffset.X:= DINT_TO_REAL(refCmdData.n32Data[5]);
stOffset.Y:= DINT_TO_REAL(refCmdData.n32Data[6]);
stOffset.Z:= DINT_TO_REAL(refCmdData.n32Data[7]);

nCurrentPropIndex := 8;

//Slots parametrieren
nFirstSlotPropIndex := nCurrentPropIndex;
nNumberOfSlots := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);

//Falls SlotList noch nicht existiert, dann neue erstellen
IF fbSlotList.P_nCount = 0 THEN
	FOR i:= 1 TO nNumberOfSlots BY 1 DO
		pSlot := __NEW(FB_Slot(pOwner := THIS));
		fbSlotList.M_Add(pSlot);
		nCurrentPropIndex := nCurrentPropIndex + 1;
		pSlot^.P_nNr := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
		nCurrentPropIndex := nCurrentPropIndex + 1;
		stTempPos.X := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
		nCurrentPropIndex := nCurrentPropIndex + 1;
		stTempPos.Y := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
		nCurrentPropIndex := nCurrentPropIndex + 1;
		stTempPos.Z := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
		pSlot^.P_stRelPos := stTempPos;
	END_FOR
ELSE
	IF nNumberOfSlots <> fbSlotList.P_nCount THEN
		M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_ChangeNoOfSlotsNotAllowed;
		RETURN;
	END_IF
	FOR i:= 1 TO nNumberOfSlots BY 1 DO
		nCurrentPropIndex := nCurrentPropIndex + 1;
		pSlot := fbSlotList.M_GetAtNr(DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]));
		IF pSlot > 0 THEN
			nCurrentPropIndex := nCurrentPropIndex + 1;
			stTempPos.X := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
			nCurrentPropIndex := nCurrentPropIndex + 1;
			stTempPos.Y := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
			nCurrentPropIndex := nCurrentPropIndex + 1;
			stTempPos.Z := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
			pSlot^.P_stRelPos := stTempPos;
		ELSE
			M_SetAllProps := 222;
			RETURN;
		END_IF
	END_FOR
END_IF
nLastSlotPropIndex := nCurrentPropIndex;

nNoOfProps := nCurrentPropIndex + 1;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSingleProp" Id="{5f29e294-b3c2-486b-956f-da1989a82a3d}">
      <Declaration><![CDATA[METHOD M_SetSingleProp : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR

VAR
	nSlotIndex	: UINT;
	nIndex		: UINT;
	pSlot		: POINTER TO FB_Slot;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Basisproperties schreiben
CASE refCmdData.aHeader[1] OF	//Property-Nr
	2:	//RelPosX
		stRelPos.X := DINT_TO_REAL(refCmdData.n32Data[0]);
	3:	//RelPosY
		stRelPos.Y := DINT_TO_REAL(refCmdData.n32Data[0]);
	4:	//RelPosZ
		stRelPos.Z := DINT_TO_REAL(refCmdData.n32Data[0]);
	5:	//OffsetY
		stOffset.X := DINT_TO_REAL(refCmdData.n32Data[0]);
	6:	//OffsetY
		stOffset.Y := DINT_TO_REAL(refCmdData.n32Data[0]);
	7:	//OffsetY
		stOffset.Z := DINT_TO_REAL(refCmdData.n32Data[0]);
	8:	//NumberOfSlots
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	ELSE
		//Handelt es sich bei dem PropNr um eine SlotPropNr?
		IF refCmdData.aHeader[1] >= nFirstSlotPropIndex AND refCmdData.aHeader[1] <= nLastSlotPropIndex THEN
			nIndex := (refCmdData.aHeader[1]- nFirstSlotPropIndex);	
			IF nIndex MOD 4 = 0 THEN
				nSlotIndex := nIndex / 4;
			ELSE
				nSlotIndex := nIndex / 4 + 1;
			END_IF		
			pSlot := fbSlotList.M_GetAtIndex(nSlotIndex);
			IF pSlot > 0 THEN
				nIndex := nIndex - ((nSlotIndex - 1)* 4);
				CASE nIndex OF
					2:	pSlot^.P_rRelPosX := DINT_TO_REAL(refCmdData.n32Data[0]);
					
					3:	pSlot^.P_rRelPosY := DINT_TO_REAL(refCmdData.n32Data[0]);
					
					4:	pSlot^.P_rRelPosZ := DINT_TO_REAL(refCmdData.n32Data[0]);
				END_CASE
			END_IF			
		ELSE
			M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{a8f647f1-3dfe-4ec7-a0b7-cca9ad9c7510}">
