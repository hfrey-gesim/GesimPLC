    </Method>
    <Method Name="M_GetPropCheckSum" Id="{beca6b54-e34a-43f6-bea3-13c1ece9c9bd}">
      <Declaration><![CDATA[METHOD M_GetPropCheckSum : UINT
VAR_INPUT
END_VAR

VAR
	i			: UINT;
	stData 		: ST_CmdData;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetAllProps(stData);
wChecksum := F_DATA_TO_CRC16_CCITT(ADR(stData.n32Data[0]),nNoOfProps * 4,16#FFFF);
M_GetPropCheckSum := wChecksum;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetSlot" Id="{5bf38d48-7f66-4c09-8857-15ea2b2f15c2}">
      <Declaration><![CDATA[METHOD M_GetSlot : POINTER TO FB_Slot
VAR_INPUT
	nSlotNr	: UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetSlot := fbSlotList.M_GetAtNr(nSlotNr);]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetSlotFromChild" Id="{fd1fbe30-0179-4971-9021-dac75c59f2ea}">
      <Declaration><![CDATA[METHOD M_GetSlotFromChild : POINTER TO FB_Slot
VAR_INPUT
	pObject : POINTER TO FB_Object;
END_VAR

VAR
	pSlot : POINTER TO FB_Slot;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Die SlotList iterieren und vergleichen ob Objekte übereinstimmen
fbSlotList.M_SetCurrentToHead();
REPEAT
	pSlot := fbSlotList.M_GetNext();
	IF pSlot > 0 THEN
		IF pSlot^.P_pChild = pObject THEN
			M_GetSlotFromChild := pSlot;
			EXIT;
		END_IF
	END_IF
UNTIL pSlot = 0
END_REPEAT]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetXYRange" Id="{ec18b085-89ad-49bb-a4b2-ac1e10f10a52}">
      <Declaration><![CDATA[METHOD M_GetXYRange : ST_Rectangle
VAR_INPUT
END_VAR
VAR
	stAbsPosTotal : ST_3DPoint;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[stAbsPosTotal := P_stAbsPosTotal;
IF pXDrive > 0 THEN
	M_GetXYRange.X1 := pXDrive^.P_rMinPos + stAbsPosTotal.X;
	M_GetXYRange.X2 := pXDrive^.P_rMaxPos + stAbsPosTotal.X;	
END_IF
IF pYDrive > 0 THEN
	M_GetXYRange.Y1 := pYDrive^.P_rMinPos + stAbsPosTotal.Y;
	M_GetXYRange.Y2 := pYDrive^.P_rMaxPos + stAbsPosTotal.Y;	
END_IF]]></ST>
      </Implementation>
    </Method>
