<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_MzBase" Id="{b81da648-b95e-47ec-864e-12282447efac}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_MzBase EXTENDS FB_Object IMPLEMENTS I_Device

VAR_OUTPUT
	bBusy				: BOOL;
END_VAR

VAR
	bInitFB				: BOOL := TRUE;			//zum erstmaligen Initialisieren des FB
	

	fbSlotList			: FB_SlotList;
	nNumberOfSlots		: UINT;
	nFirstSlotPropIndex	: UINT;	//erster Index für Slots (benötigt in M_SetSingleProps)
	nLastSlotPropIndex	: UINT;	//letzte Index für Slots (benötigt in M_SetSingleProps)
	
	//Variablen allgemeine Statemachine
	bCanceled			: BOOL;
	bError				: BOOL;
	stError				: ST_Error;
	bStopAllOnError		: BOOL;
	eCurrentState		: E_MachineState := E_MachineState.MACHINESTATE_Idle;
	i					: UINT;					//allg. Zählvariable

	nDeviceIdx			: UINT;			//eigener Index in aI_Device[Idx]
	nCurrentPropIndex	: UINT;

	nSpecPropIndex		: UINT;			//erster Index für Specialproperties (ab direkter Erbe von FB_MzTool) (benötigt in M_SetSingleProps + M_GetSingleProp)
	
	pAssignWorkplate	: POINTER TO FB_Workplate;
	nNotifyId			: UINT;
	stRelPos			: ST_3DPoint;	//Relative Position zum Parent
	stOffset			: ST_3DPoint;	//Offset

	
	pFbMultiZ			: POINTER TO FB_MultiZRef;
	pXDrive				: POINTER TO FB_XYDriveBase;
	pYDrive				: POINTER TO FB_XYDriveBase;
	pPiece				: POINTER TO FB_PieceBase;

	//****************************************Aktionvariablen****************************************************
	
	//Verkettete Liste für BasicActions
	fbList				: FB_LinkedListCtrl;
	hList				: T_HLINKEDLIST;
	aNodes           	: ARRAY[0..4] OF T_LinkedListEntry;
	getValue			: PVOID;
	getPosPtr       	: POINTER TO T_LinkedListEntry := 0;

	//Action: "InitBase"
	bInitAxisOk			: BOOL;
	bInitToolOk			: BOOL;
	bInitAxis			: BOOL;
	bReInit				: BOOL;
	nStateA_InitAxis	: USINT;			//State von A_Init() BasisFb
	bInitReadyX			: BOOL;
	bInitReadyY			: BOOL;
	bInitErrorX			: BOOL;
	bInitErrorY			: BOOL;
	fbZmHome			: FB_ZM_Home;
	nCurInitZAxis		: USINT;
	timeoutInit			: TON;
	
	bMeasured			: BOOL;				//als Merker, ob bei Tipvermessung bereits komplette Vermessung durchgeführt wurde
	bDisableFreeMove	: BOOL;
	
	//Action: "JogXY"
	bJogXY				: BOOL;
	nStateA_JogXY		: USINT;			//State von A_JogXY()
	eJogXYDirectionNew	: E_MoveDirection;
	eJogXYDirection		: E_MoveDirection;
	nCurrentJogXYAxis	: USINT;			//1= X, 2=Y, 3=Z;(Z wird in FB_MzTool verarbeitet)
	bJogXYForward		: BOOL;
	bJogXYBackwards		: BOOL;
	bJogXYClock			: BOOL;
	bJogXYModeInchingNew: BOOL;				//wenn True dann Tipbetrieb sonst kontinuierlich
	bJogXYModeInching	: BOOL;				//wenn True dann Tipbetrieb sonst kontinuierlich
	rJogXYDistance		: REAL;
	rJogXYSpeed			: REAL;
	bJogXYImpuls		: BOOL;	
	
	//Action: "MoveX"
	bMoveX				: BOOL;
	nStateA_MoveX		: USINT;			//State von A_MoveX()
	bFlagMoveX			: BOOL := TRUE;		//Hilfsflag
	
	//Action: "MoveY"	
	bMoveY				: BOOL;
	nStateA_MoveY		: USINT;			//State von A_MoveX()
	bFlagMoveY			: BOOL := TRUE;		//Hilfsflag
	
	//Action: "MoveXY"	
	bMoveXY				: BOOL;
	nStateA_MoveXY		: USINT;			//State von A_MoveXY()
	bFlagMoveXY			: BOOL := TRUE;		//Hilfsflag
	bMoveXReady			: BOOL;
	bMoveXError			: BOOL;
	bMoveYReady			: BOOL;
	bMoveYError			: BOOL;
	bMoveXYReady		: BOOL;
	recteMoveRange		: FB_Rectangle;
	pHighestTarget		: POINTER TO FB_TargetBase;
	bSynchron			: BOOL;	//beide Achsen kommen zeitgleich an
	stCurrentPosPhys	: ST_3DPoint;
	
	//Action: "MoveZ"
	bMoveZ				: BOOL;
	nStateA_MoveZ		: USINT;			//State von A_Move()
	bFlagMoveZ			: BOOL := TRUE;		//Hilfsflag
	eMoveModeZ			: E_MoveMode;
	
	fbZmMove			: FB_ZM_Move;
	fbZmStop			: FB_ZM_Stop;

	//Action: "Move allgemein"
	eMoveMode			: E_MoveMode;
	bMoveModeXYRelativ	: BOOL;
	rMovePositionX		: REAL;
	rMovePositionY		: REAL;
	rMovePositionZ		: REAL;
	rMoveSpeedX			: REAL;
	rMoveSpeedY			: REAL;
	rMoveSpeedZ			: REAL;
	rDistanceX			: REAL;
	rDistanceY			: REAL;
	st3DPoint			: ST_3DPoint;
	st3DPoint1			: ST_3DPoint;
	//stDimension			: ST_3DDimension;
	stAreaCollFree		: FB_Rectangle;		//kollisionsfreier XY-Bereich um die aktuelle XY-Position des Tools(wird bei Z-Zustellung gesetzt)
	bIgnoreZCollision	: BOOL;
	eCrashAvoidanceMode	: E_CrashAvoidanceMode;
	stActionData		: ST_ActionData;
	bZIsMoving			: BOOL;
	bXYIsMoving			: BOOL;
	pMtp				: POINTER TO FB_Mtp;
	pHead				: POINTER TO FB_MzHead;
	pCustomUnitType1	: POINTER TO FB_CustomUnitType1;
	
	//Action: "Stop"
	bStop				: BOOL;
	nStateA_Stop		: USINT;			//State von A_Stop()
	bFlagStop			: BOOL := TRUE;		//Hilfsflag
	
	//Action: "Reset"
	nStateA_ResetBase	: USINT;			//State von A_Reset() BasisFB
	nStateA_ResetTool	: USINT;
	nStateA_ResetSpec	: USINT;			//State von A_Reset() SpecialFB
	bFlagA_ResetBase	: BOOL := TRUE;		//Hilfsflag von A_Reset() BasisFB
	bFlagA_ResetSpec	: BOOL := TRUE;		//Hilfsflag von A_Reset() SpecialFB
	timeoutReset		: TON;
	
	//Prozessdaten
	stProcessData		: ST_ObjectProcData;	//werden am Ende in globales Array übertragen, welches per Notifiction zum PC übertragen werden 
	stCurrentPos		: ST_3DPoint;
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF bInitFB THEN
	bInitFB := FALSE;
	F_CreateLinkedListHnd( ADR( aNodes ), SIZEOF( aNodes ), hList );
	stError.ObjectId := nObjectID;
	stError.HardwareGrp := E_HardwareGrp.Nothing;
END_IF

CASE eCurrentState OF
	E_MachineState.MACHINESTATE_Active:
		bBusy := TRUE;
		IF bInitAxis THEN	//Initialisieren
			A_Init();
			IF nStateA_InitAxis >= 80 THEN
				IF nStateA_InitAxis >= 99 THEN
					bError := TRUE;
				END_IF
				bInitAxis := FALSE;
				nStateA_InitAxis := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_Init);
			END_IF
		END_IF
		
		IF bJogXY THEN	//Joggen
			A_JogXY();
			IF nStateA_JogXY >= 80 THEN
				IF nStateA_JogXY >= 99 THEN
					bError := TRUE;
				END_IF
				bJogXY := FALSE;
				nStateA_JogXY := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_Jog);
			END_IF
		END_IF

		IF bMoveX THEN	//Move X absolut oder relativ
			A_MoveX();
			IF nStateA_MoveX >= 80 THEN
				IF nStateA_MoveX >= 99 THEN
					bStopAllOnError := TRUE; 
					bError := TRUE;
				END_IF
				bMoveX := FALSE;
				bXYIsMoving := FALSE;
				nStateA_MoveX := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_MoveX);
			END_IF
		END_IF		
		
		IF bMoveY THEN	//Move Y absolut oder relativ
			A_MoveY();
			IF nStateA_MoveY >= 80 THEN
				IF nStateA_MoveY >= 99 THEN
					bStopAllOnError := TRUE;
					bError := TRUE;
				END_IF
				bMoveY := FALSE;
				bXYIsMoving := FALSE;
				nStateA_MoveY := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_MoveY);
			END_IF
		END_IF	

		IF bMoveXY THEN	//Move XY absolut oder relativ
			A_MoveXY();
			IF nStateA_MoveXY >= 80 THEN
				IF nStateA_MoveXY >= 99 THEN
					bStopAllOnError := TRUE; 
					bError := TRUE;
				END_IF
				bMoveXY := FALSE;
				bXYIsMoving := FALSE;
				nStateA_MoveXY := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_MoveXY);
			END_IF
		END_IF
		
		IF bMoveZ THEN	//Move Z absolut oder relativ
			A_MoveZ();
			IF nStateA_MoveZ >= 80 THEN
				IF nStateA_MoveZ >= 99 THEN
					bStopAllOnError := TRUE;
					bError := TRUE;
				END_IF
				bMoveZ := FALSE;
				bZIsMoving := FALSE;
				nStateA_MoveZ := 0;
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_MoveZ);
			END_IF
		END_IF		
		
		IF bStop THEN	//alle Actions stoppen
			A_Stop();
			IF nStateA_Stop >= 80 THEN
				IF nStateA_Stop >= 99 THEN
					bError := TRUE;					
				END_IF
				M_RemoveListEntry(nSearchValue:= E_Action.ACTION_Stop);
				bStop := FALSE;
				nStateA_Stop := 0;
				bCanceled := TRUE;
			END_IF							
		END_IF

		IF hList.nCount = 0 THEN
			eCurrentState := E_MachineState.MACHINESTATE_Ready;
		END_IF
		
		IF bError THEN
			IF hList.nCount > 1 THEN	//mehr Aktionen als die den Fehler verursachende
				bStop := TRUE;
			ELSE
				eCurrentState := E_MachineState.MACHINESTATE_Error;	
			END_IF
		END_IF

	E_MachineState.MACHINESTATE_Reset:
		A_Reset();
		//Wenn A_Reset() in SpezialFB existiert, dann wird sie dort aufgerufen
		//in diesem Fall wird FB_MzBase.A_Reset() von SpezialFB über SUPER^.A_Reset() aufgerufen
		
		IF nStateA_ResetBase >= 80 THEN
			IF nStateA_ResetBase >= 99 THEN
				bError := TRUE;
				eCurrentState := E_MachineState.MACHINESTATE_Error;
			ELSE
				fbList.A_Reset(hList := hList);
				bStopAllOnError := FALSE;
				bError := FALSE;
				eCurrentState := E_MachineState.MACHINESTATE_Idle;
			END_IF
			bBusy := FALSE;
			nStateA_ResetBase := 0;
			nStateA_ResetTool := 0;
			nStateA_ResetSpec := 0;
		END_IF
END_CASE

//Nicht im CASE-Block, damit busy in gleichem Zyklus zurückgesetzt wird		
IF eCurrentState = E_MachineState.MACHINESTATE_Ready THEN
		bBusy := FALSE;
		eCurrentState := E_MachineState.MACHINESTATE_Idle;
ELSIF eCurrentState = E_MachineState.MACHINESTATE_Error THEN
		bBusy := FALSE;
END_IF

//Prozessdaten aktualisieren
stProcessData.nObjId := nObjectID;
stProcessData.n32Data[0] := BOOL_TO_DINT(P_bIsInit);
stProcessData.n32Data[1] := eCurrentState;
stProcessData.n32Data[2] := stError.ErrorId;]]></ST>
    </Implementation>
    <Action Name="A_Init" Id="{cb8fb62f-1258-4748-a841-7a6a21b68ff2}">
      <Implementation>
        <ST><![CDATA[//Initilaisierung erfolgt jeweils in FB_MzTool.A_Init() und FB_XXXX.A_Init()]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_JogXY" Id="{9935cac7-87cf-40f5-8564-df273a66c940}">
      <Implementation>
        <ST><![CDATA[IF nStateA_JogXY = 0 THEN
	IF bJogXYModeInching THEN
		nStateA_JogXY := 1;	//Incr
	ELSE
		nStateA_JogXY := 3;	//Continous
	END_IF
END_IF
 
IF nStateA_JogXY = 1 THEN	//incrementellen Jog-Befehl 1x absetzen
	CASE eJogXYDirection OF
		E_MoveDirection.DIRECTION_XPLUS:
			nCurrentJogXYAxis := 1;
			pXDrive^.M_Jog(bForward:= TRUE, bBackward:= FALSE, bInching:= TRUE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
			bXYIsMoving := TRUE;
		E_MoveDirection.DIRECTION_XMINUS:	
			nCurrentJogXYAxis := 1;
			pXDrive^.M_Jog(bForward:= FALSE, bBackward:= TRUE, bInching:= TRUE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
			bXYIsMoving := TRUE;
			bXYIsMoving := TRUE;
		E_MoveDirection.DIRECTION_YPLUS:
			nCurrentJogXYAxis := 2;
			pYDrive^.M_Jog(bForward:= TRUE, bBackward:= FALSE, bInching:= TRUE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
			bXYIsMoving := TRUE;
		E_MoveDirection.DIRECTION_YMINUS:
			nCurrentJogXYAxis := 2;
			pYDrive^.M_Jog(bForward:= FALSE, bBackward:= TRUE, bInching:= TRUE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
			bXYIsMoving := TRUE;
	END_CASE
	nStateA_JogXY := 2;
END_IF

IF nStateA_JogXY = 2 THEN //warten bis inkrementelles Joggen fertig bzw auf neuen Befehl warten
	IF NOT bJogXYModeInching THEN //Wechseln zu kontinulierlichem Joggen
		nStateA_JogXY := 3;
	END_IF
	
	IF eJogXYDirection = E_MoveDirection.DIRECTION_STOP THEN
		nStateA_JogXY := 4;
	END_IF
END_IF

IF nStateA_JogXY = 3 THEN //zyklisches Absetzen des kontinuierlichen Jog-Befehls, hier kann auch Stop abgesetzt werden, bzw neuer inkr. Befehl
	IF bJogXYImpuls THEN
		CASE eJogXYDirection OF
			E_MoveDirection.DIRECTION_STOP:
				nStateA_JogXY := 4;
			E_MoveDirection.DIRECTION_XPLUS:
				nCurrentJogXYAxis := 1;
				pXDrive^.M_Jog(bForward:= TRUE, bBackward:= FALSE, bInching:= FALSE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
				bXYIsMoving := TRUE;
			E_MoveDirection.DIRECTION_XMINUS:	
				nCurrentJogXYAxis := 1;
				pXDrive^.M_Jog(bForward:= FALSE, bBackward:= TRUE, bInching:= FALSE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
				bXYIsMoving := TRUE;
				bXYIsMoving := TRUE;
			E_MoveDirection.DIRECTION_YPLUS:
				nCurrentJogXYAxis := 2;
				pYDrive^.M_Jog(bForward:= TRUE, bBackward:= FALSE, bInching:= FALSE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
				bXYIsMoving := TRUE;
			E_MoveDirection.DIRECTION_YMINUS:
				nCurrentJogXYAxis := 2;
				pYDrive^.M_Jog(bForward:= FALSE, bBackward:= TRUE, bInching:= FALSE, rDistance:= rJogXYDistance, rSpeed:= rJogXYSpeed);
				bXYIsMoving := TRUE;
		END_CASE
	END_IF
	bJogXYImpuls := FALSE;
END_IF

IF nStateA_JogXY = 4 THEN //Stop
	pXDrive^.M_Jog(bForward:= FALSE, bBackward:= FALSE, bInching:= FALSE, rDistance:= 0.0, rSpeed:= 0.0);
	pYDrive^.M_Jog(bForward:= FALSE, bBackward:= FALSE, bInching:= FALSE, rDistance:= 0.0, rSpeed := 0.0);
	//IF bJogXYModeInching THEN
		pXDrive^.M_Stop();
		pYDrive^.M_Stop();
	//END_IF
	nStateA_JogXY := 5;
END_IF

//Abfragen, ob Jogging fertig
IF nCurrentJogXYAxis = 1 THEN	//X
	IF NOT pXDrive^.P_bBusy THEN
		IF pXDrive^.P_bError THEN
			stError.ErrorId := pXDrive^.P_nErrorId;
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			stError.HardwareNr	:= 1;
			stError.POUState := nStateA_JogXY;
			nStateA_JogXY := 99;
		ELSE
			nStateA_JogXY := 80;	
		END_IF
		nCurrentJogXYAxis := 0;
		bXYIsMoving := FALSE;
	END_IF
ELSIF nCurrentJogXYAxis = 2 THEN	//Y
	IF NOT pYDrive^.P_bBusy THEN
		IF pYDrive^.P_bError THEN
			stError.ErrorId := pYDrive^.P_nErrorId;
			stError.HardwareGrp := E_HardwareGrp.AxisY;
			stError.HardwareNr	:= 1;
			stError.POUState := nStateA_JogXY;
			nStateA_JogXY := 99;
		ELSE
			nStateA_JogXY := 80;	
		END_IF
		nCurrentJogXYAxis := 0;
		bXYIsMoving := FALSE;
	END_IF
ELSE
	nStateA_JogXY := 80;
END_IF

//Errorhandling
IF nStateA_JogXY = 99 THEN
	stError.Cmd := E_Action.ACTION_Jog;
	stError.POU := E_POU.POU_FB_MzBase;
	stError.POUAction := E_POUACT.POUACT_A_JogXY;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveX" Id="{1ea90e71-51ae-49b2-a6d4-cbb93cc272e3}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nStateA_MoveX;

CASE nStateA_MoveX OF
	0:	
		IF NOT bIgnoreZCollision THEN
			//Distanz ermitteln, für ev. Freifahren der Z-Achsen
			IF eMoveMode = E_MoveMode.MODE_Relative THEN
				rDistanceX := rMovePositionX;
			ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN
				st3DPoint := P_stCurrentPosTotal;
				rDistanceX := ABS(rMovePositionX - st3DPoint.X);
			ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN
				rDistanceX := ABS(rMovePositionX - pXDrive^.P_rActPos);
			END_IF
			
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Free;
			stActionData.aParams[3] := -1;
			
			//Bei MoveX müssen definitiv die Achsen aller Heads kollisionsfrei sein
			nStateA_MoveX := 1;
			FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
				IF NOT afbMzHead[i].P_bCollFree THEN
					stError.ErrorId := afbMzHead[i].M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						stError.HardwareGrp := E_HardwareGrp.AxisZ;
						stError.HardwareNr := 0;
						nStateA_MoveX := 99;
						EXIT;
					END_IF
				END_IF
			END_FOR
		ELSE
			nStateA_MoveX := 2;
		END_IF
		
	1:	//warten bis beide Köpfe fertig
		nStateA_MoveX := 2;
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			IF afbMzHead[i].M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				nStateA_MoveX := 1;
			END_IF
			IF afbMzHead[i].P_bError THEN
				stError.ErrorId := afbMzHead[i].P_nErrorId;
				stError.HardwareGrp := E_HardwareGrp.AxisZ;
				nStateA_MoveX := 99;
				EXIT;
			END_IF
		END_FOR			
		
	2:	//In Abhängigkeit von MoveMode absolut oder relativ fahren
		IF eMoveMode = E_MoveMode.MODE_Relative THEN	//Relativ
			stError.ErrorId := pXDrive^.M_MoveRel(rDistance:= rMovePositionX, rSpeed:= rMoveSpeedX, rAcceleration:= 0.0, rDeceleration:= 0.0);
			nStateA_MoveX := 3; 
		ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN	//Absolut mit Offsets
			//Achsenposition berechnen
			//Position ergibt sich aus Zielposition abzüglich aller Offsets
			st3DPoint := P_stAbsPosTotal;	//Summe aller Offsets
			rMovePositionX := rMovePositionX - st3DPoint.X;
			stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= rMovePositionX, rSpeed:= rMoveSpeedX, rAcceleration:= 0.0, rDeceleration:= 0.0);
			nStateA_MoveX := 3; 
		ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN	//Absolut OHNE Offsets!!
			stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= rMovePositionX, rSpeed:= rMoveSpeedX, rAcceleration:= 0.0, rDeceleration:= 0.0);
 			nStateA_MoveX := 3;
		ELSIF eMoveMode = E_MoveMode.MODE_Home THEN	//auf 0 fahren
			stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= 0.0, rSpeed:= rMoveSpeedX, rAcceleration:= 0.0, rDeceleration:= 0.0);
 			nStateA_MoveX := 3;
		ELSE
			nStateA_MoveX := 99; //Error (Dieser Fall sollte nicht auftreten. MoveMode wird in M_ExeAction() abgefangen)
		END_IF
		
		IF stError.ErrorId > 0 THEN
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			nStateA_MoveX := 99;
		END_IF
		
	3:	//Warten bis Positionierung fertig
		IF NOT pXDrive^.P_bBusy THEN
			IF pXDrive^.P_bError THEN
				stError.ErrorId := pXDrive^.P_nErrorId;
				stError.HardwareNr	:= 1;
				//fbXDrive resetten!!
 				nStateA_MoveX := 99;
			ELSE
				nStateA_MoveX := 80;
			END_IF
		END_IF
	
	70:	//Stoppen
		pXDrive^.M_Stop();
		IF NOT pXDrive^.P_bBusy THEN
			nStateA_MoveX := 80;
		END_IF
END_CASE

//Errorhandling
IF nStateA_MoveX = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_MoveX;
	stError.POU := E_POU.POU_FB_MzBase;
	stError.POUAction := E_POUACT.POUACT_A_MoveX;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveXY" Id="{a18248e0-4505-4f01-ad91-ed9dee680559}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nStateA_MoveXY;

//States sind in separaten IF-Blöcken, um Zyklen zu sparen
IF nStateA_MoveXY = 0 THEN
	stCurrentPosPhys := P_stCurrentPosPhys;
	nStateA_MoveXY := 1;
	//Distanz ermitteln, für ev. Freifahren der Z-Achsen
	IF eMoveMode = E_MoveMode.MODE_Relative THEN
		rDistanceX := rMovePositionX;
		rDistanceY := rMovePositionY;
	ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN
		st3DPoint := P_stCurrentPosTotal;
		rDistanceX := ABS(rMovePositionX - st3DPoint.X);
		rDistanceY := ABS(rMovePositionY - st3DPoint.Y);
	ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN
		rDistanceX := ABS(rMovePositionX - pXDrive^.P_rActPos);
		rDistanceY := ABS(rMovePositionY - pYDrive^.P_rActPos);
	END_IF
	
	IF eCrashAvoidanceMode = E_CrashAvoidanceMode.MoveAllFree THEN
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1; //MaxSpeed
		
		//Die Achsen ermitteln, bei denen der CollFreeArea in den Verfahrweg passt
		//und diese dann vom Freifahren ausschließen
		
		//Wenn nur X-Speed = 0 -> X wird nicht bewegt, dann müssen nur die Achsen des eigenen Heads
		//freigefahren werden
		IF rMoveSpeedX = 0 THEN
			IF NOT P_pMzHead^.M_GetCollFree(rDistanceX,rDistanceY) THEN
				stError.ErrorId := P_pMzHead^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.HardwareGrp := E_HardwareGrp.AxisZ;
					stError.HardwareNr := 0;
					nStateA_MoveXY := 99;
				END_IF
			END_IF
		ELSE
			FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
				IF NOT afbMzHead[i].M_GetCollFree(rDistanceX,rDistanceY) THEN
					stError.ErrorId := afbMzHead[i].M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						stError.HardwareGrp := E_HardwareGrp.AxisZ;
						stError.HardwareNr := 0;
						nStateA_MoveXY := 99;
					END_IF
				END_IF
			END_FOR				
		END_IF
	ELSIF eCrashAvoidanceMode = E_CrashAvoidanceMode.MoveNoneFree THEN //Crash-Vermeidung ist deaktiviert
		nStateA_MoveXY := 2;
	ELSIF eCrashAvoidanceMode = E_CrashAvoidanceMode.MoveUnusedFree THEN //Alle anderen Tools werden auf FreeHeight gefahren, für sich selbst erfolgt Targetüberwachung
		//Rechteck bilden aus aktueller Position und Zielposition
		//In diesem Rechteck darf sich auf aktueller Höhe kein Target befinden
		recteMoveRange.M_Clear();
		stCurrentPos := P_stCurrentPosTotal;
		 
		IF (rDistanceX > 0.0) THEN
			recteMoveRange.X1 := stCurrentPos.X;
			recteMoveRange.X2 := stCurrentPos.X + rDistanceX + P_rToolRadius;
		ELSE
			recteMoveRange.X2 := stCurrentPos.X;
			recteMoveRange.X1 := stCurrentPos.X + rDistanceX - P_rToolRadius;
		END_IF
		
		IF (rDistanceY > 0.0) THEN
			recteMoveRange.Y1 := stCurrentPos.Y;
			recteMoveRange.Y2 := stCurrentPos.Y + rDistanceY + P_rToolRadius;
		ELSE
			recteMoveRange.Y2 := stCurrentPos.Y;
			recteMoveRange.Y1 := stCurrentPos.Y + rDistanceY - P_rToolRadius;
		END_IF
		
		IF P_pMzHead^.P_bIsTopHead THEN
			pHighestTarget := pAssignWorkplate^.M_GetHighestTarget(recteMoveRange,0.0);	
		END_IF
		
		IF pHighestTarget > 0 THEN //bei unteren Head gibt es kein highest target
			//Ist pHighestTarget eine MTP? und recteMoveRange innerhalb eines Wells?
			IF pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp THEN
				//Mtp erhält einen Methode M_RectIsInnerWell
				pMtp := pHighestTarget;
				IF NOT pMtp^.M_GetRectIsInnerWell(recteMoveRange) THEN
					stError.ErrorId := E_ErrorIdCmd.ERRORID_MoveXYRiskOfCrash;
					nStateA_MoveXY := 99;
				END_IF
			ELSIF pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_CustomUnitType1 THEN
				//CustomUnitType1 erhält eine Methode M_RectIsInnerSlot
				pCustomUnitType1 := pHighestTarget;
				IF NOT pCustomUnitType1^.M_GetRectIsInnerSlot(recteMoveRange) THEN
					stError.ErrorId := E_ErrorIdCmd.ERRORID_MoveXYRiskOfCrash;
					nStateA_MoveXY := 99;
				END_IF
			ELSIF pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Slide OR 
					pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SpotArray OR
					pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_TargetTray THEN
				IF NOT F_RectInnerRect(recteMoveRange, pHighestTarget^.P_fbAbsRect) THEN
					stError.ErrorId := E_ErrorIdCmd.ERRORID_MoveXYRiskOfCrash;
					nStateA_MoveXY := 99;
				END_IF
			ELSIF pHighestTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_HighVoltTray THEN
				//Hier sind manchmal Slides in das Tray eingelassen
				IF NOT F_RectInnerRect(recteMoveRange, pHighestTarget^.P_fbAbsRect) THEN
					stError.ErrorId := E_ErrorIdCmd.ERRORID_MoveXYRiskOfCrash;
					nStateA_MoveXY := 99;
				END_IF
			ELSIF (pHighestTarget^.P_rAbsFreeHeight > stCurrentPosPhys.Z) THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_MoveXYRiskOfCrash;
				nStateA_MoveXY := 99;
			END_IF
		END_IF
		
		IF nStateA_MoveXY <> 99 THEN
			//Alle anderen Tools freifahren
			IF rMoveSpeedX = 0 THEN	//Falls kein X-Move, dann braucht CoHead nicht freigefahren werden
				IF NOT P_pMzHead^.M_GetCollFree(rDistanceX,rDistanceY) THEN
					stError.ErrorId := P_pMzHead^.M_MoveFree(THIS);
					IF stError.ErrorId > 0 THEN
						stError.HardwareGrp := E_HardwareGrp.AxisZ;
						stError.HardwareNr := 0;
						nStateA_MoveXY := 99;
					END_IF
				END_IF				
			ELSE
				
				IF NOT P_pMzHead^.M_GetCollFree(rDistanceX,rDistanceY) THEN
					stError.ErrorId := P_pMzHead^.M_MoveFree(THIS);
					IF stError.ErrorId > 0 THEN
						stError.HardwareGrp := E_HardwareGrp.AxisZ;
						stError.HardwareNr := 0;
						nStateA_MoveXY := 99;
					END_IF
				END_IF
				
				IF nStateA_MoveXY <> 99 THEN
					IF P_pMzHead^.P_pCoHead > 0 THEN
						IF NOT P_pMzHead^.P_pCoHead^.M_GetCollFree(rDistanceX,rDistanceY) THEN
							stError.ErrorId := P_pMzHead^.P_pCoHead^.M_MoveFree(0);
							IF stError.ErrorId > 0 THEN
								stError.HardwareGrp := E_HardwareGrp.AxisZ;
								stError.HardwareNr := 0;
								nStateA_MoveXY := 99;
							END_IF
						END_IF
					END_IF
				END_IF
			END_IF
		END_IF
	ELSE
		stError.ErrorId := E_ErrorIdCmd.ERRORID_InvalidCrashAvoidanceMode;
		nStateA_MoveXY := 99;
	END_IF
END_IF
		
//warten bis beide Köpfe fertig
IF nStateA_MoveXY = 1 THEN
	//nochmal zu State 0 wechseln, dadurch wird erneut festgestellt, ob alles frei??
	//würde allerdings noch einen Zyklus kosten
	nStateA_MoveXY := 2;
	FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
		IF afbMzHead[i].M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nStateA_MoveXY := 1;
		END_IF
		IF afbMzHead[i].P_bError THEN
			stError.ErrorId := afbMzHead[i].P_nErrorId;
			stError.HardwareGrp := E_HardwareGrp.AxisZ;
			nStateA_MoveXY := 99;
			EXIT;
		END_IF
	END_FOR
END_IF

//In Abhängigkeit von MoveMode absolut oder relativ fahren
IF nStateA_MoveXY = 2 THEN
	IF bSynchron THEN
		F_SynchronizeSpeeds(rSpeedSum:= rMoveSpeedX, rDistance1:= rDistanceX, rDistance2:= rDistanceY, rSpeed1:= rMoveSpeedX, rSpeed2 := rMoveSpeedY);	
	END_IF
	nStateA_MoveXY := 3;
	IF eMoveMode = E_MoveMode.MODE_Relative THEN	//Relativ
		stError.ErrorId := pXDrive^.M_MoveRel(rDistance:= rMovePositionX, rSpeed:= rMoveSpeedX, rAcceleration:= 0.0, rDeceleration:= 0.0);
		IF stError.ErrorId > 0 THEN
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			stError.POUState := nStateA_MoveXY;
			nStateA_MoveXY := 99;
		ELSE
			stError.ErrorId := pYDrive^.M_MoveRel(rDistance:= rMovePositionY, rSpeed:= rMoveSpeedY, rAcceleration:= 0.0 ,rDeceleration:= 0.0);
			IF stError.ErrorId > 0 THEN //XDrive muss abgebrochen werden
				pXDrive^.M_Stop();
				stError.HardwareGrp := E_HardwareGrp.AxisY;
				nStateA_MoveXY := 99;
			END_IF
		END_IF
	ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN	//Absolut mit Offsets
		//Position ergibt sich aus Zielposition abzüglich aller Offsets
		st3DPoint := P_stAbsPosTotal;	//Summe aller Offsets
		rMovePositionX := rMovePositionX - st3DPoint.X;
		rMovePositionY := rMovePositionY - st3DPoint.Y;
		IF rDistanceX <> 0 THEN
			stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= rMovePositionX, rSpeed:= rMoveSpeedX ,rAcceleration:= 0.0, rDeceleration:= 0.0);	
		END_IF
		
		IF stError.ErrorId > 0 THEN
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			nStateA_MoveXY := 99;
		ELSE
			IF rDistanceY <> 0 THEN
				stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= rMovePositionY, rSpeed:= rMoveSpeedY ,rAcceleration:= 0.0, rDeceleration:= 0.0);	
			END_IF
			IF stError.ErrorId > 0 THEN //XDrive muss abgebrochen werden
				pXDrive^.M_Stop();
				stError.HardwareGrp := E_HardwareGrp.AxisY;
				nStateA_MoveXY := 99;
			END_IF
		END_IF
	ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN	//Absolut OHNE Offsets!!
		stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= rMovePositionX, rSpeed:= rMoveSpeedX ,rAcceleration:= 0.0, rDeceleration:= 0.0);
		IF stError.ErrorId > 0 THEN
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			nStateA_MoveXY := 99;
		ELSE
			stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= rMovePositionY, rSpeed:= rMoveSpeedY ,rAcceleration:= 0.0, rDeceleration:= 0.0);
			IF stError.ErrorId > 0 THEN //XDrive muss abgebrochen werden
				pXDrive^.M_Stop();
				stError.HardwareGrp := E_HardwareGrp.AxisY;
				nStateA_MoveXY := 99;
			END_IF
		END_IF
	ELSIF eMoveMode = E_MoveMode.MODE_Home THEN	//auf 0 fahren
		stError.ErrorId := pXDrive^.M_MoveAbs(rPosition:= 0.0, rSpeed:= rMoveSpeedX ,rAcceleration:= 0.0, rDeceleration:= 0.0);
		IF stError.ErrorId > 0 THEN
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			nStateA_MoveXY := 99;
		ELSE
			stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= 0.0, rSpeed:= rMoveSpeedY ,rAcceleration:= 0.0, rDeceleration:= 0.0);
			IF stError.ErrorId > 0 THEN //XDrive muss abgebrochen werden
				pXDrive^.M_Stop();
				stError.HardwareGrp := E_HardwareGrp.AxisY;
				nStateA_MoveXY := 99;
			END_IF
		END_IF
	END_IF
//Warten bis Positionierung fertig
ELSIF nStateA_MoveXY = 3 THEN
	IF pXDrive^.P_bError THEN
		pYDrive^.M_Stop();
		stError.ErrorId := pXDrive^.P_nErrorId;
		stError.HardwareGrp := E_HardwareGrp.AxisX;
		stError.HardwareNr	:= 1;
		nStateA_MoveXY := 99;
	ELSIF pYDrive^.P_bError THEN
		pXDrive^.M_Stop();
		stError.ErrorId := pYDrive^.P_nErrorId;
		stError.HardwareGrp := E_HardwareGrp.AxisY;
		stError.HardwareNr	:= 1;
		nStateA_MoveXY := 99;
	ELSE
		IF NOT (pXDrive^.P_bBusy OR pYDrive^.P_bBusy) THEN
			nStateA_MoveXY := 80;
		END_IF
	END_IF
//Stoppen
ELSIF nStateA_MoveXY = 70 THEN
	pXDrive^.M_Stop();
	pYDrive^.M_Stop();
	IF NOT (pXDrive^.P_bBusy OR pYDrive^.P_bBusy) THEN
		nStateA_MoveXY := 80;
	END_IF
END_IF

//Errorhandling
IF nStateA_MoveXY = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_MoveXY;
	stError.POU := E_POU.POU_FB_MzBase;
	stError.POUAction := E_POUACT.POUACT_A_MoveXY;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveY" Id="{113dd112-03a5-4cd4-ace6-40d021133d39}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nStateA_MoveY;

CASE nStateA_MoveY OF
	0:
		IF NOT bIgnoreZCollision THEN
			//Distanz ermitteln, für ev. Freifahren der Z-Achsen
			IF eMoveMode = E_MoveMode.MODE_Relative THEN
				rDistanceY := rMovePositionY;
			ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN
				st3DPoint := P_stCurrentPosTotal;
				rDistanceY := ABS(rMovePositionY - st3DPoint.Y);
			ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN
				rDistanceY := ABS(rMovePositionY - pYDrive^.P_rActPos);
			END_IF
			
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Free;
			stActionData.aParams[3] := -1;	//MaxSpeed
			
			//MoveY erfordert nur, dass die Achsen am selben Head OK sind
			nStateA_MoveY := 1;
			IF NOT P_pMzHead^.P_bCollFree THEN
				stError.ErrorId := P_pMzHead^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.Cmd := E_Action.ACTION_MoveZ;
					nStateA_MoveY := 99;
				END_IF
			END_IF
		ELSE
			nStateA_MoveY := 2;		
		END_IF		

	1:	//warten bis alle Achsen fertig
		nStateA_MoveY := 2;
		pHead := P_pMzHead;
		IF pHead^.M_CheckChildsForActionBusy(E_Action.ACTION_MoveZ) THEN
			nStateA_MoveY := 1;
		END_IF
		
		stError.ErrorId := pHead^.M_CheckChildsForError(); 
		IF stError.ErrorId > 0 THEN
			nStateA_MoveY := 99;
		END_IF

	2:	//In Abhängigkeit von MoveMode absolut oder relativ fahren
		IF eMoveMode = E_MoveMode.MODE_Relative THEN	//Relativ
			stError.ErrorId := pYDrive^.M_MoveRel(rDistance:= rMovePositionY, rSpeed:= rMoveSpeedY, rAcceleration:= 0.0, rDeceleration:= 0.0);
			nStateA_MoveY := 3; 
		ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN	//Absolut mit Offsets
			//Achsenposition berechnen
			//Position ergibt sich aus Zielposition abzüglich aller Offsets
			st3DPoint := P_stAbsPosTotal;	//Summe aller Offsets
			rMovePositionY := rMovePositionY - st3DPoint.Y;
			stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= rMovePositionY, rSpeed:= rMoveSpeedY, rAcceleration:= 0.0, rDeceleration:= 0.0);
			nStateA_MoveY := 3; 
		ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN	//Absolut OHNE Offsets!!
			stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= rMovePositionY, rSpeed:= rMoveSpeedY, rAcceleration:= 0.0, rDeceleration:= 0.0); 
			nStateA_MoveY := 3;
		ELSIF eMoveMode = E_MoveMode.MODE_Home THEN	//auf 0 fahren
			stError.ErrorId := pYDrive^.M_MoveAbs(rPosition:= 0.0, rSpeed:= rMoveSpeedY, rAcceleration:= 0.0, rDeceleration:= 0.0); 
			nStateA_MoveY := 3;
		ELSE
			nStateA_MoveY := 99; //Error (Dieser Fall sollte nicht auftreten. MoveMode wird in M_ExeAction() abgefangen)
		END_IF
		
		IF stError.ErrorId > 0 THEN
			nStateA_MoveY := 99;
		END_IF	

	3:	//Warten bis Positionierung fertig
		IF NOT pYDrive^.P_bBusy THEN
			IF pYDrive^.P_bError THEN
				stError.ErrorId := pYDrive^.P_nErrorId;
				//fbYDrive resetten!!
 				nStateA_MoveY := 99;
			ELSE
				nStateA_MoveY := 80;
			END_IF
		END_IF

	70:	//Stoppen
		pYDrive^.M_Stop();
		IF NOT pYDrive^.P_bBusy THEN
			nStateA_MoveY := 80;
		END_IF		
END_CASE

//Errorhandling
IF nStateA_MoveY = 99 THEN
	stError.HardwareGrp := E_HardwareGrp.AxisY;
	stError.HardwareNr := 1;
	stError.Cmd := E_Action.ACTION_MoveY;
	stError.POU := E_POU.POU_FB_MzBase;
	stError.POUAction := E_POUACT.POUACT_A_MoveY;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveZ" Id="{d7ea602f-5929-4cb4-a373-a1f189b6a250}">
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_Reset" Id="{cbb5ad01-db84-4e48-86cd-ad7643722f0c}">
      <Implementation>
        <ST><![CDATA[IF nStateA_ResetBase = 0 THEN //ist noch irgendeine Action aktiv?		
	IF bJogXY THEN
		bJogXY := FALSE;
		nStateA_JogXY := 0;
	END_IF
	IF bMoveX THEN
		bMoveX := FALSE;
		bXYIsMoving := FALSE;
		nStateA_MoveX := 0;
	END_IF
	IF bMoveY THEN
		bMoveY := FALSE;
		bXYIsMoving := FALSE;
		nStateA_MoveY := 0;
	END_IF		
	IF bMoveXY THEN
		bMoveXY := FALSE;
		bXYIsMoving := FALSE;
		nStateA_MoveXY := 0;
	END_IF
	IF bMoveZ THEN
		bMoveZ := FALSE;
		nStateA_MoveZ := 80;
	END_IF		
	nStateA_InitAxis := 0;
	nStateA_JogXY := 0;
	nStateA_Stop := 0;
	nStateA_MoveX := 0;
	nStateA_MoveY := 0;
	nStateA_MoveXY := 0;
	nStateA_MoveZ := 0;
	nStateA_ResetBase := 0;
	nStateA_ResetSpec := 0;
	bXYIsMoving := FALSE;
	bZIsMoving := FALSE;		
	nStateA_ResetBase := 1;
ELSIF nStateA_ResetBase = 1 THEN //Warten, bis Drives zurückgesetzt
	IF NOT (pXDrive^.P_bError OR pYDrive^.P_bError) THEN 
		nStateA_ResetBase := 2;
	END_IF
ELSIF nStateA_ResetBase = 2 THEN	//ResetTool ready?		
	IF nStateA_ResetTool = 80 THEN
		stError.ErrorId := 0;
		nStateA_ResetBase := 80;
	ELSIF nStateA_ResetTool >= 80 THEN
		nStateA_ResetBase := 99;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_Stop" Id="{b95c87f5-2a1c-433a-8c5c-254cfae199a6}">
      <Implementation>
        <ST><![CDATA[//Diese Aktion wird in der Regel vom "FB_Tool.A_stop()" aufgerufen
//kommt der Aufruf von "FB_Tool.A_stop()" das erst mal, ist "nStateA_Stop" = 2

IF nStateA_Stop <= 2 THEN
	IF bInitAxis AND nStateA_InitAxis < 70 THEN
		nStateA_InitAxis := 70;
	END_IF
	
	IF bJogXY AND nStateA_JogXY < 4 THEN
		nStateA_JogXY := 4;
	END_IF
	
	IF bMoveX AND nStateA_MoveX < 70 THEN	//X-Move stoppen
		nStateA_MoveX := 70;
	END_IF
	
	IF bMoveY AND nStateA_Movey < 70 THEN	//X-Move stoppen
		nStateA_MoveY := 70;
	END_IF	
	
	IF bMoveXY AND nStateA_MoveXY < 70 THEN	//X-Move stoppen
		bFlagMoveX := TRUE;
		bFlagMoveY := TRUE;
		nStateA_MoveXY := 70;
	END_IF

	IF bMoveZ AND nStateA_MoveZ < 70 THEN	//Z-Move stoppen
		nStateA_MoveZ := 70;
	END_IF
	
	nStateA_Stop := 3;

ELSIF nStateA_Stop = 3 THEN
	//Warten bis alle Actions abgebrochen
	IF hList.nCount = 1 THEN	//nur der Eintrag von Stop
		nStateA_Stop := 80;
	END_IF	
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_AddChild" Id="{f9cbc5dd-1d65-4f84-989e-945992d61b0a}">
      <Declaration><![CDATA[METHOD M_AddChild : ERRORID
VAR_INPUT
	pObject	: POINTER TO FB_Object;
	nSlotNr	: UINT;
	nIndex : INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Die Methode muss zwingend von den abgeleiteten FBs implementiert werden]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CancelAction" Id="{f56956bd-0a51-47ce-a58e-7af4e1b5406e}">
      <Declaration><![CDATA[METHOD M_CancelAction
VAR_INPUT
	eAction : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eAction OF
	E_Action.ACTION_Init:
		IF bInitAxis AND nStateA_InitAxis < 70 THEN
			nStateA_InitAxis := 70;
		END_IF	
	E_Action.ACTION_Jog:
		IF bJogXY AND nStateA_JogXY < 4 THEN	//Jogging stoppen
			nStateA_JogXY := 4;
		END_IF	
	E_Action.ACTION_MoveX:
		IF bMoveX AND nStateA_MoveX < 70 THEN	//X-Move stoppen
			nStateA_MoveX := 70;
		END_IF	
	E_Action.ACTION_MoveY:
		IF bMoveY AND nStateA_Movey < 70 THEN	//X-Move stoppen
			nStateA_MoveY := 70;
		END_IF	
	E_Action.ACTION_MoveZ:
		IF bMoveZ AND nStateA_MoveZ < 70 THEN	//Z-Move stoppen
			nStateA_MoveZ := 70;
		END_IF	
	E_Action.ACTION_MoveXY:
		IF bMoveXY AND nStateA_MoveXY < 70 THEN	//X-Move stoppen
			bFlagMoveX := TRUE;
			bFlagMoveY := TRUE;
			nStateA_MoveXY := 70;
		END_IF
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckAction" Id="{dd0b1c53-a238-45d2-b04e-3985e2e5af14}">
      <Declaration><![CDATA[METHOD M_CheckAction : ERRORID
VAR_INPUT
	refActionData 	: REFERENCE TO ST_ActionData;
	pCorrelObject	: POINTER TO FB_Object;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_CheckAction := E_ErrorIdCmd.ERRORID_InvalidAction;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckMoveLimit" Id="{8c322e7e-a3e8-4985-9143-233250777601}">
      <Declaration><![CDATA[METHOD M_CheckMoveLimit : BOOL
VAR_INPUT
	sAxis			: STRING[2];
	eMoveMode		: E_MoveMode;
	rMovePosition	: REAL;
END_VAR

VAR
	st3DPoint		: ST_3DPoint;
	rMovePosTemp	: REAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF sAxis = 'X' THEN 
	IF eMoveMode = E_MoveMode.MODE_Relative THEN	//Relativ
		rMovePosTemp := pXDrive^.P_rActPos + rMovePosition; 
	ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN	//Absolut mit Offsets
		st3DPoint := P_stAbsPosTotal;	//Summe aller Offsets
		rMovePosTemp := rMovePosition - st3DPoint.X;
	ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN	//Absolut OHNE Offsets!!
		rMovePosTemp := rMovePosition;
	END_IF
	
	IF rMovePosTemp >= pXDrive^.P_rMinPos AND rMovePosTemp <= pXDrive^.P_rMaxPos THEN
		M_CheckMoveLimit := TRUE;
	END_IF
ELSIF sAxis = 'Y' THEN
	IF eMoveMode = E_MoveMode.MODE_Relative THEN	//Relativ
		rMovePosTemp := pYDrive^.P_rActPos + rMovePosition; 
	ELSIF eMoveMode = E_MoveMode.MODE_AbsWithOffset THEN	//Absolut mit Offsets
		st3DPoint := P_stAbsPosTotal;	//Summe aller Offsets
		rMovePosTemp := rMovePosition - st3DPoint.Y;
	ELSIF eMoveMode = E_MoveMode.MODE_AbsNoneOffset THEN	//Absolut OHNE Offsets!!
		rMovePosTemp := rMovePosition;
	END_IF

	IF rMovePosTemp >= pYDrive^.P_rMinPos AND rMovePosTemp <= pYDrive^.P_rMaxPos THEN
		M_CheckMoveLimit := TRUE;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckProcDataType" Id="{4b3321e5-064a-4165-aa4d-ae6656bd053c}">
