    <Property Name="P_pUpperParentTool" Id="{f0ac7dbf-2486-4a44-971c-a5e727b8e765}">
      <Declaration><![CDATA[//Das Tool, was als Parent den Head hat bzw. direkt an der Achse befindet
PROPERTY P_pUpperParentTool : POINTER TO FB_MzTool]]></Declaration>
      <Get Name="Get" Id="{e4240c03-6a89-4e31-a643-f567c2690628}">
        <Declaration><![CDATA[VAR
	pTool : POINTER TO FB_MzTool;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF pParentMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_MZHead THEN
	P_pUpperParentTool := THIS;
ELSE
	pTool := pParentMzTool;
	P_pUpperParentTool := pTool^.P_pUpperParentTool;
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_pZAxisRef" Id="{80ce9f15-f5e5-47fc-bd90-71374cbb9fcd}">
      <Declaration><![CDATA[PROPERTY P_pZAxisRef : POINTER TO FB_ZAxisRef]]></Declaration>
      <Get Name="Get" Id="{a924c3a1-18e5-4c5f-b87f-23bfad2eb2e3}">
