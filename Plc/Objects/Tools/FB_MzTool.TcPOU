END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_pZAxisRef := pZAxisRef;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_rToolRadius" Id="{699da09b-d3fa-490d-9904-e64d414ff74a}">
      <Declaration><![CDATA[PROPERTY P_rToolRadius : REAL]]></Declaration>
      <Get Name="Get" Id="{dd03e77c-26e5-439a-9e4b-a3f29844f35c}">
        <Declaration><![CDATA[VAR
	stDim : ST_3DDimension;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[//Manche abgeleitete Tools definieren ihren eigenen Tool-Radius
IF pPiece > 0 THEN
	stDim := pPiece^.P_stDimension;
	P_rToolRadius := stDim.Width / 2.0;
ELSE
	P_rToolRadius := 10000.0;	
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_stAbsPosPhys" Id="{5599b342-d998-44ea-bf15-7bf33080e3f5}">
      <Declaration><![CDATA[PROPERTY P_stAbsPosPhys : ST_3DPoint]]></Declaration>
      <Get Name="Get" Id="{68317d0c-6560-4849-8cc9-8ca5e48474a0}">
        <Declaration><![CDATA[VAR
	stTemp	: ST_3DPoint;
	stDim	: ST_3DDimension;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[//Die absolute Postion eines Tool in "Z" hat nicht den gleichen Bezug wie X und Y
//X und Y beziehen sich auf den Koordinatenursprung, wenn die Achsen theoretisch aus Antrieb (0;0) stehen
//Z bezieht sich auf die Sliderunterkante des Z-Antriebes verechnet mit AbsPos vom Head(Ergebnis ist in den meisten Fällen negativ)

stTemp := F_Add3DPoints(stRelPos,stOffset);
//Offsets der Pieces verrechnen
IF pPiece > 0 THEN
	stDim := pPiece^.P_stDimension;
	IF NOT pPiece^.P_bIgnoreOffset THEN
		stTemp := F_Add3DPoints(stTemp,pPiece^.P_stOffset);	
	END_IF
	stTemp.Z := stTemp.Z + pPiece^.P_rZOverlapTool - stDim.Height;
	IF pPiece^.P_pParentSlot > 0 THEN
		stTemp := F_Add3DPoints(stTemp,pPiece^.P_pParentSlot^.P_stRelPos);
	END_IF
END_IF
//AbsPos vom ParentSlot holen
IF pParentSlot > 0 THEN
	stTemp := F_Add3DPoints(stTemp,pParentSlot^.P_stAbsPos);
END_IF

P_stAbsPosPhys := stTemp;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_stAbsPosPhysExclPiece" Id="{05041368-fa69-4523-976d-dfa9118de286}">
      <Declaration><![CDATA[PROPERTY P_stAbsPosPhysExclPiece : ST_3DPoint]]></Declaration>
      <Get Name="Get" Id="{d7903e48-e77e-4181-bd62-2ad2614615dd}">
        <Declaration><![CDATA[VAR
	stTemp	: ST_3DPoint;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[//Die absolute Postion eines Tool in "Z" hat nicht den gleichen Bezug wie X und Y
//X und Y beziehen sich auf den Koordinatenursprung, wenn die Achsen theoretisch aus Antrieb (0;0) stehen
//Z bezieht sich auf die Sliderunterkante des Z-Antriebes verechnet mit AbsPos vom Head(Ergebnis ist in den meisten Fällen negativ)

stTemp := F_Add3DPoints(stRelPos,stOffset);
//AbsPos vom ParentSlot holen
IF pParentSlot > 0 THEN
	stTemp := F_Add3DPoints(stTemp,pParentSlot^.P_stAbsPos);
END_IF

P_stAbsPosPhysExclPiece := stTemp;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_stCurrentPosPhys" Id="{46d9fc97-0df4-4bdb-a54b-a49821b2afd3}">
      <Declaration><![CDATA[PROPERTY P_stCurrentPosPhys : ST_3DPoint]]></Declaration>
      <Get Name="Get" Id="{cc78202b-f575-4b08-865f-704a133e2335}">
        <Declaration><![CDATA[VAR
	stTemp		: ST_3DPoint;
	stAbsPos : ST_3DPoint;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[stAbsPos := P_stAbsPosPhys;
stTemp.X := pXDrive^.P_rActPos + stAbsPos.X;
stTemp.Y := pYDrive^.P_rActPos + stAbsPos.Y;

IF pZAxisRef > 0  THEN
	stTemp.Z := stAbsPos.Z + pZAxisRef^.P_rCurrentPos;
END_IF
P_stCurrentPosPhys := stTemp;
 
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_stCurrentXYArea" Id="{9e4cea2b-6cfd-418f-a0d7-d59a4f73b73b}">
      <Declaration><![CDATA[PROPERTY P_stCurrentXYArea : FB_RectAngle]]></Declaration>
      <Get Name="Get" Id="{c8e457c8-43f0-4360-8dd8-88418c004958}">
        <Declaration><![CDATA[VAR
	stPoint : ST_3DPoint;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[stPoint := P_stCurrentPosPhys;
P_stCurrentXYArea.X1 := stPoint.X - 1.0;
P_stCurrentXYArea.X2 := stPoint.X + 1.0;
P_stCurrentXYArea.Y1 := stPoint.Y - 1.0;
P_stCurrentXYArea.Y2 := stPoint.Y + 1.0;]]></ST>
        </Implementation>
      </Get>
    </Property>
