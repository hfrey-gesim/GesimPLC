      </Implementation>
    </Method>
    <Property Name="P_nGCodeToolNr" Id="{7a8407f9-50c9-41e9-b365-6801dac01bf6}">
      <Declaration><![CDATA[PROPERTY P_nGCodeToolNr : USINT]]></Declaration>
      <Get Name="Get" Id="{6020b870-7c2b-4146-826a-d9856fc3e614}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nGCodeToolNr := nGCodeToolNr;]]></ST>
        </Implementation>
      </Get>
    </Property>
