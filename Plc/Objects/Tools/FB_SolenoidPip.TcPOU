        <Implementation>
          <ST><![CDATA[IF pParentMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_SinglePiezoHolder THEN
	P_bSensorMounted := pZAxisRef^.stInput.nToolState.1;	
END_IF]]></ST>
        </Implementation>
      </Get>
