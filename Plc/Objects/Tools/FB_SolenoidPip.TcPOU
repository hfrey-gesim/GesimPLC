    <Property Name="P_stCurrentXYArea" Id="{737f5dce-e97f-4fe0-aeca-9f2914b32af5}">
      <Declaration><![CDATA[PROPERTY P_stCurrentXYArea : FB_RectAngle]]></Declaration>
      <Get Name="Get" Id="{720fdbfb-eb9f-442a-8593-743737574643}">
        <Declaration><![CDATA[VAR
	stPoint : ST_3DPoint;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[stPoint := P_stCurrentPosPhys;
P_stCurrentXYArea.X1 := stPoint.X - 1500.0;
P_stCurrentXYArea.X2 := stPoint.X + 1500.0;
P_stCurrentXYArea.Y1 := stPoint.Y - 1500.0;
P_stCurrentXYArea.Y2 := stPoint.Y + 1500.0;]]></ST>
        </Implementation>
      </Get>
    </Property>
