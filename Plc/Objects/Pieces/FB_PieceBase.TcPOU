    <Method Name="M_ClearAllProps" Id="{7719d9df-58e4-46b7-b1d8-5dfd54045015}">
      <Declaration><![CDATA[{attribute 'object_name' := 'M_ClearAllProps'}
METHOD M_ClearAllProps

VAR_INPUT
	bIgnoreParent : BOOL; //Es wird das gesamte OD gelöscht. -> Zeiger auf Parent nicht mehr gültig!
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT bIgnoreParent THEN
	IF pParentSlot > 0 THEN
		pParentSlot^.P_pChild := 0;
	END_IF	
END_IF
nObjectID := 0;
pParentObject := 0;
pParentSlot := 0;
pObjCollectNode := 0;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetRelPosTopCenter" Id="{895bb838-4287-4255-85e0-880c3d6350cd}">
      <Declaration><![CDATA[METHOD M_GetRelPosTopCenter : ST_3DPoint
VAR_INPUT
END_VAR
VAR
	stPosTemp : ST_3DPoint;
	pPieceSlot : POINTER TO FB_PieceSlot;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF pParentObject > 0 THEN
	IF pParentObject^.M_bIsGroup(E_ObjectGroup.OBJECTGROUP_Target) THEN
		IF pParentSlot > 0 THEN
			pPieceSlot := pParentSlot;
			stPosTemp := pPieceSlot^.P_stRelPos;
			//Wenn OverlapSlot > SlotTiefe, dann sitzt Piece auf dem Grund des Slots auf
			IF rZOverlapSlot > pPieceSlot^.rDepth THEN
				stPosTemp.Z := stPosTemp.Z - pPieceSlot^.rDepth + stDimension.Height;
			ELSE
				stPosTemp.Z := stPosTemp.Z - rZOverlapSlot + stDimension.Height;
			END_IF
			IF bIgnoreOffset THEN
				M_GetRelPosTopCenter := stPosTemp;
			ELSE
				M_GetRelPosTopCenter := F_Add3DPoints(stPosTemp,stOffset);	
			END_IF
		END_IF
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSingleProp" Id="{8b42104b-9230-4634-bf32-5bb53ab65987}">
      <Declaration><![CDATA[{attribute 'object_name' := 'M_SetSingleProp'}
METHOD M_SetSingleProp : ERRORID
VAR_INPUT
	refCmdData	: REFERENCE TO ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE refCmdData.aHeader[1] OF
	0,1:
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	2:	stDimension.Width := DINT_TO_REAL(refCmdData.n32Data[0]);
	3:	stDimension.Depth := DINT_TO_REAL(refCmdData.n32Data[0]);
	4:	stDimension.Height := DINT_TO_REAL(refCmdData.n32Data[0]);
	5:	rSlotDiameter := DINT_TO_REAL(refCmdData.n32Data[0]);
	6:	rZOverlapTool := DINT_TO_REAL(refCmdData.n32Data[0]);
	7:	rZOverlapSlot := DINT_TO_REAL(refCmdData.n32Data[0]);
	8:	stOffset.X := DINT_TO_REAL(refCmdData.n32Data[0]);
	9:	stOffset.Y := DINT_TO_REAL(refCmdData.n32Data[0]);
	10:	stOffset.Z := DINT_TO_REAL(refCmdData.n32Data[0]);
	11: rMeasureDistance := DINT_TO_REAL(refCmdData.n32Data[0]);
	12:	rDockOffset := DINT_TO_REAL(refCmdData.n32Data[0]);
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ClearOffset" Id="{8ce0672d-aa64-4446-b80a-5f086ed20313}">
      <Declaration><![CDATA[METHOD M_ClearOffset
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stOffset.X := 0.0;
stOffset.Y := 0.0;
stOffset.Z := 0.0;]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_rMeasureDistance" Id="{9bae66cb-d201-4dcc-8eb2-a70f9ca72cb0}">
      <Declaration><![CDATA[PROPERTY P_rMeasureDistance : REAL]]></Declaration>
      <Get Name="Get" Id="{62c0c84e-0df8-4c92-befd-d44a6bd21024}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_rMeasureDistance := rMeasureDistance;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="M_GetAllProps" Id="{b457f268-2efd-4fe4-9c95-d0bca3e91460}">
      <Declaration><![CDATA[{attribute 'object_name' := 'M_GetAllProps'}
METHOD M_GetAllProps : ERRORID
VAR_INPUT
	refCmdData	: REFERENCE TO ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[refCmdData.aHeader[0] := nObjectID;
refCmdData.aHeader[1] := eObjectType;
refCmdData.aHeader[2] := 0;

IF pParentObject > 0 THEN
	refCmdData.n32Data[0] := pParentObject^.P_nObjectID;
ELSE
	refCmdData.n32Data[0] := 0;
END_IF

IF pParentSlot > 0 THEN
	refCmdData.n32Data[1] := pParentSlot^.nNr;
ELSE
	refCmdData.n32Data[1] := 0;
END_IF

//Dimensionen lesen
refCmdData.n32Data[2] := REAL_TO_DINT(stDimension.Width);
refCmdData.n32Data[3] := REAL_TO_DINT(stDimension.Depth);
refCmdData.n32Data[4] := REAL_TO_DINT(stDimension.Height);
refCmdData.n32Data[5] := REAL_TO_DINT(rSlotDiameter);
refCmdData.n32Data[6] := REAL_TO_DINT(rZOverlapTool);
refCmdData.n32Data[7] := REAL_TO_DINT(rZOverlapSlot);
refCmdData.n32Data[8] := REAL_TO_DINT(stOffset.X);
refCmdData.n32Data[9] := REAL_TO_DINT(stOffset.Y);
refCmdData.n32Data[10] := REAL_TO_DINT(stOffset.Z);
refCmdData.n32Data[11] := REAL_TO_DINT(rMeasureDistance);
refCmdData.n32Data[12] := REAL_TO_DINT(rDockOffset);
nCurrentPropIndex := 12;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_AddChild" Id="{bcc24b54-37c5-4672-ac4e-4def77d6218c}">
      <Declaration><![CDATA[METHOD M_AddChild : ERRORID
VAR_INPUT
	pObject	: POINTER TO FB_Object;
	nSlotNr	: UINT;
	nIndex 	: INT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Pieces könnnen keine Childs aufnehmen
M_AddChild := E_ErrorIdObjMgmt.ERRORID_ObjectCanNotTakeChilds;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetAllProps" Id="{c95aee18-be78-4b3d-b6ed-71f97931af31}">
      <Declaration><![CDATA[{attribute 'object_name' := 'M_SetAllProps'}
METHOD M_SetAllProps : ERRORID
VAR_INPUT
	refCmdData	: REFERENCE TO ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF fbObjectDirectory.M_GetObjPointer(DINT_TO_UINT(refCmdData.n32Data[0])) = 0 THEN
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidParentObject;
	RETURN;
END_IF

//ParentSlot unterschiedlich?

(*IF pParentSlot = 0 THEN
	M_SetAllProps := M_SetParent(aI_Object[refCmdData.n32Data[0]],DINT_TO_UINT(refCmdData.n32Data[1]));
ELSE
	IF pParentSlot^.P_nNr <> DINT_TO_UINT(refCmdData.n32Data[1]) THEN
		M_SetAllProps := M_SetParent(aI_Object[refCmdData.n32Data[0]],DINT_TO_UINT(refCmdData.n32Data[1]));
	END_IF
END_IF

IF M_SetAllProps > 0 THEN
	RETURN;
END_IF*)

//Dimensionen setzen
stDimension.Width := DINT_TO_REAL(refCmdData.n32Data[2]);
stDimension.Depth := DINT_TO_REAL(refCmdData.n32Data[3]);
stDimension.Height := DINT_TO_REAL(refCmdData.n32Data[4]);
rSlotDiameter := DINT_TO_REAL(refCmdData.n32Data[5]);
rZOverlapTool := DINT_TO_REAL(refCmdData.n32Data[6]);
rZOverlapSlot := DINT_TO_REAL(refCmdData.n32Data[7]);
stOffset.X := DINT_TO_REAL(refCmdData.n32Data[8]);
stOffset.Y := DINT_TO_REAL(refCmdData.n32Data[9]);
stOffset.Z := DINT_TO_REAL(refCmdData.n32Data[10]);
rMeasureDistance := DINT_TO_REAL(refCmdData.n32Data[11]);
rDockOffset := DINT_TO_REAL(refCmdData.n32Data[12]);
nCurrentPropIndex := 12;
nNoOfProps := nCurrentPropIndex + 1;]]></ST>
      </Implementation>
    </Method>
