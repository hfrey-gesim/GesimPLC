<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_PieceBase" Id="{63b07fb9-5ab1-4920-9bfc-a43e0b6ab977}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_PieceBase EXTENDS FB_Object
VAR_INPUT
END_VAR
VAR_OUTPUT
	bUsingPiece			: BOOL;	
END_VAR
VAR
	pParentObject		: POINTER TO FB_Object;
	stDimension			: ST_3DDimension;
	rSlotDiameter		: REAL;
	stOffset			: ST_3DPoint;	//Offset
	rZOverlapTool		: REAL;
	rZOverlapSlot		: REAL;
	rMeasureDistance	: REAL;
	rDockOffset			: REAL;
	nCurrentPropIndex	: USINT;
	nSpecPropIndex		: USINT;			//erster Index für Specialproperties
	bIgnoreOffset		: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="M_UpdateParent" Id="{12272a62-205a-4dc2-ab64-81302efaa155}">
      <Declaration><![CDATA[METHOD M_UpdateParent
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF pObjCollectNode > 0 AND_THEN pObjCollectNode^.pOwnerColl > 0 THEN
	pParentObject := pObjCollectNode^.pOwnerColl^.pOwnerNode^.P_pObject;
ELSE
	pParentObject := 0;
END_IF

IF pParentObject > 0 THEN
	pParentSlot := pParentObject^.M_GetSlotFromChild(THIS);
ELSE
	pParentSlot := 0;
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetPropCheckSum" Id="{18633363-fac8-4800-9b10-f9ba3b401402}">
      <Declaration><![CDATA[METHOD M_GetPropCheckSum : UINT
VAR_INPUT
END_VAR

VAR
	stData 		: ST_CmdData;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetAllProps(stData);
wChecksum := F_DATA_TO_CRC16_CCITT(ADR(stData.n32Data[0]),nNoOfProps * 4,16#FFFF);
M_GetPropCheckSum := wChecksum;]]></ST>
      </Implementation>
    </Method>
