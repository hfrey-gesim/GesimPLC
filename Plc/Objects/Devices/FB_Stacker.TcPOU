    <Property Name="P_eCurrentSpinPositon" Id="{3206e673-f0f5-4bd7-9945-06da70f5b2c6}">
      <Declaration><![CDATA[PROPERTY P_eCurrentSpinPositon : E_StackerRotPosition]]></Declaration>
      <Get Name="Get" Id="{1d04ee20-06da-4582-a47e-e5b9842e8bb0}">
        <Declaration><![CDATA[VAR
	nActPosTemp : DINT;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF pHwRef_SpinDrive^.P_nActualPosition > 359000 THEN
	nActPosTemp := -(360000 - pHwRef_SpinDrive^.P_nActualPosition);
ELSE
	nActPosTemp := pHwRef_SpinDrive^.P_nActualPosition;
END_IF

IF nActPosTemp >= (nLoadingPosAngle - 100) AND nActPosTemp <= (nLoadingPosAngle + 100) THEN
	P_eCurrentSpinPositon := E_StackerRotPosition.LoadingPosition;
ELSIF nActPosTemp >= (nTransferPosAnglePrint1 - 100) AND nActPosTemp <= (nTransferPosAnglePrint1 + 100) THEN
	P_eCurrentSpinPositon := E_StackerRotPosition.TransferPositionPrinter1;
ELSIF nActPosTemp >= (nTransferPosAnglePrint2 - 100) AND nActPosTemp <= (nTransferPosAnglePrint2 + 100) THEN
	P_eCurrentSpinPositon := E_StackerRotPosition.TransferPositionPrinter2;
ELSE
	P_eCurrentSpinPositon := E_StackerRotPosition.UNDEFINED;
END_IF
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_eCurrentState" Id="{e23c968c-9a73-4198-b0ff-88105f5ba9b2}">
      <Declaration><![CDATA[PROPERTY P_eCurrentState : E_MachineState]]></Declaration>
      <Get Name="Get" Id="{d56ba0af-dc92-43f1-b47f-9b63d86b6b62}">
