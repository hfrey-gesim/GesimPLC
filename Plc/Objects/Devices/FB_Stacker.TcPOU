    <Method Name="M_Reset" Id="{1020664e-004e-41e5-897d-2290e44b8ebe}">
      <Declaration><![CDATA[METHOD M_Reset
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bBusy := TRUE;
eCurrentState := E_MachineState.MACHINESTATE_Reset;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetAllProps" Id="{a7e0c6d5-8999-4f49-8640-388d6dd9fbff}">
      <Declaration><![CDATA[METHOD M_SetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR

VAR
	i : UINT;
	nCurrentPropIndex	: UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[nCurrentPropIndex := 1;
nParentSlotNr := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
//Shelfes (Fächer) parametrieren
nNumberOfShelves := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
IF nNumberOfShelves > cMaxShelfes THEN
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidNumberOfShelfes;
	RETURN;
END_IF

FOR i := 1 TO nNumberOfShelves DO
	nCurrentPropIndex := nCurrentPropIndex + 1;
	aShelfes[i].nPosition := refCmdData.n32Data[nCurrentPropIndex];
	aShelfes[i].bConfigured := TRUE;
END_FOR

{IF defined (Stacker)}
	pHwRef_SpinDrive := ADR(fbHwRefSpinDrive);
	pHwRef_LiftDrive := ADR(fbHwRefLiftDrive);
	pHwRef_TrayStop := ADR(fbHwRefTrayStop);
{ELSE}
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_Stacker_NotDefined;
	RETURN;
{END_IF}

nCurrentPropIndex := nCurrentPropIndex + 1;
nLoadingPosAngle := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
nTransferPosAnglePrint1 := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
nTransferPosAnglePrint2 := refCmdData.n32Data[nCurrentPropIndex];
nNoOfProps := nCurrentPropIndex + 1;
 ]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSingleProp" Id="{d842e7bc-c393-4c16-beba-31952210c5cb}">
      <Declaration><![CDATA[METHOD M_SetSingleProp : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*IF nSpecPropIndex = refCmdData.aHeader[1] THEN
	nLoadingPosAngle := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 1) = refCmdData.aHeader[1] THEN
	nTransferPosAnglePrint1 := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 2) = refCmdData.aHeader[1] THEN
	nTransferPosAnglePrint2 := refCmdData.n32Data[0];
ELSE
	M_SetSingleProp := SUPER^.M_SetSingleProp(refCmdData);
END_IF*)]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{1ad0d9cd-a1b7-4420-a794-812f186f2be3}">
      <Declaration><![CDATA[METHOD M_Stop : ERRORID
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eCurrentState = E_MachineState.MACHINESTATE_Active THEN
	IF bInit AND nStateA_Init < 70 THEN
		nStateA_Init := 70;
	END_IF
	
	IF bTurnTo AND nStateA_TurnTo < 70 THEN
		nStateA_TurnTo := 70;
	END_IF
	
	IF bMoveLifter AND nStateA_MoveLifter < 70 THEN
		nStateA_MoveLifter := 70;
	END_IF
	
	IF bOpClTrayStop AND nStateA_OpClTrayStop < 70 THEN
		nStateA_OpClTrayStop := 70;
	END_IF	
END_IF]]></ST>
      </Implementation>
    </Method>
