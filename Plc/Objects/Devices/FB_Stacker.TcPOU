<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.11">
  <POU Name="FB_Stacker" Id="{f8d592f7-3fdb-4527-8cd4-2934179103ba}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Stacker EXTENDS FB_Object IMPLEMENTS I_Device

VAR
	nParentSlotNr		: UINT;		//Stacker befindet sich zwar an keinem Slot, aber virtuell in der GUI (am Root)#
	eCurrentState		: E_MachineState := E_MachineState.MACHINESTATE_Idle;
	nNotifyId			: UINT;
	nErrorId			: ERRORID;
	bCanceled			: BOOL;
	bStopAllOnError		: BOOL;
	bIsInit				: BOOL;
	bBusy				: BOOL;
	bError				: BOOL;
	stError				: ST_Error :=(POU := E_POU.POU_FB_Stacker);
	
	nNumberOfShelves	: USINT;
	aShelfes			: ARRAY[1..cMaxShelfes] OF ST_Shelf;
	
	//Hardware-Referenzen
	pHwRef_SpinDrive	: POINTER TO FB_HwRefEL70xxDrive;
	pHwRef_LiftDrive	: POINTER TO FB_HwRefEL70xxDrive;
	pHwRef_TrayStop		: POINTER TO FB_HwRefEL70xxDrive;
	
	bSensorTransAreaLeft 		AT %I* : BOOL;
	bSensorTransAreaRight		AT %I* : BOOL;
	bSensorTrayAlignmentLeft 	AT %I* : BOOL;
	bSensorTrayAlignmentRight 	AT %I* : BOOL;
	bSensorTrayDetection		AT %I* : BOOL;
	
	//Spec-Properties
	nLoadingPosAngle		: DINT;	//Drehwinkel Beladeposition
	nTransferPosAnglePrint1 : DINT;	//Drehwinkel Transferpostion zu Drucker 1
	nTransferPosAnglePrint2 : DINT;	//Drehwinkel Transferpostion zu Drucker 2 (wird derzeit nicht verwendet)
		
	//****************************************Aktionvariablen****************************************************
	
	//Action: "Init"
	bInit				: BOOL;
	nStateA_Init		: USINT;
	fbPower 			: FB_HWECtrl_EL70xx_Power;
	fbHoming 			: FB_HWECtrl_EL70xx_Home;
	pCurrentInitDrive	: POINTER TO FB_HwRefEL70xxDrive;
	
	//Action: "TurnTo"
	bTurnTo				: BOOL;
	nStateA_TurnTo		: USINT;
	fbHwCtrl_Turn		: FB_HWECtrl_EL70xx_Move;
	nTurnToPosition		: DINT;
	
	//Action: "MoveLifter"
	bMoveLifter			: BOOL;
	nStateA_MoveLifter	: USINT;
	nMoveLifterPosition	: DINT;
	nMoveLifterSpeed	: DINT;
	fbHWECtrl_MoveLifter: FB_HWECtrl_EL70xx_Move;
	
	//Action: "OpenCloseTrayStop"
	bOpClTrayStop			: BOOL;
	nStateA_OpClTrayStop	: USINT;
	eOpClTrayStopCtrl		: E_OpClCtrl;
	fbHwCtrl_MoveTrayStop 	: FB_HWECtrl_EL70xx_Move;
	
	//Action: "Load" (Bestücken oder Entnehmen)
	bLoad			: BOOL;
	nStateA_Load	: USINT;
	nBottomShelf	: UINT; //unterstes Fach
	
	stProcessData		: ST_ObjectProcData;
	
END_VAR

VAR CONSTANT
	cMaxShelfes : UINT := 10;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[CASE eCurrentState OF
	E_MachineState.MACHINESTATE_Active:
	
		IF bInit THEN
			A_Init();
			IF nStateA_Init >= 80 THEN
				IF nStateA_Init >= 99 THEN
					bError := TRUE;	
				END_IF
				bInit := FALSE;
				nStateA_Init := 0;
			END_IF
		END_IF
		
		IF bTurnTo THEN
			A_TurnTo();
			IF nStateA_TurnTo >= 80 THEN
				IF nStateA_TurnTo >= 99 THEN
					bError := TRUE;	
				END_IF
				bTurnTo := FALSE;
				nStateA_TurnTo := 0;
			END_IF
		END_IF
		
		IF bMoveLifter THEN
			A_MoveLifter();
			IF nStateA_MoveLifter >= 80 THEN
				IF nStateA_MoveLifter >= 99 THEN
					bError := TRUE;	
				END_IF
				bMoveLifter := FALSE;
				nStateA_MoveLifter := 0;
			END_IF
		END_IF
		
		IF bOpClTrayStop THEN
			A_OpClTrayStop();
			IF nStateA_OpClTrayStop >= 80 THEN
				IF nStateA_OpClTrayStop >= 99 THEN
					bError := TRUE;	
				END_IF
				bOpClTrayStop := FALSE;
				nStateA_OpClTrayStop := 0;
			END_IF
		END_IF
		
		IF bLoad THEN
			A_Load();
			IF nStateA_Load >= 80 THEN
				IF nStateA_Load >= 99 THEN
					bError := TRUE;	
				END_IF
				bLoad := FALSE;
				nStateA_Load := 0;
			END_IF
		END_IF
		
		IF NOT (bInit OR bTurnTo OR bMoveLifter OR bOpClTrayStop OR bLoad) THEN
			bBusy := FALSE;
			eCurrentState := E_MachineState.MACHINESTATE_Idle;
		END_IF

		IF bError  THEN
			eCurrentState := E_MachineState.MACHINESTATE_Error;
		END_IF

	E_MachineState.MACHINESTATE_Reset:
		nStateA_Init := 0;
		nStateA_TurnTo := 0;
		nStateA_MoveLifter := 0;
		nStateA_OpClTrayStop := 0;
		nStateA_Load := 0;
		bBusy := FALSE;
		bError := FALSE;
		bStopAllOnError := FALSE;
		stError.Cmd := 0;
		stError.ErrorId := 0;
		eCurrentState := E_MachineState.MACHINESTATE_Idle;
	
	E_MachineState.MACHINESTATE_Error:
		bBusy := FALSE;
END_CASE

//Prozessdaten aktualisieren
stProcessData.nObjId := nObjectID;
stProcessData.n32Data[0] := BOOL_TO_DINT(P_bIsInit);
stProcessData.n32Data[1] := eCurrentState;
stProcessData.n32Data[2] := stError.ErrorId;
stProcessData.n32Data[3] := pHwRef_LiftDrive^.P_nActualPosition;
stProcessData.n32Data[4] := pHwRef_SpinDrive^.P_nActualPosition;
IF pHwRef_TrayStop^.bInput1 THEN //Open
	stProcessData.n32Data[5] := E_OpClState.Open;
ELSIF pHwRef_TrayStop^.bInput2 THEN //Closed
	stProcessData.n32Data[5] := E_OpClState.Closed;
ELSE
	stProcessData.n32Data[5] := E_OpClState.UNDEFINED;
END_IF
	stProcessData.n32Data[6] := BOOL_TO_DINT(bSensorTrayAlignmentLeft AND bSensorTrayAlignmentRight);

aObjProcData[nNotifyId] := stProcessData;]]></ST>
    </Implementation>
    <Action Name="A_Init" Id="{6a4671f8-a2b8-4336-b86c-03d30b71aca8}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nStateA_Init;

CASE nStateA_Init OF
	0:	//Power TrayStop
		pCurrentInitDrive := pHwRef_TrayStop;
		fbPower(pHwRef:= pHwRef_TrayStop, bEnable:= TRUE, bExecute:= TRUE);
		IF NOT fbPower.bBusy THEN
			IF fbPower.bError THEN
				stError.ErrorId := fbPower.nErrorId;
				nStateA_Init := 99;
			ELSE
				nStateA_Init := 1;
			END_IF
			fbPower(pHwRef := pHwRef_TrayStop, bExecute:= FALSE);
		END_IF
		
	1:	//Power SpinDrive
		pCurrentInitDrive := pHwRef_SpinDrive;
		fbPower(pHwRef:= pHwRef_SpinDrive, bEnable:= TRUE, bExecute:= TRUE);
		IF NOT fbPower.bBusy THEN
			IF fbPower.bError THEN
				stError.ErrorId := fbPower.nErrorId;
				nStateA_Init := 99;
			ELSE
				nStateA_Init := 2;
			END_IF
			fbPower(pHwRef:= pHwRef_SpinDrive, bExecute:= FALSE);
		END_IF

	2:	//Power LiftDrive
		pCurrentInitDrive := pHwRef_LiftDrive;
		fbPower(pHwRef:= pHwRef_LiftDrive, bEnable:= TRUE, bExecute:= TRUE);
		IF NOT fbPower.bBusy THEN
			IF fbPower.bError THEN
				stError.ErrorId := fbPower.nErrorId;
				nStateA_Init := 99;
			ELSE
				nStateA_Init := 3;
			END_IF
			fbPower(pHwRef:= pHwRef_LiftDrive, bExecute:= FALSE);
		END_IF
		
	3:	//Homing TrayStop
		pCurrentInitDrive := pHwRef_TrayStop;
		fbHoming(pHwRef:= pHwRef_TrayStop, bExecute:= TRUE);
		IF NOT fbHoming.bBusy THEN
			IF fbHoming.bError THEN
				stError.ErrorId := fbHoming.nErrorId;
				nStateA_Init := 99;
			ELSE
				nStateA_Init := 4;
			END_IF
			fbHoming(pHwRef:= pHwRef_TrayStop, bExecute:= FALSE);
		END_IF

	4:	//Homing SpinDrive
		pCurrentInitDrive := pHwRef_SpinDrive;
		fbHoming(pHwRef:= pHwRef_SpinDrive, bExecute:= TRUE);
		IF NOT fbHoming.bBusy THEN
			IF fbHoming.bError THEN
				stError.ErrorId := fbHoming.nErrorId;
				nStateA_Init := 99;
			ELSE
				nStateA_Init := 5;
			END_IF
			fbHoming(pHwRef:= pHwRef_SpinDrive, bExecute:= FALSE);
		END_IF
		
	5:	//Homing LiftDrive
		pCurrentInitDrive := pHwRef_LiftDrive;
		//TransArea überwachen
		IF NOT P_bTransAreaFree THEN
			//Stoppen und dann in Error
			fbHoming(pHwRef:= pHwRef_LiftDrive, bStop := TRUE);
			nStateA_Init := 75;
		ELSE
			fbHoming(pHwRef:= pHwRef_LiftDrive, bExecute:= TRUE);
			IF NOT fbHoming.bBusy THEN
				IF fbHoming.bError THEN
					stError.ErrorId := fbHoming.nErrorId;
					nStateA_Init := 99;
				ELSE
					nStateA_Init := 80;
				END_IF
				fbHoming(pHwRef:= pHwRef_LiftDrive, bExecute:= FALSE);
			END_IF
		END_IF
		
	70:	//Abbrechen
		IF fbPower.bBusy THEN //Warten bis fbPower fertig
			nStateA_Init := 71;
		ELSIF fbHoming.bBusy THEN
			nStateA_Init := 72;
		ELSE
			nStateA_Init := 80;
		END_IF
		
	71:	//Power ready?
		fbPower(pHwRef:= pCurrentInitDrive);
		IF NOT fbPower.bBusy THEN
			fbPower(pHwRef:= pCurrentInitDrive, bExecute := FALSE);
			nStateA_Init := 80;
		END_IF
		
	72:	//Homing abbrechen
		fbHoming(pHwRef:= pCurrentInitDrive, bStop:= TRUE);
		IF NOT fbHoming.bBusy THEN
			fbHoming(pHwRef:= pCurrentInitDrive, bStop:= FALSE, bExecute := FALSE);
			nStateA_Init := 80;
		END_IF
		
	75:	//Homing Lifter abbrechen und dann in Error
		fbHoming(pHwRef:= pCurrentInitDrive, bStop:= TRUE);
		IF NOT fbHoming.bBusy THEN
			fbHoming(pHwRef:= pCurrentInitDrive, bStop:= FALSE, bExecute := FALSE);
			stError.ErrorId := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
			nStateA_Init := 99;
		END_IF
 	
END_CASE

//Errorhandling
IF nStateA_Init = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_Init;
	stError.POUAction := E_POUACT.POUACT_A_Init;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_Load" Id="{e778a475-0736-4db9-b8d8-85e9b4b33938}">
      <Implementation>
        <ST><![CDATA[//Diese Action darf nur ausgeführt werden, wenn:
//Initialisiert ist
//keine andere Action aktiv ist
//Es werden alle Actions einzeln ausgeführt.
//1. turn
//2. move lifter
//3. close tray stopper
//4. open interlock

CASE nStateA_Load OF
	0:	//Turn to loading position
		nTurnToPosition := nLoadingPosAngle;
		A_TurnTo();
		IF nStateA_TurnTo >= 80 THEN
			IF nStateA_TurnTo >= 99 THEN
				nStateA_Load := 99;
			ELSE
				nStateA_Load := 1;
			END_IF
			nStateA_TurnTo := 0;
		END_IF

	1:	//Move lifter
		nMoveLifterPosition := M_GetBottomShelfPos();
		nMoveLifterSpeed := pHwRef_LiftDrive^.P_nMaxSpeed;
		A_MoveLifter();
		IF nStateA_MoveLifter >= 80 THEN
			IF nStateA_MoveLifter >= 99 THEN
				nStateA_Load := 99;
			ELSE
				nStateA_Load := 2;
			END_IF
			nStateA_MoveLifter := 0;
		END_IF
				
	2:	//Close tray stopper
		eOpClTrayStopCtrl := E_OpClCtrl.Close;
		A_OpClTrayStop();
		IF nStateA_OpClTrayStop >= 80 THEN
			IF nStateA_OpClTrayStop >= 99 THEN
				nStateA_Load := 99;
			ELSE
				nStateA_Load := 3;
			END_IF
			nStateA_OpClTrayStop := 0;
		END_IF
		
	3:	//Open interlock stacker
		{IF defined(Stacker)}
		fbSafetyStacker.M_Control(E_SafetyCtrl.Unlock);
		{END_IF}
		nStateA_Load := 80;
	
	70:	//Cancel
		//Which actin is active?
		//we can identify the active action wich nStateA_xxxx is greather than 0
		IF nStateA_TurnTo > 0 THEN
			;
		ELSIF nStateA_MoveLifter > 0 THEN
			;
		ELSIF nStateA_OpClTrayStop > 0 THEN
			;
		END_IF
	
	
END_CASE

]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveLifter" Id="{bdc9ef98-55ce-4c64-b557-b10613fc331f}">
      <Implementation>
        <ST><![CDATA[IF nStateA_MoveLifter = 0 THEN
	//Nur TransArea überwachen	
	IF NOT P_bTransAreaFree THEN
		//Stoppen und dann in Error
		fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, bStop:= TRUE);
		nStateA_MoveLifter := 75;
	ELSE
		fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, nPosition := nMoveLifterPosition, nSpeed:= nMoveLifterSpeed, bExecute:= TRUE);
		IF NOT fbHWECtrl_MoveLifter.bBusy THEN
			IF fbHWECtrl_MoveLifter.bError THEN
				stError.ErrorId := fbHWECtrl_MoveLifter.nErrorId;
				nStateA_MoveLifter := 99;
			ELSE
				nStateA_MoveLifter := 80;
			END_IF
			fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, bExecute:= FALSE);
		END_IF
	END_IF
	
ELSIF nStateA_MoveLifter = 70 THEN //Normal stoppen
	fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, bStop := TRUE);
	IF NOT fbHWECtrl_MoveLifter.bBusy THEN
		IF fbHWECtrl_MoveLifter.bError THEN
			stError.ErrorId := fbHWECtrl_MoveLifter.nErrorId;
			nStateA_MoveLifter := 99;
		ELSE
			nStateA_MoveLifter := 80;
		END_IF
		fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, bExecute:= FALSE);
	END_IF
	
ELSIF nStateA_MoveLifter = 75 THEN //Stoppen mit folgender Error-Meldung
	fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive);
	IF NOT fbHWECtrl_MoveLifter.bBusy THEN
		IF fbHWECtrl_MoveLifter.bError THEN
			stError.ErrorId := fbHWECtrl_MoveLifter.nErrorId;
		ELSE
			stError.ErrorId := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
		END_IF
		fbHWECtrl_MoveLifter(pHwRef:= pHwRef_LiftDrive, bExecute:= FALSE);
		nStateA_MoveLifter := 99;
	END_IF
END_IF

//Errorhandling
IF nStateA_MoveLifter = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_MoveLifter;
	stError.POUAction := E_POUACT.POUACT_A_MoveLifter;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_OpClTrayStop" Id="{fad61029-ac97-4061-82b7-aa3f29a40dba}">
      <Implementation>
        <ST><![CDATA[IF nStateA_OpClTrayStop = 0 THEN
	IF eOpClTrayStopCtrl = E_OpClCtrl.Close THEN
		fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop, nPosition:= pHwRef_TrayStop^.P_nMaxPos, nSpeed:= pHwRef_TrayStop^.P_nMaxSpeed, bExecute:= TRUE);
		nStateA_OpClTrayStop := 1;
	ELSE
		fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop, nPosition:= 0, nSpeed:= pHwRef_TrayStop^.P_nMaxSpeed, bExecute:= TRUE);
		nStateA_OpClTrayStop := 1;
	END_IF
ELSIF nStateA_OpClTrayStop = 1 THEN
	fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop);
	IF NOT fbHwCtrl_MoveTrayStop.bBusy THEN
		IF fbHwCtrl_MoveTrayStop.bError THEN
			stError.ErrorId := fbHwCtrl_MoveTrayStop.nErrorId;
			nStateA_OpClTrayStop := 99;
		ELSE
			IF eOpClTrayStopCtrl = E_OpClCtrl.Close THEN
				IF pHwRef_TrayStop^.bInput2 THEN
					nStateA_OpClTrayStop := 80;
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_TrayStopNotClosed;
					nStateA_OpClTrayStop := 99;
				END_IF
			ELSE
				IF pHwRef_TrayStop^.bInput1 THEN
					nStateA_OpClTrayStop := 80;
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_TrayStopNotOpen;
					nStateA_OpClTrayStop := 99;
				END_IF
			END_IF
		END_IF
		fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop, bExecute:= FALSE);
	END_IF
ELSIF nStateA_OpClTrayStop = 70 THEN
	fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop, bStop := TRUE);
	IF NOT fbHwCtrl_MoveTrayStop.bBusy THEN
		IF fbHwCtrl_MoveTrayStop.bError THEN
			stError.ErrorId := fbHwCtrl_MoveTrayStop.nErrorId;
			nStateA_OpClTrayStop := 99;
		ELSE
			nStateA_OpClTrayStop := 80;
		END_IF
		fbHwCtrl_MoveTrayStop(pHwRef:= pHwRef_TrayStop, bExecute:= FALSE);
	END_IF
	
END_IF

//Errorhandling
IF nStateA_OpClTrayStop = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_OpenClose;
	stError.POUAction := E_POUACT.POUACT_A_OpClTrayStop;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TurnTo" Id="{236ce99b-081e-458c-8081-62ddfff656f2}">
      <Implementation>
        <ST><![CDATA[IF nStateA_TurnTo = 0 THEN
	fbHwCtrl_Turn(pHwRef:= pHwRef_SpinDrive, nPosition:= nTurnToPosition, nSpeed:= pHwRef_SpinDrive^.P_nMaxSpeed,
					nToleranceWindow:= 50, bExecute:= TRUE);
	IF NOT fbHwCtrl_Turn.bBusy THEN
		IF fbHwCtrl_Turn.bError THEN
			stError.ErrorId := fbHwCtrl_Turn.nErrorId;
			nStateA_TurnTo := 99;
		ELSE
			nStateA_TurnTo := 80;
		END_IF
		fbHwCtrl_Turn(pHwRef:= pHwRef_SpinDrive, bExecute := FALSE);
	END_IF
ELSIF nStateA_TurnTo = 70 THEN
	fbHwCtrl_Turn(pHwRef:= pHwRef_SpinDrive, bStop:= TRUE);
	IF NOT fbHwCtrl_Turn.bBusy THEN
		IF fbHwCtrl_Turn.bError THEN
			stError.ErrorId := fbHwCtrl_Turn.nErrorId;
			nStateA_TurnTo := 99;
		ELSE
			nStateA_TurnTo := 80;
		END_IF
		fbHwCtrl_Turn(pHwRef:= pHwRef_SpinDrive, bExecute := FALSE);
	END_IF	
END_IF

//Errorhandling
IF nStateA_TurnTo = 99 THEN
	stError.ObjectId := nObjectID;
	stError.Cmd := E_Action.ACTION_TurnTo;
	stError.POUAction := E_POUACT.POUACT_A_TurnTo;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="FB_init" Id="{f9a7eb7f-9be7-4bc9-953c-9146258cbf9c}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains 		: BOOL; // if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode 		: BOOL;  // if TRUE, the instance afterwards gets moved into the copy code (online change)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[eObjectType := E_ObjectType.OBJECTTYPE_Stacker;
eObjectGroup := E_ObjectGroup.OBJECTGROUP_Device;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CancelAction" Id="{52aeec01-1bfb-4d1e-a15b-ca58b70141c6}">
      <Declaration><![CDATA[METHOD M_CancelAction
VAR_INPUT
	eAction : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eAction OF
	E_Action.ACTION_Init:
		IF bInit AND nStateA_Init < 70 THEN
			nStateA_Init := 70;
		END_IF
		
	E_Action.ACTION_TurnTo:
		IF bTurnTo AND nStateA_TurnTo < 70 THEN
			nStateA_TurnTo := 70;
		END_IF
		
	E_Action.ACTION_MoveLifter:
		IF bMoveLifter AND nStateA_MoveLifter < 70 THEN
			nStateA_MoveLifter := 70;
		END_IF
		
	E_Action.ACTION_OpenClose:
		IF bOpClTrayStop AND nStateA_OpClTrayStop < 70 THEN
			nStateA_OpClTrayStop := 70;
		END_IF
		
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckAction" Id="{cdd695e1-2576-4bf3-aeea-155881d07d0c}">
      <Declaration><![CDATA[METHOD M_CheckAction : ERRORID
VAR_INPUT
	refActionData 	: REFERENCE TO ST_ActionData;
	pCorrelObject	: POINTER TO FB_Object;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_CheckAction := E_ErrorIdCmd.ERRORID_InvalidAction;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CheckProcDataType" Id="{097f035e-a523-4887-a70f-c028028da1da}">
      <Declaration><![CDATA[METHOD M_CheckProcDataType : BOOL
VAR_INPUT
	eProcDataType : E_ProcDataType;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ClearAllProps" Id="{766e1508-7eb0-4d9d-b34f-fa0031c4612d}">
      <Declaration><![CDATA[METHOD M_ClearAllProps
VAR_INPUT
	bIgnoreParent : BOOL; //Es wird das gesamte OD gelöscht. -> Zeiger auf Parent nicht mehr gültig!	
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[MEMSET(ADR(aShelfes), 0, SIZEOF(aShelfes));]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ExeAction" Id="{c158a3da-a343-4259-b179-02467dfff6a8}">
      <Declaration><![CDATA[METHOD M_ExeAction : ERRORID
VAR_INPUT
	refActionData	: REFERENCE TO ST_ActionData;
END_VAR


VAR
	eStackerRotPosition : E_StackerRotPosition;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Stacker ist so implementiet, dass mehrere Actions nicht zeitgleich ausgeführt werden können.
//Das bedeutet, dass eCurrentState idle sein muss
IF eCurrentState = E_MachineState.MACHINESTATE_Active THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_BasicActionActive;
	RETURN;	
ELSIF eCurrentState = E_MachineState.MACHINESTATE_Error OR eCurrentState = E_MachineState.MACHINESTATE_Reset THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidState;
	RETURN;	
END_IF

IF refActionData.eAction <> E_Action.ACTION_Init THEN
	IF NOT P_bIsInit THEN
		M_ExeAction := E_ErrorIdCmd.ERRORID_DeviceNotInitialized;
		RETURN;
	END_IF
END_IF

{IF defined(Stacker)}
IF fbSafetyStacker.eCurrentState <> E_SafetyState.Locked THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_InterlockNotLocked;
END_IF
{END_IF}

CASE refActionData.eAction OF
	E_Action.ACTION_Init:
		IF NOT bInit THEN
			IF NOT P_bTransAreaFree THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
				RETURN;
			END_IF
			
			IF NOT P_bTraysAligned THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TraysNotAligned;
				RETURN;
			END_IF
			bInit := TRUE;
		ELSE
			RETURN;
		END_IF

	E_Action.ACTION_TurnTo:
		IF NOT bTurnTo THEN
			IF NOT P_bTransAreaFree THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
				RETURN;
			END_IF
			
			IF NOT P_bTraysAligned THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TraysNotAligned;
				RETURN;
			END_IF
			
			eStackerRotPosition := DINT_TO_USINT(refActionData.aParams[1]);
			CASE eStackerRotPosition OF
				E_StackerRotPosition.LoadingPosition:
					nTurnToPosition := nLoadingPosAngle;
				E_StackerRotPosition.TransferPositionPrinter1:
					nTurnToPosition := nTransferPosAnglePrint1;
				E_StackerRotPosition.TransferPositionPrinter2:
					nTurnToPosition := nTransferPosAnglePrint2;
			ELSE
				M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidStackerAngle;
				RETURN;
			END_CASE
			bTurnTo := TRUE;
		ELSE
			RETURN;
		END_IF
		
	E_Action.ACTION_MoveLifter:
		IF NOT bMoveLifter THEN
			IF NOT P_bTransAreaFree THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
				RETURN;
			END_IF
			
			IF NOT P_bTraysAligned THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_TraysNotAligned;
				RETURN;
			END_IF
			
			nMoveLifterPosition := refActionData.aParams[1];
			nMoveLifterSpeed := refActionData.aParams[2];
			bMoveLifter := TRUE;
		ELSE
			RETURN;
		END_IF
		
	E_Action.ACTION_OpenClose:
		IF NOT bOpClTrayStop THEN
			eOpClTrayStopCtrl := DINT_TO_USINT(refActionData.aParams[1]);
			bOpClTrayStop := TRUE;
		ELSE
			RETURN;
		END_IF
		
	E_Action.ACTION_LoadStacker:
		IF NOT P_bTransAreaFree THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_TransferAreaNotFree;
			RETURN;
		END_IF
		
		IF NOT P_bTraysAligned THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_TraysNotAligned;
			RETURN;
		END_IF
		
		IF NOT bLoad THEN
			bLoad := TRUE;
		ELSE
			RETURN;
		END_IF
	
END_CASE

eCurrentState := E_MachineState.MACHINESTATE_Active;
bBusy := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetActionBusy" Id="{4456857c-8d47-4244-b2f0-54a996bd0baa}">
      <Declaration><![CDATA[METHOD M_GetActionBusy : BOOL
VAR_INPUT
	eAction : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eAction OF
	E_Action.ACTION_Init:
		M_GetActionBusy := bInit;
	E_Action.ACTION_TurnTo:
		M_GetActionBusy := bTurnTo;
	E_Action.ACTION_MoveLifter:
		M_GetActionBusy := bMoveLifter;
	E_Action.ACTION_OpenClose:
		M_GetActionBusy := bOpClTrayStop;
	E_Action.ACTION_LoadStacker:
		M_GetActionBusy := bLoad;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetAllProps" Id="{98ef0bf2-59e0-4987-aa75-3f69b4ec7e59}">
      <Declaration><![CDATA[METHOD M_GetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR

VAR
	nCurrentPropIndex	: UINT;
	i : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[refCmdData.aHeader[0] := nObjectID;
refCmdData.aHeader[1] := eObjectType;
refCmdData.aHeader[2]:= nNotifyId;

nCurrentPropIndex := 1;
refCmdData.n32Data[nCurrentPropIndex] := nParentSlotNr;
nCurrentPropIndex := nCurrentPropIndex + 1;
refCmdData.n32Data[nCurrentPropIndex] := nNumberOfShelves;
FOR i := 1 TO nNumberOfShelves DO
	nCurrentPropIndex := nCurrentPropIndex + 1;
	refCmdData.n32Data[nCurrentPropIndex] := aShelfes[i].nPosition;	
END_FOR
nCurrentPropIndex := nCurrentPropIndex + 1;
refCmdData.n32Data[nCurrentPropIndex] := nLoadingPosAngle;
nCurrentPropIndex := nCurrentPropIndex + 1;
refCmdData.n32Data[nCurrentPropIndex] := nTransferPosAnglePrint1;
nCurrentPropIndex := nCurrentPropIndex + 1;
refCmdData.n32Data[nCurrentPropIndex] := nTransferPosAnglePrint2;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetBottomShelfPos" Id="{337386ba-3fa1-4591-946b-350815013f06}">
      <Declaration><![CDATA[METHOD M_GetBottomShelfPos : DINT
VAR_INPUT
END_VAR

VAR
	i 		: UINT;
	nPos	: DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[FOR i := 1 TO nNumberOfShelves DO
	IF aShelfes[i].nPosition > nPos THEN
		nPos :=	aShelfes[i].nPosition;
	END_IF
END_FOR
M_GetBottomShelfPos := nPos;]]></ST>
      </Implementation>
    </Method>
