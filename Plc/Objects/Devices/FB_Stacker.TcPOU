    <Property Name="P_nCurrentShelf" Id="{1f0642f9-267f-42d5-9605-9f1ed3d48939}">
      <Declaration><![CDATA[PROPERTY P_nCurrentShelf : UINT]]></Declaration>
      <Get Name="Get" Id="{2e8f0b79-d584-46ab-b308-7a7339c1edcb}">
        <Declaration><![CDATA[VAR
	i : USINT;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[FOR i := 1 TO nNumberOfShelves DO
	IF pHwRef_LiftDrive^.P_nActualPosition >= aShelfes[i].nPosition - 200 AND pHwRef_LiftDrive^.P_nActualPosition <= aShelfes[i].nPosition + 200 THEN
		P_nCurrentShelf := i;
		EXIT;
	END_IF
END_FOR]]></ST>
        </Implementation>
      </Get>
    </Property>
