    <Property Name="P_bTransAreaFree" Id="{e38fb50b-44c8-440e-8214-b2b569b51375}">
      <Declaration><![CDATA[PROPERTY P_bTransAreaFree : BOOL]]></Declaration>
      <Get Name="Get" Id="{a8af8630-d44c-4f87-b5de-f190505aefcc}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_bTransAreaFree := TRUE;
IF F_GetMappingStatus(ADR(bSensorTransAreaLeft),SIZEOF(bSensorTransAreaLeft)) = EPlcMappingStatus.MS_Partial THEN
	IF NOT bSensorTransAreaLeft THEN
		P_bTransAreaFree := FALSE;
	END_IF
END_IF

IF F_GetMappingStatus(ADR(bSensorTransAreaRight),SIZEOF(bSensorTransAreaRight)) = EPlcMappingStatus.MS_Partial THEN
	IF NOT bSensorTransAreaRight THEN
		P_bTransAreaFree := FALSE;
	END_IF	
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
