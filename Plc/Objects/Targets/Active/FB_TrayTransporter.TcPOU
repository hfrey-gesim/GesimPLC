    <Property Name="P_nDrivingPinGap" Id="{c822823c-ef47-496c-aa26-c3bf8d34c5fe}">
      <Declaration><![CDATA[PROPERTY P_nDrivingPinGap : DINT]]></Declaration>
      <Get Name="Get" Id="{9ddd8816-ec40-416f-9dbe-f79092ab4933}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nDrivingPinGap := (nHollowWidth - nDrivingPinThickness) / 2;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_nHollowDistance" Id="{376a6c35-a82e-4337-9220-acfc640320fa}">
