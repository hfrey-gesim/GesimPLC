    <Property Name="P_nHollowToHollow" Id="{d4a6752c-cdbd-4ca4-a321-4d353a885a21}">
      <Declaration><![CDATA[PROPERTY P_nHollowToHollow : DINT]]></Declaration>
      <Get Name="Get" Id="{5730f85c-0312-4a09-a891-4cb93d0c4b77}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nHollowToHollow := nTrayLength - 2 * nHollowDistance; ]]></ST>
        </Implementation>
      </Get>
    </Property>
