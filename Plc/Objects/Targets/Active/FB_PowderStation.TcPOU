    <Method Name="M_RemoveListEntry" Id="{aa230f4f-e4e4-4cc1-9942-6b66807a12e6}">
      <Declaration><![CDATA[METHOD M_RemoveListEntry : BOOL
VAR_INPUT
	nSearchValue : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[getPosPtr := 0;(* start from first node element *)
fbList.A_FindNext( hList := hList, putPosPtr := getPosPtr, putValue := nSearchValue, getValue=>getValue, getPosPtr=>getPosPtr );
IF fbList.bOk THEN	//Eintrag wurde gefunden
	fbList.A_RemoveValueAtPosPtr(hList:= hList,	putPosPtr:= getPosPtr);
	IF fbList.bOk THEN
		M_RemoveListEntry := TRUE;
	END_IF
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetAllProps" Id="{643b6824-b05d-49fa-992f-371209d8836b}">
      <Declaration><![CDATA[METHOD M_SetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_SetAllProps := SUPER^.M_SetAllProps(refCmdData);

IF M_SetAllProps > 0 THEN
	RETURN;
END_IF

nCurrentPropIndex := nCurrentPropIndex + 1;
nSpecPropIndex := nCurrentPropIndex;
//NumberOfSlots immer "1"
nNoOfSlots := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
IF nNoOfSlots <> 1 THEN
	nNoOfSlots := 1;
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidNoOfSlots;
	RETURN;
END_IF
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_nNr := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
//SlotNr immer "1"
IF fbVialSlot.P_nNr <> 1 THEN
	fbVialSlot.P_nNr := 1;
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidSlotNumber;
	RETURN;
END_IF

nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosX := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosY := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosZ := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rDepth := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);

{IF defined (variable:aFbPowderStatRef)}
nCurrentPropIndex := nCurrentPropIndex + 1;
nSpecPropIndex := nCurrentPropIndex;
nNoOfSpecPoints := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
stPickPoint.X := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
stPickPoint.Y := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
stPickPoint.Z := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef := ADR(aFbPowderStatRef[1]);
pPowdStatRef^.P_nPidKp := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nPidKi := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nPidKd := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nPidTa := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nVibrationPower1 := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nVibrationPower2 := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pPowdStatRef^.P_nVibrationPower3 := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
{ELSE}
M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidHardwareRef;
RETURN;
{END_IF}
nCurrentPropIndex := nCurrentPropIndex + 1;
nLevelOffset := refCmdData.n32Data[nCurrentPropIndex];
nNoOfProps := nCurrentPropIndex + 1;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSingleProp" Id="{5c670c18-75a2-4592-abc4-6cdeadd0b5ea}">
      <Declaration><![CDATA[METHOD M_SetSingleProp : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nSpecPropIndex = refCmdData.aHeader[1] THEN
	M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty; //Anzahl Specpoints darf nicht verändert werden
ELSIF (nSpecPropIndex + 1) = refCmdData.aHeader[1] THEN
	stPickPoint.X := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 2) = refCmdData.aHeader[1] THEN
	stPickPoint.Y := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 3) = refCmdData.aHeader[1] THEN
	stPickPoint.Z := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 4) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nPidKp := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 5) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nPidKi := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 6) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nPidKd := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 7) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nPidTa := DINT_TO_USINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 8) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nVibrationPower1 := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 9) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nVibrationPower2 := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 10) = refCmdData.aHeader[1] THEN
	pPowdStatRef^.P_nVibrationPower3 := DINT_TO_UINT(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 11) = refCmdData.aHeader[1] THEN
	nLevelOffset := refCmdData.n32Data[0];
ELSE
	M_SetSingleProp := SUPER^.M_SetSingleProp(refCmdData);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSpeed" Id="{163173ed-417a-400b-a2e3-1779a3778811}">
      <Declaration><![CDATA[METHOD PRIVATE M_SetSpeed : BOOL
VAR_INPUT
	nSpeed : UDINT;
END_VAR

VAR_OUTPUT
	nErrorId	: ERRORID;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*//Profile Speed setzen
fbSdoWrite(sADSNetID:= stPowdStatRef.stAdsAdress.sNetId,nPortNr:= stPowdStatRef.stAdsAdress.nPort, 
			nIndex:= 16#6081, nSubIndex:= 0, nDataLength:= 4, nData:= UDINT_TO_DINT(nSpeed), bExecute:= TRUE);

M_SetSpeed := fbSdoWrite.bBusy; 

IF NOT fbSdoWrite.bBusy THEN
	IF fbSdoWrite.bError THEN
		nErrorId := fbSdoWrite.nAdsErrorId;
	END_IF
	fbSdoWrite(bExecute:= FALSE);
END_IF			
*)

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{b49afc43-ce32-43e7-b158-d3e638932d39}">
      <Declaration><![CDATA[METHOD M_Stop : ERRORID
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Stop braucht nur ausgeführt werden, wenn irgendwas aktiv ist
IF NOT bStop AND eCurrentState = E_MachineState.MACHINESTATE_Active THEN
 	//stPowdStatRef.bShaker := FALSE;
	bStop := TRUE;
	fbList.A_AddHeadValue(hList := hList, putValue := E_Action.ACTION_Stop);
END_IF]]></ST>
      </Implementation>
    </Method>
