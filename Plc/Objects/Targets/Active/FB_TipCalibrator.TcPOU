    </Property>
    <Property Name="P_stCalibPoint" Id="{3739c9d6-63cd-48ab-9ba4-a3a0c408b6bc}">
      <Declaration><![CDATA[PROPERTY P_stCalibPoint : ST_3DPoint]]></Declaration>
      <Get Name="Get" Id="{f2babf0f-c1c6-4ab5-aa2a-02acff5ffa51}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_stCalibPoint := stCalibPoint;]]></ST>
