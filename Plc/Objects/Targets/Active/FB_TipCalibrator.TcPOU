    <Property Name="P_bXSensor" Id="{b6c1e2d0-60d5-423b-8e99-cbd4244bc909}">
      <Declaration><![CDATA[PROPERTY P_bXSensor : BOOL]]></Declaration>
      <Get Name="Get" Id="{c01a6cbf-6962-411f-af7e-4060d072f04c}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_bXSensor := stTipCalibrator.bXSensor XOR stTipCalibrator.bInvert;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_bYSensor" Id="{044ab980-9fc9-4b8b-a11c-c6d8e0a8806c}">
      <Declaration><![CDATA[PROPERTY P_bYSensor : BOOL]]></Declaration>
