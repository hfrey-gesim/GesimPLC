      </Get>
      <Set Name="Set" Id="{ba5746ce-a73c-4914-b69c-6da3491be0c0}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[stCalibPoint := P_stCalibPoint;]]></ST>
        </Implementation>
      </Set>
    </Property>
