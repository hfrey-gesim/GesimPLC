    <Method Name="M_RemoveListEntry" Id="{a48b3eea-d958-4f68-98ac-62b2aa561f5c}">
      <Declaration><![CDATA[METHOD M_RemoveListEntry : BOOL
VAR_INPUT
	nSearchValue : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[getPosPtr := 0;(* start from first node element *)
fbList.A_FindNext( hList := hList, putPosPtr := getPosPtr, putValue := nSearchValue, getValue=>getValue, getPosPtr=>getPosPtr );
IF fbList.bOk THEN	//Eintrag wurde gefunden
	fbList.A_RemoveValueAtPosPtr(hList:= hList,	putPosPtr:= getPosPtr);
	IF fbList.bOk THEN
		M_RemoveListEntry := TRUE;
	END_IF
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetAllProps" Id="{bd6c172c-2562-4f73-94f4-12edfafd11e7}">
      <Declaration><![CDATA[METHOD M_SetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR

VAR
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[{IF defined (variable:aFbReactDriveRef)}
pDriveRef := ADR(aFbReactDriveRef[1]);
{ELSE}
M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidHardwareRef;
{END_IF}

M_SetAllProps := SUPER^.M_SetAllProps(refCmdData);

IF M_SetAllProps > 0 THEN
	RETURN;
END_IF

nCurrentPropIndex := nCurrentPropIndex + 1;
nSpecPropIndex := nCurrentPropIndex;
//NumberOfSlots immer "1"
nNoOfSlots := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
IF nNoOfSlots <> 1 THEN
	nNoOfSlots := 1;
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidNoOfSlots;
	RETURN;
END_IF
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_nNr := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
//SlotNr immer "1"
IF fbVialSlot.P_nNr <> 1 THEN
	fbVialSlot.P_nNr := 1;
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidSlotNumber;
	RETURN;
END_IF

nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosX := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosY := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rRelPosZ := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
fbVialSlot.P_rDepth := DINT_TO_REAL(refCmdData.n32Data[nCurrentPropIndex]);

{IF defined (variable:aFbReactHeatRef)}
pHeaterRef := ADR(aFbReactHeatRef[1]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pHeaterRef^.P_nPidKp := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1; 
pHeaterRef^.P_nPidKi := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pHeaterRef^.P_nPidKd := DINT_TO_UINT(refCmdData.n32Data[nCurrentPropIndex]);
nCurrentPropIndex := nCurrentPropIndex + 1;
pHeaterRef^.P_nPidTa := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
{ELSE}
{warning 'implement errorId}
M_SetAllProps := 5555;
{END_IF}
{IF defined (variable:aFbReactHeatRef)}


{END_IF}
nCurrentPropIndex := nCurrentPropIndex + 1;
IF refCmdData.n32Data[nCurrentPropIndex] > 0 AND refCmdData.n32Data[nCurrentPropIndex] <= cNoOfValves THEN
	nValveNrCool := DINT_TO_USINT(refCmdData.n32Data[nCurrentPropIndex]);
ELSE
	M_SetAllProps := E_ErrorIdObjMgmt.ERRORID_InvalidValveNumber;
END_IF

//ClosedPositionen
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nClosedPosition[1] := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nClosedPosition[2] := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nClosedPosition[3] := refCmdData.n32Data[nCurrentPropIndex];
//MoveSpeeds
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nMotorSpeed[1] := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nMotorSpeed[2] := refCmdData.n32Data[nCurrentPropIndex];
nCurrentPropIndex := nCurrentPropIndex + 1;
pDriveRef^.nMotorSpeed[3] := refCmdData.n32Data[nCurrentPropIndex];

nNoOfProps := nCurrentPropIndex + 1;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSingleProp" Id="{02d55a7e-56ba-4607-a9d3-df07ef9055e6}">
      <Declaration><![CDATA[METHOD M_SetSingleProp : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO  ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nSpecPropIndex = refCmdData.aHeader[1] THEN //Anzahl Slots darf nicht verändert werden
	M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
ELSIF (nSpecPropIndex + 1) = refCmdData.aHeader[1] THEN
	M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty; //SlotNr darf nicht verändert werden
ELSIF (nSpecPropIndex + 2) = refCmdData.aHeader[1] THEN
	fbVialSlot.P_rRelPosX := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 3) = refCmdData.aHeader[1] THEN
	fbVialSlot.P_rRelPosY := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 4) = refCmdData.aHeader[1] THEN
	fbVialSlot.P_rRelPosZ := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 5) = refCmdData.aHeader[1] THEN
	fbVialSlot.P_rDepth := DINT_TO_REAL(refCmdData.n32Data[0]);
ELSIF (nSpecPropIndex + 6) = refCmdData.aHeader[1] THEN
	IF pHeaterRef > 0 THEN
		pHeaterRef^.P_nPidKp := DINT_TO_UINT(refCmdData.n32Data[0]);
	ELSE
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	END_IF	
ELSIF (nSpecPropIndex + 7) = refCmdData.aHeader[1] THEN
	IF pHeaterRef > 0 THEN
		pHeaterRef^.P_nPidKi := DINT_TO_UINT(refCmdData.n32Data[0]);
	ELSE
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	END_IF	
ELSIF (nSpecPropIndex + 8) = refCmdData.aHeader[1] THEN
	IF pHeaterRef > 0 THEN
		pHeaterRef^.P_nPidKd := DINT_TO_UINT(refCmdData.n32Data[0]);
	ELSE
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	END_IF	
ELSIF (nSpecPropIndex + 9) = refCmdData.aHeader[1] THEN
	IF pHeaterRef > 0 THEN
		pHeaterRef^.P_nPidTa := DINT_TO_USINT(refCmdData.n32Data[0]);
	ELSE
		M_SetSingleProp := E_ErrorIdCmd.ERRORID_InvalidProperty;
	END_IF	
ELSIF (nSpecPropIndex + 10) = refCmdData.aHeader[1] THEN
	IF refCmdData.n32Data[0] > 0 AND refCmdData.n32Data[0] <= cNoOfValves THEN
		nValveNrCool := DINT_TO_USINT(refCmdData.n32Data[0]);
	ELSE
		M_SetSingleProp := E_ErrorIdObjMgmt.ERRORID_InvalidValveNumber;
	END_IF
ELSIF (nSpecPropIndex + 11) = refCmdData.aHeader[1] THEN
	pDriveRef^.nClosedPosition[1] := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 12) = refCmdData.aHeader[1] THEN
	pDriveRef^.nClosedPosition[2] := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 13) = refCmdData.aHeader[1] THEN
	pDriveRef^.nClosedPosition[3] := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 14) = refCmdData.aHeader[1] THEN
	pDriveRef^.nMotorSpeed[1] := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 15) = refCmdData.aHeader[1] THEN
	pDriveRef^.nMotorSpeed[2] := refCmdData.n32Data[0];
ELSIF (nSpecPropIndex + 16) = refCmdData.aHeader[1] THEN
	pDriveRef^.nMotorSpeed[3] := refCmdData.n32Data[0];
ELSE
	M_SetSingleProp := SUPER^.M_SetSingleProp(refCmdData);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSpeed" Id="{91260925-ed05-4463-b313-8f0f2e04d088}">
      <Declaration><![CDATA[METHOD PRIVATE M_SetSpeed : BOOL
VAR_INPUT
	nSpeed : UDINT;
END_VAR

VAR_OUTPUT
	nErrorId	: ERRORID;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[(*//Profile Speed setzen
fbSdoWrite(sADSNetID:= stPowdStatRef.stAdsAdress.sNetId,nPortNr:= stPowdStatRef.stAdsAdress.nPort, 
			nIndex:= 16#6081, nSubIndex:= 0, nDataLength:= 4, nData:= UDINT_TO_DINT(nSpeed), bExecute:= TRUE);

M_SetSpeed := fbSdoWrite.bBusy; 

IF NOT fbSdoWrite.bBusy THEN
	IF fbSdoWrite.bError THEN
		nErrorId := fbSdoWrite.nAdsErrorId;
	END_IF
	fbSdoWrite(bExecute:= FALSE);
END_IF			
*)

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{14996378-af9d-4411-8e9a-ecc48c105dd9}">
      <Declaration><![CDATA[METHOD M_Stop : ERRORID
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Stop braucht nur ausgeführt werden, wenn irgendwas aktiv ist
IF NOT bStop AND eCurrentState = E_MachineState.MACHINESTATE_Active THEN
 	//stPowdStatRef.bShaker := FALSE;
	bStop := TRUE;
	fbList.A_AddHeadValue(hList := hList, putValue := E_Action.ACTION_Stop);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_TakePiece" Id="{52d50d76-01b9-4da0-a400-1ede9b5bfc89}">
      <Declaration><![CDATA[METHOD M_TakePiece : POINTER TO FB_PieceSlot
VAR_INPUT
	pPiece : POINTER TO FB_PieceBase;
	nSlotNr : UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF pPiece > 0 THEN
	IF 	nSlotNr = 1 THEN
		//Slot frei?
		IF fbVialSlot.P_pPiece = 0 THEN
			fbVialSlot.P_pPiece := pPiece;
			M_TakePiece := ADR(fbVialSlot);
		END_IF
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_bCoverAreaIsFree" Id="{c363ff8c-3682-4d1d-a062-267fbd3abf9b}">
      <Declaration><![CDATA[PROPERTY P_bCoverAreaIsFree : BOOL]]></Declaration>
      <Get Name="Get" Id="{ec199860-c30b-43ee-ab49-dfa58266606c}">
        <Declaration><![CDATA[VAR
	i : UINT;
	stCurPosMzTool	: ST_3DPoint;
	stCurPosThis	: ST_3DPoint;
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[//Checken, ob sich im Bewegungsbereich des Deckel ein MzTool befindet
P_bCoverAreaIsFree := TRUE;
(*FOR i:= 1 TO fbObjectDirectory.nCntMzTool BY 1 DO
	IF NOT (aI_MzTool[i].P_eObjectType = E_ObjectType.OBJECTTYPE_MZHead) THEN
		IF NOT aI_MzTool[i].P_bCollFree THEN	//Tool ist nicht im kollisionsfreiem Bereich
			
			stCurPosMzTool := aI_MzTool[i].P_stCurrentPosPhys;
			stCurPosThis := P_stAbsPosLB;
			IF (stCurPosMzTool.Z - 2000) < stCurPosThis.Z THEN //MzTool befindet sich 5mm unterhalb der Oberkante Reaktor und in dessen XY Bereich
				IF stCurPosMzTool.X >= stCurPosThis.X AND stCurPosMzTool.X <= (stCurPosThis.X + stDimension.Width)
				AND stCurPosMzTool.Y >= stCurPosThis.Y AND stCurPosMzTool.Y <= (stCurPosThis.Y + stDimension.Depth) THEN
					P_bCoverAreaIsFree := FALSE;
					RETURN;
				END_IF
			END_IF
 		END_IF
	END_IF
END_FOR*)]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_bVialInSlot" Id="{8000358e-1f45-48e2-bc1b-7e955955224d}">
      <Declaration><![CDATA[PROPERTY P_bVialInSlot : BOOL]]></Declaration>
      <Get Name="Get" Id="{10cad4dd-d0a6-4532-aef1-5e915f539b1b}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF pHeaterRef > 0 THEN
	P_bVialInSlot := pHeaterRef^.P_bVialDetected;
END_IF
]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_pVial" Id="{2791e3f5-6243-48f8-bbcc-0aec6634c080}">
      <Declaration><![CDATA[PROPERTY P_pVial : POINTER TO FB_Vial]]></Declaration>
      <Get Name="Get" Id="{ba32f4a8-d03b-45fd-945d-349f25eef050}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_pVial := fbVialSlot.P_pPiece;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{e215b3bb-bfe9-4280-b3f3-274aa17250f8}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[fbVialSlot.P_pPiece := P_pVial;]]></ST>
        </Implementation>
      </Set>
    </Property>
