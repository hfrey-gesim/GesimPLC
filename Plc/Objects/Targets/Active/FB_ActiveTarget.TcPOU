    <Method Name="M_Reset" Id="{53156c17-4a46-4002-b3af-bc5d6d07a4bb}">
      <Declaration><![CDATA[METHOD M_Reset
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bBusy := TRUE;
eCurrentState := E_MachineState.MACHINESTATE_Reset;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{2fd9dd19-8a3e-41d4-8cae-d39f6ea2c4f5}">
      <Declaration><![CDATA[METHOD M_Stop : ERRORID
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Stop braucht nur ausgeführt werden, wenn irgendwas aktiv ist
IF NOT bStop AND eCurrentState = E_MachineState.MACHINESTATE_Active THEN
	bStop := TRUE;
	fbList.A_AddHeadValue(hList := hList, putValue := E_Action.ACTION_Stop);
END_IF]]></ST>
      </Implementation>
    </Method>
