  <POU Name="FB_ActiveTarget" Id="{f71f8edd-f391-4a79-953f-1ef5fbc17e11}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ActiveTarget EXTENDS FB_TargetBase IMPLEMENTS I_Device
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	bInitFB			: BOOL := TRUE;
	nNotifyId		: UINT;
	bError			: BOOL;
	nErrorId		: ERRORID;
	bCanceled		: BOOL;
	bStop			: BOOL;
	bBusy			: BOOL;
	eCurrentState	: E_MachineState := E_MachineState.MACHINESTATE_Idle;
	stError			: ST_Error;
	bIsInit			: BOOL;	
	stProcessData	: ST_ObjectProcData;
	eCurrentAction	: E_Action;
	
	//Verkettete Liste für BasicActions
	fbList				: FB_LinkedListCtrl;
	hList				: T_HLINKEDLIST;
	aNodes           	: ARRAY[0..4] OF T_LinkedListEntry;
	getValue			: PVOID;
	getPosPtr       	: POINTER TO T_LinkedListEntry := 0;
	
	
	//Action: "Init"
	bInit				: BOOL;				//Action A_Init() aktiv setzen
	nStateA_Init		: USINT;			//State von A_Init()
	bFlagA_Init			: BOOL := TRUE;		//Hilfsflag A_Init()
	
	//Action: Stop
	nStateA_Stop		: USINT;	//Statemachine von A_Stop()
	bStopAllOnError		: BOOL;
	
	//Action: "Reset"
	nStateA_Reset		: USINT;	//Statemachine von A_Reset();	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
