    <Method Name="M_GetAllProps" Id="{bd35db0b-f5db-4f94-be53-888817275f9f}">
      <Declaration><![CDATA[METHOD M_GetAllProps : ERRORID
VAR_INPUT
	refCmdData : REFERENCE TO ST_CmdData;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetAllProps := SUPER^.M_GetAllProps(refCmdData);
refCmdData.aHeader[2] := nNotifyId;]]></ST>
      </Implementation>
