    <Property Name="P_rSpaceRows" Id="{18f9e039-a54e-4c63-b0f6-e8e63e69a4db}">
      <Declaration><![CDATA[PROPERTY P_rSpaceRows : REAL]]></Declaration>
      <Get Name="Get" Id="{c9de390f-8156-4e08-a2a0-5393b059feac}">
