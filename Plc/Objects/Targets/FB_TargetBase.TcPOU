    <Property Name="P_stRelPosLB" Id="{7780027f-74e8-4e88-88e6-b6dc0c174589}">
      <Declaration><![CDATA[PROPERTY P_stRelPosLB : ST_3DPoint]]></Declaration>
      <Get Name="Get" Id="{0ae7cbba-84f6-47bf-a45f-2181e6e1f963}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_stRelPosLB := stRelPos;
P_stRelPosLB.Z := stRelPos.Z + stDimension.Height + rZOffset;
IF pParentTarget > 0 AND_THEN pParentSlot > 0 THEN
	P_stRelPosLB := F_Add3DPoints(P_stRelPosLB,pParentSlot^.P_stRelPos);
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
