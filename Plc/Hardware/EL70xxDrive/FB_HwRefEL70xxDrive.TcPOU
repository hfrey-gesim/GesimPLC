<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_HwRefEL70xxDrive" Id="{eca6a7e8-f0ed-41df-8811-c2bfb9665c0c}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_HwRefEL70xxDrive EXTENDS FB_HwModule
VAR_INPUT
	STM_Control : ST_EL70xx_STM_Control;
	POS_Control	: ST_EL70xx_POS_Control;	
END_VAR
VAR_OUTPUT
	STM_Status : ST_EL70xx_STM_Status;
	POS_Status : ST_EL70xx_POS_Status;
	nMotorLoad 		AT %I* : UINT;
	nMotorCurrent 	AT %I* : UINT;
	bInput1			AT %I* : BOOL;
	bInput2			AT %I* : BOOL;
	bHwEnable		AT %I* : BOOL;	//muss mit Input1 oder Input2 der Klemme verknüpft werden
									//entsprechend muss dieser Input auch konfiguriert werden
									//8012:32 bzw. 36 auf Hardware enable konfigurieren
	
END_VAR
VAR
	stAdsAddress : ST_AdsAdress;	
	rTranslationFactorPosition : REAL;
	
	fbEcCoESdoRead 			: FB_EcCoESdoRead;
	nMotorFullsteps 		: UINT;
	nEncoderIncrements		: UDINT;
	nSpeedRangeRaw			: USINT;	//wie es im OD steht
	nSpeedRangeCalculated	: UINT;		//wird berechnet aus 2^nSpeedRangeRaw * 1000
	eEncoderType			: E_EL70xx_EncoderType := E_EL70xx_EncoderType.InternCounter;
	sTermName				: STRING(5);
	
	nActualPosition			: DINT;
	eHomingMode				: E_EL70xx_StartType;
	bPrepare				: BOOL;
	nStateA_Prepare 		: USINT;
	
END_VAR
VAR PERSISTENT
	nDistPerMotorRev	: DINT; //reale Einheit (Weg oder Winkel)
	nRefPos	 			: DINT; //reale Einheit (Weg oder Winkel)
	nMinPos				: DINT; //reale Einheit (Weg oder Winkel)
	nMaxPos				: DINT; //reale Einheit (Weg oder Winkel)
	nMaxSpeed			: DINT;	//reale Einheit/s
	bInvertInitDir		: BOOL;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF bPrepare THEN
	bBusy := TRUE;
	A_Prepare();
	IF nStateA_Prepare >= 80 THEN
		IF nStateA_Prepare >= 99 THEN
			bError := TRUE;
		END_IF
		nStateA_Prepare := 0;
		bPrepare := FALSE;
		bBusy := FALSE;
	END_IF
ELSE
	bBusy := POS_Status.Busy;
	bError := POS_Status.Error OR STM_Status.Error;
	A_CalcActPosition();
END_IF
]]></ST>
    </Implementation>
    <Action Name="A_CalcActPosition" Id="{ec641027-becc-4bb5-a9ea-4491124111d1}">
      <Implementation>
        <ST><![CDATA[IF rTranslationFactorPosition > 0 THEN
	nActualPosition := REAL_TO_DINT(DINT_TO_REAL(POS_Status.ActualPosition) / rTranslationFactorPosition);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_Prepare" Id="{b5862633-92e0-477d-ace4-61e3252384e3}">
      <Implementation>
        <ST><![CDATA[//Werte aus Coe auslesen
//Motor fullsteps (8010:06)
IF nStateA_Prepare = 0 THEN
	fbEcCoESdoRead(sNetId:= stAdsAddress.sNetId, nSlaveAddr:= stAdsAddress.nPort, nIndex:= 16#8010, nSubIndex:= 6 , 
					pDstBuf:= ADR(nMotorFullsteps) , cbBufLen:=SIZEOF(nMotorFullsteps) , bExecute:= TRUE);
	IF NOT fbEcCoESdoRead.bBusy THEN
		IF fbEcCoESdoRead.bError THEN
			nStateA_Prepare := 99;
		ELSE
			IF eEncoderType <> E_EL70xx_EncoderType.InternCounter THEN //Initialwert
				//Encodertype wurde bereits in der abgeleiteten Klasse gesetzt, deshalb wird dieser nicht aus der Klemme gelesen
				//auch die Inkremente werden nicht gelesen, diese werden auch in der abgeleiteten Klasse gesetzt
				nStateA_Prepare := 3;
			ELSE
				nStateA_Prepare := 1;	
			END_IF			
		END_IF
		fbEcCoESdoRead(bExecute:= FALSE);		
	END_IF
END_IF
 
//die ersten 5 Stellen des Klemmentyps auslesen
IF nStateA_Prepare = 1 THEN
	fbEcCoESdoRead(nIndex:= 16#1008, nSubIndex:= 0, pDstBuf:= ADR(sTermName), cbBufLen:=SIZEOF(sTermName), bExecute:= TRUE);
	IF NOT fbEcCoESdoRead.bBusy THEN
		IF fbEcCoESdoRead.bError THEN
			nStateA_Prepare := 99;
		ELSE
			sTermName[5] := 0; //da der String nicht komplett ausgelesen wurde, muss das letzte Byte im String wieder terminiert werden
			IF sTermName = 'EL704' THEN //nur die Klemmen dieser Reihe können einen internen Encoder
				nStateA_Prepare := 2;
			ELSE
				nStateA_Prepare := 4;
			END_IF
		END_IF
		fbEcCoESdoRead(bExecute:= FALSE);
	END_IF
END_IF

//Encodertype bzw. Feedback auslesen (8012:08)
IF nStateA_Prepare = 2 THEN
	fbEcCoESdoRead(nIndex:= 16#8012, nSubIndex:= 8, pDstBuf:= ADR(eEncoderType) , cbBufLen:=SIZEOF(eEncoderType), bExecute:= TRUE);
	IF NOT fbEcCoESdoRead.bBusy THEN
		IF fbEcCoESdoRead.bError THEN
			nStateA_Prepare := 99;	
		ELSE
			IF eEncoderType = E_EL70xx_EncoderType.InternEncoder THEN
				nStateA_Prepare := 3;
			ELSE
				nStateA_Prepare := 4;
			END_IF
		END_IF
		fbEcCoESdoRead(bExecute:= FALSE);
	END_IF	
END_IF

//Encoder increments (8010:07) nur wenn Feedbacktype "InternEncoder"
//Achtung, nEncoderIncrements ist UDINT, der Wert im OD aber nur UINT
IF nStateA_Prepare = 3 THEN
	fbEcCoESdoRead(nIndex:= 16#8010, nSubIndex:= 7, pDstBuf:= ADR(nEncoderIncrements) , cbBufLen:= 2, bExecute:= TRUE);
	IF NOT fbEcCoESdoRead.bBusy THEN
		IF fbEcCoESdoRead.bError THEN
			nStateA_Prepare := 99;
		ELSE
			nStateA_Prepare := 4;
		END_IF
		fbEcCoESdoRead(bExecute:= FALSE);		
	END_IF	
END_IF

//Speedrange (8012:05)
IF nStateA_Prepare = 4 THEN
	fbEcCoESdoRead(nIndex:= 16#8012, nSubIndex:= 5, pDstBuf:= ADR(nSpeedRangeRaw) , cbBufLen:=SIZEOF(nSpeedRangeRaw), bExecute:= TRUE);
	IF NOT fbEcCoESdoRead.bBusy THEN
		IF fbEcCoESdoRead.bError THEN
			nStateA_Prepare := 99;	
		ELSE
			nSpeedRangeCalculated := SHL(1,nSpeedRangeRaw) * 1000;
			M_CalcTranslationFact();
			nStateA_Prepare := 80;
		END_IF
		fbEcCoESdoRead(bExecute:= FALSE);		
	END_IF	
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="FB_init" Id="{1208c288-5abb-4dd6-896b-1f2ae06a2970}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains 	: BOOL; 	// if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode  	: BOOL;  	// if TRUE, the instance afterwards gets moved into the copy code (online change)
	nBoxAddress		: UINT;
	eHomingMode		: E_EL70xx_StartType;
END_VAR

VAR
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.eHomingMode := eHomingMode;
stAdsAddress.nPort := nBoxAddress;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CalcTranslationFact" Id="{d6f1580e-b3d1-4933-9ac0-b42d0ff00f5e}">
      <Declaration><![CDATA[METHOD M_CalcTranslationFact
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nDistPerMotorRev > 0 THEN
	IF eEncoderType = E_EL70xx_EncoderType.InternCounter OR eEncoderType = E_EL70xx_EncoderType.ExternSingleturnAbs THEN 
		rTranslationFactorPosition := (nMotorFullsteps * 64) / DINT_TO_REAL(nDistPerMotorRev);
	ELSE
		rTranslationFactorPosition := UDINT_TO_REAL(nEncoderIncrements) / DINT_TO_REAL(nDistPerMotorRev);
	END_IF
END_IF
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetPosDiff" Id="{347db253-9f8c-429e-99e7-3ca6b484bbdf}">
      <Declaration><![CDATA[METHOD M_GetPosDiff : DINT
VAR_INPUT
	nSetPosition : DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetPosDiff := nSetPosition - P_nActualPosition;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Prepare" Id="{29f7d2d8-f23d-4dba-8737-36e12a1bf9d5}">
      <Declaration><![CDATA[METHOD M_Prepare
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bPrepare := TRUE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetSpeed" Id="{770bb2d1-9fcb-4db1-9b6f-558a509c94f1}">
      <Declaration><![CDATA[METHOD M_SetSpeed : BOOL
VAR_INPUT
	nValue : DINT; //Speed in µm/s oder 1/100°/sec
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF (nValue > 0) AND (nValue <= nMaxSpeed) THEN
	POS_Control.Velocity := DINT_TO_INT(nMotorFullsteps * nValue / nDistPerMotorRev * 10000 / nSpeedRangeCalculated);
	M_SetSpeed := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetTargetPos" Id="{77092a79-58ea-45cf-88c8-48174c5a92f8}">
      <Declaration><![CDATA[METHOD M_SetTargetPos : BOOL
VAR_INPUT
	nValue : DINT; //Reale Einheit
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF (nValue >= nMinPos) AND (nValue <= nMaxPos) THEN
	POS_Control.StartType := E_EL70xx_StartType.Absolute;
	POS_Control.TargetPosition := REAL_TO_DINT(DINT_TO_REAL(nValue) * rTranslationFactorPosition);
	M_SetTargetPos := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_bHardwareEnable" Id="{1808b1c3-adba-4a18-bf19-9d6b7da816fb}">
      <Declaration><![CDATA[PROPERTY P_bHardwareEnable : BOOL]]></Declaration>
      <Get Name="Get" Id="{1c2bc4aa-0836-4e83-94fd-ad76daac39c6}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF F_GetMappingStatus(ADR(bHwEnable), SIZEOF(bHwEnable)) = EPlcMappingStatus.MS_Partial THEN
	P_bHardwareEnable := bHwEnable;
ELSE
	P_bHardwareEnable := TRUE;
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
