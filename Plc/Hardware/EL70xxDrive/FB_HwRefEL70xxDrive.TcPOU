    <Property Name="P_nActualPosition" Id="{bc38b5bd-91a2-49cc-a0ed-19577ea3d6ad}">
      <Declaration><![CDATA[PROPERTY P_nActualPosition : DINT]]></Declaration>
      <Get Name="Get" Id="{05c35a6c-dfb6-40a9-890c-9a8d35a50368}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
