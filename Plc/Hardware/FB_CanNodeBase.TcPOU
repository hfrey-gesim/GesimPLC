        </Implementation>
      </Get>
      <Set Name="Set" Id="{c93449ed-8e7b-4cdb-8f64-1a80ca7b78a9}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bStopMonitor := P_bStopMonitor;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="P_nAdsPort" Id="{6848950f-a1d2-45d3-bf84-b343725deeda}">
      <Declaration><![CDATA[PROPERTY P_nAdsPort : UINT]]></Declaration>
      <Get Name="Get" Id="{4a86aa97-c218-41cc-9a6d-25cc62dbe0a6}">
