<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.11">
  <POU Name="FB_CanNodeBase" Id="{b9ec44d1-32d5-48f9-a4be-3244e9a62111}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_CanNodeBase EXTENDS FB_HwModule
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	stAdsAdress		: ST_AdsAdress;
	bNodeEnabled	: BOOL;
	bNodeFound		: BOOL;
	nNodeId			: USINT;
	nNodeState		AT %I* : USINT;	//PDO
	nErrorId 		: ERRORID;
	nErrorId2 		: UDINT;
	sHardwVersion	: STRING(15);
	sSoftwVersion	: STRING(15);
	
	bPrepare			: BOOL;
	nStateA_Prepare 	: USINT;
	bPreparingOK		: BOOL;
	
	bResetError		: BOOL;
	nStateResetError: USINT;
	
	bResetApp		: BOOL;
	nStateA_ResetApp: USINT;
	
	fbSdoRead 		: FB_SDO_READ;
	fbSdoWrite		: FB_SDO_WRITE;
	nPOUState 		: USINT;
	
	bStopMonitor	: BOOL;
	
	timeout			: TON;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF bPrepare THEN
	A_Prepare();
	IF nStateA_Prepare >= 80 THEN
		IF nStateA_Prepare >= 99 THEN
			bError := TRUE;
		ELSE
			bPreparingOK := TRUE;
		END_IF
		nStateA_Prepare := 0;
		bPrepare := FALSE;
	END_IF
END_IF

IF bResetApp THEN
	A_ResetApp();
	IF nStateA_ResetApp >= 80 THEN
		IF nStateA_ResetApp >= 99 THEN
			bError := TRUE;
		END_IF
		nStateA_ResetApp := 0;
		bResetApp := FALSE;
	END_IF
END_IF

bBusy := bPrepare OR bResetError OR bResetApp;]]></ST>
    </Implementation>
    <Action Name="A_Monitor" Id="{0d17c58a-e01a-445a-b762-2a34737c732c}">
      <Implementation>
        <ST><![CDATA[IF nNodeState > 0  THEN
	bError := TRUE;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_Prepare" Id="{03af6d06-3a0c-44ed-993d-f1f04445b64e}">
      <Implementation>
        <ST><![CDATA[nPOUState := nStateA_Prepare;
CASE nStateA_Prepare OF
	0:	//Checken, ob Node "operational"
		//Timeout von 10s
		timeout(IN:= TRUE, PT:= T#10S);
		IF nNodeState = 0 THEN
			timeout(IN:= FALSE);
			bNodeFound := TRUE;
			nStateA_Prepare := 1;
		END_IF
		IF timeout.Q THEN
			timeout(IN:= FALSE);
			nStateA_Prepare := 99;
			CASE nNodeState OF
				1:	nErrorId := E_ErrorIdCan.ERRORID_NodeDeactivated;
				2:	nErrorId := E_ErrorIdCan.ERRORID_NodeNotFound;
					//Nur in Fehler gehen, wenn Node die Kopfbasisplatine ist.
					//Ein Error zu folge hätte, dann würde es auch bei einem abgestecktem Mtp-Heater zu einem Error kommen.
					IF stHardwareId.eGroup <> E_HardwareGrp.MultiZBasis THEN
						nStateA_Prepare := 80;	
					END_IF
				4:	nErrorId := E_ErrorIdCan.ERRORID_SdoSyntaxErrorAtStartup;
				5:	nErrorId := E_ErrorIdCan.ERRORID_SdoDataMismatchAtStartup;
				12:	nErrorId := E_ErrorIdCan.ERRORID_NodePreOP;
			END_CASE
		END_IF

	1:	//Hardwareversion auslesen
		fbSdoRead(sADSNetID:= stAdsAdress.sNetId, nPortNr:= stAdsAdress.nPort,
				nIndex:= 16#1009, nSubIndex:= 0, nDataLength:= 20, bExecute:= TRUE);
				
		IF NOT fbSdoRead.bBusy THEN
			IF fbSdoRead.bError THEN
				nErrorId := fbSdoRead.nAdsErrorId;
				nErrorId2 := fbSdoRead.nSdoErrorId;
				nStateA_Prepare := 99;	//Error
			ELSE
				sHardwVersion := fbSdoRead.sData;
				nStateA_Prepare := 2;
			END_IF
			fbSdoRead(bExecute:= FALSE);
		END_IF
		
	2:	//Softwareversion auslesen
		fbSdoRead(sADSNetID:= stAdsAdress.sNetId, nPortNr:= stAdsAdress.nPort,
				nIndex:= 16#100A, nSubIndex:= 0, nDataLength:= 20, bExecute:= TRUE);
				
		IF NOT fbSdoRead.bBusy THEN
			IF fbSdoRead.bError THEN
				nErrorId := fbSdoRead.nAdsErrorId;
				nErrorId2 := fbSdoRead.nSdoErrorId;
				nStateA_Prepare := 99;	//Error
			ELSE
				sSoftwVersion := fbSdoRead.sData;
				nStateA_Prepare := 80;
			END_IF
			fbSdoRead(bExecute:= FALSE);
		END_IF
	
END_CASE

IF nStateA_Prepare = 99 THEN
	stError.Cmd := 0;
	stError.ErrorId := nErrorId;
	stError.HardwareGrp := stHardwareId.eGroup;
	stError.HardwareNr := stHardwareId.nItem;
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ResetApp" Id="{b4df81c7-2860-4bb6-a757-1bd4c4080877}">
      <Implementation>
        <ST><![CDATA[nStateA_ResetApp := 80;]]></ST>
      </Implementation>
    </Action>
    <Method Name="M_GetHwInfo" Id="{e2728c97-1dcc-42b0-979f-0bc23b688b75}">
      <Declaration><![CDATA[METHOD M_GetHwInfo : ST_HardwareInfo
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[M_GetHwInfo := SUPER^.M_GetHwInfo();
M_GetHwInfo.sHardwVersion := sHardwVersion;
M_GetHwInfo.sSoftwVersion := sSoftwVersion;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Prepare" Id="{df7aae7f-708a-49a0-8cbb-d2dc76284000}">
      <Declaration><![CDATA[METHOD M_Prepare
VAR_INPUT
	sAdsNetId	: STRING(23);
	nCanNodeId	: USINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stAdsAdress.sNetId := sAdsNetId;
stAdsAdress.nPort := nCanNodeId + 4096;
nNodeId := nCanNodeId;
bNodeEnabled := TRUE;
bPrepare := TRUE;
bPreparingOK := FALSE;
]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Reset" Id="{3b4e5415-444f-40fb-a667-87fc7eaa3528}">
      <Declaration><![CDATA[METHOD M_Reset
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bError THEN
	bResetError := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ResetApp" Id="{a5af6c9b-c604-4312-87b5-76ce3df628fe}">
      <Declaration><![CDATA[METHOD M_ResetApp
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[bResetApp := TRUE;]]></ST>
      </Implementation>
    </Method>
