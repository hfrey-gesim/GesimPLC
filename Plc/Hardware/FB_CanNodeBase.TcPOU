    <Property Name="P_nNodeId" Id="{dcdb7a94-7c75-4152-ae3d-d6d003a4662e}">
      <Declaration><![CDATA[PROPERTY P_nNodeId : USINT]]></Declaration>
      <Get Name="Get" Id="{d6b8713a-f10b-4a04-a227-0d991c9bdfc1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nNodeId := nNodeId;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="P_nNodeState" Id="{ea850228-3a02-41d0-866d-57183016bb1d}">
      <Declaration><![CDATA[PROPERTY P_nNodeState : USINT]]></Declaration>
      <Get Name="Get" Id="{53bb4b89-dc9b-468d-9670-603647029f44}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_nNodeState := nNodeState;]]></ST>
        </Implementation>
      </Get>
    </Property>
