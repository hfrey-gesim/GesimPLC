      <Get Name="Get" Id="{69605781-ddd0-45c9-989e-89d5e51a07d1}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_eSubType := eSubType;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{c004b309-5d0c-4b33-858e-5baf5b4d4f0f}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[eSubType := P_eSubType;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="P_nMaxPos" Id="{3c095b0e-bd84-4c83-ba07-7049027e6496}">
