END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF eSubType = E_ExtruderType.PistonExtruder1 THEN
	P_nMaxPos := cMaxPosPiston;
ELSIF eSubType = E_ExtruderType.SyringeExtruder1 THEN
	P_nMaxPos := cMaxPosSyringe;
END_IF]]></ST>
        </Implementation>
      </Get>
    </Property>
