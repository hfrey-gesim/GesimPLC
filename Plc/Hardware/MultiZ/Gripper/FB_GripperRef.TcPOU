      <LineId Id="5" Count="0" />
    </LineIds>
    <LineIds Name="FB_GripperRef.P_bVialDetector.Get">
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="FB_GripperRef.P_eGripperState.Get">
      <LineId Id="2" Count="0" />
      <LineId Id="7" Count="0" />
      <LineId Id="5" Count="0" />
      <LineId Id="8" Count="4" />
      <LineId Id="6" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>