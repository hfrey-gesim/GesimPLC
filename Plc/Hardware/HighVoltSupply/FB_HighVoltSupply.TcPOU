<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4022.12">
  <POU Name="FB_HighVoltSupply" Id="{ea8f4d89-fbc6-471e-b2ba-67b32ca57e1f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_HighVoltSupply
VAR_INPUT
	nAnalogInVoltage	AT %I* : INT;	//muss mit Analogklemme verknüpft werden
	nAnalogInCurrent	AT %I* : INT;	//muss mit Analogklemme verknüpft werden
	bSafeVoltage		AT %I* : BOOL;	//Spannungsfreiheit
	bHVPSAvailable		AT %I* : BOOL;	//HVPS angesteckt und eingeschalten
END_VAR
VAR_OUTPUT
	nAnalogOutVoltage	AT %Q* : INT;	//muss mit Analogklemme verknüpft werden
	nAnalogOutCurrent	AT %Q* : INT;	//muss mit Analogklemme verknüpft werden
	bDigiOutVoltage1	AT %Q* : BOOL := TRUE;
	bDigiOutVoltage2	AT %Q* : BOOL := TRUE;
END_VAR
VAR
	nCurrentChannel	: USINT;
END_VAR

VAR PERSISTENT
	rMinVoltage		: REAL;
	rMaxVoltage		: REAL;
	rMinVoltageCV	: REAL;
	rMaxVoltageCV	: REAL;
	rMinVoltageMV	: REAL;
	rMaxVoltageMV	: REAL;
	rMinCurrent		: REAL;
	rMaxCurrent		: REAL;
	rMinCurrentCV	: REAL;
	rMaxCurrentCV	: REAL;
	rMinCurrentMV	: REAL;
	rMaxCurrentMV	: REAL;
	bLegacy			: BOOL;
END_VAR

VAR CONSTANT
	cVoltageMax		: REAL := 30000;	//maximal einstellbare Spannung in V
	cCurrentMax		: REAL := 30000;	//maximal einstellbarer Strom in µA (max 30µA bzw max 300µA
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF fbSafety.bEmergencyStop THEN
	bDigiOutVoltage1 := bDigiOutVoltage2 := TRUE;
END_IF
]]></ST>
    </Implementation>
