        </Implementation>
      </Get>
    </Property>
    <Method Name="M_GetCurrent" Id="{c63444a7-6c59-42a6-bedd-853486b57770}">
      <Declaration><![CDATA[METHOD M_GetCurrent : DINT
VAR_INPUT
END_VAR

VAR
	rAnaIn	: REAL;
END_VAR

]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Bei älterer Bauform gibt es keine Strommessung
IF bLegacy THEN
	RETURN;
END_IF
IF bHVPSAvailable THEN
	rAnaIn := nAnalogInCurrent;
	M_GetCurrent := REAL_TO_DINT(F_YFuncX(rxMin:= rMinCurrentMV,
										rxMax:= rMaxCurrentMV,
										ryMin:= rMinCurrent,
										ryMax:= rMaxCurrent,
										rx:= 10000.0 / 32767.0 * rAnaIn) * 10.0); //Faktor 10.0 da in 10tel µA mit der
																				  //GUI kommuniziert wird
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_bLegacy" Id="{cdb8bbcb-b400-484e-840c-52d532e8092e}">
