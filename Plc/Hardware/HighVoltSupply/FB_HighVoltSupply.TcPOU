    <Method Name="M_SetVoltage" Id="{59c0b058-9bad-4737-8f40-dc5c0a498942}">
      <Declaration><![CDATA[METHOD M_SetVoltage : INT
VAR_INPUT
	nValue : INT;
END_VAR

VAR
	rAnaOut			: REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[rAnaOut := F_YFuncX(rxMin:= rMinVoltage,
					rxMax:= rMaxVoltage,
					ryMin:= rMinVoltageCV,
					ryMax:= rMaxVoltageCV,
					rx:= nValue) * 32767.0 / 10000.0;

nAnalogOutVoltage := REAL_TO_INT(rAnaOut);]]></ST>
      </Implementation>
    </Method>
