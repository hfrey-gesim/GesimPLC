    <Method Name="M_SwitchVoltage" Id="{6e522ad5-fd71-45f5-8b10-7582f20c1db2}">
      <Declaration><![CDATA[METHOD M_SwitchVoltage
VAR_INPUT
	nChannel : USINT;
	bOn : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[nCurrentChannel := nChannel;
IF bOn THEN
	pFbSafety^.M_MesBoxOn();
END_IF
IF nChannel = 1 THEN
	bDigiOutVoltage1 := NOT bOn;
	bDigiOutVoltage2 := TRUE;
ELSIF nChannel = 2 THEN
	bDigiOutVoltage1 := TRUE;
	bDigiOutVoltage2 := NOT bOn;
ELSE
	RETURN;
END_IF]]></ST>
      </Implementation>
    </Method>
