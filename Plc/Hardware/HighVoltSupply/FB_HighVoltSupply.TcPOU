    <Method Name="M_GetVoltageOk" Id="{9ee35ed6-f1f4-4fa6-8b2f-0ab5cee52c3a}">
      <Declaration><![CDATA[METHOD M_GetVoltageOk : BOOL
VAR_INPUT
	nChannel : USINT;
	nSetVoltage	: INT;
	nTolerancePlus	: INT;
	nToleranceMinus	: INT;	
END_VAR

VAR
	nCurrentVoltage : DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[nCurrentVoltage := M_GetVoltage();

IF (nCurrentVoltage >= nSetVoltage - nToleranceMinus) AND (nCurrentVoltage <= nSetVoltage + nTolerancePlus)THEN
	M_GetVoltageOk := TRUE;
	RETURN;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetVoltage" Id="{c08f74a7-f3d2-4e47-90f7-146febcf8499}">
      <Declaration><![CDATA[METHOD M_GetVoltage : DINT
VAR_INPUT
END_VAR

VAR
	rAnaIn	: REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bHVPSAvailable THEN
	//Bei der älteren Bauform wird die Spannung von Kanal2 über den zweiten analogen Eingang gemessen, was bei der neueren Bauform die Strommesung ist
	IF bLegacy AND (nCurrentChannel = 2) THEN
		rAnaIn := nAnalogInCurrent;
	ELSE
		rAnaIn := nAnalogInVoltage;
	END_IF
	
	M_GetVoltage := REAL_TO_DINT(F_YFuncX(rxMin:= rMinVoltageMV,
							rxMax:= rMaxVoltageMV,
							ryMin:= rMinVoltage,
							ryMax:= rMaxVoltage,
							rx:= 10000.0 / 32767.0 * rAnaIn));
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Property Name="P_nMaxVoltageCV" Id="{c51afd8b-b19d-40ab-be05-4ed59e7a644e}">
      <Declaration><![CDATA[PROPERTY P_nMaxVoltageCV : DINT]]></Declaration>
      <Set Name="Set" Id="{b7380290-b74b-44c1-aaf7-b5427a71a8c0}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[rMaxVoltageCV := DINT_TO_REAL(P_nMaxVoltageCV);
fbSettings.M_WritePersData();]]></ST>
        </Implementation>
      </Set>
      <Get Name="Get" Id="{d1b1a8bc-0bbd-4e40-b2bd-923cc295015a}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
