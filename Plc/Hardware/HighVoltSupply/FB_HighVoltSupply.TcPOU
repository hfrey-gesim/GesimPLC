        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bLegacy := P_bLegacy;
fbSettings.M_WritePersData();]]></ST>
        </Implementation>
      </Set>
      <Get Name="Get" Id="{d17d789f-c5b8-4ac4-8db9-a0ec1306d436}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[P_bLegacy := bLegacy;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="M_SetCurrent" Id="{d6089e56-d5ad-4563-8d90-79b20d141023}">
      <Declaration><![CDATA[METHOD M_SetCurrent : INT
VAR_INPUT
	nValue : UINT;
END_VAR

VAR
	rAnaOut			: REAL;
	rValue			: REAL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[rValue := DINT_TO_REAL(nValue) / 10.0;
rAnaOut := F_YFuncX(rxMin:= rMinCurrent,
					rxMax:= rMaxCurrent,
					ryMin:= rMinCurrentCV,
					ryMax:= rMaxCurrentCV,
					rx:= rValue) * 32767.0 / 10000.0;

nAnalogOutCurrent := REAL_TO_INT(rAnaOut);]]></ST>
      </Implementation>
    </Method>
