<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.6">
  <POU Name="FB_HwRefUnistat" Id="{1f3a8ac2-b2e6-4c49-959b-680e319c841a}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_HwRefUnistat
VAR_INPUT
END_VAR
VAR_OUTPUT
END_VAR
VAR
	SerialPort 	: REFERENCE TO FB_SerialComPort_Base;
	fbSendCmd 	: FB_Unistat_SendCmd;
	
	bPolling			: BOOL := TRUE;
	nCurrentTempIntern 	: DINT;
	nCurrentTempExtern 	: DINT;
	eState				: E_UnistatState;
	nState				: USINT;
	nStateNext			: USINT := 1;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[IF NOT __ISVALIDREF(SerialPort) THEN
	RETURN;
END_IF
fbSendCmd.SerialPort REF= SerialPort;
IF NOT SerialPort.bIsWorking THEN
	RETURN;
END_IF

IF nState = 0 THEN
	IF bPolling THEN
		nState := nStateNext;
	END_IF
END_IF

CASE nState OF
	1:	//Status abrufen
		fbSendCmd(bExecute:= TRUE, eCommand:= E_Unitstat_Command.Get_Status);
		IF NOT fbSendCmd.bBusy THEN
			IF NOT fbSendCmd.bError THEN
				eState := fbSendCmd.nReceiveData;
			END_IF
			fbSendCmd(bExecute:= FALSE);
			nState := 0;
			nStateNext := 2;
		END_IF	

	2:	//Temp intern abrufen
		fbSendCmd(bExecute:= TRUE, eCommand:= E_Unitstat_Command.Get_TempActualIntern);
		IF NOT fbSendCmd.bBusy THEN
			IF fbSendCmd.bError THEN
				nCurrentTempIntern := 16#FFFF;
			ELSE
				nCurrentTempIntern := fbSendCmd.nReceiveData;
			END_IF
			fbSendCmd(bExecute:= FALSE);
			nState := 0;
			nStateNext := 3;
		END_IF
	3:	//Temp extern abrufen
		fbSendCmd(bExecute:= TRUE, eCommand:= E_Unitstat_Command.Get_TempActualExtern);
		IF NOT fbSendCmd.bBusy THEN
			IF fbSendCmd.bError THEN
				nCurrentTempExtern := 16#FFFF;
			ELSE
				IF fbSendCmd.nReceiveData = -1510 THEN
					nCurrentTempExtern := 16#FFFF;
				ELSE
					nCurrentTempExtern := fbSendCmd.nReceiveData;	
				END_IF
			END_IF
			fbSendCmd(bExecute:= FALSE);
			nState := 1;
			nStateNext := 1;
		END_IF
END_CASE


	

 ]]></ST>
    </Implementation>
    <Method Name="FB_init" Id="{1f73a08f-2ff2-4e08-8f4d-0dc18f6f5e64}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains : BOOL; // if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode : BOOL;  // if TRUE, the instance afterwards gets moved into the copy code (online change)
	SerialPort 	: REFERENCE TO FB_SerialComPort_Base;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.SerialPort REF= SerialPort;]]></ST>
      </Implementation>
    </Method>
