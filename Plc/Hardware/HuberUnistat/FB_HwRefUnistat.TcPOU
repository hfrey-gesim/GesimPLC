    <Property Name="P_nCurrentTempIntern" Id="{c43559a4-6e4d-41e8-a347-5d499abeb97e}">
      <Declaration><![CDATA[PROPERTY P_nCurrentTempIntern : DINT]]></Declaration>
      <Get Name="Get" Id="{13b5494c-6c55-476e-96f5-de6d9ca9a1f2}">
        <Declaration><![CDATA[VAR
