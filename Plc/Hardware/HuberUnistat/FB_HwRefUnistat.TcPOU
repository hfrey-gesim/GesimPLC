        <Implementation>
          <ST><![CDATA[P_bPolling := bPolling;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{d6d04eff-5b7a-4369-a2eb-edd357694c15}">
        <Declaration><![CDATA[VAR
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[bPolling := P_bPolling;]]></ST>
        </Implementation>
      </Set>
    </Property>
