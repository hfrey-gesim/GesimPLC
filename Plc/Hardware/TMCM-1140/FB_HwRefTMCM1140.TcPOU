<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.14">
  <POU Name="FB_HwRefTMCM1140" Id="{c5eb1d93-7bbb-4586-940d-476c77b762b9}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_HwRefTMCM1140 EXTENDS FB_CanNodeBase
VAR_INPUT
	nControlword	AT%Q* : UINT;
	nMode			AT%Q* : SINT;
	nTargetPosition AT%Q* : DINT;	//PP-mode
	nTargetSpeed	AT%Q* : INT;	//VL-mode (in PP-mode anders Object über SDO)	
END_VAR
VAR_OUTPUT
	nStatusword 	 	AT%I* : UINT;
	nCurrentMode 	 	AT%I* : SINT;
	nDigiInputs 	 	AT%I* : UDINT;
	nCurrentPosIntern 	AT%I* : DINT;
END_VAR

VAR
	//Diese Variablen werden in FB_Init() initialisiert
	bSetDigiOut0		: BOOL;
	bSetDigiOut1		: BOOL;
	nSwitchConfig		: USINT;
	eHomingMethode		: E_TMCM_HomingMethode;
	nMicrostepResol 	: UINT;
	nFullStepRevo		: UINT;     //0-65535
	nRampDivisor		: USINT; 	//0-13 ; erweitert bei PureDyne Anpassung
	nPulseDivisor		: USINT;	//0-13
	
	//////////////////////////////////////////////////
	nStateNext			: USINT;
	bIsHomed 			: BOOL;
	lrMicroStepsPerRevo	: LREAL; //FullstepPerRevo * nMicrostepResol (FB_Init()) 
	nCurrentPosReal		: DINT;
END_VAR

VAR PERSISTENT
	nMaxCurrent				: UINT;	//Maximaler Strom in mA
	nHoldCurrent 			: UINT;	//Haltestrom in mA
	nDistPerMotorRev		: DINT; //Weg der prop Motorumdrehung zurückgelegt wird (hier wird Getriebeübersetzung oder Spindelsteigung
									//mit beachtet) reale Einheit (Weg oder Winkel) 
	nRefPos					: DINT; //reale Einheit (Weg oder Winkel)
	nMinPos					: DINT; //reale Einheit (Weg oder Winkel)
	nMaxPos					: DINT; //reale Einheit (Weg oder Winkel)
	nHomePos				: DINT; //reale Einheit (Weg oder Winkel)
	nFastHomingSpeed		: DINT;	//reale Einheit/s
	nSlowHomingSpeed		: DINT; //reale Einheit/s
	nMaxSpeed				: DINT; //reale Einheit/s

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^();
IF lrMicroStepsPerRevo > 0 THEN
	nCurrentPosReal := LREAL_TO_DINT((DINT_TO_LREAL(nCurrentPosIntern) * nDistPerMotorRev) / lrMicroStepsPerRevo);
END_IF]]></ST>
    </Implementation>
    <Method Name="FB_init" Id="{a7b87af1-14ab-4334-b720-9513c8bb0bd4}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains : BOOL; // if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode  : BOOL;  // if TRUE, the instance afterwards gets moved into the copy code (online change)
	bSetDigiOut0 : BOOL; //bei TMCM-1140 open drain
	bSetDigiOut1 : BOOL; //bei TMCM-1140 5V
	eLimitSwitchLeftConfig 	: E_TMCM_SwitchConfig;
	eLimitSwitchRightConfig : E_TMCM_SwitchConfig;
	eHomeSwitchConfig	: E_TMCM_SwitchConfig;
	eHomingMethode		: E_TMCM_HomingMethode;
	nMicrostepResol 	: UINT; //2, 4, 8, 16, 32, 64, 128 oder 256
	nFullStepRevo		: UINT;  //0-65535
	nRampDivisor		: USINT; //0-13
	nPulseDivisor		: USINT; //0-13
END_VAR

VAR
	nSwitchConfigLimitLeft 	: USINT;
	nSwitchConfigLimitRight : USINT;
	nSwitchConfigHome 		: USINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[THIS^.bSetDigiOut0 := bSetDigiOut0;
THIS^.bSetDigiOut1 := bSetDigiOut1;
IF eLimitSwitchLeftConfig = E_TMCM_SwitchConfig.Deactivated THEN
	nSwitchConfigLimitLeft := 1;
ELSIF eLimitSwitchLeftConfig = E_TMCM_SwitchConfig.Inverted THEN
	nSwitchConfigLimitLeft := 4;
END_IF
IF eLimitSwitchRightConfig = E_TMCM_SwitchConfig.Deactivated THEN
	nSwitchConfigLimitRight := 2;
ELSIF eLimitSwitchRightConfig = E_TMCM_SwitchConfig.Inverted THEN
	nSwitchConfigLimitRight := 8;
END_IF
IF eHomeSwitchConfig = E_TMCM_SwitchConfig.Deactivated THEN
	nSwitchConfigHome := 16;
ELSIF eHomeSwitchConfig = E_TMCM_SwitchConfig.Inverted THEN
	nSwitchConfigHome := 32;
END_IF
nSwitchConfig := nSwitchConfigLimitLeft OR nSwitchConfigLimitRight OR nSwitchConfigHome;
THIS^.eHomingMethode := eHomingMethode;
THIS^.nMicrostepResol := nMicrostepResol;
THIS^.nFullStepRevo := nFullStepRevo;
THIS^.nRampDivisor := nRampDivisor;
THIS^.nPulseDivisor := nPulseDivisor;
lrMicroStepsPerRevo := nFullStepRevo * nMicrostepResol; ]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetDS402State" Id="{7f6da09d-40e1-4f27-9a81-cf6c8cf9e193}">
      <Declaration><![CDATA[METHOD M_GetDS402State : E_CoDS402States
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF (nStatusword AND 16#4F) = 0 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_NotReadyToSwitchOn;
ELSIF (nStatusword AND 16#4F) = 16#40 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_SwitchOnDisabled;
ELSIF (nStatusword AND 16#6F) = 16#21 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_ReadyToSwitchOn;
ELSIF (nStatusword AND 16#6F) = 16#23 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_SwitchedOn;
ELSIF (nStatusword AND 16#6F) = 16#27 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_OperationEnabled;
ELSIF (nStatusword AND 16#6F) = 16#07 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_QuickStopActive;
ELSIF (nStatusword AND 16#4F) = 16#0F THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_FaultReactionActive;
ELSIF (nStatusword AND 16#4F) = 16#08 THEN
	M_GetDS402State := E_CoDS402States.DS402STATE_Fault;
ELSE
	M_GetDS402State := E_CoDS402States.DS402STATE_Notspecified;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetHomingState" Id="{fd45d7c0-c12d-4253-a813-44d3445f79ea}">
      <Declaration><![CDATA[METHOD M_GetHomingState : E_CoDS402HomingState
VAR_INPUT
END_VAR

VAR 
	nTest : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//werted nur die Bits 10,12,13 vom Statusword aus
nTest := nStatusword AND 16#3400;
CASE nStatusword AND 16#3400 OF
	16#0000:	M_GetHomingState := E_CoDS402HomingState.HomingInProgress;
	16#0400:	M_GetHomingState := E_CoDS402HomingState.HomingInteruptedOrNotReached;
	16#1000:	M_GetHomingState := E_CoDS402HomingState.HomingAttainedButNotReached;
	16#1400:	M_GetHomingState := E_CoDS402HomingState.HomingSuccess;
	16#2000,
	16#2400		:M_GetHomingState := E_CoDS402HomingState.HomingError;
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_RealToInternPos" Id="{d187c7d6-3b5e-40d5-b106-dc85af1b1e6f}">
      <Declaration><![CDATA[METHOD M_RealToInternPos : DINT
VAR_INPUT
	nValue : DINT; //RealPos
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Formel siehe TMCM-Berechungen.xlsx
IF nDistPerMotorRev > 0 THEN //Div/0 vermeiden
	M_RealToInternPos := LREAL_TO_DINT(lrMicroStepsPerRevo * DINT_TO_LREAL(nValue) / nDistPerMotorRev); 
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_RealToInternSpeed" Id="{e76c359a-da47-432c-8476-da4292c4b2ab}">
      <Declaration><![CDATA[METHOD M_RealToInternSpeed : DINT
VAR_INPUT
	nValue : DINT; //reelle Speed,z.B. µm/s oder °/s. Hängt von Einheit DistancePerRevolution ab
END_VAR

VAR
	lrResult	: LREAL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Formel siehe TMCM-Berechungen.xlsx
IF nDistPerMotorRev > 0 THEN //Div/0 vermeiden
	lrResult := (nValue * lrMicroStepsPerRevo * EXPT(2, nPulseDivisor) * 65536) / (nDistPerMotorRev * LREAL#16000000);
	M_RealToInternSpeed := MIN(2047, LREAL_TO_DINT(lrResult));
END_IF

]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetTargetPos" Id="{cac2517f-deeb-4c0f-b2b8-664739899eab}">
      <Declaration><![CDATA[METHOD M_SetTargetPos : BOOL
VAR_INPUT
	nValue 		: DINT; //Reale Position
	bRelative 	: BOOL;
END_VAR

VAR
	nTempTargetPos : DINT; //Nur für Min/Max Überprüfung
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bRelative THEN
	nTempTargetPos := nCurrentPosReal + nValue;
ELSE
	nTempTargetPos := nValue;
END_IF

//Wenn MinPos und MaxPos = 0, dann handelt es sich im Antriebe wie FDM-Extruder o.ä.
//Diese haben diese Begrenzung nicht.
IF (nTempTargetPos >= nMinPos) AND (nTempTargetPos <= nMaxPos) OR (nMinPos = 0 AND nMaxPos = 0) THEN
	nTargetPosition := M_RealToInternPos(nValue);
	M_SetTargetPos := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_SetVLSpeed" Id="{5db492af-304d-4948-9c1e-8315ae7e894e}">
      <Declaration><![CDATA[METHOD M_SetVLSpeed : BOOL
VAR_INPUT
	nValue 	: DINT; //reelle Speed,z.B. µm/s oder °/s. Hängt von Einheit DistancePerRevolution ab
	bCCW	: BOOL;	//Drehrichtung gehen den Uhrzeigersinn
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nValue >= 0 AND nValue <= nMaxSpeed THEN
	nTargetSpeed := DINT_TO_INT(M_RealToInternSpeed(nValue));
	IF bCCW THEN
		nTargetSpeed := nTargetSpeed * -1;
	END_IF
	M_SetVLSpeed := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
