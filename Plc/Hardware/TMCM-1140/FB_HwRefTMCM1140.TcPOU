    <Property Name="P_nHoldCurrentConverted" Id="{27a0b968-3355-4d60-a270-3de37c90431e}">
      <Declaration><![CDATA[PROPERTY P_nHoldCurrentConverted : USINT]]></Declaration>
      <Get Name="Get" Id="{912bc745-68ad-425d-8e64-c19c08603925}">
        <Declaration><![CDATA[VAR
	rValue : REAL;
END_VAR

VAR CONSTANT
	cMaxCurrent : REAL := 2000.0;	//maximaler Strom der Steuerung im mA entspricht 255 
END_VAR
]]></Declaration>
        <Implementation>
          <ST><![CDATA[rValue := UINT_TO_REAL(nHoldCurrent);
rValue := 255.0 / cMaxCurrent * rValue;
P_nHoldCurrentConverted := MIN(255,REAL_TO_USINT(rValue));]]></ST>
        </Implementation>
      </Get>
    </Property>
