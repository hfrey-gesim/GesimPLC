    <LineIds Name="FB_XYDrive_Beck.A_Setup">
      <LineId Id="2" Count="20" />
      <LineId Id="84" Count="1" />
      <LineId Id="87" Count="0" />
      <LineId Id="89" Count="3" />
      <LineId Id="86" Count="0" />
      <LineId Id="27" Count="6" />
