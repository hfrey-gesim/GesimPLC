<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4022.10">
  <POU Name="FB_XYDriveBase" Id="{0cc81cef-caec-4402-ba44-d8abe23431c9}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_XYDriveBase EXTENDS FB_HwModule
VAR PERSISTENT
	rRefPosMaster		: REAL;
	rWorkplateLength 	: REAL;
	rNullPosDist 		: REAL;
	rMaxPosDist 		: REAL;
	rSetupPosDist 		: REAL;
	rLimitMargeNeg 		: REAL;
	rLimitMargePos 		: REAL;
	rMaxSpeed 			: REAL;
	bSetupOK 			: BOOL; //Setup wurde durchgeführt	
	bInvertInitDir 		: BOOL; //Richtung bei Initialisierung umkehren(negativ)
END_VAR

VAR
	nErrorId 			: ERRORID;
	rActPos				: REAL;
	bHomed				: BOOL;
	
	eXYOrientation		: E_XYOrientation;

	bWriteAxisParameter : BOOL;
	nStateA_WriteAxisParamter : USINT;
	nStateWriteLimitNegative : USINT;
	nStateWriteLimitPositive : USINT;
	nStateWriteNCIFastSpeed : USINT;

	bSetup : BOOL;
	nStateA_Setup : USINT;
	bSetupWaitForResp : BOOL;
	bContinueSetup : BOOL;
	bSetupError: BOOL;
	
	bInit : BOOL;
	nStateA_Init : USINT;
	bReInit : BOOL;
	rHomePos : REAL;
	Delay : TON;
	bStopInit : BOOL;
	
	bJog : BOOL;
	nStateA_Jog : USINT;
	bJogForward : BOOL;
	bJogBackward : BOOL;
	bJogInching : BOOL;
	tmrJog : TON;	
	
	bMoveAbs : BOOL;
	nStateMoveAbs : USINT;
	bMoveRel : BOOL;
	nStateMoveRel : USINT;
	
	bCapture : BOOL;
	nStateA_Capture : USINT;
	bStopCapture : BOOL;
	nStateA_StopCapture : USINT;
	bCaptureOk 			: BOOL;
	bCaptureStopped 	: BOOL;
	rCapturedPos		: REAL;
	
	bStop	: BOOL;
	nStateA_Stop : USINT;
	
	bReset : BOOL;
	nStateA_Reset : USINT;
	
	nStateA_Error : USINT;
	
	pMultiZRef : POINTER TO FB_MultiZRef;
	
	stAdsAddress : ST_AdsAdress;
	
	rTrigError	: R_TRIG;

END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[
IF bWriteAxisParameter THEN
	A_WriteAxisParameter();
	IF nStateA_WriteAxisParamter >= 80 THEN
		IF nStateA_WriteAxisParamter >= 99 THEN
			bError := TRUE;
		END_IF
		nStateA_WriteAxisParamter := 0;
		bWriteAxisParameter := FALSE;
	END_IF
END_IF

IF bSetup THEN
	A_Setup();
	IF nStateA_Setup >= 80 THEN
		IF nStateA_Setup >= 99 THEN
			bError := TRUE;
		END_IF
		nStateA_Setup := 0;
		bSetup := FALSE;
	END_IF
END_IF

IF bInit THEN
	A_Init();
	IF nStateA_Init = 80 THEN
		nStateA_Init := 0;
		bInit := FALSE;
	END_IF

	IF nStateA_Init = 99 THEN	//Error
		nStateA_Init := 0;
		bInit := FALSE;
		bError := TRUE;
	END_IF
END_IF

IF bMoveAbs THEN
	A_MoveAbs();
	IF nStateMoveAbs >= 80 THEN
		IF nStateMoveAbs >= 99 THEN	//Error
			bError := TRUE;
		END_IF
		nStateMoveAbs := 0;
		bMoveAbs := FALSE;
	END_IF	
END_IF

IF bMoveRel THEN
	A_MoveRel();
	IF nStateMoveRel >= 80 THEN
		IF nStateMoveRel >= 99 THEN	//Error
			bError := TRUE;
		END_IF
		nStateMoveRel := 0;
		bMoveRel := FALSE;
	END_IF	
END_IF

IF bJog THEN
	A_Jog();
	IF nStateA_Jog >= 80 THEN
		IF nStateA_Jog >= 99 THEN	//Error
			bError := TRUE;
		END_IF
		nStateA_Jog := 0;
		bJog := FALSE;
	END_IF	
END_IF

IF bCapture THEN
	A_Capture();
	IF nStateA_Capture >= 80 THEN
		IF nStateA_Capture >= 99 THEN	//Error
			bError := TRUE;
		END_IF
		nStateA_Capture := 0;
		bCapture := FALSE;
	END_IF	
END_IF

IF bStopCapture THEN
	A_StopCapture();
	IF nStateA_StopCapture >= 80 THEN
		IF nStateA_StopCapture >= 99 THEN	//Error
			bError := TRUE;
		END_IF
		nStateA_StopCapture := 0;
		bStopCapture := FALSE;
	END_IF	
END_IF

IF bReset THEN
	A_Reset();
	IF nStateA_Reset >= 80 THEN
		IF nStateA_Reset >= 99 THEN
			bError := TRUE;
		END_IF
		nStateA_Reset := 0;
		bReset := FALSE;
	END_IF
END_IF

IF bError THEN
	A_Error();
END_IF

IF NOT (bInit OR bMoveAbs OR bMoveRel OR bJog OR bReset OR bSetup) THEN
	bStop := FALSE;
	bBusy := FALSE;
ELSE
	bBusy := TRUE;
END_IF

rTrigError(CLK:= bError);
IF rTrigError.Q THEN
	stError.ErrorId := nErrorId;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
    </Implementation>
