    <Method Name="M_Setup" Id="{2e8c7a39-7c20-435f-b3f0-a05db367cb6c}">
      <Declaration><![CDATA[METHOD M_Setup : ERRORID
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bBusy THEN
	M_Setup := E_ErrorIdCmd.ERRORID_AxisStillBusy;
ELSE
	THIS^.bReInit := TRUE;
	rHomePos := 0;
	bSetup := TRUE;
END_IF
]]></ST>
