    <Method Name="M_GetProperty" Id="{14ca934f-2dd6-4c93-a9fb-0f709d4531b2}">
      <Declaration><![CDATA[METHOD M_GetProperty : ERRORID
VAR_INPUT
	eType	: E_HardwarePropType;
END_VAR
VAR_OUTPUT
	nValue 	: DINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[CASE eType OF
	E_HardwarePropType.RefPos1:
		nValue := REAL_TO_DINT(rRefPosMaster);
	E_HardwarePropType.MinPos:
		nValue := REAL_TO_DINT(P_rMinPos);
	E_HardwarePropType.MaxPos:
		nValue := REAL_TO_DINT(P_rMaxPos);
	E_HardwarePropType.LimitMargeNeg:
		nValue := REAL_TO_DINT(rLimitMargeNeg);
	E_HardwarePropType.LimitMargePos:
		nValue := REAL_TO_DINT(rLimitMargePos);
	E_HardwarePropType.MaxSpeed:
		nValue := REAL_TO_DINT(rMaxSpeed);
	E_HardwarePropType.WorkplateDim:
		nValue := REAL_TO_DINT(rWorkplateLength);
	E_HardwarePropType.NullPosDist:
		nValue := REAL_TO_DINT(rNullPosDist);
	E_HardwarePropType.MaxPosDist:
		nValue := REAL_TO_DINT(rMaxPosDist);
	E_HardwarePropType.SetupPosDist:
		nValue := REAL_TO_DINT(rSetupPosDist);
	E_HardwarePropType.InvertInitDir:
		nValue := BOOL_TO_DINT(bInvertInitDir);		
ELSE
	M_GetProperty := E_ErrorIdCmd.ERRORID_InvalidHwProperty;	
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Init" Id="{1b2c623a-418c-45db-902e-4b8ea38aef27}">
      <Declaration><![CDATA[METHOD M_Init : ERRORID
VAR_INPUT
	bReInit : BOOL;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF bBusy THEN
	M_Init := E_ErrorIdCmd.ERRORID_AxisStillBusy;
ELSE
	THIS^.bReInit := bReInit;
	//Die Action wird von hier aus einmalig ausgeführt damit ein Aufruf schon in diesem Zyklus stattfindet
	rHomePos := rRefPosMaster;
	bInit := TRUE;
	A_Init();		
END_IF

]]></ST>
      </Implementation>
    </Method>
