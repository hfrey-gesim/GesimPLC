    <Property Name="P_bCaptureOk" Id="{dff6745d-29cc-44de-9196-207bdcc83e78}">
      <Declaration><![CDATA[PROPERTY P_bCaptureOk : BOOL]]></Declaration>
      <Get Name="Get" Id="{2d150d8f-92bb-456d-86b5-f302b98d775c}">
        <Declaration><![CDATA[VAR
END_VAR
