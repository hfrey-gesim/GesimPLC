<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="FB_ComplexAction" Id="{b650c0e7-6803-4c22-baf8-46c779c7402e}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ComplexAction

VAR_OUTPUT
	bBusy				: BOOL;
	bError				: BOOL;
	nErrorId			: ERRORID;
	eCurrentState		: E_MachineState := E_MachineState.MACHINESTATE_Idle;
END_VAR

VAR
	//Variablen allgemeine Statemachine
	stError				: ST_Error;
	bInternCanceled		: BOOL;
	bPauseRequestIntern	: BOOL;	//Weiterleitung an ActionDispacher dann an Sequence
								//ermöglicht einer Action, welche aus einer Sequence aufgerufen wurde, diese in Pause zu versetzen
	bLastActionResult	: BOOL;
	nLastActionResult	: DINT;	//wird nur von ausgewählten ComplexActions zurückgegeben
	
	
	nActionState		: USINT;
	nActionStateNext	: USINT;
	
	bStop				: BOOL;
	
	eCurrentAction		: E_Action;
	
	//*****************************************ObjectPointer*****************************************************
	pMzTool					: POINTER TO FB_MzTool;
	pZLevelSensor			: POINTER TO FB_ZLevelSensor;
	pStampSupport			: POINTER TO FB_StampSupport;
	pPiezoPip				: POINTER TO FB_PiezoPip;
	pPassivePip				: POINTER TO FB_PassivPip;
	pLuer					: POINTER TO FB_Luer;
	pLuer2					: POINTER TO FB_Luer;
	pTriplePip				: POINTER TO FB_TriplePip;
	pDiluter1				: POINTER TO FB_Diluter;
	pDiluter2				: POINTER TO FB_Diluter;
	pTwinPiezoHolder		: POINTER TO FB_TwinPiezoHolder;
	pSolenoidPip			: POINTER TO FB_SolenoidPip;
	pVacuumHandler			: POINTER TO FB_VacuumHandler;
	ppHElectrode			: POINTER TO FB_pHElectrode;
	pHybridDispenser		: POINTER TO FB_HybridDispenser;
	pMultiCartHolder		: POINTER TO FB_MultiCartHolder;
	pExtruder				: POINTER TO FB_Extruder;
	pTwinExtruder			: POINTER TO FB_TwinExtruder;
	pGripper				: POINTER TO FB_Gripper;
	
	pTarget					: POINTER TO FB_TargetBase;
	pArray					: POINTER TO FB_Array;
	pInkStation				: POINTER TO FB_InkStation;
	pTipCalibrator			: POINTER TO FB_TipCalibrator;
	pTipCleaner				: POINTER TO FB_TipCleaner;
	pTipCleanerGen2			: POINTER TO FB_TipCleanerGen2;
	pStampMagazine			: POINTER TO FB_StampMagazine;
	pWashStation			: POINTER TO FB_WashStation;
	pMtp					: POINTER TO FB_Mtp;
	pDryPad					: POINTER TO FB_DryPad;
	pStroboscope			: POINTER TO FB_Stroboscope;
	pRack					: POINTER TO FB_Rack;
	pNeedleRack				: POINTER TO FB_NeedleRack;
	pFlipTubeRack			: POINTER TO FB_FlipTubeRack;
	pReactor				: POINTER TO FB_Reactor;
	pPowderStation			: POINTER TO FB_PowderStation;
	pHighVoltTray			: POINTER TO FB_HighVoltTray;
	ppHElectrCapRack		: POINTER TO FB_pHElectrodeCapRack;
	pSlide					: POINTER TO FB_Slide;
	pCartDispenser			: POINTER TO FB_CartDispenser;
	pTrayTransporter		: POINTER TO FB_TrayTransporter;
	
	pPiece					: POINTER TO FB_PieceBase;
	pSlot					: POINTER TO FB_Slot;
	pPieceSlot				: POINTER TO FB_PieceSlot;
	pNeedle					: POINTER TO FB_Needle;
	pTip					: POINTER TO FB_Tip;
	pFlipTube				: POINTER TO FB_FlipTube;
	pVial					: POINTER TO FB_Vial;
	pNozzle					: POINTER TO FB_Nozzle;
	
	iTargetZSensor			: I_TargetZSensor;
	iUsingDryPad			: I_UsingDryPad;
	iDispenser				: I_Dispenser;
	
	pSequence				: POINTER TO FB_Sequence;
	
	//****************************************Aktionvariablen****************************************************
	i						: UINT;
	bFlag					: BOOL; //Flag zur allgemeinen Verwendung
	bSingleStep				: BOOL;
	bSingleStepContinue		: BOOL;
	nSingleStepNextState	: USINT;
	
	eAction					: E_Action;
	stActionData			: ST_ActionData;
	stActionData2			: ST_ActionData;
	nCol					: UINT;
	nRow					: UINT;
	nSpecPointSlotNr		: UINT;
	stPoint1 				: ST_3DPoint;
	stPoint2 				: ST_3DPoint;
	stDimension				: ST_3DDimension;
	nZOffset1				: DINT;
	nZOffset2				: DINT;
	nZOffset3				: DINT;
	nDistance1				: DINT;
	nSpeed1					: DINT;
	rSumDockOffset			: REAL;	//Summe von DockOffset Tool und Piece
	
	eTargetRef				: E_TargetRef;
	nTargetCol				: UINT;
	nTargetRow				: UINT;
	
	nTime					: UDINT;
	nPressure1				: INT;
	nPressure2				: INT;
	nQuantity1				: DINT;
	nQuantity2				: DINT;
	nQuantity3				: DINT;
	nFlow1					: DINT;
	nPeriode				: DINT;
	nDutycycle				: DINT;
	
	timer1					: TON;
	time1					: TIME;
	
	bOpen					: BOOL;	//Öffnen
	
	//Action: "ActionOnArray"
	eActOnArrayOrder		: E_ArrayOrder;
	nActOnArraySpeedX		: DINT;
	nActOnArraySpeedY		: DINT;
	nActOnArraySpeedZ		: DINT;
	nActOnArraySpeedZRelease: DINT;
	bReleaseMoveInstantly	: BOOL;
	tReleaseMoveDelay		: TIME;
	
	//CleanTip
	eCleaningMode			: E_TipCleaningMode;
	tCleaningDispenseTime	: TIME;
	nCleaningWireSpeed		: DINT;
	
	//DispenseTest
	nDispenseTrials			: DINT;
	nDispenseTestArg2		: DINT; //wird einfach per InteractRequest weitergeleitet
	bInhibitDispenseTrials	: BOOL; //wenn gesetzt, dann bleibt nDispenseTrial nach Test auf "0"
	
	//Action: "ExchangePiece"
	bExchangeNeedle			: BOOL;
	bExchangeTip			: BOOL;
	bExchangeStamp			: BOOL;
	bExchangeSeptum			: BOOL;
	bExchangeVial			: BOOL;
	bExchangepHCap			: BOOL;
	bTakePiece				: BOOL;		//True = Take, False = Drop
	eExchangeOption			: E_ExchangePieceOption;
	nExchangePieceCnt		: USINT;
	nExchangePieceCnt2		: USINT;
	
	//Action: "GetPipSample"
	bGetPipSample_SwitchBypass	: BOOL;
	bGetPipSample_ActivatePiezo	: BOOL;
	
	//Action: "InsertTool"
	nInsertLevel				: USINT; //0=TopLevel, 1=BottomLevel
	
	//Action: "MeasureXXX"
	stMeasOffset				: ST_3DPoint;
	stMeasCurrentPos			: ST_3DPoint;
	
	//Action: "MeasureStamp"
	bMeasureStamp			: BOOL;
	
	//Action: "MeasureTarget"
	bMeasureTarget			: BOOL;
	eMeasureTargetMode		: E_MeasureMode;
	rMeasureTargetDistance	: REAL;
	fbReadZSensorID			: FB_ZM_ReadZSensorID;
	nZSensorId				: DINT;
	rZSensorCalibration		: REAL;
	stMeasureTargetTgtPos	: ST_3DPoint;
	
	//Action: "MeasureTip"
	bMeasureTip					: BOOL;
	bMeasureTipLegacy			: BOOL;
	eMeasTipOption				: E_MeasureOption;
	fbMeasTip					: FB_MeasTip;
	stMeasCalibPoint			: ST_3DPoint;
	stMeasPassIntersect			: ST_3DPoint;
	stMeasStartPos				: ST_3DPoint;
	stMeasEndPos				: ST_3DPoint;
	stXYLimits					: ST_Rectangle;
	rMeasureDistance			: REAL;
	
	//Action: "CalibrateTipCalibrator"
	bCalibrateTipCalibrator		: BOOL;
	
	
	//Action: "MoveAllHome"
	
	//Action: "MoveToTarget"
	fbMoveToTarget				: FB_MoveToTarget;
	
	//gemeinsame Variablen für TeachTarget und TeachTool
	eTeachOption			: E_TeachTrgtOption;
	
	//Action: "WashSequence"
	aWashSteps				: ARRAY[1..3] OF ST_WashStep;
	nCurrentWashStep		: USINT;
	
	//Action: "WashTool"
	eWashMode				: E_WashMode;
	nRinseChannel			: USINT;
	nDilInputNr				: DINT;
	
	//Action: "TransferTray"
	eTransferTrayCtrl		: E_TransferTrayCtrl;
	nTransferTrayPos		: DINT;
	nStateA_TransferTray	: USINT;
	bAdditionalMoves		: BOOL;
	
END_VAR

VAR CONSTANT
	cMoveTraySpeed : DINT := 50000; //µm/s
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[CASE eCurrentState OF
	E_MachineState.MACHINESTATE_Idle:
		bBusy := FALSE;
	E_MachineState.MACHINESTATE_Active:
		IF bStop THEN
			bStop := FALSE;
			nActionState := 70;
		END_IF
		CASE eCurrentAction OF
			E_Action.ACTION_ActionOnArray:
				A_ActionOnArray();
			E_Action.ACTION_CalibrateZSensor:
				A_CalibrateZSensor();
			E_Action.ACTION_CleanTip:
				IF pTipCleaner^.P_eObjectType = E_ObjectType.OBJECTTYPE_TipCleaner THEN
					A_CleanTip();
				ELSIF pTipCleaner^.P_eObjectType = E_ObjectType.OBJECTTYPE_TipCleanerGen2 THEN
					A_CleanTipGen2();
				END_IF
			E_Action.ACTION_DockTool:
				A_DockTool();
			E_Action.ACTION_DryPip:
				A_DryPip();
			E_Action.ACTION_DryToolInside:
				A_DryToolInside();
			E_Action.ACTION_ExchangePiece:
				//hier noch zwischen den einzelnen Piece-Typen unterscheiden
				IF bExchangeNeedle THEN
					A_ExchangeNeedle();
				ELSIF bExchangeSeptum THEN
					A_ExchangeSeptum();
				ELSIF bExchangeVial THEN
					IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Gripper THEN
						A_ExchangeVialGripper();
					ELSE
						A_ExchangeVial();
					END_IF
				ELSIF bExchangeStamp THEN
					A_ExchangeStamp();
				ELSIF bExchangeTip THEN
					A_ExchangeTip();
				ELSIF bExchangepHCap THEN
					A_ExchangepHCap();
				END_IF
			E_Action.ACTION_GetPipSample:
				A_GetPipSample();
			E_Action.ACTION_InsertTool:
				A_InsertTool();
			E_Action.ACTION_MeasureTool:
				IF bMeasureStamp THEN
					A_MeasureStamp();
				ELSIF bMeasureTarget THEN
					A_MeasureTarget();
				ELSIF bMeasureTip THEN
					IF bMeasureTipLegacy THEN
						A_MeasureTipLegacy();	
					ELSE
						A_MeasureTip();
					END_IF
				ELSIF bCalibrateTipCalibrator THEN
					A_CalibrateTipCalibrator();
				END_IF
			E_Action.ACTION_MoveAllHome:
				A_MoveAllHome();
			E_Action.ACTION_MoveToTarget:
				A_MoveToTarget();
			E_Action.ACTION_OpenCloseFlipTube:
				A_OpenCloseFlipTube();
			E_Action.ACTION_StampDemolding:
				A_StampDemold();
			E_Action.ACTION_StampInking:
				A_StampInking();
			E_Action.ACTION_TeachTarget:
				A_TeachTarget();
			E_Action.ACTION_TeachTool:
				A_TeachTool();
			E_Action.ACTION_DispenseTest:
				A_DispenseTest();
			E_Action.ACTION_TransferLiquid:
				A_TransferLiquid();
			E_Action.ACTION_TransferGas:
				A_TransferGas();
			E_Action.ACTION_TransferTray:
				A_TransferTray();
			E_Action.ACTION_WashTool:
				A_WashTool();
		END_CASE
		
		IF nActionState >= 80 THEN
			IF nActionState >= 99 THEN
				eCurrentState := E_MachineState.MACHINESTATE_Error;
			ELSE
				eCurrentState := E_MachineState.MACHINESTATE_Idle;
			END_IF
			nActionState := 0;
		END_IF
	
	E_MachineState.MACHINESTATE_PauseRequest:
		//Was passiert, wenn bStop hier kommt?
		//DispenseTest abbrechen
		nActionState := 70;
		A_DispenseTest();
		IF nActionState >= 80 THEN
			IF nActionState >= 99 THEN
				eCurrentState := E_MachineState.MACHINESTATE_Error;
			ELSE
				IF bStop THEN
					eCurrentState := E_MachineState.MACHINESTATE_Idle;
				ELSE
					eCurrentState := E_MachineState.MACHINESTATE_Pause;
				END_IF
			END_IF
			nActionState := 0;
		END_IF
		
	E_MachineState.MACHINESTATE_Pause:
		IF bStop THEN
			bStop := FALSE;
			eCurrentState := E_MachineState.MACHINESTATE_Idle;
		END_IF
		
	E_MachineState.MACHINESTATE_Reset:
		bStop := FALSE;
		bError := FALSE;
		nErrorId := 0;
		eCurrentState := E_MachineState.MACHINESTATE_Idle;

	E_MachineState.MACHINESTATE_Error:
		nErrorId := stError.ErrorId;
		bError := TRUE;
		bBusy := FALSE;
END_CASE]]></ST>
    </Implementation>
    <Action Name="A_ActionOnArray" Id="{81e29213-83c2-426b-b051-cdd527602f54}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;	
END_IF

IF nActionState = 0 THEN
	//MoveToTarget zum ersten ArrayIndex
	nActionState := 1;
	IF pArray^.M_GetNextArrayIndex(eOrder:= eActOnArrayOrder, nStartCol:= nTargetCol,nStartRow:= nTargetRow,
									nCol=>nTargetCol,nRow=>nTargetRow) THEN
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pArray^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
		stActionData.aParams[2] := nTargetCol;
		stActionData.aParams[3] := nTargetRow;
		//stActionData.aParams[4] Area bleibt 0
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := nZOffset1;
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
		END_IF			
	ELSE
		nActionState := 99;
	END_IF

ELSIF nActionState = 1 THEN		
	//MoveToTarget ready? -> Execute Action
	fbMoveToTarget(bExecute:= TRUE);
	IF NOT fbMoveToTarget.bBusy THEN
		IF fbMoveToTarget.bError THEN
			stError.ErrorId := fbMoveToTarget.nErrorId;
			nActionState := 99;
		ELSE
			nActionState := 4;	
		END_IF
		fbMoveToTarget(bExecute:= FALSE);
	END_IF

ELSIF nActionState = 2 THEN
	//MoveXY
	IF pArray^.M_GetNextArrayIndex(eOrder:= eActOnArrayOrder, nStartCol:= nTargetCol,nStartRow:= nTargetRow,
									nCol=>nTargetCol,nRow=>nTargetRow) THEN
		stPoint1 := pArray^.M_GetAbsPos(pChildPos:= 0, E_TargetRef.TARGETREF_TwoDimArray,nTargetCol,nTargetRow,0,0);
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint1.X);
		stActionData.aParams[3] := REAL_TO_DINT(stPoint1.Y);
		stActionData.aParams[4] := nActOnArraySpeedX;
		stActionData.aParams[5] := nActOnArraySpeedY;
		stActionData.aParams[6] := 1; //IgnoreCollision
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF			
	ELSE
		nActionState := 12;
	END_IF
ELSIF nActionState = 3 THEN		
	//MoveXY ready? -> MoveZ  auf ZOffsetAction (ZOffset1)
	IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
		nActionState := 4;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + nZOffset1;
		stActionData.aParams[3] := nActOnArraySpeedZ;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
	END_IF
ELSIF nActionState = 4 THEN
	//MoveZ ready? -> Execute Action
	IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
		nActionState := 5;
		IF stActionData2.eAction = E_Action.ACTION_TakePicture THEN //für Weiterleitung an InteractRequest.Arg3 und Arg4
			stActionData2.aParams[4] := nTargetCol;
			stActionData2.aParams[5] := nTargetRow;
		END_IF
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData2);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF			
	END_IF
ELSIF nActionState = 5 THEN
	IF NOT pMzTool^.M_GetActionBusy(stActionData2.eAction) OR bReleaseMoveInstantly THEN
		timer1(IN:= FALSE);
		nActionState := 6;
	END_IF
END_IF

IF nActionState = 6 THEN
	IF tReleaseMoveDelay > T#0S THEN
		timer1(IN:=TRUE, PT:= tReleaseMoveDelay);
		IF timer1.Q THEN
			nActionState := 7;
		END_IF
	ELSE
		nActionState := 7;
	END_IF
END_IF

IF nActionState = 7 THEN
	//Hier entscheiden, ob ZMove erforderlich ist
	//Falls ZDistanceRelease > 0, dann MoveZ relativ
	stPoint1 := pArray^.M_GetAbsPos(0,E_TargetRef.TARGETREF_TwoDimArray,nTargetCol,nTargetRow,0,0);
	MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
	stActionData.eAction := E_Action.ACTION_MoveZ;
	stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
	IF nDistance1 > 0 THEN //MoveZ auf ZOffsetRelease
		nActionState := 8;
	ELSIF nZOffset2 > (nZOffset1 + nDistance1) THEN //MoveZ auf ZOffsetXYMove
		nActionState := 10;
	ELSIF NOT pMzTool^.M_GetActionBusy(stActionData2.eAction) THEN
		nActionState := 2; //nächster XY Move
	END_IF	
END_IF

//Achtung, ab hier die States anpassen!!
		
IF nActionState = 8 THEN //MoveZ auf ZOffsetRelease
	nActionState := 9;
	stPoint1 := pArray^.M_GetAbsPos(0, E_TargetRef.TARGETREF_TwoDimArray,nTargetCol,nTargetRow,0,0);
	stActionData.eAction := E_Action.ACTION_MoveZ;
	stActionData.aParams[1] := E_MoveMode.MODE_Relative;
	stActionData.aParams[2] := nDistance1;
	stActionData.aParams[3] := nActOnArraySpeedZRelease;
	stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
	IF stError.ErrorId > 0 THEN
		nActionState := 99;
	END_IF
ELSIF nActionState = 9 THEN //MoveZ ready?
	IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
		//Muss für den XY-Move noch weiter in Z gefahren werden?
		//wenn ZOffset2 > ZOffset1 + DistanceRelease
		IF nZOffset2 > (nZOffset1 + nDistance1) THEN
			nActionState := 10;
		ELSIF NOT pMzTool^.M_GetActionBusy(stActionData2.eAction) THEN
			nActionState := 2;
		END_IF
	END_IF
END_IF
	
IF nActionState = 10 THEN //MoveZ auf ZOffsetXYMove
	nActionState := 11;
	stPoint1 := pArray^.M_GetAbsPos(0, E_TargetRef.TARGETREF_TwoDimArray,nTargetCol,nTargetRow,0,0);
	stActionData.eAction := E_Action.ACTION_MoveZ;
	stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
	stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + nZOffset2;
	stActionData.aParams[3] := nActOnArraySpeedZ;
	stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
	IF stError.ErrorId > 0 THEN
		nActionState := 99;
	END_IF
ELSIF nActionState = 11 THEN //MoveZ and Action ready? -> MoveXY
	IF NOT (pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) OR pMzTool^.M_GetActionBusy(stActionData2.eAction)) THEN
		nActionState := 2;
	END_IF
ELSIF nActionState = 12 THEN //MoveZ free
	stActionData.eAction := E_Action.ACTION_MoveZ;
	stActionData.aParams[1] := E_MoveMode.MODE_Free;
	stActionData.aParams[3] := -1; //max Speed
	stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
	IF stError.ErrorId > 0 THEN
		nActionState := 99;
	ELSE
		nActionState := 13;
	END_IF	
ELSIF nActionState = 13 THEN //MoveZ ready?
	IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
		nActionState := 80;
	END_IF
END_IF
		
IF nActionState = 70 THEN //Abbrechen
	IF fbMoveToTarget.bBusy THEN
		fbMoveToTarget(bStop:= TRUE);
	ELSE
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSIF pMzTool^.M_GetActionBusy(stActionData2.eAction) THEN
			pMzTool^.M_CancelAction(stActionData2.eAction);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			timer1(IN:= FALSE);
			nActionState := 80;
		END_IF		
	END_IF
END_IF

//Errorhandling
IF nActionState = 99 THEN
	timer1(IN:= FALSE);
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ActionOnArray;
	stError.POUAction := E_POUACT.POUACT_A_ActionOnArray;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_CalibrateTipCalibrator" Id="{e30de4f8-4d0a-4bf8-82fb-c396f355d668}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

CASE nActionState OF
	0:	//Alle Achsen des Heads auf Home fahren
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1;	//MaxSpeed Z
		stError.ErrorId := pMzTool^.P_pMzHead^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
		
	1:	//Head ready?
		IF NOT pMzTool^.P_pMzHead^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pMzTool^.P_pMzHead^.P_bError THEN
				stError.ErrorId := pMzTool^.P_pMzHead^.P_nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 2;
			END_IF
		END_IF	

	2:	//Vorberechnung und MoveXY(Startpos TipCalibrator)
		nActionState := 3;
	
		//Wenn noch nicht vermessen wurde und angeforderte Option = "MEAS_OPTION_OnlyXY", dann
		//Option auf "MEAS_OPTION_SlowApproach" ändern
		stPoint1 := pMzTool^.P_stRelPos;
		stPoint2 := pMzTool^.P_stOffset;
		
		//Startposition und Endposition des X-Moves berechnen
		stMeasPassIntersect := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 1, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasCalibPoint := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 2, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasStartPos := stMeasPassIntersect;
		stMeasStartPos.X := stMeasCalibPoint.X + rMeasureDistance;
		stMeasEndPos := stMeasPassIntersect;
		stMeasEndPos.X := stMeasCalibPoint.X - rMeasureDistance;
	
		//MoveXY auf stMeasStartPos
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
		stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
		stActionData.aParams[4] := -1;	//MaxSpeed X
		stActionData.aParams[5] := -1;	//MaxSpeed Y
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
		
	3:	//MoveXY ready? -> MoveZ auf StartPos
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 4;
			//ZMove auf stMeasStartPos
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			fbMeasTip.nZFeedStart := -1000;
			fbMeasTip.nZFeedEnde := -50;
			fbMeasTip.nZFeedMax := -4000;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Z); //ZPos
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				stActionData.aParams[3] := -1;	//MaxSpeed Z
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		
	4:	//MoveZ ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pTipCalibrator^.P_bXSensor AND pTipCalibrator^.P_bYSensor THEN //Beide Lichtschranken müssen frei sein
				nActionState := 5;	
			ELSE  //Error, mindestens eine der beiden Lichtschranken ist nicht frei
				stError.ErrorId := E_ErrorIdCmd.ERRORID_TipCalibSensor;
				nActionState := 99;
			END_IF 
		END_IF
		
	5:	//Z-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 3,
				 stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
	
		IF NOT fbMeasTip.bBusy THEN
			nActionState := 6;
			IF fbMeasTip.bError THEN //Error
				stError.ErrorId := fbMeasTip.nErrorId;
				nActionState := 99;
			ELSE
				
				MEMSET(ADR(stMeasOffset),0,SIZEOF(stMeasOffset));
				stMeasOffset.Z := fbMeasTip.stProbePos.Z - stMeasCalibPoint.Z;
				stMeasOffset.X := fbMeasTip.stProbePos.X - stMeasCalibPoint.X;
				//Dieser Offset muss während der nächsten Positionierungen mit dazu addiert werden!
				
				//Start und Endposition für folgende Y-Vermessung berechnen und in X auf Ausgangsposition fahren
				stMeasStartPos := stMeasPassIntersect;
				stMeasStartPos.Y := stMeasCalibPoint.Y - rMeasureDistance;
				stMeasEndPos := stMeasPassIntersect;
				stMeasEndPos.Y := stMeasCalibPoint.Y + rMeasureDistance;
				
				stMeasStartPos := F_Add3DPoints(stMeasStartPos,stMeasOffset);
				stMeasEndPos := F_Add3DPoints(stMeasEndPos,stMeasOffset);
				
				//MoveX StartPosX
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveX;
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
				stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
				stActionData.aParams[3] := -1;	//MaxSpeed X
				stActionData.aParams[4] := 1; //ignore Z-Kollission
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN //Error
					nActionState := 99;
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);	
		END_IF
		
	6:	//MoveX ready? -> MoveY StartPosY
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			nActionState := 7;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveY;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
			stActionData.aParams[3] := -1;	//MaxSpeed Y
			stActionData.aParams[4] := 1; //ignore Z-Kollission
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);		
			IF stError.ErrorId > 0 THEN //Error
				nActionState := 99;
			END_IF
		END_IF
		
	7:	//MoveY ready? -> MoveZ auf StartPointZ (300µ unterhalb CalibPoint)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			nActionState := 8;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			//stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z) -300;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z + stMeasOffset.Z) -300;
			stActionData.aParams[3] := -1;	//MaxSpeed Z
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData); //ErrorHandling am Ende
			IF stError.ErrorId > 0 THEN //Error
				nActionState := 99;
			END_IF
		END_IF

	8:	//MoveZ ready? -> weiter zu Y-Measurement
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 9;
		END_IF
		
	9:	//Y-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 2,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);		
	
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
				nActionState := 99;
			ELSE
				//Gemessenen Y Wert verrechnen und als OffsetWert in Tool eintragen
				stMeasOffset.Y := fbMeasTip.stProbePos.Y - stMeasCalibPoint.Y;
				
				//Start und Endposition für folgende Y-Vermessung berechnen und in X auf Ausgangsposition fahren
				stMeasStartPos := stMeasPassIntersect;
				stMeasStartPos.X := stMeasCalibPoint.X + rMeasureDistance;
				stMeasEndPos := stMeasPassIntersect;
				stMeasEndPos.X := stMeasCalibPoint.X - rMeasureDistance;
				
				stMeasStartPos := F_Add3DPoints(stMeasStartPos,stMeasOffset);
				stMeasEndPos := F_Add3DPoints(stMeasEndPos,stMeasOffset);

				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveY;
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
				stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
				stActionData.aParams[3] := -1;	//MaxSpeed Y
				stActionData.aParams[4] := 1; //ignore Z-Kollission
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN //Error
					nActionState := 99;
				ELSE
					nActionState := 10;	
				END_IF

			END_IF
			fbMeasTip(bExecute:= FALSE);	
		END_IF
		
	10:	//MoveY ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			nActionState := 11;
		END_IF
		
	11:	//X-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 1,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
					
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
			ELSE
				stMeasOffset.X := fbMeasTip.stProbePos.X - stMeasCalibPoint.X;
				pTipCalibrator^.P_stCalibPoint := F_Add3DPoints(pTipCalibrator^.P_stCalibPoint,stMeasOffset);
				
				//MoveZ-Free
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_Free;
				stActionData.aParams[3] := -1;	//MaxSpeed Z
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN //Error
					nActionState := 99;
				ELSE
					nActionState := 12;	
				END_IF

			END_IF
			fbMeasTip(bExecute:= FALSE);
		END_IF
	
	12:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			fbObjectDirectory.M_SetObjChange(pTipCalibrator^.P_nObjectID);
			nActionState := 80;
		END_IF
	
	70:	//Action abbrechen
		nActionState := 80;
		IF fbMeasTip.bBusy THEN
			fbMeasTip.M_Cancel();
			fbMeasTip();
			nActionState := 70;
		ELSE
			fbMeasTip(bExecute:= FALSE);
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
				pMzTool^.M_CancelAction(ACTION_MoveX);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
				pMzTool^.M_CancelAction(ACTION_MoveY);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
				pMzTool^.M_CancelAction(ACTION_MoveXY);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.M_CancelAction(ACTION_MoveZ);
				nActionState := 70;				
			END_IF
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMeasTip(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_MeasureTool;
	stError.POUAction := E_POUACT.POUACT_A_MeasureTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_CalibrateZSensor" Id="{eaa337a8-6f5a-4a5e-a875-8ba62a0cfd85}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pZLevelSensor^.P_bError THEN
	stError.ErrorId := pZLevelSensor^.P_nErrorId;
	nActionState := 99;
END_IF

IF nActionState > 0 AND nActionState < 70 AND pZLevelSensor^.P_bCanceled THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveXY zum Target (Target muss Point sein -> wird vorher abgefragt)
		nActionState := 1;	
		stPoint1 := pTarget^.P_stAbsPosCenter;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint1.X); //XPos
		stActionData.aParams[3] := REAL_TO_DINT(stPoint1.Y); //YPos
		stActionData.aParams[4] := -1;	//MaxSpeed X
		stActionData.aParams[5] := -1;	//MaxSpeed Y
		stError.ErrorId := pZLevelSensor^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF

	1:	//MoveXY ready? -> MoveZ in PrePos
		IF NOT pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 2;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + 5000; 
			stActionData.aParams[3] := -1; //MaxSpeed Z
			stError.ErrorId := pZLevelSensor^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			END_IF
		END_IF

	2:	//MoveZ ready? -> Messzyklus starten
		IF NOT pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 3;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Measure;
			stMeasCurrentPos := pZLevelSensor^.P_stCurrentPosPhys;
			rMeasureTargetDistance := - 7500;
			stActionData.aParams[2] := REAL_TO_DINT(rMeasureTargetDistance);
			stActionData.aParams[3] := 10000;	//Speed nur damit kein Fehler von MultiZ auftritt(MeasureSpeed ist fix)
			stError.ErrorId := pZLevelSensor^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			END_IF
		END_IF
		
	3:	//Messzyklus ready? -> MoveZ-Home
		IF NOT pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 4;
			//Der CalibrationValue ist die aktuelle Achsposition(Raw) zuzüglich ReferenzTarget
			pZLevelSensor^.P_pFbMultiZ^.M_SetZSensorCalib(nZSensorId := pZLevelSensor^.P_pZAxisRef^.P_nZSensorID,
															nAxisNr := pZLevelSensor^.P_nZAxisNr,
															rValue := pZLevelSensor^.P_pZAxisRef^.P_rCurrentPos - stPoint1.Z);
			//Freifahren
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MaxSpeedZ	
			stError.ErrorId := pZLevelSensor^.M_ExeAction(stActionData);  //ErrorHandling am Ende
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			END_IF
		END_IF
		
	4:	//MoveZ ready? -> Action ready
		IF NOT pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF
		
	70:	//Action abbrechen
		nActionState := 80;
		//MoveXY oder MoveZ vom MzTool abbrechen (schließen sich gegenseitig aus)
		IF pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 70;
			pZLevelSensor^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pZLevelSensor^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 70;
			pZLevelSensor^.M_CancelAction(E_Action.ACTION_MoveZ);
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.ObjectId := pZLevelSensor^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_CalibrateZSensor;
	stError.POUAction := E_POUACT.POUACT_A_CalibrateZSensor;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_CleanTip" Id="{916171ad-c85a-4b57-b6d1-fd3ca0193df7}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;	
ELSIF pTipCleaner^.P_bError THEN
	stError.ObjectId := pTipCleaner^.P_nObjectID;
	stError.ErrorId := pTipCleaner^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	pNozzle := pMzTool^.M_GetNozzle();
		(*pSlot := pMzTool^.M_GetSlot(1); 
		IF pSlot > 0 THEN
			IF pSlot^.P_iChild <> 0 THEN
				IF pSlot^.P_iChild.P_eObjectType = E_ObjectType.OBJECTTYPE_Nozzle THEN
					pNozzle := pSlot^.P_iChild.P_pObject;
				END_IF
			END_IF
		END_IF*)
		//Wenn TipCleaner noch nicht offen, dann öffnen
		nActionState := 1;
		IF pTipCleaner^.P_eStripState <> E_OpClState.Open THEN
			//TipCleaner öffnen
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_OpenClose;
			stActionData.aParams[1] := 0;
			stError.ErrorId := pTipCleaner^.M_ExeAction(stActionData);
		 	IF stError.ErrorId > 0 THEN
				stError.ObjectId := pTipCleaner^.P_nObjectID;
				nActionState := 99;
		 	END_IF
		END_IF
		
	1:	//MoveToTarget nächster Reinigungspunkt fahren
		IF NOT pTipCleaner^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveToTarget;
			stActionData.nObject := pMzTool^.P_nObjectID;
			stActionData.nTarget := pTipCleaner^.P_nObjectID;
			stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
			stActionData.aParams[2] := pTipCleaner^.M_GetNextPointNr();
			stActionData.aParams[3] := 1; //Row immer "1"
			stActionData.aParams[5] := -1;	//MaxSpeed X
			stActionData.aParams[6] := -1;	//MaxSpeed Y
			stActionData.aParams[7] := -1;	//MaxSpeed Z
			IF pNozzle > 0 THEN
				stActionData.aParams[10] := -pNozzle^.P_nCleaningDepth;	//Eintauchtiefe	
			END_IF
			
			stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		 	IF stError.ErrorId > 0 THEN
				//stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				fbMoveToTarget(bExecute:= TRUE);
				nActionState := 2;
		 	END_IF
		END_IF
		
	2:	//MoveToTarget ready? -> Close TipCleaner
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_OpenClose;
				stActionData.aParams[1] := 1;	//schließen
				stError.ErrorId := pTipCleaner^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.ObjectId := pTipCleaner^.P_nObjectID;
					nActionState := 99;
				ELSE
					nActionState := 3;
				END_IF			
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	3:	//TipCleaner ready? -> MoveZ 10mm nach oben
		IF NOT pTipCleaner^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			nActionState := 4;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			//stActionData.aParams[2] := 10000;	//Distanz
			IF pNozzle > 0 THEN
				stActionData.aParams[2] := pNozzle^.P_nCleaningDepth + 1000; //Eintauchtiefe	
			END_IF			
 			stActionData.aParams[3] := 10000;	//Speed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
		
	4:	//MoveZ ready? -> Open TipCleaner
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 5;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_OpenClose;
			stActionData.aParams[1] := 0;
			stError.ErrorId := pTipCleaner^.M_ExeAction(stActionData);
		 	IF stError.ErrorId > 0 THEN
				stError.ObjectId := pTipCleaner^.P_nObjectID;
				nActionState := 99;
		 	END_IF	
		END_IF
		
	5:	//TipCleaner ready? -> MoveZ Free
		IF NOT pTipCleaner^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			nActionState := 6;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Free;
			stActionData.aParams[3] := -1;	//MaxSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
		
	6:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		IF pTipCleaner^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			pTipCleaner^.M_CancelAction(E_Action.ACTION_OpenClose);
		ELSIF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);	
			nActionState := 80;	
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_CleanTip;
	stError.POUAction := E_POUACT.POUACT_A_CleanTip;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_CleanTipGen2" Id="{5b08de20-f568-456c-9773-d9164f88616a}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;	
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 1 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	pNozzle := pMzTool^.M_GetNozzle();
		pTipCleanerGen2^.M_GenerateCleaningPoints(pSlot,pNozzle);
		IF eCleaningMode = E_TipCleaningMode.Wire OR eCleaningMode = E_TipCleaningMode.WireAndBrush THEN
			nActionState := 1;
		ELSIF eCleaningMode = E_TipCleaningMode.Brush THEN
			nActionState := 10; //nur Bürstenreinigung (Wire überspringen)
		ELSE
			stError.ErrorId := E_ErrorIdCmd.ERRORID_InvalidCleaningMode;
			nActionState := 99;
		END_IF
		
	1: 	//MoveXY zu WireCleaningStartPoint
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(0);
		stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(1);
		stActionData.aParams[4] := -1;
		stActionData.aParams[5] := -1;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 2;
		END_IF
		
	2:	//Ready ? -> MoveZ zu WireCleaningStartPoint
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(2);
			stActionData.aParams[3] := -1; //Speed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 3;
			END_IF
		END_IF
		
	3:	//Ready? -> Move
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF tCleaningDispenseTime > T#0MS THEN
				stError.ErrorId := iDispenser.M_DispenserStart();
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				ELSE
					//Timer starten
					timer1(IN:=FALSE);
					timer1(IN:=TRUE, PT:= tCleaningDispenseTime);
					nActionState := 4;
				END_IF
			ELSE
				nActionState := 5;
			END_IF
		END_IF
		
	4:	//Timer? -> Stop Dispensing
		timer1();
		IF timer1.Q THEN
			timer1(IN:=FALSE);
			stError.ErrorId := iDispenser.M_DispenserStop();
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 5;
			END_IF
		END_IF
		
	5: 	//WireCleaning: Start erster Move
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_ACTION.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(3);
		stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(4);
		stActionData.aParams[4] := nCleaningWireSpeed; //SpeedX (Y wird nicht angegeben, da synchron)
		stActionData.aParams[6] := 1; //No collision avoidance
		stActionData.aParams[7] := 1; //Synchron
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 6;
		END_IF
		
	6:	//Move ready? -> WireCleanig: Start zweiter Move (umlenken)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(5);
			stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(6);
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 7;
			END_IF
		END_IF
		
		
	7:	//Move ready? -> WireCleanig: Start dritter Move
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(7);
			stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(8);
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 8;
			END_IF
		END_IF
		
	8:	//Move ready? -> BrushCleaning?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			IF eCleaningMode = E_TipCleaningMode.WireAndBrush THEN
				nActionStateNext := 10;
			ELSE
				nActionStateNext := 80;
			END_IF
			nActionState := 20; //Move free
		END_IF
	
	10:	//MoveXY to BrushCleaningStart  
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_ACTION.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(9);
		stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(10);
		stActionData.aParams[4] := -1; //SpeedX (Y wird nicht angegeben, da synchron)
		IF eCleaningMode <> E_TipCleaningMode.Brush THEN
			stActionData.aParams[6] := 1; //No collision avoidance (nur wenn wire nicht übersprungen wurde)	
		END_IF
		stActionData.aParams[7] := 1; //Synchron
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 11;
		END_IF
		
	11:	//MoveXY ready? -> MoveZ auf Oberkante Brush abzüglich Nozzle.CleanigDepth 
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(11) - pNozzle^.P_nCleaningDepth;
			stActionData.aParams[3] := -1; //Speed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 12;
			END_IF
		END_IF
		
	12:	//MoveZ ready? -> MoveXY hin
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_ACTION.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			//Hier muss noch unterschieden werden zwischen der Richtung.
			//Entsprechend muss die Nozzle measure distance mit X oder Y verrechnet werden. 
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(12);
			stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(13);
			stActionData.aParams[4] := 20000; //SpeedX (Y wird nicht angegeben, da synchron)
			stActionData.aParams[6] := 1; //No collision avoidance
			stActionData.aParams[7] := 1; //Synchron
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 13;
			END_IF
		END_IF
		
	13:	//MoveXY ready? -> MoveXY zurück
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pTipCleanerGen2^.M_GenerateCleaningPoints(pSlot,pNozzle);
			stActionData.aParams[2] := pTipCleanerGen2^.M_GetAbsCleaningPos(9);
			stActionData.aParams[3] := pTipCleanerGen2^.M_GetAbsCleaningPos(10);
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 14;
			END_IF
		END_IF
	
	14:	//MoveXY ready? -> Move Free
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 20; //Move free
			nActionStateNext := 80;
		END_IF
	
	20:	//Move free
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_ACTION.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1;	//MaxSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 21;
		END_IF
		
	21:	//Move free ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := nActionStateNext;
		END_IF
		
	70: //Abbrechen
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			nActionState := 80;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_CleanTip;
	stError.POUAction := E_POUACT.POUACT_A_CleanTipGen2;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_DispenseTest" Id="{539f1f8e-f006-4a45-8a05-796e0e020375}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

CASE nActionState OF
	0:	//MoveToTarget MeasurePoint Strob
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pStroboscope^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
		stActionData.aParams[2] := 1; //Point1 (Measpoint)
		stActionData.aParams[5] := -1;	//MaxSpeed XY
		stActionData.aParams[6] := -1;	//MaxSpeed XY
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			nActionState := 1;
		END_IF	
	
	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartObjRecog;	//Request "StartObjRecog"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				nDispenseTrials := nDispenseTrials + 1;
				stInteractRequest.nArg1 := nDispenseTrials; //Anzahl der bereits durchgeführten Tests
				stInteractRequest.nArg2 := nDispenseTestArg2; //wird einfach aus den ActionData weitergereicht (kommt von GCode M124 R20)
				stInteractRequest.nArg3 := pStroboscope^.P_nObjectID;
				nActionState := 2;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//Wait for Response
		//In diesem State wird die Action DispenseDrop vom PC aus gestartet
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_ObjRecogResult THEN
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			nLastActionResult := stInterResponse.nArg1;
			bLastActionResult := TRUE;
			//Falls Test erfolgreich, dann Zähler für Tests zurücksetzen
			IF nLastActionResult = 1 OR bInhibitDispenseTrials THEN
				nDispenseTrials := 0;
			END_IF
			IF stInterResponse.nArg2 = 1 THEN
				bPauseRequestIntern := TRUE;	
			END_IF
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			nDispenseTrials := 0;
			nActionState := 80;	
		END_IF		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.Cmd := E_Action.ACTION_DispenseTest;
	stError.POUAction := E_POUACT.POUACT_A_DispenseTest;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_DockTool" Id="{61e0b189-07b1-41f9-8cc3-a58b3b542307}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

//Überwachung des Tools durch fbMoveToTarget
(*IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF*)

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf Slot
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack AND pTriplePip > 0 THEN
			IF pTriplePip > 0 THEN
				stActionData.aParams[8] := - REAL_TO_DINT(pTriplePip^.P_rXMoveDockFliptube);
				stActionData.aParams[10] := REAL_TO_DINT(pTriplePip^.P_rZMoveDockFliptube);
			END_IF
		END_IF
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF		
		
	1:	//MoveToTarget ready? -> MoveZ
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack AND pTriplePip > 0 THEN //MoveX (Deckel öffnen)
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveX;
					stActionData.aParams[1] := E_MoveMode.MODE_Relative;
					stActionData.aParams[2] := REAL_TO_DINT(pTriplePip^.P_rXMoveDockFliptube);
					stActionData.aParams[3] := 45000; //Speed
					stActionData.aParams[4] := 1;	//Kein CollCheck
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN	//Error
						nActionState := 99;
					ELSE
						nActionState := 2;
					END_IF
				ELSE
					//->MoveZ
					nActionState := 3;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2: //MoveX ready? -> MoveZ
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			nActionState := 3;
		END_IF
		
	3:	//MoveZ
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack AND pTriplePip > 0 THEN
			stActionData.aParams[2] := nZOffset1 - REAL_TO_DINT(pPieceSlot^.P_pPiece^.P_rZOverlapTool - rSumDockOffset + pTriplePip^.P_rZMoveDockFliptube);
		ELSE
			stActionData.aParams[2] := nZOffset1 - REAL_TO_DINT(pPieceSlot^.P_pPiece^.P_rZOverlapTool - rSumDockOffset);	
		END_IF
		
		stActionData.aParams[3] := 5000; //Speed
		IF stActionData.aParams[2] <> 0 THEN
			pMzTool^.P_nReducedMoveZDist := -stActionData.aParams[2];
			pMzTool^.P_nReducedMoveZSpeed := stActionData.aParams[3]; 
		END_IF
		stActionData.aParams[4] := 500; //CollFreeAreaXMinus
		stActionData.aParams[5] := 500; //CollFreeAreaXPlus
		stActionData.aParams[6] := 500; //CollFreeAreaYMinus
		stActionData.aParams[7] := 500; //CollFreeAreaYPlus
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 4;
		END_IF		
	
	4:	//MoveZ ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);			
			nActionState := 80;	
		END_IF	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_DockTool;
	stError.POUAction := E_POUACT.POUACT_A_DockTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_DryPip" Id="{eeb51761-dba0-4a4f-ad48-db0b8d8778a9}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;
IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget zum nächsten Reinigungspunkt mit 2mm Offset
		pDryPad^.M_CalcNextPosData(iUsingDryPad.P_nDrypadArea); //Reinigungspunkt berechnen
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pDryPad^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
		stActionData.aParams[2] := pDryPad^.nCol;
		stActionData.aParams[3] := pDryPad^.nRow;
		stActionData.aParams[4] := iUsingDryPad.P_nDrypadArea;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := 2000; //2mm Offset -> im nächsten Schritt um diesen langsam nach unten fahren
		//stActionData.aParams[10] := nZOffset1;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF
		
	1:	//MoveToTarget ready? -> MoveZ zu Endpos
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_Relative;
				stActionData.aParams[2] := -2000 + nZOffset1;
				stActionData.aParams[3] := 2000; //Speed
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				ELSE
					nActionState := 2;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//MoveZ ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF nTime > 0 THEN
				timer1(IN:= TRUE,PT:= DWORD_TO_TIME(nTime));
				nActionState := 3;
			ELSE
				nActionState := 4; //Move free
			END_IF
		END_IF
		
	3:	//DryTime abgelaufen
		timer1();
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			nActionState := 4; //Move free
		END_IF
		
	4:	//MoveZ-Free
		nActionState := 5;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1;	//MaxSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
	
	5:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			timer1(IN:= FALSE);
			fbMoveToTarget(bExecute:= FALSE);			
			nActionState := 80;	
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_DryPip;
	stError.POUAction := E_POUACT.POUACT_A_DryPip;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_DryToolInside" Id="{ffce6e9a-aa96-407a-9004-3798e7509277}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;	
ELSIF pWashStation^.P_bError THEN
	stError.ObjectId := pWashStation^.P_nObjectID;
	stError.ErrorId := pWashStation^.P_nErrorId;
	nActionState := 99;
END_IF

CASE nActionState OF
	0:	//MoveToTarget "Washpoint"
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
		stActionData.aParams[2] := nSpecPointSlotNr;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//Speed Z
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF
		
	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
			ELSE
				//WastePumpe einschalten
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.aParams[1] := 1; //WastePump
				stActionData.aParams[2] := 1; //On
				stError.ErrorId := pWashStation^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				ELSE
					nActionState := 2;	
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		//Druck am Tool einschalten
		stActionData.eAction := E_Action.ACTION_SetPressure;
		stActionData.aParams[2] := nPressure1;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId = 0 THEN
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_PressOn;
			stActionData.aParams[2] := DWORD_TO_DINT(nTime);
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		END_IF
		
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 3;
		END_IF					
		
	3:	//Warten, bis SwitchPressure fertig
		nActionState := 4;
		IF pMzTool^.M_GetActionBusy(E_ACTION.ACTION_SwitchPressure) THEN
			nActionState := 3;
		ELSE
			stActionData.eAction := E_Action.ACTION_EmptyWaste;
			pWashStation^.M_ExeAction(stActionData);
		END_IF
	
	4:	//MoveFree
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1;	//MaxSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 5;
		END_IF
		
	5:	//MoveFree ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF		
	
	
	70:	//Abbrechen
		nActionState := 80;
		//Actionen der beteiligten Devices abbrechen
		//MoveToTarget oder MoveZ vom MzTool abbrechen (schließen sich gegenseitig aus)
		IF fbMoveToTarget.bBusy THEN
			nActionState := 70;
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SetPressure);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SwitchPressure);
		END_IF
		
		pWashStation^.M_Stop();	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	pMzTool^.M_Stop();
	pWashStation^.M_Stop();
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_WashTool;
	stError.POUAction := E_POUACT.POUACT_A_WashTool;
	fbErrorList.M_Add(stError);	
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeNeedle" Id="{2119df00-e3cf-42c0-89af-f1573b243765}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf Slot
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		
		pNeedleRack := pTarget;
		pPiece^.P_bIgnoreOffset := TRUE;
		
		IF NOT bTakePiece THEN //Drop
			stPoint1 := pNeedleRack^.P_stWasteOffset1;
			//bei Drop muss die Nadellänge zurückgerechnet werden
			stPoint1.Z := stPoint1.Z - pPiece^.P_rZOverlapSlot;
			stPoint2 := F_Sub3DPoints(pNeedleRack^.P_stWasteOffset2, stPoint1);
			stActionData.aParams[8] := REAL_TO_DINT(stPoint1.X);
			stActionData.aParams[9] := REAL_TO_DINT(stPoint1.Y);
			stActionData.aParams[10] := REAL_TO_DINT(stPoint1.Z);
		END_IF
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF		
		
	1:	//MoveToTarget ready? -> 
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
			IF bSingleStep THEN
				nActionState := 60;
				nSingleStepNextState := 2;
			ELSE
				nActionState := 2;
			END_IF
		END_IF
		
	2:	//Next Move
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		IF bTakePiece THEN //Take
			//Z-Zustellung um OverlapSlot und SumDockOffset
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := REAL_TO_DINT(pPiece^.P_rZOverlapTool * -1 + rSumDockOffset);
			stActionData.aParams[3] := 4000; //MoveSpeed
		ELSE //Drop
			//XY-Move auf WasteOffset2
			stActionData.eAction := E_Action.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := REAL_TO_DINT(stPoint2.X);
			stActionData.aParams[3] := REAL_TO_DINT(stPoint2.Y);
			stActionData.aParams[4] := 15000;
			stActionData.aParams[5] := 15000;
			stActionData.aParams[6] := 1; //Ignore Collision
		END_IF
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 3;
		END_IF		
		
	3:	//MoveXY bzw MoveZ ready?
		IF NOT (pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) OR pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ)) THEN
			IF bSingleStep THEN
				nActionState := 60;
				nSingleStepNextState := 4;
			ELSE
				nActionState := 4;
			END_IF
		END_IF
		
	4:	//Next Move
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := 3000; //3mm nach oben
		stActionData.aParams[3] := 10000; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 5;
		END_IF		

	5:	//MoveZ ready? -> MoveZ-Home
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF bSingleStep THEN
				nActionState := 60;
				nSingleStepNextState := 6;
			ELSE
				nActionState := 6;
			END_IF
		END_IF
	
	6:	//Next Move
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN		//Error
			nActionState := 99;
		ELSE
			nActionState := 7;
		END_IF
	
	7:	//MoveZ-Home ready? -> Piece zuordnen -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			//Parent von Needle wechslen
			IF bTakePiece THEN
				//Piece von NeedleRack auf MzTool übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
			ELSE
				//Piece von MzTool auf NeedleRack übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pPieceSlot^.nNr);
				//Offset von Piece löschen
				stPoint1.X := 0;
				stPoint1.Y := 0;
				stPoint1.Z := 0;
				pPiece^.P_stOffset := stPoint1;
				//Needle als benutzt kennzeichnen
				pNeedle := pPiece;
				pNeedle^.P_bUsed := TRUE;
				fbObjectDirectory.M_SetObjChange(pPiece^.P_nObjectID);
			END_IF
			pPiece^.P_bIgnoreOffset := FALSE;
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;		
			END_IF
		END_IF
		
	60:	//Wait SingleStep
		IF bSingleStepContinue THEN
			bSingleStepContinue := FALSE;
			nActionState := nSingleStepNextState;
		END_IF
		
	70:	//Action abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);		
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			nActionState := 80;
		END_IF	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	pPiece^.P_bIgnoreOffset := FALSE;
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeNeedle;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangepHCap" Id="{d7125d14-3ca4-403b-a501-18a4f1ca4f89}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Verzweigung Take/Drop
		IF bTakePiece THEN
			nActionState := 1;
		ELSE
			nActionState := 10;
		END_IF
	(********************Begin Take*************************)
	1:	//MoveToTarget auf Slot
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[5] := -1;		//MaxSpeed X
		stActionData.aParams[6] := -1;		//MaxSpeed Y
		stActionData.aParams[7] := -1;		//MaxSpeed Z
		stActionData.aParams[10] := 500;	//0.5mm ZOffset nach oben 
		pPiece^.P_bIgnoreOffset := TRUE;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 2;
		END_IF
	2:	//MoveToTarget ready? -> MoveZ down rel (OverlapTool + 0,5mm ZOffset von State 1
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_Relative;
				stActionData.aParams[2] := REAL_TO_DINT(pPiece^.P_rZOverlapTool * -1) -500;
				stActionData.aParams[3] := 5000; //MoveSpeed
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					nActionState := 99;
				ELSE
					nActionState := 3;
				END_IF		
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
	3:	//MoveZ ready? -> MoveZ up rel (0,5mm)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := 1000;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 4;
			END_IF
		END_IF
	4:	//MoveZ ready? -> MoveXY at HandlingOffset XY
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stPoint1 := ppHElectrCapRack^.P_stHandingOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.X);
			stActionData.aParams[3] := REAL_TO_DINT(stPoint1.Y);
			stActionData.aParams[4] := 10000; //SpeedX
			stActionData.aParams[5] := 10000; //SpeedY
			stActionData.aParams[6] := 1; //nicht freifahren 
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 5;
			END_IF
		END_IF
	5:	//MoveXY ready? -> MoveZ home
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 6;
			END_IF
		END_IF
	6:	//MoveZ-Home ready -> Piece zuordnen -> ACTION ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
			pPiece^.P_bIgnoreOffset := FALSE;
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;	
			END_IF
		END_IF
	
	(*********************End Take***************************)
	(*********************Beginn Drop************************)
	10:	//MoveToTarget auf Slot + HandingOffsetXY
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[5] := -1;		//MaxSpeed X
		stActionData.aParams[6] := -1;		//MaxSpeed Y
		stActionData.aParams[7] := -1;		//MaxSpeed Z
		stPoint1 := ppHElectrCapRack^.P_stHandingOffset;
		stActionData.aParams[8] := REAL_TO_DINT(stPoint1.X);
		stActionData.aParams[9] := REAL_TO_DINT(stPoint1.Y);
  		pPiece^.P_bIgnoreOffset := TRUE;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 11;
		END_IF
	11:	//MoveToTarget ready? -> MoveZ down rel (HandingOffsetZ)
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_Relative;
				stPoint1 := ppHElectrCapRack^.P_stHandingOffset;
				stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z);
				stActionData.aParams[3] := 5000; //MoveSpeed
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					nActionState := 99;
				ELSE
					nActionState := 12;
				END_IF		
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
	12:	//MoveZ ready? -> MoveZ up rel (0,5mm)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := 1000;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 13;
			END_IF
		END_IF		
	13:	//MoveZ ready? -> MoveXY at neg. HandlingOffset XY
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stPoint1 := ppHElectrCapRack^.P_stHandingOffset;
			stActionData.aParams[2] := -REAL_TO_DINT(stPoint1.X);
			stActionData.aParams[3] := -REAL_TO_DINT(stPoint1.Y);
			stActionData.aParams[4] := 10000; //SpeedX
			stActionData.aParams[5] := 10000; //SpeedY
			stActionData.aParams[6] := 1; //nicht freifahren 
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 14;
			END_IF
		END_IF
	14:	//MoveXY ready? -> MoveZ up at OverlapTool
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := REAL_TO_DINT(pPiece^.P_rZOverlapTool);
			stActionData.aParams[3] := 5000; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 15;
			END_IF
		END_IF
	15:	//MoveZ ready? -> MoveZ home
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 16;
			END_IF
		END_IF
	16:	//MoveZ-Home ready -> Piece zuordnen -> ACTION ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			//Piece von MzTool auf Rack übertragen
			stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,ppHElectrCapRack,pPieceSlot^.nNr);
			pPiece^.P_bIgnoreOffset := FALSE;
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;	
			END_IF
		END_IF		
	(*********************End Drop***************************)
	
	70:	//Action abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);		
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			nActionState := 80;
		END_IF	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	pPiece^.P_bIgnoreOffset := FALSE;
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangepHCap;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeSeptum" Id="{256d2556-f874-434e-b583-1e865fe9c0f6}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
ELSE
	IF pReactor > 0 THEN
		IF pReactor^.P_bError THEN
			stError.ObjectId := pReactor^.P_nObjectID;
			stError.ErrorId := pReactor^.P_nErrorId;
			nActionState := 99;
		END_IF
	END_IF	
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	
		nActionState := 5;
		nExchangePieceCnt := 0;
		nExchangePieceCnt2 := 0;
		timer1(IN:= FALSE);
		//Prepare
		//Druck
		//Reactor öffnen
		//Überprüfen, ob VialKlemme zu bzw prüfen, ob Vial im Slot
		//VialDetection
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			pReactor := pTarget;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_DetectVial;
			stActionData.aParams[1] := E_OpClState.Closed;
			stError.ErrorId := pReactor^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pReactor^.P_nObjectID;
				nActionState := 99;
			ELSE
				nActionState := 1;
			END_IF		
		END_IF
		
		IF nActionState <> 99 THEN
			//Hier kann die XY-Zustellung bereits angestoßen werden
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			//stActionData.bIntern := TRUE;
			stActionData.eAction := E_Action.ACTION_MoveToTarget;
			stActionData.nObject := pMzTool^.P_nObjectID;
			stActionData.nTarget := pTarget^.P_nObjectID;
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SeptumWaste THEN
				stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
				stActionData.aParams[2] := 1;
			ELSE
				stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
				stActionData.aParams[2] := pSlot^.nNr;
			END_IF
			stActionData.aParams[3] := 0;
			stActionData.aParams[5] := -1;	//MaxSpeed X
			stActionData.aParams[6] := -1;	//MaxSpeed Y
			stActionData.aParams[7] := 0;	//MaxSpeed Z
			
			stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				fbMoveToTarget(bExecute:= TRUE);
				IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN //PneuChannel vorbereiten
					pTriplePip := pMzTool;
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					//stActionData.bIntern := TRUE;
					
					IF bTakePiece THEN
						stActionData.eAction := E_Action.ACTION_SetVacuum;
						stActionData.aParams[1] := 1; //Fertigmeldung wenn Solldruck erreicht
						stActionData.aParams[2] := -80; //Value in kPa
						stActionData.aParams[3] := 5; //Toleranz
						stActionData.aParams[4] := 5; //Toleranz
						stActionData.aParams[5] := 10000; //Timeout in ms
					ELSE
						stActionData.eAction := E_Action.ACTION_SetPressure;
						stActionData.aParams[1] := 1; //Fertigmeldung wenn Solldruck erreicht
						stActionData.aParams[2] := 200; //Value in kPa
						stActionData.aParams[3] := 10; //Toleranz
						stActionData.aParams[4] := 10; //Toleranz
						stActionData.aParams[5] := 10000; //Timeout in ms
					END_IF
		
					stError.ErrorId :=  pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						stError.ObjectId := pMzTool^.P_nObjectID;
						nActionState := 99;
					ELSE
						//Ventil aus falls noch an
						IF bTakePiece THEN
							MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
							stActionData.eAction := E_Action.ACTION_SwitchPressure;
							stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
							stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
							IF stError.ErrorId > 0 THEN
								stError.ObjectId := pMzTool^.P_nObjectID;
								nActionState := 99;
							ELSE
								nActionState := 1;	
							END_IF
						ELSE
							nActionState := 1;
						END_IF
					END_IF
				END_IF
			END_IF			
		END_IF
		
	1:	//Prepare ready?
		nActionState := 5;
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			nActionState := 2;
			IF pReactor^.M_GetActionBusy(E_Action.ACTION_DetectVial) THEN
				nActionState := 1;
			END_IF
		END_IF
		
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN //Vacuum OK?
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
				nActionState := 1;
			END_IF
		END_IF
		
	2:	//Auswertung VialDetection
		IF NOT pReactor^.P_bVialInSlot THEN
			stError.ErrorId := E_ErrorIdCmd.ERRORID_NoVialInReactor;
			stError.ObjectId := pReactor^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 3;
		END_IF
		
	3:	//Open Reactor
		nActionState := 4;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_ReactorOpCl;
		stActionData.aParams[1] := E_ReactDrive.CoverBoth;
		stActionData.aParams[2] := E_OpClCtrl.Open;
		stError.ErrorId := pReactor^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pReactor^.P_nObjectID;
			nActionState := 99;
		END_IF			
		
	4:	//Reactor open? -> Close Clamp
		IF NOT pReactor^.M_GetActionBusy(E_Action.ACTION_ReactorOpCl) THEN
			nActionState := 5;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_ReactorOpCl;
			stActionData.aParams[1] := E_ReactDrive.Clamp;
			stActionData.aParams[2] := E_OpClCtrl.Close;
			stError.ErrorId := pReactor^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pReactor^.P_nObjectID;
				nActionState := 99;
			END_IF			
		END_IF
	
	5:	//MoveToTarget zu SeptumWaste bzw. ReactorSlot
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
				fbMoveToTarget(bExecute:= FALSE);
			ELSE
				fbMoveToTarget(bExecute:= FALSE);
				
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				//stActionData.bIntern := TRUE;
				stActionData.eAction := E_Action.ACTION_MoveToTarget;
				stActionData.nObject := pMzTool^.P_nObjectID;
				stActionData.nTarget := pTarget^.P_nObjectID;
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SeptumWaste THEN
					stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
					stActionData.aParams[2] := 1;
				ELSE
					stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
					stActionData.aParams[2] := pSlot^.nNr;
				END_IF
				stActionData.aParams[3] := 0;
				stActionData.aParams[5] := -1;	//MaxSpeed X
				stActionData.aParams[6] := -1;	//MaxSpeed Y
				stActionData.aParams[7] := -1;	//MaxSpeed Z
				IF bTakePiece THEN
					IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
						stActionData.aParams[8] := -3000;	//OffsetX (Einstechen Needle außerhalb Mitte)
					ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
						stActionData.aParams[10] := - 800; //Offset Z (Anpressdruck)
					END_IF
				ELSE
					IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
						stActionData.aParams[10] := - REAL_TO_DINT(pPiece^.P_rZOverlapSlot); //OffsetZ 				
					END_IF
				END_IF
				stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					stError.ObjectId := pMzTool^.P_nObjectID;
					nActionState := 99;
				ELSE
					fbMoveToTarget(bExecute:= TRUE);
					nActionState := 6;
				END_IF
			END_IF
		END_IF

	6:	//MoveToTarget ready? -> Übergabe
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF bTakePiece THEN
					nActionState := 7;
				ELSE
					nActionState := 14;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	7:	//Übergabe Take
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
			//Vacuum zuschalten
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_VacOn;
			nActionState := 8;
		ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
			//Needle einstechen
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stDimension := pPiece^.P_stDimension;
			stActionData.aParams[2] := -(REAL_TO_DINT(stDimension.Height) + 2000);
			stActionData.aParams[3] := 2000; //Speed
			nActionState := 10;
		END_IF
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		END_IF

	8:	//Zeit warten bis Vaccum sich eingestellt hat
		timer1(IN:= TRUE, PT:=T#1S);
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			nActionState := 9;
		END_IF
	
	9:	//Vacuum OK ?
		//Hier sollte definitiv ein Timeout eingebaut werden
		//bei Timeout 0,5mm MoveZ nach unten
		//Das max. 2x durchführen
		IF pTriplePip^.M_GetVacuumOk(nSetPressValue:= pTriplePip^.P_nHoldVacSept, nSetPressTolPlus:= 0, nSetPressTolMin := 99) THEN
			timer1(IN:= FALSE);
			nActionState := 11;	//Weiter zu Anheben
			nExchangePieceCnt := 0;
		ELSE
			timer1(IN:= TRUE, PT:=T#2S);
			IF timer1.Q THEN
				timer1(IN:= FALSE);
				nExchangePieceCnt := nExchangePieceCnt + 1;
				IF nExchangePieceCnt > 2 THEN
					stError.ObjectId := pMzTool^.P_nObjectID;
					nActionState := 99;
				ELSE
					nActionState := 55;	//Weiter zu Anheben
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Relative;
					stActionData.aParams[2] := REAL_TO_DINT(rSumDockOffset);
					stActionData.aParams[3] := 2000; //Speed
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN	//Error
						stError.ObjectId := pMzTool^.P_nObjectID;
						nActionState := 99;
					END_IF
				END_IF
			END_IF
		END_IF
		
	55: //Anheben ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 8;
		END_IF
	
	10:	//MoveZ ready? -> Anheben
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 11;	//Weiter zu Anheben
		END_IF
	
	11:	//Anheben
		nActionState := 12;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := 4000; //5mm anheben
		stActionData.aParams[3] := 2000; //Speed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		END_IF
	
	12:	//Anheben ready? -> MoveZ-Free
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
				//Ist Septum noch dran?
				IF pTriplePip^.M_GetVacuumOk(nSetPressValue:= pTriplePip^.P_nHoldVacSept + 15, nSetPressTolPlus:= 0, nSetPressTolMin := 99) THEN
					nActionState := 30;
				ELSE
					nActionState := 5;
					nExchangePieceCnt2 := nExchangePieceCnt2 + 1;
					IF nExchangePieceCnt2 > 2 THEN
						stError.ObjectId := pMzTool^.P_nObjectID;
						nActionState := 99;
					END_IF
				END_IF
			ELSE
				nActionState := 30;
			END_IF
		END_IF
	
	14:	//Übergabe Drop
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
			//Vacuum abschalten
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := 2; //Channel
			stActionData.aParams[2] := E_PressCtrl.PRESSCTRL_Off;
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				stActionData.eAction := E_Action.ACTION_SetPressure;
				stActionData.aParams[1] := 2; //Channel
				stActionData.aParams[2] := 0; //Sofortige Fertigmeldung
				stActionData.aParams[3] := 0; //Druck
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.ObjectId := pMzTool^.P_nObjectID;
					nActionState := 99;
				ELSE
					nActionState := 15;	
				END_IF
			END_IF
		ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
			//MoveXY zu WastePoint2
			stPoint1 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1 := 2,nParam2 := 0,nParam3 := 0,nZLevel:=0);
			stActionData.eAction := E_Action.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.X); //XPos 
			stActionData.aParams[3] := REAL_TO_DINT(stPoint1.Y); //YPos
			stActionData.aParams[4] := -1; //XSpeed 
			stActionData.aParams[5] := -1; //YSpeed
			stActionData.aParams[6] := 1; //IngnoreZCollision
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);	
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				nActionState := 19;
			END_IF
		END_IF
		
	15:	//Zeit warten (Drop TriplePip)
		timer1(IN:= TRUE, PT:=T#1S);
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			nActionState := 16;
		END_IF
		
	16:	//DruckImpuls 1s und gleichzeitig 1mm nach oben (Drop TriplePip)
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		stActionData.aParams[1] := 1; //Channel
		stActionData.aParams[2] := E_PressCtrl.PRESSCTRL_PressOn;
		stActionData.aParams[3] := 2000; //Zeit in ms
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;		
		ELSE
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := 2000; //5mm anheben
			stActionData.aParams[3] := 1000; //Speed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;		
			ELSE
				nActionState := 17;		
			END_IF
		END_IF
		
	17: //DruckImpuls und ZMove fertig (Drop TriplePip)
		IF NOT (pMzTool^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) OR pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ))THEN
			nActionState := 30; //MoveFree	
		END_IF
		
	19:	//MoveXY ready? (Drop Luer in SeptumWaste) -> Abziehen
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 20; //Abziehen	
		END_IF
		
	20:	//Abziehen (Drop Luer in SeptumWaste)
		nActionState := 21;
		//Septum auf Target übertragen, damit mit Needle auf Oberkante SeptumWaste gefahre werden kann
		stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,0);
		IF stError.ErrorId = 0 THEN
			stPoint1 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_Center,0,0,0,0);
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z);
			stActionData.aParams[3] := 2000; //Speed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		ELSE
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		END_IF
	
	21:	//Abziehen ready? (Drop Luer in SeptumWaste) -> MoveZ-Free
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 30;	
		END_IF
	
	30:	//MoveZ-Free und wenn Reactor, Open Clamp
		nActionState := 31;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_ReactorOpCl;
				stActionData.aParams[1] := E_ReactDrive.Clamp;
				stActionData.aParams[2] := E_OpClCtrl.Open;
				stError.ErrorId := pReactor^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.ObjectId := pReactor^.P_nObjectID;
					nActionState := 99;
				END_IF
			END_IF
		END_IF

	31:	//MoveZ-Free ready? -> Piece zuordnen -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
			IF bTakePiece THEN
				IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
				ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool^.P_pPiece,0);
				END_IF
			ELSE
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pReactor^.P_pVial,0);
					nActionState := 32;
				ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SeptumWaste THEN
					//pPiece^.M_SetParent(pTarget^,0);
					;
				ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SeptumRack THEN
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pSlot^.P_nNr);
				END_IF
			END_IF
			IF stError.ErrorId > 0 THEN
				nActionState := 99;	
			END_IF
		END_IF
	
	32:	//Reactor ready?
		IF NOT pReactor^.M_GetActionBusy(E_action.ACTION_ReactorOpCl) THEN
			nActionState := 80;
		END_IF
	
	70:	//Abbrechen
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip AND bTakePiece THEN
			nActionState := 71;
		ELSE
			nActionState := 80;
		END_IF
		
		//Actionen der beteiligten Decvices abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
				nActionState := 70;
			END_IF
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SetPressure);
		END_IF

		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SetVacuum);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SwitchPressure);
		END_IF
		
		IF pReactor > 0 THEN
			IF pReactor^.M_GetActionBusy(E_action.ACTION_ReactorOpCl) THEN
				pReactor^.M_CancelAction(E_action.ACTION_ReactorOpCl);
				nActionState := 70;
			ELSIF pReactor^.M_GetActionBusy(E_action.ACTION_DetectVial) THEN
				pReactor^.M_CancelAction(E_action.ACTION_DetectVial);
				nActionState := 70;
			END_IF
		END_IF
		
	71:	//Vacuum OFF (nur wenn TriplePip und Take)
		nActionState := 80;
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId = 0 THEN
			stActionData.eAction := E_Action.ACTION_SetVacuum;
			stActionData.aParams[1] := 0; //Sofortige Fertigmeldung
			stActionData.aParams[2] := 0; //Druck
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip AND bTakePiece THEN
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
		pMzTool^.M_ExeAction(stActionData);
		stActionData.eAction := E_Action.ACTION_SetPressure;
		stActionData.aParams[1] := 0; //Sofortige Fertigmeldung
		stActionData.aParams[2] := 0; //Druck
		pMzTool^.M_ExeAction(stActionData);
		stActionData.eAction := E_Action.ACTION_SetVacuum;
		stActionData.aParams[1] := 0; //Sofortige Fertigmeldung
		stActionData.aParams[2] := 0; //Druck
		pMzTool^.M_ExeAction(stActionData);
		
	END_IF
	pPiece^.P_bIgnoreOffset := FALSE;
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeSeptum;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeStamp" Id="{5051ce3a-34cf-46cb-bcc4-f104e98da64a}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pStampSupport^.P_bError THEN
	stError.ErrorId := pStampSupport^.P_nErrorId;
	nActionState := 99;
END_IF

IF pStampSupport^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	
		nActionState := 1;
		pPiece^.P_bIgnoreOffset := TRUE;
		//MoveToTarget auf CheckPosition Magazin //nur in XY
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pStampSupport^.P_nObjectID;
		stActionData.nTarget := pStampMagazine^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := 0;	//MaxSpeed Z
		stPoint1 := pStampMagazine^.P_stOffsetStampDetect;
		stActionData.aParams[8] := REAL_TO_DINT(stPoint1.X); //OffsetX
		stActionData.aParams[9] := REAL_TO_DINT(stPoint1.Y); //-45000; //OffsetY
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		
		IF stError.ErrorId > 0 THEN	//Error
			stError.POUState := nActionState;
			nActionState := 99;
		ELSE
			//Wenn bTakePiece, dann Entriegeln, fall noch verriegelt
			IF bTakePiece AND pStampSupport^.P_bLocked THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_LockUnlock;
				stActionData.aParams[1] := 0;	//Öffnen
				stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					nActionState := 99;
				END_IF
			END_IF
			IF nActionState <> 99 THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_SwitchPressure;
				stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		IF nActionState = 1 THEN
			fbMoveToTarget(bExecute:= TRUE);
		END_IF
		
	1:	//Winkelverstellung auf "0"
		nActionState := 2;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_StampAdjust;
		stActionData.aParams[1] := 0;	//Winkel
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.POUState := nActionState;
			nActionState := 99;
		END_IF
		IF nActionState = 2 THEN
			fbMoveToTarget(bExecute:= TRUE);
		END_IF		
		
	2:	//MoveToTarget, Entriegelung und Adjustment ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT (pStampSupport^.M_GetActionBusy(E_Action.ACTION_LockUnlock) OR 
				pStampSupport^.M_GetActionBusy(E_Action.ACTION_StampAdjust)OR
				fbMoveToTarget.bBusy) THEN
			fbMoveToTarget(bExecute:= FALSE);
			nActionState := 3;
			//Z-Positionierung auf Sensorhöhe
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stPoint1 :=  pStampMagazine^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_Slot,
														nParam1 := UINT_TO_USINT(pPieceSlot^.nNr),
														nParam2 := 0,
														nParam3 := 0,
														nZLevel := 0);
			stPoint2 := pStampMagazine^.P_stOffsetStampDetect;														
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z + stPoint2.Z);
			stActionData.aParams[3] := -1; //SpeedZ
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
		
	3:	//MoveZ ready?
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 4;
			IF bTakePiece THEN
				IF NOT pStampSupport^.P_bStampInMagazine THEN //Error, kein Stempel erkannt
					stError.ErrorId := E_ErrorIdCmd.ERRORID_NoPieceInSlot;
					nActionState := 99;
				END_IF
			ELSE
				IF pStampSupport^.P_bStampInMagazine THEN //Error, da bereits Stempel im Magazin
					stError.ErrorId := E_ErrorIdCmd.ERRORID_PieceAlreadyInSlot;
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		
	4:	//MoveToTarget auf ExchangePosition Magazine
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pStampSupport^.P_nObjectID;
		stActionData.nTarget := pStampMagazine^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 5;
		END_IF
		
	5:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 6;	//Z-Zustellung	
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF

	6:	//MoveZ auf Übergabeposition
		nActionState := 7;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[3] := 5000; //SpeedZ
		IF bTakePiece THEN //Take - um ZOffsetUnlocked abzuglich OverlapTool nach unten fahren 
			stActionData.aParams[2] := REAL_TO_DINT(pStampSupport^.P_rZOffsetUnlocked + pPiece^.P_rZOverlapTool + 2000); 
		ELSE //Drop - um OverlapSlot von Stamp nach unten fahren
			stActionData.aParams[2] := REAL_TO_DINT(-pPiece^.P_rZOverlapSlot) + 800;	
		END_IF
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
		
	7:	//Übergabeposition erreicht?
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 8;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_LockUnlock;
			IF bTakePiece THEN
				stActionData.aParams[1] := 1;	//Verriegeln		
			END_IF
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF

	8:	//StampLock/Unlock ready?
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_LockUnlock) THEN
			IF bTakePiece THEN	//sofort freifahren
				nActionState := 11;	
			ELSE //3mm langsam nach oben fahren
				nActionState := 9;
			END_IF
		END_IF
		
	9:	//MoveZ langsam 
		nActionState := 10;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := 3000;
		stActionData.aParams[3] := 5000;	//MaxSpeed
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
		
	10:	//MoveZ ready?
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 11;
		END_IF
		
	11:	//MoveZ-Free
		nActionState := 12;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1;	//MaxSpeed
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
		
	12:	//MoveZ-Free ready? -> Piece zuordnen -> Action ready
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
			IF bTakePiece THEN
				//Piece von Magazin auf Support übertragen
				IF pStampSupport^.P_bStampInSupport THEN
					//das letze Slot ermitteln
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pStampSupport,pStampSupport^.P_nNumberOfSlots);
				ELSE //Take fehlgeschlagen, weil Stamp nicht im Support detektierbar
					stError.ErrorId := E_ErrorIdCmd.ERRORID_PieceExchangeFailed;
				END_IF
			ELSE //Drop
				//Piece von Support auf Magazin übertragen
				IF pStampSupport^.P_bStampInSupport THEN //Drop fehlgeschlagen, weil weil Stamp noch im Support detektierbar
					stError.ErrorId := E_ErrorIdCmd.ERRORID_PieceExchangeFailed;
					nActionState := 99;
				ELSE
					stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pPieceSlot^.nNr);
				END_IF
			END_IF
			pPiece^.P_bIgnoreOffset := FALSE;
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;		
			END_IF
		END_IF
		
	70:	//Action abbrechen
		nActionState := 80;
		pPiece^.P_bIgnoreOffset := FALSE;
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSIF pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_LockUnlock) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_LockUnlock);
			nActionState := 70;
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_StampAdjust) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_StampAdjust);
			nActionState := 70;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	pPiece^.P_bIgnoreOffset := FALSE;
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pStampSupport^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeStamp;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeTip" Id="{de90b719-326e-4176-9e18-63ba27c1803e}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf Slot
		nActionState := 1;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		
		IF NOT bTakePiece THEN //Drop
			stDimension :=  pPiece^.P_stDimension;
			stActionData.aParams[10] := - REAL_TO_DINT(stDimension.Height - pPiece^.P_rZOverlapTool);
		END_IF
		
		pPiece^.P_bIgnoreOffset := TRUE;
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF		
		
	1:	//MoveToTarget ready? -> MoveZ bei Take bzw Eject bei Drop
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF bTakePiece THEN //Take
					//Z-Zustellung um OverlapTool und SumDockOffset
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Relative;
					stActionData.aParams[2] := REAL_TO_DINT(pPiece^.P_rZOverlapTool * -1 + rSumDockOffset);
					stActionData.aParams[3] := 4000; //MoveSpeed
				ELSE
					stActionData.eAction := E_Action.ACTION_Eject;
				END_IF
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					nActionState := 99;
				ELSE
					nActionState := 2;
				END_IF		
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//MoveZ bzw Eject ready? -> MoveZ-Home
		IF NOT (pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) OR pMzTool^.M_GetActionBusy(E_Action.ACTION_Eject)) THEN
			nActionState := 3;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
		
	3:	//MoveZ-Home ready -> Piece zuordnen -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF bTakePiece THEN
				//Piece von NeedleRack auf MzTool übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
			ELSE
				//Piece von MzTool auf Rack übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pPieceSlot^.nNr);
				//Offset von Piece löschen
				stPoint1.X := 0;
				stPoint1.Y := 0;
				stPoint1.Z := 0;
				pPiece^.P_stOffset := stPoint1;
				//Tip als "used" kennzeichnen
				pTip := pPiece;
				pTip^.P_bUsed := TRUE;
				fbObjectDirectory.M_SetObjChange(pPiece^.P_nObjectID);
			END_IF
			pPiece^.P_bIgnoreOffset := FALSE;
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;		
			END_IF
		END_IF
 		
	70:	//Action abbrechen
		pPiece^.P_bIgnoreOffset := FALSE;
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			nActionState := 80;
		END_IF		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	pPiece^.P_bIgnoreOffset := FALSE;
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeTip;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeVial" Id="{2b5222c3-c230-4afc-a2e5-af790b6b06ef}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
ELSE
	IF pReactor > 0 THEN
		IF pReactor^.P_bError THEN
			stError.ObjectId := pReactor^.P_nObjectID;
			stError.ErrorId := pReactor^.P_nErrorId;
			nActionState := 99;
		END_IF
	END_IF	
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Prepare
		//Druck
		//Reactor öffnen
		//Überprüfen, ob VialKlemme zu bzw prüfen, ob Vial im Slot
		//VialDetection
		nActionState := 5;
		timer1(IN:= FALSE);
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			pReactor := pTarget;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_DetectVial;
			stActionData.aParams[1] := E_OpClState.Open;
			
			stError.ErrorId := pReactor^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pReactor^.P_nObjectID;
				nActionState := 99;
			ELSE
				nActionState := 1;	
			END_IF			
		END_IF
		
		IF nActionState <> 99 THEN
			//Hier kann die XY-Zustellung bereits angestoßen werden
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			//stActionData.bIntern := TRUE;
			stActionData.eAction := E_Action.ACTION_MoveToTarget;
			stActionData.nObject := pMzTool^.P_nObjectID;
			stActionData.nTarget := pTarget^.P_nObjectID;
			stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
			stActionData.aParams[2] := pPieceSlot^.nNr;
			stActionData.aParams[3] := 0;
			stActionData.aParams[5] := -1;	//MaxSpeed X
			stActionData.aParams[6] := -1;	//MaxSpeed Y
			stActionData.aParams[7] := 0;	//MaxSpeed Z
			stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN //PneuChannel vorbereiten
					pTriplePip := pMzTool;
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_SetVacuum;
					IF bTakePiece THEN
						stActionData.aParams[1] := 1; //Fertigmeldung wenn Solldruck erreicht
						stActionData.aParams[2] := -80; //Value in kPa
						stActionData.aParams[3] := 5; //Toleranz
						stActionData.aParams[4] := 5; //Toleranz
						stActionData.aParams[5] := 10000; //Timeout in ms
						stError.ErrorId :=  pMzTool^.M_ExeAction(stActionData);
						IF stError.ErrorId > 0 THEN
							stError.ObjectId := pMzTool^.P_nObjectID;
							nActionState := 99;
						ELSE
							//Ventil aus falls noch an
							MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
							stActionData.eAction := E_Action.ACTION_SwitchPressure;
							stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
							stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
							IF stError.ErrorId > 0 THEN
								stError.ObjectId := pMzTool^.P_nObjectID;
								nActionState := 99;
							ELSE
								nActionState := 1;
							END_IF
						END_IF
					ELSE
						nActionState := 1;
					END_IF
				END_IF				
			END_IF
		END_IF
		IF nActionState = 1 THEN
			fbMoveToTarget(bExecute:= TRUE);
		END_IF
 		
	1:	//Prepare ready?
		nActionState := 5;
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			nActionState := 2;
			IF pReactor^.M_GetActionBusy(E_Action.ACTION_DetectVial) THEN
				nActionState := 1;
			END_IF
		END_IF
		
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN //Vacuum OK?
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
				nActionState := 1;
			END_IF
		END_IF
		
	2:	//Auswertung VialDetection
		nActionState := 3;
		IF bTakePiece THEN
			IF NOT pReactor^.P_bVialInSlot THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_NoVialInReactor;
				nActionState := 99;
			END_IF
		ELSE
			IF pReactor^.P_bVialInSlot THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_VialAlreadyInReactor;		
				nActionState := 99;
			END_IF
		END_IF
		
	3:	//Open Reactor
		nActionState := 4;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_ReactorOpCl;
		stActionData.aParams[1] := E_ReactDrive.CoverBoth;
		stActionData.aParams[2] := E_OpClCtrl.Open;
		stError.ErrorId := pReactor^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pReactor^.P_nObjectID;
			nActionState := 99;
		END_IF			
		
	4:	//Reactor open?
		IF NOT pReactor^.M_GetActionBusy(E_Action.ACTION_ReactorOpCl) THEN
			nActionState := 5;
		END_IF
	
	5:	//MoveToTarget Slot
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
				fbMoveToTarget(bExecute:= FALSE);
			ELSE
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveToTarget;
				stActionData.nObject := pMzTool^.P_nObjectID;
				stActionData.nTarget := pTarget^.P_nObjectID;
				stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
				stActionData.aParams[2] := pPieceSlot^.nNr;
				stActionData.aParams[3] := 0;
				stActionData.aParams[5] := -1;	//MaxSpeed X
				stActionData.aParams[6] := -1;	//MaxSpeed Y
				stActionData.aParams[7] := -1;	//MaxSpeed Z
				IF bTakePiece THEN
					stActionData.aParams[10] := REAL_TO_DINT(rSumDockOffset);
				END_IF
				fbMoveToTarget(bExecute:= FALSE);
				stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					stError.ObjectId := pMzTool^.P_nObjectID;
					nActionState := 99;
				ELSE
					fbMoveToTarget(bExecute:= TRUE);
					nActionState := 6;
				END_IF
			END_IF
		END_IF
	
	6:	//MoveToTarget ready? -> Übergabe
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF bTakePiece THEN
					nActionState := 7;
				ELSE
					nActionState := 10;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	7:	//Übergabe Take
		nActionState := 8;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		//Vacuum zuschalten
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_VacOn;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		END_IF
		
	8:	//Zeit warten
		timer1(IN:= TRUE, PT:=T#1S);
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			nActionState := 9;
		END_IF
		
	9:	//Vaccum OK ? -> MoveZ-Free
		IF pTriplePip^.M_GetVacuumOk(nSetPressValue:= pTriplePip^.P_nHoldVacVial, nSetPressTolPlus:= 0, nSetPressTolMin := 99) THEN
			nActionState := 13;
		END_IF
		
	10:	//Übergabe Drop
		//MoveZ relativ um Slot-Tiefe abzüglich 1mm
		nActionState := 11;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := -(REAL_TO_DINT((pPieceSlot^.P_rDepth - 1000)));
		stActionData.aParams[3] := 20000; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		END_IF
	
	11:	//MoveZ ready? -> MoveX 1mm zum lösen vom Vial, Vacuum Off
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 12;
			//Move 1mm in X, damit Vial sich vom Tool löst
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveX;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := 500;
			stActionData.aParams[3] := 10000; //MoveSpeed
			stActionData.aParams[4] := 1; //Ignore Collision
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				//Vacuum OFF
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_SwitchPressure;
				stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
				stError.ErrorId :=  pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.ObjectId := pMzTool^.P_nObjectID;
					nActionState := 99;
				ELSE
					//Set Vacuum "0"
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_SetVacuum;
					stActionData.aParams[1] := 0; //Fertigmeldung sofort
					stActionData.aParams[2] := 0; //Value in kPa
					stError.ErrorId :=  pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						stError.ObjectId := pMzTool^.P_nObjectID;
						stError.POUState := nActionState;
						nActionState := 99;
					END_IF
				END_IF
			END_IF
		END_IF
		
	12:	//MoveX ready? -> MoveZ 1mm nach oben
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			nActionState := 13;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := 500; //0,5mm nach oben
			stActionData.aParams[3] := 1000; //MoveSpeed
			stError.ErrorId :=  pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
		
	13:	//MoveZ-Free
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MoveSpeed
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
			nActionState := 14;
		END_IF

	14:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF bTakePiece THEN	//Vial von Target auf MzTool übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
				pVial := pPiece;
				pVial^.P_bUsed := TRUE;
				fbObjectDirectory.M_SetObjChange(pPiece^.P_nObjectID);
			ELSE	//Vial von MzTool auf Target übertragen
				stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pPieceSlot^.nNr);
			END_IF
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;		
			END_IF
		END_IF
		
	70:	//Abbrechen
		IF NOT bTakePiece THEN
			nActionState := 71;
		ELSE
			nActionState := 80;
		END_IF
	
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveX);
			nActionState := 70;
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SetVacuum);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SwitchPressure);
		END_IF
		
		IF pReactor > 0 THEN
			IF pReactor^.M_GetActionBusy(E_action.ACTION_ReactorOpCl) THEN
				pReactor^.M_CancelAction(E_action.ACTION_ReactorOpCl);
				nActionState := 70;
			ELSIF pReactor^.M_GetActionBusy(E_action.ACTION_DetectVial) THEN
				pReactor^.M_CancelAction(E_action.ACTION_DetectVial);
				nActionState := 70;
			END_IF
		END_IF	
	
	71:	//Vacuum OFF (nur wenn Take)
		nActionState := 80;
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId = 0 THEN
			stActionData.eAction := E_Action.ACTION_SetVacuum;
			stActionData.aParams[1] := 0; //Sofortige Fertigmeldung
			stActionData.aParams[2] := 0; //Druck
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	IF bTakePiece THEN
		stActionData.eAction := E_Action.ACTION_SwitchPressure;
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off;
		pMzTool^.M_ExeAction(stActionData);
		stActionData.eAction := E_Action.ACTION_SetVacuum;
		stActionData.aParams[1] := 0; //Sofortige Fertigmeldung
		stActionData.aParams[2] := 0; //Druck
		pMzTool^.M_ExeAction(stActionData);
	END_IF
	pPiece^.P_bIgnoreOffset := FALSE;
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeVial;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_ExchangeVialGripper" Id="{be5abbc5-950d-46c0-8403-fff2b2635fe6}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
ELSE
	IF pPowderStation > 0 AND_THEN pTarget = pPowderStation THEN
		IF pPowderStation^.P_bError THEN
			stError.ObjectId := pPowderStation^.P_nObjectID;
			stError.ErrorId := pPowderStation^.P_nErrorId;
			nActionState := 99;
		END_IF
	ELSIF pReactor > 0 AND_THEN pTarget = pReactor THEN
		IF pReactor^.P_bError THEN
			stError.ObjectId := pReactor^.P_nObjectID;
			stError.ErrorId := pReactor^.P_nErrorId;
			nActionState := 99;
		END_IF
	END_IF
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Move free für Gripper-Test
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
		
	1:	//Move free ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			//Gripper vorbereiten bzw. checken, ob State zur Belegung des VialSlots passt.
			//Auch bei TakePiece muss zuerst geschlosse werden, da ja aus irgendwelchen Gründen
			//noch ein Vial im Greifer sein kann und das Vial womöglich auf die Workplate falle würde
			stError.ErrorId := pGripper^.M_OpenClose(E_OpClCtrl.Close, FALSE);
			IF stError.ErrorId = 0 THEN
				nActionState := 2;
			ELSE
				nActionState := 99;
			END_IF			
		END_IF
	
	2:	//Gripper ready?
		IF NOT pGripper^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			IF bTakePiece THEN
				//Muss vollständig geschlossen sein, was bedeutet, dass sich kein Vial im Gripper befindet
				IF pGripper^.P_eCurrentGripperState = E_GripperState.FullyClosed THEN
					//wieder öffnen
					stError.ErrorId := pGripper^.M_OpenClose(E_OpClCtrl.Open, FALSE);
					IF stError.ErrorId = 0 THEN
						nActionState := 3;
					ELSE
						nActionState := 99;	
					END_IF
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_ToolNotFreeOrBlocked;
					nActionState := 99;
				END_IF
			ELSE //Drop
				IF pGripper^.P_eCurrentGripperState = E_GripperState.HalfClosed THEN
					IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_PowderStation THEN
						nActionState := 10;
					 	
					ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
						nActionState := 20;
					ELSE
						nActionState := 30;
					END_IF
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_NoPieceOnTool;
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		
	3:	//Gripper ready?
		IF NOT pGripper^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			IF pGripper^.P_eCurrentGripperState = E_GripperState.Open THEN
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_PowderStation THEN
					nActionState := 10;
				ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
					nActionState := 20;
				ELSE
					nActionState := 30;
				END_IF
 			ELSE
				stError.ErrorId := E_ErrorIdCmd.ERRORID_CouldNotOpenGripper;
				nActionState := 99;
			END_IF
		END_IF
		
	10:	//PowderStation in ReloadPos fahren
		stActionData.eAction := E_Action.ACTION_PowdStatReload;
		stError.ErrorId := pPowderStation^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pPowderStation^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 11;
		END_IF
		
	11:	//RealoadPos ready?
		IF NOT pPowderStation^.M_GetActionBusy(E_Action.ACTION_PowdStatReload) THEN
			nActionState := 30;
		END_IF
		
	20: //Reaktor ist noch nicht implementiert
		stError.ErrorId := E_ErrorIdCmd.ERRORID_InvalidTarget;
		nActionState := 99;
		
	30:	//Wenn Drop, dann muss noch über den Vialdetector überprüft werden,
		//ob nicht schon ein Vial im Target steckt. Dazu muss also ein MoveToTarget
		//mit entsprechendem Offset gemacht werden.
		IF bTakePiece THEN
			nActionState := 32;
		ELSE
			//move zur Übergabe mit Offset und checken
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveToTarget;
			stActionData.nObject := pMzTool^.P_nObjectID;
			stActionData.nTarget := pTarget^.P_nObjectID;
			stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
			stActionData.aParams[2] := pPieceSlot^.nNr;
			stActionData.aParams[3] := 0;
			stActionData.aParams[5] := -1;	//MaxSpeed X
			stActionData.aParams[6] := -1;	//MaxSpeed Y
			stActionData.aParams[7] := -1;	//MaxSpeed Z
			stActionData.aParams[8] :=	0;	//Offset X
			stActionData.aParams[9] :=	-25500;	//Offset Y
			stActionData.aParams[10] :=	15000;	//Offset Z	
			stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pMzTool^.P_nObjectID;
				nActionState := 99;
			ELSE
				fbMoveToTarget(bExecute:= TRUE);
				nActionState := 31;
			END_IF
		END_IF
	
	31:	//MoveToTarget ready?
		fbMoveToTarget();
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF NOT pGripper^.P_bVialDetector THEN //Es befindet sich ein Vial im Target
					stError.ErrorId := E_ErrorIdCmd.ERRORID_PieceAlreadyInSlot;
					nActionState := 99;
				ELSE
					//Eigentlicher MoveToTarget
					nActionState := 32;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	32:	//MoveToTarget
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := 30000;	//Speed Z
		IF bTakePiece THEN
			stActionData.aParams[10] := -REAL_TO_DINT(pPiece^.P_rZOverlapTool);
		END_IF
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 33;
		END_IF
	
	33:	//MoveToTarget ready?
		fbMoveToTarget();
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF bTakePiece THEN
					nActionState := 40;
				ELSE //Drop
					nActionState := 42;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	40:	//Übergabe Take -> Close Gripper
		stError.ErrorId := pGripper^.M_OpenClose(E_OpClCtrl.Close, FALSE);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 41;
		END_IF
		
	41:	//Gripper closed? (HALF)
		IF NOT pGripper^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			IF pGripper^.P_eCurrentGripperState = E_GripperState.HalfClosed THEN
				nActionState := 50; //Move free
			ELSE
				stError.ErrorId := E_ErrorIdCmd.ERRORID_NoPieceTaken;
				nActionState := 99;
			END_IF
		END_IF
		
	42:	//Übergabe Drop ->MoveZ relativ um Slot-Tiefe abzüglich 1mm
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := -(REAL_TO_DINT((pPieceSlot^.P_rDepth - 1000)));
		stActionData.aParams[3] := 20000; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 43;
		END_IF
		
	43: //MoveZ ready? -> Open Gripper
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			stError.ErrorId := pGripper^.M_OpenClose(E_OpClCtrl.Open, FALSE);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 44;
			END_IF
		END_IF
		
	44:	//Gripper open?
		IF NOT pGripper^.M_GetActionBusy(E_Action.ACTION_OpenClose) THEN
			IF pGripper^.P_eCurrentGripperState = E_GripperState.Open THEN
				nActionState := 50; //Move free
			ELSE
				stError.ErrorId := E_ErrorIdCmd.ERRORID_NotFullyOpened;
				nActionState := 99;
			END_IF
		END_IF
		
	50:	//Move free
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1; //MoveSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 51;
		END_IF
		
	51:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			//Vial richtig angekommen? Geht nur bei Gripper, Reaktor oder bei PowderStation
			IF bTakePiece THEN
				IF pGripper^.P_eCurrentGripperState = E_GripperState.HalfClosed THEN
					nActionState := 60; //weiter zu Vial im OD verschieben
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_NoPieceTaken;
					nActionState := 99;
				END_IF
			ELSE //Drop
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
					//Hier muss die DetectAction noch ausgeführt werden
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_DetectVial;
					stActionData.aParams[1] := E_OpClState.Closed;
					stError.ErrorId := pReactor^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						stError.ObjectId := pReactor^.P_nObjectID;
						nActionState := 99;
					ELSE
						//nActionState := 15; //Überprüfung, ob Vial auch im Reaktor angekommen???
					END_IF
				ELSE
					nActionState := 60; //weiter zu Vial im OD verschieben
				END_IF
			END_IF
		END_IF
		
	60:	//Vial im OD verschieben
		IF bTakePiece THEN	//Vial von Target auf MzTool übertragen
			stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pMzTool,1);
			pVial := pPiece;
			//pVial^.P_bUsed := TRUE;
			fbObjectDirectory.M_SetObjChange(pPiece^.P_nObjectID);
		ELSE	//Vial von MzTool auf Target übertragen
			stError.ErrorId := fbObjectDirectory.M_MoveObject(pPiece,pTarget,pPieceSlot^.nNr);
		END_IF
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 80;		
		END_IF
	
	70:	//Abbrechen
		nActionState := 80;
		
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveX);
			nActionState := 70;
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		END_IF
		
		IF pReactor > 0 THEN
			IF pReactor^.M_GetActionBusy(E_action.ACTION_ReactorOpCl) THEN
				pReactor^.M_CancelAction(E_action.ACTION_ReactorOpCl);
				nActionState := 70;
			ELSIF pReactor^.M_GetActionBusy(E_action.ACTION_DetectVial) THEN
				pReactor^.M_CancelAction(E_action.ACTION_DetectVial);
				nActionState := 70;
			END_IF
		END_IF	

END_CASE

//Errorhandling
IF nActionState = 99 THEN
	pPiece^.P_bIgnoreOffset := FALSE;
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_ExchangePiece;
	stError.POUAction := E_POUACT.POUACT_A_ExchangeVialGripper;
	fbErrorList.M_Add(stError);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_GetPipSample" Id="{411b2e03-fc3b-4f77-9fa9-ac6299cd5cf1}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget zu Mtp in PrePos
		timer1(IN:= FALSE);
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
			stActionData.nObject := pTwinPiezoHolder^.P_pPiezoPipFirst^.P_nObjectID;
		ELSE
			stActionData.nObject := pMzTool^.P_nObjectID;	
		END_IF
		stActionData.nTarget := pMtp^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
		stActionData.aParams[2] := nCol;
		stActionData.aParams[3] := nRow;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF
		
	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF nQuantity2 > 0 THEN //AirGap
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_Aspirate;
					stActionData.aParams[1] := nQuantity2; //Quantity Airgap
					stActionData.aParams[2] := nFlow1;
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						nActionState := 99;
					ELSE
						nActionState := 2;
					END_IF
				ELSE
					nActionState := 4;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF	
		
	2: //AirGap ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_Aspirate) THEN
			IF nTime > 0 THEN
				timer1(IN:= TRUE, PT:= DWORD_TO_TIME(nTime));
				nActionState := 3;
			ELSE
				nActionState := 4;
			END_IF
		END_IF
		
	3:	//Delay elapsed?
		timer1();
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			nActionState := 4;
		END_IF
	
	4:	//Eintauchen in Well
		stPoint1 := pMtp^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_TwoDimArray, nParam1:= nCol, nParam2:= nRow,
									nParam3:= 1,nZLevel:= 1);			
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z);
		stActionData.aParams[3] := -1;
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 5;	
		END_IF
		
	5:	//Eintauchen ready? -> Aspirieren
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 6;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_Aspirate;
			stActionData.aParams[1] := nQuantity1;
			stActionData.aParams[2] := nFlow1;
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pMzTool^.P_nObjectID;
				stError.POUState := nActionState;
				nActionState := 99;
			ELSE
				IF bGetPipSample_ActivatePiezo THEN
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_DispenseDrops;
					stActionData.aParams[2] := 1; //Ein
					stActionData.aParams[5] := 1; //Skip valve move
					pMzTool^.M_ExeAction(stActionData);
				END_IF
			END_IF
		END_IF
		
	6:	//Aspirate ready? -> Delay
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_Aspirate) THEN
			IF nTime > 0 THEN
				timer1(IN:= TRUE, PT:= DWORD_TO_TIME(nTime));
				nActionState := 7;
			ELSE
				nActionState := 8;
			END_IF
		END_IF
	
	7:	//Delay elapsed? -> bei Piezo au Bypass sonst MoveZ_Free
		timer1();
		IF timer1.Q THEN
			timer1(IN:= FALSE);
			IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PiezoPip THEN
				nActionState := 8;
			ELSE
				nActionState := 10;
			END_IF
		END_IF
		
	8:	//Valve auf Bypass stellen
		IF bGetPipSample_SwitchBypass THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_DilMoveValve;
			stActionData.aParams[1] := 3; //Bypass-Position
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 9;	
			END_IF		
		ELSE
			nActionState := 10;
		END_IF
		
	9:	//Valve auf Bypass?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_DilMoveValve) THEN
			nActionState := 10;
		END_IF
	
	10:	//MoveZ-Free
		pMzTool^.M_CancelAction(E_Action.ACTION_DispenseDrops);
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1; //MaxSpeed Z
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pMzTool^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 11;
		END_IF
		
	11:	//MoveZ-Free ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
 		END_IF
		
	70:	//Abbrechen
		nActionState := 80;
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		ELSE
			fbMoveToTarget(bExecute := FALSE);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_Aspirate) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_Aspirate);
			nActionState := 70;
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_DilMoveValve) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_DilMoveValve);
			nActionState := 70;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_GetPipSample;
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.POUAction := E_POUACT.POUACT_A_GetPipSample;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_InsertTool" Id="{aedaf8f2-ada9-4e3f-863c-954f4394d794}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf Slot
		//Wenn aktuelle XY-Position des Tools mit der Position des Slots übereinstimmt(Tolerenz +-5µm)
		//muss kann MoveToTarget übersprungen werden
		//Hilfreich beim Anheben der Needle auf anderes Level ohne dass vorher herausgezogen wird
		stPoint1 := pMzTool^.P_stCurrentPosPhys;
		stPoint2 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef,nTargetCol,nTargetRow,0,0);
		IF ABS(stPoint1.X - stPoint2.X) <= 5.0 AND ABS(stPoint1.Y - stPoint2.Y) <= 5.0 THEN
			nActionState := 3; //-> EIntauchen
			RETURN;
		END_IF
 		
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := eTargetRef;
		stActionData.aParams[2] := nTargetCol;
		stActionData.aParams[3] := nTargetRow;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack THEN
			stActionData.aParams[8] := -4000;	//XOffset	
			stActionData.aParams[10] := 1000;	//ZOffset	
		END_IF
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF		
		
	1:	//MoveToTarget ready? (nur für FlipTube) (Deckel etwas weiter öffnen) MoveX
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack THEN //MoveX (Deckel öffnen)
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveX;
					stActionData.aParams[1] := E_MoveMode.MODE_Relative;
					stActionData.aParams[2] := 13000;
					stActionData.aParams[3] := 45000;
					stActionData.aParams[4] := 1;
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN	//Error
						nActionState := 99;
					ELSE
						nActionState := 2;	
					END_IF
				ELSE	//Eintauchen
					nActionState := 4;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//MoveX ready? (nur für FlipTube) (zur Mitte zurück)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveX;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := -9000; 
			stActionData.aParams[3] := 45000;
			stActionData.aParams[4] := 1;
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 3;
			END_IF
		END_IF
		
	3:	IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			nActionState := 4;
		END_IF

	4:	//Eintauchen
		//Eintauchen bis InsertLevel
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;;
		stActionData.aParams[3] := 10000; //Speed (wird ev. überschrieben durch reduzierte Eintauchgeschwindigkeit
		
		IF eTargetRef = E_TargetRef.TARGETREF_Slot THEN
			stPoint1 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef,nTargetCol,0,0,0);
			IF pPieceSlot^.P_pPiece > 0 THEN
				IF pPieceSlot^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_Vial OR pPieceSlot^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_VialClosed THEN
					pVial := pPieceSlot^.P_pPiece;
					IF nInsertLevel = 0 THEN
						stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + pVial^.P_nTopLevel;
						pMzTool^.P_nReducedMoveZDist := - pVial^.P_nTopLevel;
					ELSE
						stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + pVial^.P_nBottomLevel;
						pMzTool^.P_nReducedMoveZDist := - pVial^.P_nBottomLevel;
					END_IF
					IF pVial^.P_eObjectType = E_ObjectType.OBJECTTYPE_VialClosed OR pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TitrationTool THEN
						stActionData.aParams[3] := 10000;
						pMzTool^.P_nReducedMoveZSpeed := 10000;
					END_IF
				ELSIF pPieceSlot^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTube THEN
					pFlipTube := pPieceSlot^.P_pPiece;
					IF nInsertLevel = 0 THEN
						stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + pFlipTube^.P_nTopLevel;
					ELSE
						stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z) + pFlipTube^.P_nBottomLevel;
					END_IF
				END_IF
			END_IF
		ELSIF eTargetRef = E_TargetRef.TARGETREF_TwoDimArray THEN
			stPoint1 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef,nTargetCol,nTargetRow,0, nInsertLevel);
			stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z);
		END_IF
		
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 5;
		END_IF			
		
	5:	//MoveZ ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSE
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
				pMzTool^.M_CancelAction(E_Action.ACTION_MoveX);
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
			ELSE
				fbMoveToTarget(bExecute:= FALSE);
				nActionState := 80;
			END_IF
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_InsertTool;
	stError.POUAction := E_POUACT.POUACT_A_InsertTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MeasureStamp" Id="{04a8f503-34af-4207-941e-bfa1bd861e3b}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf "MeasurePoint"
		pStampSupport := pMzTool;
		pPiece := pStampSupport^.P_pPiece;
		pPiece^.P_bIgnoreOffset := FALSE;
		
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pStampSupport^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
		stActionData.aParams[2] := 1; //MeasurePoint
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//Speed Z
		stActionData.aParams[10] := 9000;	//ZOffset
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF
		
	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
			ELSE
				nActionState := 2;	
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
	
	2:	//MoveZ langsam (max 5mm) nach unten bis Sensor schaltet
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := -12000;
		stActionData.aParams[3] := 2000;
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
	
	3:	//MoveZ ready oder Sensor -> MoveZ Stop
		IF iTargetZSensor.P_bSensor THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_MoveZ);
			IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				nActionState := 4;
			END_IF
		ELSE
			IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				//Sensor not reached -> Sensor defect
				stError.ErrorId := E_ErrorIdCmd.ERRORID_MeasureZDistanceExeeded;
				nActionState := 99;
			END_IF
		END_IF
	
	4:	//MoveZ langsam (max 5mm) nach oben bis Sensor schaltet
		nActionState := 5;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		//stActionData.bIntern := TRUE;
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := 3000;
		stActionData.aParams[3] := 200;
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
	
	5:	//Warten bis MoveZ fertig bzw Sensor schaltet
		IF NOT iTargetZSensor.P_bSensor THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_MoveZ);
		END_IF
		
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 6;
		ELSIF NOT pStampSupport^.M_GetActionBusy( E_Action.ACTION_MoveZ) THEN
			stError.ErrorId := E_ErrorIdCmd.ERRORID_MeasureZDistanceExeeded;
			nActionState := 99;
		END_IF
		
	6:	//MoveZ-Free und ZOffset eintragen
		nActionState := 7; 
		stMeasCalibPoint := pTarget^.M_GetAbsPos(pChildPos:= 0, E_TargetRef.TARGETREF_SpecPoint,1,0,0, nZLevel:=0);
		stMeasCurrentPos := pStampSupport^.P_stCurrentPosPhys;
		stMeasOffset := pPiece^.P_stOffset;
		stMeasOffset.Z := stMeasOffset.Z + stMeasCalibPoint.Z - stMeasCurrentPos.Z;
		pPiece^.P_stOffset := stMeasOffset; 
  		
		fbObjectDirectory.M_SetObjChange(pPiece^.P_nObjectID);

		//Freifahren
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		//stActionData.bIntern := TRUE;
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1; //MaxSpeed Z
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
		
	7:	//MoveZ-Free ready? -> Action ready
		IF NOT pStampSupport^.M_GetActionBusy( E_Action.ACTION_MoveZ)  THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		//MoveToTarget oder MoveZ vom MzTool abbrechen (schließen sich gegenseitig aus)
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);			
			nActionState := 80;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_MeasureTool;
	stError.POUAction := E_POUACT.POUACT_A_MeasureStamp;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MeasureTarget" Id="{65b22b02-811d-4b35-9f90-d8b418e4980f}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 1 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Z-SensorID auslesen
		fbReadZSensorID(pFbZAxisRef:= pMzTool^.P_pZAxisRef, bExecute := TRUE);
		IF NOT fbReadZSensorID.bBusy THEN
			IF fbReadZSensorID.bError THEN
				stError.ErrorId := fbReadZSensorID.nErrorID;
				nActionState := 99;
			ELSE
				nZSensorId := pMzTool^.P_pZAxisRef^.P_nZSensorID;
				//Z-SensorCalibrationValue ermitteln
				rZSensorCalibration := pMzTool^.P_pFbMultiZ^.M_GetZSensorCalib(nZSensorId,pMzTool^.P_nZAxisNr);
				IF rZSensorCalibration = 0.0 THEN //Error
					stError.ErrorId := ERRORID_ZSensorNotCalibrated;
					nActionState := 99;
				ELSE
					//TargetPosition ermitteln
					IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach THEN
						pTarget^.P_rZOffset := 0;
						fbObjectDirectory.M_SetObjChange(pTarget^.P_nObjectID);
					END_IF
					//Bei Inkstation wird nur SpecPoint2 vermessen
					IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_InkStation THEN
						stMeasureTargetTgtPos := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,
																		nParam1:= 2,
																		nParam2:= 0,
																		nParam3:= 0,
																		nZLevel:= 0);
					ELSE
						stMeasureTargetTgtPos := pTarget^.P_stAbsPosCenter;	
					END_IF
					nActionState := 1;
				END_IF				
			END_IF
			fbReadZSensorID(bExecute := FALSE);
		END_IF

	1:	//Wenn Mode "Auto" dann in MoveXY zu TargetPos
		IF eMeasureTargetMode = E_MeasureMode.MEAS_MODE_Auto THEN
			nActionState := 2;
			//Move XY zum Target
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveXY;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasureTargetTgtPos.X); //XPos
			stActionData.aParams[3] := REAL_TO_DINT(stMeasureTargetTgtPos.Y); //YPos
			stActionData.aParams[4] := -1;	//MaxSpeed X
			stActionData.aParams[5] := -1;	//MaxSpeed Y
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
		
	2:	//MoveXY ready? -> MoveZ PrePos
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 3;
			IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_FastApproach THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
				stActionData.aParams[2] := REAL_TO_DINT(stMeasureTargetTgtPos.Z) + 5000; 
				stActionData.aParams[3] := -1; //MaxSpeed Z
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		
	3:	//MoveZ ready? start Measurement 
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 4;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Measure;
			stMeasCurrentPos := pMzTool^.P_stCurrentPosTotal;
			rMeasureTargetDistance := stMeasureTargetTgtPos.Z - stMeasCurrentPos.Z - 4500;
			stActionData.aParams[2] := REAL_TO_DINT(rMeasureTargetDistance);
			stActionData.aParams[3] := 10000;	//Speed nur damit kein Fehler von MultiZ auftritt(MeasureSpeed ist fix)
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
		
	4:	//Measurement ready? -> Offsets berechnen, MoveZ-Free
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 5;
			//Neue Gesamthöhe = CalibrationValue - AktAxisPos(Raw)
			stPoint1.Z := pMzTool^.P_pZAxisRef^.P_rCurrentPos - rZSensorCalibration;
			//Differenz aus alter Gesamthöhe und neuer Gesamthöhe ermitteln
			stPoint2.Z := stPoint1.Z - stMeasureTargetTgtPos.Z;
			//Diese Differnz auf Offset des Targets aufschlagen
			pTarget^.P_rZOffset := pTarget^.P_rZOffset + stPoint2.Z;
			//MoveZ-Free		
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			//stActionData.bIntern := TRUE;
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Home;
			stActionData.aParams[3] := -1; //MaxSpeedZ
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF	
		END_IF
		
	5:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			fbObjectDirectory.M_SetObjChange(pTarget^.P_nObjectID);
			nActionState := 80;
		END_IF

	70:	//Action abbrechen
		IF fbReadZSensorID.bBusy THEN
			fbReadZSensorID(bExecute:= FALSE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveXY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			nActionState := 80;
		END_IF
		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_MeasureTool;
	stError.POUAction := E_POUACT.POUACT_A_MeasureTarget;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MeasureTip" Id="{330db07a-a078-4cb2-8c2e-d44f0a50b11b}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

CASE nActionState OF
	0:	//Alle Achsen des Heads auf Home fahren
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1;	//MaxSpeed Z
		stError.ErrorId := pMzTool^.P_pMzHead^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
		
	1:	//Head ready?
		IF NOT pMzTool^.P_pMzHead^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pMzTool^.P_pMzHead^.P_bError THEN
				stError.ErrorId := pMzTool^.P_pMzHead^.P_nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 2;
			END_IF
		END_IF
		
	2:	//Wenn noch nicht vermessen wurde und angeforderte Option = "MEAS_OPTION_OnlyXY", dann
		//Option auf "MEAS_OPTION_SlowApproach" ändern
		stPoint1 := pMzTool^.P_stRelPos;
		stPoint2 := pMzTool^.P_stOffset;
		
		IF (NOT pMzTool^.P_bMeasured AND eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY) OR (stPoint1.Z = 0 AND stPoint2.Z = 0) THEN
			eMeasTipOption := E_MeasureOption.MEAS_OPTION_SlowApproach;
		END_IF
		
		IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach THEN
			IF pMzTool^.pPiece > 0 THEN
				pMzTool^.pPiece^.M_ClearOffset();
			ELSE
				pMzTool^.M_ClearOffset();	
			END_IF
		END_IF
		
		//Berechnung Startpos X-Direction
		stMeasPassIntersect := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 1, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasCalibPoint := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 2, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasStartPos := stMeasPassIntersect;
		stMeasStartPos.X := stMeasStartPos.X + rMeasureDistance;
		stMeasEndPos := stMeasPassIntersect;
		stMeasEndPos.X := stMeasEndPos.X - rMeasureDistance;
		//MoveXY		
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
		stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
		stActionData.aParams[4] := -1;	//MaxSpeed X
		stActionData.aParams[5] := -1;	//MaxSpeed Y
		
		nActionState := 20;	//Execute MoveAction
		nActionStateNext := 3; //danach weiter zu Z-Zustellung
	
	3:	//MoveZ
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[3] := -1;	//MaxSpeed Z
		//In Abhängigkeit von MeasOption "Z" zustellen und Z-Feed voreinstellen
		CASE eMeasTipOption OF
			E_MeasureOption.MEAS_OPTION_SlowApproach: //keine Z-Zustellung, es von oben angefangen
				fbMeasTip.nZFeedStart := -1000;
				fbMeasTip.nZFeedEnde := -25;
				nActionState := 4; //weiter zu Z-Measurement
			E_MeasureOption.MEAS_OPTION_FastApproach:
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
				fbMeasTip.nZFeedStart := -1000;
				fbMeasTip.nZFeedEnde := -25;
				fbMeasTip.nZFeedMax := -4000;
				stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Z); //ZPos
				nActionState := 20; //Execute MoveAction
				nActionStateNext := 4;	//danach weiter zu Z-Measurement
			E_MeasureOption.MEAS_OPTION_OnlyXY:
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;		
				stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z) -300; //ZPos
				nActionState := 20; //Execute MoveAction
				nActionStateNext := 7;	//danach weiter zu X-Measurement
		ELSE
			stError.ErrorId := E_ErrorIdCmd.ERRORID_InvalidMeasureMode;
		END_CASE
		bFlag := TRUE;
		
	4:	//Z-Measurement
		IF bFlag THEN
			bFlag := FALSE;
			//FeedMax (maximaler Gesamtvorschub Z berechnen
			IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach THEN
				stPoint1 := pMzTool^.P_stCurrentPosPhys;
				IF pMzTool^.P_pPiece > 0 THEN
					stDimension := pMzTool^.P_pPiece^.P_stDimension;
					stPoint2 := pTarget^.P_stAbsPosCenter;
					fbMeasTip.nZFeedMax := -(REAL_TO_DINT(stPoint1.Z - stPoint2.Z + stDimension.Height - pMzTool^.P_pPiece^.P_rZOverlapTool))- 5000;
				ELSE
					stPoint2 := pTarget^.M_GetAbsPos(pChildPos:= 0, E_TargetRef.TARGETREF_SpecPoint,2,0,0,0); //CalibPoint
					fbMeasTip.nZFeedMax := -(REAL_TO_DINT(stPoint1.Z - stPoint2.Z + 5500));
				END_IF
			END_IF
			
			IF NOT pTipCalibrator^.P_bXSensor THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_TipCalibProbeSensorX;
				nActionState := 99;
			END_IF
		END_IF
		
		IF nActionState <> 99 THEN
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 3,
					 stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
		
			IF NOT fbMeasTip.bBusy THEN
				IF fbMeasTip.bError THEN //Error
					stError.ErrorId := fbMeasTip.nErrorId;
					nActionState := 99;
				ELSE
					//Gemessenen Z Wert verrechnen und als OffsetWert in Tool bzw Piece eintragen
					IF pMzTool^.pPiece > 0 THEN
						stMeasOffset := pMzTool^.pPiece^.P_stOffset;
						stMeasOffset.Z := stMeasOffset.Z - (fbMeasTip.stProbePos.Z - stMeasCalibPoint.Z);
						stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
						pMzTool^.pPiece^.P_stOffset := stMeasOffset;
					ELSE
						stMeasOffset := pMzTool^.P_stOffset;
						stMeasOffset.Z := stMeasOffset.Z - (fbMeasTip.stProbePos.Z - stMeasCalibPoint.Z);
						stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
						pMzTool^.P_stOffset := stMeasOffset;
					END_IF
					
					//Berechnung Startpos Y-Direction
					stMeasStartPos := stMeasPassIntersect;
					//für Vermessung HT-Extruder, der in Y-Vermessung teilweise in Y-Min-Limit fährt
					stXYLimits := pMzTool^.M_GetXYRange();
					stMeasStartPos.Y := MAX((stMeasStartPos.Y - rMeasureDistance),stXYLimits.Y1 + 1.000);
					/////////////////////////////////////////////////////////////////////////////////
					stMeasEndPos := stMeasPassIntersect;
					stMeasEndPos.Y := stMeasEndPos.Y + rMeasureDistance;
					//MoveXY		
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveXY;
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
					stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
					stActionData.aParams[4] := -1;	//MaxSpeed X
					stActionData.aParams[5] := -1;	//MaxSpeed Y
					stActionData.aParams[6] := 1;	//Disable crash check
					
					nActionState := 20;		//Execute MoveAction
					nActionStateNext := 5;	//danach weiter zu MoveZ 300µ below CalibPoint
				END_IF
				fbMeasTip(bExecute:= FALSE);	
			END_IF
		END_IF

	5:	//MoveZ
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z) -300;
		stActionData.aParams[3] := -1;	//MaxSpeed Z
		nActionStateNext := 6;	//danach weiter zu Y-Measurement
		nActionState := 20; //Execute MoveAction	
	
	6:	//Y-Measurement
		IF bFlag THEN
			bFlag := FALSE;
			IF NOT pTipCalibrator^.P_bYSensor THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_TipCalibProbeSensorY;
			END_IF
		END_IF
	
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 2,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);		
	
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
				nActionState := 99;
			ELSE
				//Gemessenen Y Wert verrechnen und als OffsetWert in Tool eintragen
				IF pMzTool^.pPiece > 0 THEN
					stMeasOffset := pMzTool^.pPiece^.P_stOffset;
					stMeasOffset.Y := stMeasOffset.Y - (fbMeasTip.stProbePos.Y - stMeasCalibPoint.Y);
					pMzTool^.pPiece^.P_stOffset := stMeasOffset;
				ELSE
					stMeasOffset := pMzTool^.P_stOffset;
					stMeasOffset.Y := stMeasOffset.Y - (fbMeasTip.stProbePos.Y - stMeasCalibPoint.Y);
					pMzTool^.P_stOffset := stMeasOffset;
				END_IF
				
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY THEN	//Freifahren, denn X wurde bereits durch Z-Measurement erledigt
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Free;
					stActionData.aParams[3] := -1;	//MaxSpeed Z
					nActionState := 20;
					nActionStateNext := 80;	//Ready!				
				ELSE
					//Berechnung Startpos X-Direction
					stMeasStartPos := stMeasPassIntersect;
					stMeasStartPos.X := stMeasStartPos.X + rMeasureDistance;
					stMeasEndPos := stMeasPassIntersect;
					stMeasEndPos.X := stMeasEndPos.X - rMeasureDistance;
					//MoveXY		
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveXY;
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
					stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
					stActionData.aParams[4] := -1;	//MaxSpeed X
					stActionData.aParams[5] := -1;	//MaxSpeed Y
					stActionData.aParams[6] := 1;	//Disable crash check
					
					nActionState := 20;		//Execute MoveAction
					nActionStateNext := 7;	//danach weiter zu X-Measurement
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);	
		END_IF	
	
	7:	//X-Measurement
		IF bFlag THEN
			bFlag := FALSE;
			IF NOT pTipCalibrator^.P_bXSensor THEN
				stError.ErrorId := E_ErrorIdCmd.ERRORID_TipCalibProbeSensorX;
			END_IF
		END_IF
	
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 1,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
					
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
			ELSE
				//Wenn Piece am Tool, den Offset des Pieces verrechnen sonst des Tools
				IF pMzTool^.pPiece > 0 THEN
					stMeasOffset := pMzTool^.pPiece^.P_stOffset;
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.pPiece^.P_stOffset := stMeasOffset;
				ELSE
					stMeasOffset := pMzTool^.P_stOffset;
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.P_stOffset := stMeasOffset;
				END_IF
				
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY THEN
					//Berechnung Startpos Y-Direction
					stMeasStartPos := stMeasPassIntersect;
					//für Vermessung HT-Extruder, der in Y-Vermessung teilweise in Y-Min-Limit fährt
					stXYLimits := pMzTool^.M_GetXYRange();
					stMeasStartPos.Y := MAX((stMeasStartPos.Y - rMeasureDistance),stXYLimits.Y1 + 1.000);
					/////////////////////////////////////////////////////////////////////////////////
					stMeasEndPos := stMeasPassIntersect;
					stMeasEndPos.Y := stMeasEndPos.Y + rMeasureDistance;
					//MoveXY		
					stActionData.eAction := E_Action.ACTION_MoveXY;
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
					stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
					stActionData.aParams[4] := -1;	//MaxSpeed X
					stActionData.aParams[5] := -1;	//MaxSpeed Y
					stActionData.aParams[6] := 1;	//Disable crash check
					
					nActionState := 20;		//Execute MoveAction
					nActionStateNext := 6;	//danach weiter zu Y-Measurement
				ELSE
					//MoveZ-Free
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Free;
					stActionData.aParams[3] := -1;	//MaxSpeed Z
					
					nActionState := 20;		//Execute MoveAction
					nActionStateNext := 80;	//Ready
					pMzTool^.P_bMeasured := TRUE;
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);
		END_IF						
END_CASE

CASE nActionState OF
	20:	//Execute Move-Action
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		nActionState := 21;
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
	
	21:	//Move-Action ready? ready?
		IF NOT pMzTool^.M_GetActionBusy(stActionData.eAction) THEN
			nActionState := nActionStateNext;
			bFlag := TRUE;
			IF nActionState = 80 THEN
				IF pMzTool^.P_pPiece > 0 THEN
					fbObjectDirectory.M_SetObjChange(pMzTool^.pPiece^.P_nObjectID);
				ELSE
					fbObjectDirectory.M_SetObjChange(pMzTool^.P_nObjectID);
				END_IF
			END_IF
		END_IF
		
	70:	//Action abbrechen
		nActionState := 80;
		IF fbMeasTip.bBusy THEN
			fbMeasTip.M_Cancel();
			fbMeasTip();
			nActionState := 70;
		ELSE
			fbMeasTip(bExecute:= FALSE);
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
				pMzTool^.M_CancelAction(ACTION_MoveX);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.M_CancelAction(ACTION_MoveZ);
				nActionState := 70;
			ELSIF pMzTool^.P_pMzHead^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.P_pMzHead^.M_CancelAction(ACTION_MoveZ);
				nActionState := 70;
			END_IF
		END_IF		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMeasTip(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_MeasureTool;
	stError.POUAction := E_POUACT.POUACT_A_MeasureTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MeasureTipLegacy" Id="{94c78643-f9ab-41a2-957e-b5c06186e3a0}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

CASE nActionState OF
	0:	//Alle Achsen des Heads auf Home fahren
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1;	//MaxSpeed Z
		stError.ErrorId := pMzTool^.P_pMzHead^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
		
	1:	//Head ready?
		IF NOT pMzTool^.P_pMzHead^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pMzTool^.P_pMzHead^.P_bError THEN
				stError.ErrorId := pMzTool^.P_pMzHead^.P_nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 2;
			END_IF
		END_IF	

	2:	//Vorberechnung und MoveXY(Startpos TipCalibrator)
		nActionState := 3;
	
		//Wenn noch nicht vermessen wurde und angeforderte Option = "MEAS_OPTION_OnlyXY", dann
		//Option auf "MEAS_OPTION_SlowApproach" ändern
		stPoint1 := pMzTool^.P_stRelPos;
		stPoint2 := pMzTool^.P_stOffset;
		
		//Wenn bisher noch nicht vermessen wurde, dann mit "SlowApproach" beginnen
		IF (NOT pMzTool^.P_bMeasured AND eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY) OR (stPoint1.Z = 0 AND stPoint2.Z = 0) THEN
			eMeasTipOption := E_MeasureOption.MEAS_OPTION_SlowApproach;
		END_IF
		
		IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach THEN
			IF pMzTool^.pPiece > 0 THEN
				pMzTool^.pPiece^.M_ClearOffset();
			ELSE
				pMzTool^.M_ClearOffset();	
			END_IF
		END_IF		
		
		//Startposition und Endposition des X-Moves berechnen
		stMeasPassIntersect := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 1, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasCalibPoint := pTipCalibrator^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= E_TargetRef.TARGETREF_SpecPoint,nParam1:= 2, nParam2:=0, nParam3:=0, nZLevel:=0);
		stMeasStartPos := stMeasPassIntersect;
		stMeasStartPos.X := stMeasCalibPoint.X + rMeasureDistance;
		stMeasEndPos := stMeasPassIntersect;
		stMeasEndPos.X := stMeasCalibPoint.X - rMeasureDistance;
	
		//MoveXY auf stMeasStartPos
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
		stActionData.aParams[3] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
		stActionData.aParams[4] := -1;	//MaxSpeed X
		stActionData.aParams[5] := -1;	//MaxSpeed Y
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
		
	3:	//MoveXY ready? -> MoveZ auf StartPos
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
			nActionState := 4;
			//ZMove auf stMeasStartPos
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			//In Abhängigkeit von MeasOption "Z" zustellen und Z-Feed voreinstellen
			CASE eMeasTipOption OF
				E_MeasureOption.MEAS_OPTION_SlowApproach: //keine Z-Zustellung, es von oben angefangen
					stActionData.aParams[1] := E_MoveMode.MODE_Home;
					fbMeasTip.nZFeedStart := -3000;
					fbMeasTip.nZFeedEnde := -50;
				E_MeasureOption.MEAS_OPTION_FastApproach:
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					fbMeasTip.nZFeedStart := -1000;
					fbMeasTip.nZFeedEnde := -50;
					fbMeasTip.nZFeedMax := -4000;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Z); //ZPos
				E_MeasureOption.MEAS_OPTION_OnlyXY:
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;		
					stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z) -300; //ZPos
			ELSE
				stError.ErrorId := E_ErrorIdCmd.ERRORID_InvalidMeasureMode;
			END_CASE
			
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				stActionData.aParams[3] := -1;	//MaxSpeed Z
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				END_IF
			END_IF
		END_IF
		
	4:	//MoveZ ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pTipCalibrator^.P_bXSensor AND pTipCalibrator^.P_bYSensor THEN //Beide Lichtschranken müssen frei sein
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY THEN
					nActionState := 11;
				ELSE
					IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach THEN
						stPoint1 := pMzTool^.P_stCurrentPosPhys;
						stPoint2 := pTarget^.P_stAbsPosCenter;
						//der Kartuschenhalter kann so theoretisch bis 500µ über TipCalibrator heran 
						IF pMzTool^.P_pPiece > 0 THEN
							stDimension := pMzTool^.P_pPiece^.P_stDimension;
							fbMeasTip.nZFeedMax := - (REAL_TO_DINT(stPoint1.Z - stPoint2.Z + stDimension.Height - pMzTool^.P_pPiece^.P_rZOverlapTool) - 500);
						ELSE
							fbMeasTip.nZFeedMax := -(REAL_TO_DINT(stPoint1.Z - stPoint2.Z + 8500));
						END_IF
					END_IF
					nActionState := 5;	
				END_IF
			ELSE  //Error, mindestens eine der beiden Lichtschranken ist nicht frei
				stError.ErrorId := E_ErrorIdCmd.ERRORID_TipCalibSensor;
				nActionState := 99;
			END_IF 
		END_IF
		
	5:	//Z-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 3,
				 stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
	
		IF NOT fbMeasTip.bBusy THEN
			nActionState := 6;
			IF fbMeasTip.bError THEN //Error
				stError.ErrorId := fbMeasTip.nErrorId;
				nActionState := 99;
			ELSE
				//Gemessenen Z Wert verrechnen und als OffsetWert in Tool bzw Piece eintragen
				IF pMzTool^.pPiece > 0 THEN
					stMeasOffset := pMzTool^.pPiece^.P_stOffset;
					stMeasOffset.Z := stMeasOffset.Z - (fbMeasTip.stProbePos.Z - stMeasCalibPoint.Z);
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.pPiece^.P_stOffset := stMeasOffset;
				ELSE
					stMeasOffset := pMzTool^.P_stOffset;
					stMeasOffset.Z := stMeasOffset.Z - (fbMeasTip.stProbePos.Z - stMeasCalibPoint.Z);
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.P_stOffset := stMeasOffset;
				END_IF
				
				//Start und Endposition für folgende Y-Vermessung berechnen und in X auf Ausgangsposition fahren
				stMeasStartPos := stMeasPassIntersect;
				stMeasStartPos.Y := stMeasCalibPoint.Y - rMeasureDistance;
				stMeasEndPos := stMeasPassIntersect;
				stMeasEndPos.Y := stMeasCalibPoint.Y + rMeasureDistance;
				
				//MoveX StartPosX
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveX;
				stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
				stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
				stActionData.aParams[3] := -1;	//MaxSpeed X
				stActionData.aParams[4] := 1; //ignore Z-Kollission
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN //Error
					nActionState := 99;
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);	
		END_IF
		
	6:	//MoveX ready? -> MoveY StartPosY
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			nActionState := 7;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveY;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
			stActionData.aParams[3] := -1;	//MaxSpeed Y
			stActionData.aParams[4] := 1; //ignore Z-Kollission
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);		
			IF stError.ErrorId > 0 THEN //Error
				nActionState := 99;
			END_IF
		END_IF
		
	7:	//MoveY ready? -> MoveZ auf StartPointZ (300µ unterhalb CalibPoint)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			nActionState := 8;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
			stActionData.aParams[2] := REAL_TO_DINT(stMeasCalibPoint.Z) -300;
			stActionData.aParams[3] := -1;	//MaxSpeed Z
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData); //ErrorHandling am Ende
			IF stError.ErrorId > 0 THEN //Error
				nActionState := 99;
			END_IF
		END_IF

	8:	//MoveZ ready? -> weiter zu Y-Measurement
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 9;
		END_IF
		
	9:	//Y-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 2,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);		
	
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
				nActionState := 99;
			ELSE
				//Gemessenen Y Wert verrechnen und als OffsetWert in Tool eintragen
				IF pMzTool^.pPiece > 0 THEN
					stMeasOffset := pMzTool^.pPiece^.P_stOffset;
					stMeasOffset.Y := stMeasOffset.Y - (fbMeasTip.stProbePos.Y - stMeasCalibPoint.Y);
					pMzTool^.pPiece^.P_stOffset := stMeasOffset;
				ELSE
					stMeasOffset := pMzTool^.P_stOffset;
					stMeasOffset.Y := stMeasOffset.Y - (fbMeasTip.stProbePos.Y - stMeasCalibPoint.Y);
					pMzTool^.P_stOffset := stMeasOffset;
				END_IF				
				
				//Start und Endposition für folgende Y-Vermessung berechnen und in X auf Ausgangsposition fahren
				stMeasStartPos := stMeasPassIntersect;
				stMeasStartPos.X := stMeasCalibPoint.X + rMeasureDistance;
				stMeasEndPos := stMeasPassIntersect;
				stMeasEndPos.X := stMeasCalibPoint.X - rMeasureDistance;
				
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY THEN
					//Z-Achse freifahren
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Free;
					stActionData.aParams[3] := -1;	//MaxSpeed Z
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN //Error
						nActionState := 99;
					ELSE
						nActionState := 12;	
					END_IF
				ELSE
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveY;
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.Y); //YPos
					stActionData.aParams[3] := -1;	//MaxSpeed Y
					stActionData.aParams[4] := 1; //ignore Z-Kollission
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN //Error
						nActionState := 99;
					ELSE
						nActionState := 10;	
					END_IF
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);	
		END_IF
		
	10:	//MoveY ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			nActionState := 11;
		END_IF
		
	11:	//X-Measurement
		fbMeasTip(bExecute:= TRUE, pMzTool:= pMzTool, pTipCalibrator:= pTipCalibrator, nDirection:= 1,
					stStartPos:= stMeasStartPos, stEndPos:= stMeasEndPos);
					
		IF NOT fbMeasTip.bBusy THEN
			IF fbMeasTip.bError THEN
				stError.ErrorId := fbMeasTip.nErrorId;
			ELSE
				//Wenn Piece am Tool, den Offset des Pieces verrechnen sonst des Tools
				IF pMzTool^.pPiece > 0 THEN
					stMeasOffset := pMzTool^.pPiece^.P_stOffset;
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.pPiece^.P_stOffset := stMeasOffset;
				ELSE
					stMeasOffset := pMzTool^.P_stOffset;
					stMeasOffset.X := stMeasOffset.X - (fbMeasTip.stProbePos.X - stMeasCalibPoint.X);
					pMzTool^.P_stOffset := stMeasOffset;
				END_IF
				
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_OnlyXY THEN
					//weiter zu Y-Vermessung
					//Start und Endposition für folgende Y-Vermessung berechnen und in X auf Ausgangsposition fahren
					stMeasStartPos := stMeasPassIntersect;
					stMeasStartPos.Y := stMeasCalibPoint.Y - rMeasureDistance;
					stMeasEndPos := stMeasPassIntersect;
					stMeasEndPos.Y := stMeasCalibPoint.Y + rMeasureDistance;
					
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveX;
					stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
					stActionData.aParams[2] := REAL_TO_DINT(stMeasStartPos.X); //XPos
					stActionData.aParams[3] := -1;	//MaxSpeed X
					stActionData.aParams[4] := 1; //ignore Z-Kollission
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN //Error
						nActionState := 99;
					ELSE
						nActionState := 6;	
					END_IF
				ELSE
					//MoveZ-Free
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_MoveZ;
					stActionData.aParams[1] := E_MoveMode.MODE_Free;
					stActionData.aParams[3] := -1;	//MaxSpeed Z
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN //Error
						nActionState := 99;
					ELSE
						nActionState := 12;	
					END_IF
				END_IF
			END_IF
			fbMeasTip(bExecute:= FALSE);
		END_IF					
	
	12:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pMzTool^.P_pPiece > 0 THEN
				fbObjectDirectory.M_SetObjChange(pMzTool^.pPiece^.P_nObjectID);
			ELSE
				fbObjectDirectory.M_SetObjChange(pMzTool^.P_nObjectID);
			END_IF			
			pMzTool^.P_bMeasured := TRUE;
			nActionState := 80;
		END_IF
	
	70:	//Action abbrechen
		nActionState := 80;
		IF fbMeasTip.bBusy THEN
			fbMeasTip.M_Cancel();
			fbMeasTip();
			nActionState := 70;
		ELSE
			fbMeasTip(bExecute:= FALSE);
			IF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
				pMzTool^.M_CancelAction(ACTION_MoveX);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
				pMzTool^.M_CancelAction(ACTION_MoveY);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
				pMzTool^.M_CancelAction(ACTION_MoveXY);
				nActionState := 70;
			ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				pMzTool^.M_CancelAction(ACTION_MoveZ);
				nActionState := 70;				
			END_IF
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMeasTip(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_MeasureTool;
	stError.POUAction := E_POUACT.POUACT_A_MeasureTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveAllHome" Id="{09b08668-5879-4ea8-8541-958527d9d859}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

CASE nActionState OF
	0:	//MoveZ Heads in Home
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Home;
		stActionData.aParams[3] := -1;
		nActionState := 1;
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			stError.ErrorId := afbMzHead[i].M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.HardwareGrp := E_HardwareGrp.AxisZ;
				stError.HardwareNr := 0;
				nActionState := 99;
				EXIT;
			END_IF
		END_FOR
		
	1:	//Alle Heads fertig?
		nActionState := 2;
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			IF afbMzHead[i].P_bError THEN
				stError.ErrorId := afbMzHead[i].P_nErrorId;
				nActionState := 99;
				EXIT;
			ELSIF afbMzHead[i].M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
				nActionState := 1;
				EXIT;
			END_IF
		END_FOR
		
	2:	//Heads in X und Y in max Pos fahren
		//In X braucht nur der erste Head fahren, da der zweite (wenn vorhanden) ja an der gleiche X-Achse hängt
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveXY;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsNoneOffset;
		stActionData.aParams[2] :=  REAL_TO_DINT(afbMzHead[1].P_pXDrive^.P_rMaxPos);
		stActionData.aParams[3] :=  REAL_TO_DINT(afbMzHead[1].P_pYDrive^.P_rMaxPos);
		stActionData.aParams[4] :=  -1;
		stActionData.aParams[5] :=  -1;
		stError.ErrorId := afbMzHead[1].M_ExeAction(stActionData);
		
		IF stError.ErrorId = 0 THEN
			{IF defined (TwoHeads)}
			IF afbMzHead[2].P_nObjectID > 0 THEN	//zweiter Head vorhanden
				stActionData.eAction := E_Action.ACTION_MoveY;
				stActionData.aParams[2] :=  REAL_TO_DINT(afbMzHead[2].P_pYDrive^.P_rMaxPos);
				stActionData.aParams[3] :=  -1;
				stError.ErrorId := afbMzHead[2].M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.HardwareGrp := E_HardwareGrp.AxisY;
					stError.HardwareNr := 0;
					nActionState := 99;
				END_IF
			END_IF
			{END_IF}
		ELSE
			stError.HardwareGrp := E_HardwareGrp.AxisX;
			stError.HardwareNr := 0;
			nActionState := 99;
		END_IF
		
	3:	//Alle Heads fertig?
		nActionState := 80;
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			IF afbMzHead[i].P_bError THEN
				stError.ErrorId := afbMzHead[i].P_nErrorId;
				nActionState := 99;
				EXIT;
			ELSIF afbMzHead[i].M_GetActionBusy(E_Action.ACTION_MoveXY) THEN
				nActionState := 3;
				EXIT;
			END_IF
		END_FOR
		
	70:	//Heads
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			afbMzHead[i].M_Stop();
		END_FOR
		nActionState := 71;
		
	71:	//Heads gestoppt?
		nActionState := 80;
		FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO
			IF afbMzHead[i].bBusy THEN
				nActionState := 71;
			END_IF
		END_FOR
		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.Cmd := E_Action.ACTION_MoveAllHome;
	stError.POUAction := E_POUACT.POUACT_A_MoveAllHome;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_MoveToTarget" Id="{c4de918c-5645-4b36-9ae8-fb7b00dc3998}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF nActionState = 0 THEN
	fbMoveToTarget(bExecute:= TRUE);
	IF NOT fbMoveToTarget.bBusy THEN
		IF fbMoveToTarget.bError THEN
			stError.ErrorId := fbMoveToTarget.nErrorId;
			nActionState := 99;
		ELSE
			nActionState := 80;
		END_IF
		fbMoveToTarget(bExecute:= FALSE);
	END_IF
ELSIF nActionState = 70 THEN	//Abbrechen
	IF fbMoveToTarget.bBusy THEN
		fbMoveToTarget(bStop:= TRUE);
	ELSE	
		fbMoveToTarget(bExecute:= FALSE);
		nActionState := 80;
	END_IF
END_IF


//Errorhandling
IF nActionState = 99 THEN
	//stError.ObjectId := 
	stError.Cmd := E_Action.ACTION_MoveToTarget;
	stError.POUAction := E_POUACT.POUACT_A_MoveToTarget;
	fbErrorList.M_Add(stError);
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_OpenCloseFlipTube" Id="{b1c54cc8-13da-44e7-ae11-bc442e1d2fe9}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget auf Slot
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_Slot;
		stActionData.aParams[2] := pPieceSlot^.nNr;
		stActionData.aParams[3] := 0;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		IF bOpen THEN
			stPoint1 := pFlipTubeRack^.P_stOpenStartPos;
		ELSE
			stPoint1 := pFlipTubeRack^.P_stCloseStartPos;
		END_IF
		stActionData.aParams[8] := REAL_TO_DINT(stPoint1.X);
		stActionData.aParams[9] := REAL_TO_DINT(stPoint1.Y);
		stActionData.aParams[10] := REAL_TO_DINT(stPoint1.Z);
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF		

	1:	//MoveToTarget ready? -> "Open Move1" bzw. "Close Move1"
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
			ELSE
				pFlipTube := pPieceSlot^.P_pPiece;
				IF bOpen THEN
					nActionState := 2;
				ELSE
					nActionState := 10;
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF	
		
	2:	//Open Move1 (Z)
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := pFlipTubeRack^.P_nOpenMove1DistZ;
		stActionData.aParams[3] := 2000; //SpeedZ
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		END_IF
			
	3:	//Open Move2 (Z)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 4;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := pFlipTubeRack^.P_nOpenMove2DistZ;
			stActionData.aParams[3] := -1; //SpeedZ
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
	
	4:	//Open Move3 (Y)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 5;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveY;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := pFlipTubeRack^.P_nOpenMove3DistY;
			stActionData.aParams[3] := -1; //SpeedY
			stActionData.aParams[4] := 1; //IgnoreZCollision
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF
		
	5:	//Open Move4 (X)
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			nActionState := 6;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveX;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := pFlipTubeRack^.P_nOpenMove4DistX;
			stActionData.aParams[3] := -1; //SpeedX
			stActionData.aParams[4] := 1; //IgnoreZCollision
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			END_IF
		END_IF		
	
	6:	//Open Move4 -> letzter Z-Move
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := pFlipTubeRack^.P_nOpenMove5DistZ;
			stActionData.aParams[3] := 20000; //SpeedZ
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 20;
				pFlipTube^.P_bIsOpen := TRUE;	
			END_IF
		END_IF
		
	10: //Close Move1
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveX;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := pFlipTubeRack^.P_nCloseMove1DistX;
		stActionData.aParams[3] := 45000; //SpeedX
		stActionData.aParams[4] := 1; //IgnoreZCollision
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 11;
		END_IF
	
	11: //Close Move2 -> letzter Z-Move
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := pFlipTubeRack^.P_nCloseMove2DistZ;
			stActionData.aParams[3] := 2000; //SpeedZ
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 20;
				pFlipTube^.P_bIsOpen := FALSE;
			END_IF
		END_IF
	
	20:	//MoveZ
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Free;
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				nActionState := 99;
			ELSE
				nActionState := 21;
			END_IF
		END_IF
		
	21:	//MoveZ-Free ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			fbObjectDirectory.M_SetObjChange(pFlipTube^.P_nObjectID);
			nActionState := 80;
		END_IF
	
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveX) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveX);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveY) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveY);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			nActionState := 80;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_OpenCloseFlipTube;
	stError.POUAction := E_POUACT.POUACT_A_OpenCloseFlipTube;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_StampDemold" Id="{45f90d75-d6c1-4e48-8331-193ecbc535b9}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Set Pressure
		nActionState := 1;
		stActionData.eAction := E_Action.ACTION_SetPressure;
		stActionData.aParams[1] := 1;
		stActionData.aParams[2] := nPressure1;
		stActionData.aParams[3] := 5;	//Tolerance +
		stActionData.aParams[4] := 5;	//Tolerance -
		stActionData.aParams[5] := 2000;	//Timeout
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF

	1:	//Pressure ready?
 		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			nActionState := 2;
		END_IF
		
	2:	//Set Vacuum
		nActionState := 3;
		stActionData.eAction := E_Action.ACTION_SetVacuum;
		stActionData.aParams[1] := 1;
		stActionData.aParams[2] := nPressure2;
		stActionData.aParams[3] := 5;	//Tolerance +
		stActionData.aParams[4] := 5;	//Tolerance -
		stActionData.aParams[5] := 2000;	//Timeout
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
		
	3:	//Vacuum ready?
 		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
			nActionState := 4;
		END_IF
		
	4:	//MoveZ
		nActionState := 5;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := nDistance1;
		stActionData.aParams[3] := nSpeed1;
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF
		
	5:	//PulsePressure
		nActionState := 6;
		//stActionData.bIntern := TRUE;
		stActionData.eAction := E_Action.ACTION_PulsePressure;
		stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_VacOn;	//Phase 1
		stActionData.aParams[2] := E_PressCtrl.PRESSCTRL_PressOn;	//Phase 2
		stActionData.aParams[3] := nPeriode;
		stActionData.aParams[4] := nDutycycle;
		stActionData.aParams[5] := 0;	//Dauerpulsen
		stActionData.aParams[6] := 1;	//On
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF		
		
	6:	//MoveZ ready? -> PulsePressure off
 		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 7;
			stActionData.aParams[6] := 0;	//PulsePressure Off
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			END_IF			
		END_IF
		
	7:	//PulsePressure ready? -> Action ready
 		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_PulsePressure) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		nActionState := 80;
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_SetPressure);
			nActionState := 70;
		END_IF

		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_SetVacuum) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_SetVacuum);
			nActionState := 70;
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_PulsePressure) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_PulsePressure);
			nActionState := 70;
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		END_IF
		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_StampDemolding;
	stError.POUAction := E_POUACT.POUACT_A_StampDemold;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_StampInking" Id="{fd6b423a-c63a-4f65-a557-812b0863353e}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;
IF pInkStation > 0 AND_THEN pInkStation^.P_bError THEN
	stError.ErrorId := pInkStation^.P_nErrorId;
	stError.ObjectId := pTarget^.P_nObjectID;
	nActionState := 99;
ELSIF pStampSupport^.P_bError THEN
	stError.ErrorId := pStampSupport^.P_nErrorId;
	stError.ObjectId := pStampSupport^.P_nObjectID;
	nActionState := 99;	
END_IF

IF pStampSupport^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	
		IF pInkStation = 0 THEN
			nActionState := 2;
			RETURN;
		END_IF
		nActionState := 1;
		//Wenn noch Spinning, dann anhalten
		IF pInkStation^.P_bIsSpinning THEN
			stActionData.eAction := E_Action.ACTION_InkSpin;
			stActionData.aParams[1] := 0;
			stActionData.aParams[2] := 0;
			stError.ErrorId := pInkStation^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pTarget^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
	
	1:	//Wenn Deckel geschlossen, dann öffnen
		nActionState := 2;
		IF pInkStation^.P_eCoverState <> E_OpClState.Open THEN
			stActionData.eAction := E_Action.ACTION_InkOpClCover;
			stActionData.aParams[1] := 0;
			stError.ErrorId := pInkStation^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pTarget^.P_nObjectID;
				nActionState := 99;
			END_IF
		END_IF
	
	2:	//Wenn Druck auf Stempel, dann Druck aus
		IF pStampSupport^.P_eCurPressState <> E_PressCtrl.PRESSCTRL_Off THEN
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_Off; 
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pStampSupport^.P_nObjectID;
				nActionState := 99;
			END_IF
		ELSE
			//Druck voreinstellen
			stActionData.eAction := E_Action.ACTION_SetPressure;
			stActionData.aParams[1] := 0;	//Action wird sofort fertig gemeldet
 			stActionData.aParams[2] := nPressure1;
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				stError.ObjectId := pStampSupport^.P_nObjectID;
				nActionState := 99;
			ELSE
				nActionState := 3;	
			END_IF
		END_IF
		
	3:	//Target eine InkStation? Open?
		nActionState := 4;
		IF pInkStation > 0 THEN
			IF NOT pInkStation^.M_GetActionBusy(E_Action.ACTION_InkOpClCover) THEN
				IF pInkStation^.P_eCoverState <> E_OpClState.Open THEN //Error
					stError.ObjectId := pInkStation^.P_nObjectID;
					stError.ErrorId := E_ErrorIdCmd.ERRORID_InkStationNotOpen;
					nActionState := 99;
				END_IF
			ELSE
				nActionState := 3;
			END_IF
		END_IF
	
	4:	//MoveToTarget
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pStampSupport^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		IF pInkStation > 0 THEN	//Inkstation
			stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
			stActionData.aParams[2] := 2; //Inkpoint
		ELSE //Point
			stActionData.aParams[1] := E_TargetRef.TARGETREF_Center;
		END_IF
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := nDistance1;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pStampSupport^.P_nObjectID;
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 5;
		END_IF
	
	5:	//MoveToTarget ready? -> Druck Ein
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 6;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF	
		
	6:	//Switch Pressure
		IF pStampSupport^.M_GetPressValueOk(nSetPressure:= nPressure1, nTolerancePlus:= 8, nToleranceMinus:= 8) THEN 
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := E_PressCtrl.PRESSCTRL_PressOn;
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		ELSE
			stError.ErrorId := E_ErrorIdCmd.ERRORID_PressTimeOut;
		END_IF
		
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pStampSupport^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 7;
		END_IF

	7:	//MoveZ um ContactDistance nach unten
		nActionState := 8;
		timer1(IN:=FALSE);
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Relative;
		stActionData.aParams[2] := - nDistance1;
		stActionData.aParams[3] := 1000;
		stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			stError.ObjectId := pStampSupport^.P_nObjectID;
			nActionState := 99;
		END_IF
		
	8:	//MoveZ ready? -> Timer starten
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			timer1(IN:=TRUE, PT:= UDINT_TO_TIME(nTime));
			nActionState := 9;
		END_IF
		
	9:	//Warten, bis Zeit abgelaufen -> MoveZ um ContactDistance nach oben
		timer1();
		IF timer1.Q THEN
			nActionState := 10;
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Relative;
			stActionData.aParams[2] := nDistance1;
			stActionData.aParams[3] := 1000;			
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pStampSupport^.P_nObjectID;
				nActionState := 99;
			END_IF				
		END_IF
		
	10:	//MoveZ ready? -> Druck aus und MoveFree
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_SwitchPressure;
			stActionData.aParams[1] := 1;
			stActionData.aParams[2] := E_PressCtrl.PRESSCTRL_Off;
			stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN	//Error
				stError.ObjectId := pStampSupport^.P_nObjectID;
				nActionState := 99;
			ELSE
				stActionData.eAction := E_Action.ACTION_MoveZ;
				stActionData.aParams[1] := E_MoveMode.MODE_Free;
				stActionData.aParams[3] := -1; //MaxSpeed Z
				stError.ErrorId := pStampSupport^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN	//Error
					stError.ObjectId := pStampSupport^.P_nObjectID;
					nActionState := 99;
				ELSE
					nActionState := 11;
				END_IF			
			END_IF
		END_IF
		
	11:	//MoveZ-Free ready? -> Target = InkStation? -> CloseInkStation
		IF NOT pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			IF pInkStation > 0 THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_InkOpClCover;
				stActionData.aParams[1] := 1;
				stError.ErrorId := pInkStation^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					stError.ObjectId := pTarget^.P_nObjectID;
					nActionState := 99;
				ELSE
					nActionState := 12;	
				END_IF
			ELSE
				nActionState := 80;
			END_IF
		END_IF
		
	12:	//Inkstation ready? -> Action ready
		IF NOT pInkStation^.M_GetActionBusy(E_Action.ACTION_InkOpClCover) THEN
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		nActionState := 80;
		//MoveToTarget oder Einzel-Moves vom MzTool abbrechen (schließen sich gegenseitig aus)
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
			nActionState := 70;
		ELSIF pStampSupport^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_MoveZ);
			nActionState := 70;
		ELSE
			fbMoveToTarget(bStop:= FALSE);
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_SetPressure);
			nActionState := 70;
		END_IF
		
		IF pStampSupport^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) THEN
			pStampSupport^.M_CancelAction(E_Action.ACTION_SwitchPressure);
			nActionState := 70;
		END_IF
		
		//InkStation abbrechen
		IF pInkStation > 0 THEN
			IF pInkStation^.M_GetActionBusy(E_Action.ACTION_InkOpClCover) THEN
				pInkStation^.M_CancelAction(E_Action.ACTION_InkOpClCover);
				nActionState := 70;
			END_IF
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_StampInking;
	stError.POUAction := E_POUACT.POUACT_A_StampInking;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TeachTarget" Id="{29ae2d02-686f-4649-85a9-86f8d5314ceb}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget
		IF eTeachOption = E_TeachTrgtOption.Option_PrePos THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveToTarget;
			stActionData.nObject := pMzTool^.P_nObjectID;
			stActionData.nTarget := pTarget^.P_nObjectID;
		
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp THEN	//MoveToTarget Well1
				stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
				stActionData.aParams[2] := 1; //Col (erstes Well immer Spalte 1)
				stActionData.aParams[3] := pMtp^.P_nRows; //Row (erstes Well immer letzte Spalte)
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SpotArray THEN	//MoveToTarget Ecke links unten
				stActionData.aParams[1] := E_TargetRef.TARGETREF_LeftBottom;
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Slide AND eTargetRef = E_TargetRef.TARGETREF_Alignment THEN	//MoveToTarget Alignment-Marke 1
				stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
				stActionData.aParams[2] := 1; //SpecPoint 1 (Marke 1)
			ELSE	//MoveToTarget Slot oder Center
				stActionData.aParams[1] := eTargetRef;
				stActionData.aParams[2] := nSpecPointSlotNr;
			END_IF
			stActionData.aParams[5] := -1;	//MaxSpeed X
			stActionData.aParams[6] := -1;	//MaxSpeed Y
			stActionData.aParams[7] := -1;	//MaxSpeed Z
			stActionData.aParams[10] := nZOffset1;
			stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				fbMoveToTarget(bExecute:= TRUE);
				nActionState := 1;
			END_IF
			
		ELSIF eTeachOption = E_TeachTrgtOption.Option_NoPrePos THEN
			//alle anderen Tools freifahren
			//dazu wird der Head benötigt:
			stError.ErrorId := pMzTool^.P_pMzHead^.M_MoveFree(pMzTool);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 2;
			END_IF
			
		ELSIF eTeachOption = E_TeachTrgtOption.Option_AssumeInstantly THEN
			//aktuellen Wert sofort übernehmen
			stError.ErrorId := pTarget^.M_ApplyPos(eTargetRef, nSpecPointSlotNr, pMzTool^.P_stCurrentPosTotal, bXPos:= TRUE, bYPos:=TRUE, bZPos:=TRUE);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				fbObjectDirectory.M_SetObjChange(pTarget^.P_nObjectID);
				nActionState := 80;
			END_IF
		ELSE
			{warnig 'ImplementErrorId'}
			stError.ErrorId := 333;
			nActionState := 99;
		END_IF
		MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));

	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 2;	
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//Interaction Request "StartTeaching"
		IF NOT pMzTool^.P_pMzHead^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
			stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;
			stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
			stInteractRequest.nArg1 := 1;
			nActionState := 3;
		END_IF
		
	3:	//Response ?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Assume THEN
			stInteractRequest.nArg1 := stInterResponse.nArg1;
			stInteractRequest.nArg2 := stInterResponse.nArg2;
			stInteractRequest.nArg3 := stInterResponse.nArg3; 
			
			pTarget^.M_ApplyPos(eTargetRef, nSpecPointSlotNr, pMzTool^.P_stCurrentPosTotal,
								bXPos:= DINT_TO_BOOL(stInterResponse.nArg1),
								bYPos:= DINT_TO_BOOL(stInterResponse.nArg2),
								bZPos:= DINT_TO_BOOL(stInterResponse.nArg3));

			fbObjectDirectory.M_SetObjChange(pTarget^.P_nObjectID);
			stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_Continue; //Request "Continue"
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));

		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished THEN
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp AND eTargetRef = E_TargetRef.TARGETREF_TwoDimArray THEN
				pMtp^.M_CalcOffsetWellLB(pMzTool^.P_stCurrentPosTotal,0);
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 2;
				nActionState := 4;
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SpotArray AND eTargetRef = E_TargetRef.TARGETREF_TwoDimArray THEN
				//Position übertragen (nur XY)
				pTarget^.M_ApplyPos(eTargetRef:= E_TargetRef.TARGETREF_LeftBottom, 0, pMzTool^.P_stCurrentPosTotal,
									bXPos:= TRUE, bYPos:= TRUE, bZPos:= FALSE);
				IF eTeachOption = E_TeachTrgtOption.Option_NoPrePos THEN
					MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
					stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
					stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
					stInteractRequest.nArg1 := 2;
					nActionState := 9;
				ELSE
					nActionState := 7; //weiter zu MoveToTarget rechte obere Ecke
				END_IF
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Slide AND eTargetRef = E_TargetRef.TARGETREF_Alignment THEN
				//Position auf Marke 1 übertragen
				pSlide := pTarget;
				pSlide^.M_SetMark1Act(pMzTool^.P_stCurrentPosTotal);
				nActionState := 10; //weiter zu MoveToTarget Alignment-Marke 2
			ELSE
				nActionState := 20; //weiter zu State "MoveZ-Free"
			END_IF
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			nActionState := 70;			
		END_IF
		
	//##################################################################################################################
	//Die nächsten 3 Schritte beziehen sich nur auf Mtp mit TargetRef "TwoDimArray"
	//##################################################################################################################
	4:	//Response "TeachingFinished"?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished THEN
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			//Offset ermitteln und auf Well1 übertragen
			pMtp := pTarget;
			pMtp^.M_CalcOffsetWellLB(pMzTool^.P_stCurrentPosTotal,1);
			//MoveTo Target Wellx
			IF eTeachOption = E_TeachTrgtOption.Option_PrePos THEN
				MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
				stActionData.eAction := E_Action.ACTION_MoveToTarget;
				stActionData.nObject := pMzTool^.P_nObjectID;
				stActionData.nTarget := pMtp^.P_nObjectID;
				stActionData.aParams[1] := E_TargetRef.TARGETREF_TwoDimArray;
				stActionData.aParams[2] := pMtp^.P_nCols; //Col (diagonales Well ermitteln)
				stActionData.aParams[3] := 1; //Row
				stActionData.aParams[5] := -1;	//MaxSpeed X
				stActionData.aParams[6] := -1;	//MaxSpeed Y
				stActionData.aParams[7] := -1;	//MaxSpeed Z
				stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
				IF stError.ErrorId > 0 THEN
					nActionState := 99;
				ELSE
					fbMoveToTarget(bExecute:= TRUE);
					nActionState := 5;
				END_IF
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 3;
				nActionState := 6;
			END_IF
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			nActionState := 70;
		END_IF
		
	5:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 3;
				nActionState := 6;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF	
		
	6:	//Response "TeachingFinished"?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished THEN
			//Offset ermitteln und auf Wellx übertragen bzw. Korrekturfaktoren ermitteln
			pMtp^.M_CalcKorrFactor(pMzTool^.P_stCurrentPosTotal);
			nActionState := 20;
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			nActionState := 70;
		END_IF
		//##################################################################################################################
		//Ende Teach Mtp Targetref "TwoDimArray
		//##################################################################################################################
		
		//##################################################################################################################
		//Die nächsten 3 Schritte beziehen sich nur auf SpotArray mit TargetRef "TwoDimArray"
		//##################################################################################################################
	7:	//MoveToTarget rechte obere Ecke
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_RightTop;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := nZOffset1;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 8;
		END_IF
		
	8:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 2;
				nActionState := 9;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	9:	//Response "TeachingFinished"?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished THEN
			//Dimension in XY neu setzen
			stPoint1 := pTarget^.P_stAbsPosLB;
			stPoint2 := pMzTool^.P_stCurrentPosTotal;
			stDimension := pTarget^.P_stDimension;
			stDimension.Width := stPoint2.X - stPoint1.X;
			stDimension.Depth := stPoint2.Y - stPoint1.Y;
			pTarget^.P_stDimension := stDimension;
			nActionState := 20;
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			nActionState := 70;
		END_IF	
		//##################################################################################################################
		//Ende Teach SpotArray Targetref "TwoDimArray
		//##################################################################################################################
		

		//##################################################################################################################
		//Die nächsten Schritte beziehen sich nur auf Slide mit TargetRef "Alignment"
		//##################################################################################################################
	10:	//MoveToTarget auf Alignment-Marke 2
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
		stActionData.aParams[2] := 2;	//SpecPoint 1
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := nZOffset1;
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 11;
		END_IF
	
	11:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Request "StartTeaching"
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 2;
				nActionState := 12;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF 
	
	12:	//Response "TeachingFinished"?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished THEN
			pSlide^.M_SetMark2Act(pMzTool^.P_stCurrentPosTotal);
			//Winkel berechnen
			pSlide^.P_bIsAligned := TRUE;
			pSlide^.M_CalcAngle();
			nActionState := 20;
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			pSlide^.P_bIsAligned := FALSE;
			nActionState := 70;
		END_IF

	20:	//MoveZ-Free
		//Falls das Tool am unteren Head ist, dann freifahren überspringen.
		nActionState := 21;
		IF pMzTool^.P_pMzHead^.P_bIsTopHead THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_MoveZ;
			stActionData.aParams[1] := E_MoveMode.MODE_Free;
			stActionData.aParams[3] := -1;	//MaxSpeed Z
			stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			END_IF
		END_IF
	
	21:	//MoveZ-Free ready? -> Action ready
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			fbObjectDirectory.M_SetObjChange(pTarget^.P_nObjectID);
			nActionState := 80;
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
		END_IF
	
	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			nActionState := 80;
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_TeachTarget;
	stError.POUAction := E_POUACT.POUACT_A_TeachTarget;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TeachTool" Id="{58218c83-64a2-4f81-b5ac-78c2453db706}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;
END_IF

IF pMzTool^.P_bCanceled AND nActionState > 0 AND nActionState < 70 THEN
	//MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//MoveToTarget
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		//stActionData.bIntern := TRUE;
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		stActionData.nObject := pMzTool^.P_nObjectID;
		stActionData.nTarget := pTarget^.P_nObjectID;
    	stActionData.aParams[1] := eTargetRef;
		stActionData.aParams[2] := nCol;
		stActionData.aParams[3] := nRow;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//MaxSpeed Z
		stActionData.aParams[10] := nZOffset1;		

		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			nActionState := 1;
		END_IF		

	1:	//MoveToTarget ready? -> Request "StartTeaching"
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
				stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_StartTeaching;	//Interaction Request absenden
				stInteractRequest.nObjectId := pMzTool^.P_nObjectID;
				stInteractRequest.nArg1 := 1;
				nActionState := 2;
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
	
	2:	//Zwischenschritt um stInteractRequest zurückzusetzen
		MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
		nActionState := 3;

	3:	//Response ?
		IF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Assume THEN
			//anhand von den Args von Response wird festgelegt, ob die Werte von X,Y,Z übernommen werden sollen
			//absolute Position (Sollposition)aus Target holen
			stPoint1 := pTarget^.M_GetAbsPos(pChildPos:= 0, eTargetRef:= eTargetRef,
												nParam1:= nCol, nParam2:= nRow, nParam3:= 0,nZLevel:= 0);			
			IF stInterResponse.nArg1 = 1 THEN
				pMzTool^.M_SetCurrentPos(1,stPoint1.X);
				stInteractRequest.nArg1 := 1;			
			END_IF

			IF stInterResponse.nArg2 = 1 THEN
				pMzTool^.M_SetCurrentPos(2,stPoint1.Y);
				stInteractRequest.nArg2 := 1;
			END_IF

			IF stInterResponse.nArg3 = 1 THEN
				pMzTool^.M_SetCurrentPos(3,stPoint1.Z);
				stInteractRequest.nArg3 := 1;
			END_IF
			stInteractRequest.eInteractMessageType := E_InteractMessageType.INTERACTMES_Continue;	//Request "Continue"
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
		ELSIF stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_TeachingFinished OR 
				stInterResponse.eInteractMessageType = E_InteractMessageType.INTERACTMES_Cancel THEN
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));				
			nActionState := 80;
		END_IF

	70:	//Abbrechen
		IF fbMoveToTarget.bBusy THEN
			fbMoveToTarget(bStop:= TRUE);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
			MEMSET(ADR(stInteractRequest),0,SIZEOF(stInteractRequest));
			MEMSET(ADR(stInterResponse),0,SIZEOF(stInterResponse));
			nActionState := 80;
		END_IF		
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	fbMoveToTarget(bExecute:= FALSE);
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.Cmd := E_Action.ACTION_TeachTool;
	stError.POUAction := E_POUACT.POUACT_A_TeachTool;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferGas" Id="{a7bd9254-a499-40a9-8564-1e5eeacea37d}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pLuer^.P_bError THEN
	stError.ObjectId := pLuer^.P_nObjectID;
	stError.ErrorId := pLuer^.P_nErrorId;
	nActionState := 99;
ELSIF pLuer2^.P_bError THEN
	stError.ObjectId := pLuer2^.P_nObjectID;
	stError.ErrorId := pLuer2^.P_nErrorId;
	nActionState := 99;	
END_IF

IF (pLuer^.P_bCanceled OR pLuer2^.P_bCanceled) AND nActionState > 0 AND nActionState < 70 THEN
	//Ein MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Voreinstellung Ventile

		//LuerSource
		//ValveDil on
		pLuer^.M_SwitchValveDiluter(TRUE);
		
		//ValveLuer off
		pLuer^.M_SwitchValveLuer(FALSE);
		
		//LuerDestination
		//ValveDil off
		pLuer2^.M_SwitchValveDiluter(FALSE);
		
		//ValveLuer on
		pLuer2^.M_SwitchValveLuer(TRUE);
		
		//Druck einstellen
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_SetPressure;
		stActionData.aParams[1] := 1; //Fertigmeldung wenn Solldruck erreicht
		stActionData.aParams[2] := nPressure1; //Value in kPa
		stActionData.aParams[3] := 15; //Toleranz
		stActionData.aParams[4] := 15; //Toleranz
		stActionData.aParams[5] := 10000; //Timeout in ms
		stError.ErrorId :=  pLuer^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pLuer^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
	
	1:	//Start Timer, ValveSynth.Gas "On"
		IF NOT pLuer^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			timer1(IN:=TRUE,PT:= DWORD_TO_TIME(nTime));
			pLuer^.M_SwitchValveSynthGas(TRUE);
			nActionState := 2;
		END_IF
		
	2:	//Timer ready? -> ValveSynth.Gas "Off"
		timer1();
		IF timer1.Q THEN
			timer1(IN:=FALSE);
			pLuer^.M_SwitchValveSynthGas(FALSE);
			pLuer^.M_SwitchValveDiluter(FALSE);
			pLuer2^.M_SwitchValveLuer(FALSE);
			nActionState := 80;
		END_IF
		
	70:	//Abbrechen
		nActionState := 80;
		IF pLuer^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			pLuer^.M_CancelAction(E_Action.ACTION_SetPressure);
			nActionState := 70;
		END_IF
		timer1(IN:=FALSE);
		pLuer^.M_SwitchValveSynthGas(FALSE);
		pLuer^.M_SwitchValveDiluter(FALSE);
		pLuer2^.M_SwitchValveLuer(FALSE);
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferGas;
	stError.POUAction := E_POUACT.POUACT_A_TransferGas;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferLiquid" Id="{9e1fa62f-48be-4177-8abb-ed228d3a5cff}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pDiluter1^.P_bError THEN
	stError.ErrorId := pDiluter1^.P_nErrorId;
	nActionState := 99;
END_IF

IF (pDiluter1^.P_bCanceled OR pLuer^.P_bCanceled OR pLuer2^.P_bCanceled) AND nActionState > 0 AND nActionState < 70 THEN
	//Ein MzTool wurde durch StopDevice abgebrochen
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Voreinstellung Ventile
		//LuerSource
		//ValveDil on
		pLuer^.M_SwitchValveDiluter(TRUE);
		//ValveLuer on
		pLuer^.M_SwitchValveLuer(TRUE);
		//LuerDestination
		//ValveDil off
		pLuer2^.M_SwitchValveDiluter(TRUE);
		//ValveLuer on
		pLuer2^.M_SwitchValveLuer(TRUE);
		
		//Transfer am DilSource ausführen
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_DilTransfer;
		stActionData.aParams[1] := pDiluter2^.P_nObjectID; //ObjectId DilDesti
		stActionData.aParams[2] := nQuantity1;
		stActionData.aParams[3] := nFlow1;
		stActionData.aParams[4] := nQuantity2;
		stActionData.aParams[5] := nQuantity3;

		stError.ErrorId :=  pDiluter1^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			stError.ObjectId := pDiluter1^.P_nObjectID;
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF		
		
	1:	//Transfer ready?
		IF NOT pDiluter1^.M_GetActionBusy(E_Action.ACTION_DilTransfer) THEN
			pLuer^.M_SwitchValveDiluter(FALSE);
			pLuer^.M_SwitchValveLuer(FALSE);
			pLuer2^.M_SwitchValveDiluter(FALSE);
			pLuer2^.M_SwitchValveLuer(FALSE);
			nActionState := 80;
		END_IF
	
	70:	//Abbrechen
		IF pDiluter1^.M_GetActionBusy(E_Action.ACTION_DilTransfer) THEN
			pDiluter1^.M_CancelAction(E_Action.ACTION_DilTransfer);
		ELSE
			pLuer^.M_SwitchValveDiluter(FALSE);
			pLuer^.M_SwitchValveLuer(FALSE);
			pLuer2^.M_SwitchValveDiluter(FALSE);
			pLuer2^.M_SwitchValveLuer(FALSE);
			nActionState := 80;			
		END_IF
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferLiquid;
	stError.POUAction := E_POUACT.POUACT_A_TransferLiquid;
	fbErrorList.M_Add(stError);
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferTray" Id="{b4635470-f773-4dee-9ec0-01b2a106e557}">
      <Implementation>
        <ST><![CDATA[//Mögliche Transfers
//-von linker Übergabestation zu TrayTransporterSlot
//-von rechter Übergabestation zu TrayTransporterSlot
//-von TrayTransporterSlot zu linker Übergabestation
//-von TrayTransporterSlot zu rechter Übergabestation

//Der Error muss für die States 0-2 hier gemeldet werden
//sonst erfolgt die Meldung aus den Sub-Actions
IF nActionState < 3 THEN
	IF pTrayTransporter^.P_bError THEN
		stError.ErrorId := pTrayTransporter^.P_nErrorId;
		stError.ObjectId := pTrayTransporter^.P_nObjectID;
		stError.Cmd := E_Action.ACTION_TransferTray;
		stError.POUAction := E_POUACT.POUACT_A_TransferTray;
		fbErrorList.M_Add(stError);
		nActionState := 99;	
	END_IF	
END_IF

IF nActionState > 0 AND nActionState < 70 AND pTrayTransporter^.P_bCanceled THEN
	nActionState := 70;
END_IF

CASE nActionState OF
	0:	//Both DrivingPins horizontal
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
		stActionData.nObject := pTrayTransporter^.P_nObjectID;
		stActionData.aParams[1] := E_DrivingPinSelection.Both;
		stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 1;
		END_IF
		
	1:	//DrivingPins ready? -> Unlock TrayLock
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
			stActionData.eAction := E_Action.ACTION_LockUnlock;
			stActionData.aParams[1] := E_LockCtrl.Unlock;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nActionState := 99;
			ELSE
				nActionState := 2;
			END_IF
		END_IF
		
	2:	//TrayLock ready?
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_LockUnlock) THEN
			IF pTrayTransporter^.P_bError THEN
				nActionState := 99;
			ELSE
				CASE eTransferTrayCtrl OF
					E_TransferTrayCtrl.LeftToSlot:
						nActionState := 3;
					E_TransferTrayCtrl.RightToSlot:
						nActionState := 4;
					E_TransferTrayCtrl.SlotToLeft:
						nActionState := 5;
					E_TransferTrayCtrl.SlotToRight:
						nActionState := 6;
				END_CASE
			END_IF
		END_IF
		
	3:	//Transfer left to slot
		A_TransferTrayLeftToSlot();
		IF nStateA_TransferTray >= 80 THEN
			IF nStateA_TransferTray = 99 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;
			END_IF
			nStateA_TransferTray := 0;
		END_IF
	
	4:	//Transfer right to slot
		A_TransferTrayRightToSlot();
		IF nStateA_TransferTray >= 80 THEN
			IF nStateA_TransferTray = 99 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;
			END_IF
			nStateA_TransferTray := 0;
		END_IF
	
	5:	//Transfer slot to left
		A_TransferTraySlotToLeft();
		IF nStateA_TransferTray >= 80 THEN
			IF nStateA_TransferTray = 99 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;
			END_IF
			nStateA_TransferTray := 0;
		END_IF
	
	6:	//Transfer slot to right
		A_TransferTraySlotToRight();
		IF nStateA_TransferTray >= 80 THEN
			IF nStateA_TransferTray = 99 THEN
				nActionState := 99;
			ELSE
				nActionState := 80;
			END_IF
			nStateA_TransferTray := 0;
		END_IF
		
	70:	//Abbrechen
		IF pTrayTransporter^.P_bBusy THEN
			pTrayTransporter^.M_Stop();
		ELSE
			nStateA_TransferTray := 0;
			nActionState := 80;
		END_IF
END_CASE	]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferTrayLeftToSlot" Id="{7c085589-7c41-4fab-8574-ac4ed088611f}">
      <Implementation>
        <ST><![CDATA[CASE nStateA_TransferTray OF
	0:	//TransferStation ready for transfer?
		stError.ErrorId := pTrayTransporter^.M_GetStateForTransfer(E_TransferTrayCtrl.LeftToSlot);
		IF stError.ErrorId = 0 THEN
			nStateA_TransferTray := 1;
		ELSE
			nStateA_TransferTray := 99;
		END_IF
		
	1:	//Move slider TransferPosition left
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		stActionData.aParams[1] := pTrayTransporter^.P_nTransferPosLeft;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 2;
		END_IF
		
	2:	//Move ready? DrivingPin left vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 3;
			END_IF
		END_IF
		
	3:	//TurnDrivingPin ready? -> Move slider to slot + gap
		//Hier kann es sein, dass es nicht mit einem Zug geht.
		//Wenn also die TransferPos > als max SliderPos ist, dann wird zuerst bis max. Pos gefahren und dann über die mittlere Aussparung
		//das benötigt zusätzliche Steps
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Left, E_TrayHollowSelection.Right) + pTrayTransporter^.P_nDrivingPinGap;
			IF nTransferTrayPos > pTrayTransporter^.P_nMaxSliderPos THEN
				nTransferTrayPos := pTrayTransporter^.P_nMaxSliderPos;
				nStateA_TransferTray := 4;
			ELSE
				nStateA_TransferTray := 20;
			END_IF
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			END_IF
		END_IF
		
	4:	//Move ready? -> Move slider centre hollow (last pos - gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos :=  nTransferTrayPos - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 5;
			END_IF
		END_IF
		
	5:	//Move ready? DrivingPinLeft horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 6;
			END_IF
		END_IF
		
	6:	//TurnDrivingPin ready? -> Move slider centre of tray (relative)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := nTransferTrayPos - pTrayTransporter^.P_nTrayLength /2 + pTrayTransporter^.P_nHollowDistance;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 7;
			END_IF
		END_IF
		
	7:	//Move ready? DrivingPinLeft vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 8;
			END_IF
		END_IF
		
	8:	//TurnDrivingPin ready? -> Move slider to Slot
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Left, E_TrayHollowSelection.Centre) + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 20;
			END_IF
		END_IF
		
	
	//Hier wird die Abzweigung in State "3" wieder zusammengeführt
		
	20:	//Move ready? -> Move slider centre hollow (last pos - gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			stActionData.aParams[1] := nTransferTrayPos - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 21;
			END_IF
		END_IF
		
	21:	//Move ready? DrivingPinLeft horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 22;
			END_IF
		END_IF

	22:	//TurnDrivingPin ready? -> Lock TrayLock
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_LockUnlock;
			stActionData.aParams[1] := E_LockCtrl.Lock;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 23;
			END_IF
		END_IF
		
	23:	//TrayLock ready? -> Action ready
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_LockUnlock) THEN
			nStateA_TransferTray := 80;
		END_IF
END_CASE

//Errorhandling
IF nStateA_TransferTray = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferTray;
	stError.POUAction := E_POUACT.POUACT_A_TransferTrayLeftToSlot;
	fbErrorList.M_Add(stError);	
END_IF


]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferTrayRightToSlot" Id="{fa6d4461-e4ef-4b76-a3f9-768d45e0fc29}">
      <Implementation>
        <ST><![CDATA[CASE nStateA_TransferTray OF
	0:	//TransferStation ready for transfer?
		stError.ErrorId := pTrayTransporter^.M_GetStateForTransfer(E_TransferTrayCtrl.RightToSlot);
		IF stError.ErrorId = 0 THEN
			nStateA_TransferTray := 1;
		ELSE
			nStateA_TransferTray := 99;
		END_IF
		
	1:	//Move slider TransferPosition right
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		stActionData.aParams[1] := pTrayTransporter^.P_nTransferPosRight;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 2;
		END_IF
		
	2:	//Move ready? DrivingPin right vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 3;
			END_IF
		END_IF
		
	3:	//TurnDrivingPin ready? -> Move slider to SafePosLeft
		//Zuerst soweit wie möglich nach links fahren und dann um Abstand der äußeren Aussparungen wieder nach rechts fahren
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nSafePosLeft;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 4;
			END_IF
		END_IF
		
	4:	//Move ready? -> Move slider centre hollow (last pos + gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos :=  nTransferTrayPos + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 5;
			END_IF
		END_IF
		
	5:	//Move ready? DrivingPinRight horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 6;
			END_IF
		END_IF
		
	6:	//Right hollow reachable?
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			IF bAdditionalMoves THEN
				IF nTransferTrayPos + pTrayTransporter^.P_nHollowToHollow / 2 <= pTrayTransporter^.P_nMaxSliderPos THEN
					nStateA_TransferTray := 10;
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_CanNotTransferTrayCompletely;
					nStateA_TransferTray := 99; 
				END_IF
			ELSE
				IF nTransferTrayPos + pTrayTransporter^.P_nHollowToHollow <= pTrayTransporter^.P_nMaxSliderPos  THEN
					nStateA_TransferTray := 10;
				ELSE
					nStateA_TransferTray := 7;
				END_IF
			END_IF
		END_IF
		
	7:	//Move slider to middle hollow
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nTrayLength/2 - pTrayTransporter^.P_nHollowDistance;
		stActionData.aParams[1] := nTransferTrayPos;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 8;
		END_IF
		
	8:	//Move ready? DrivingPin right vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 9;
			END_IF
		END_IF
		
	9:	//TurnDrivingPin ready? -> Move SafePosL
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nSafePosLeft;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				bAdditionalMoves := TRUE;
				nStateA_TransferTray := 4;
			END_IF
		END_IF

	10:	//TurnDrivingPin ready? -> Move slider at distance of both hollows (relative to previous position)
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		IF bAdditionalMoves THEN //wird in State
			nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nHollowToHollow / 2;
		ELSE
			nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nHollowToHollow;	
		END_IF
		stActionData.aParams[1] := nTransferTrayPos;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 11;
		END_IF
		
	11:	//Move ready? DrivingPinRight vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 12;
			END_IF
		END_IF
		
	12:	//TurnDrivingPin ready? -> Move slider to slot - DrivingPinGap
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Right, E_TrayHollowSelection.Right) - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 13;
			END_IF
		END_IF
		
	13:	//Move ready? -> Move slider centre hollow (last pos - gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos :=  nTransferTrayPos + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 14;
			END_IF
		END_IF

	14:	//Move ready? DrivingPinLeft horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 15;
			END_IF
		END_IF
		
	15:	//TurnDrivingPin ready? -> Lock TrayLock
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_LockUnlock;
			stActionData.aParams[1] := E_LockCtrl.Lock;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 16;
			END_IF
		END_IF
		
	16:	//TrayLock ready? -> Action ready
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_LockUnlock) THEN
			nStateA_TransferTray := 80;
		END_IF		

END_CASE

//Errorhandling
IF nStateA_TransferTray = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferTray;
	stError.POUAction := E_POUACT.POUACT_A_TransferTrayRightToSlot;
	fbErrorList.M_Add(stError);	
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferTraySlotToLeft" Id="{478815e5-45ed-4b2a-962d-6dd2471a718a}">
      <Implementation>
        <ST><![CDATA[CASE nStateA_TransferTray OF
	0:	//TransferStation ready for transfer?
		stError.ErrorId := pTrayTransporter^.M_GetStateForTransfer(E_TransferTrayCtrl.SlotToLeft);
		IF stError.ErrorId = 0 THEN
			nStateA_TransferTray := 1;
		ELSE
			nStateA_TransferTray := 99;
		END_IF
		
	1:	//Move slider to slot
		//Hier kann es sein, dass zwei Züge erforderlich sind
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		nTransferTrayPos := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Left, E_TrayHollowSelection.Right);
		IF nTransferTrayPos > pTrayTransporter^.P_nMaxSliderPos THEN //Mittlere Aussparung nutzen
			nTransferTrayPos := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Left, E_TrayHollowSelection.Centre);
			bAdditionalMoves := TRUE;
		ELSE
			bAdditionalMoves := FALSE;
		END_IF		
		stActionData.aParams[1] := nTransferTrayPos;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 2;
		END_IF
		
	2:	//Move ready? DrivingPinLeft vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 3;
			END_IF
		END_IF
		
	3:	//TurnDrivingPin ready? -> Move slider TransferPosition left - DrivingPinGap
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nTransferPosLeft - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 4;
			END_IF
		END_IF
		
	4:	//Move ready? -> Move slider centre hollow (last pos + gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 5;
			END_IF
		END_IF
		
	5:	//Move ready? DrivingPinLeft horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 6;
			END_IF
		END_IF
		
	6:	//TurnDrivingPin ready? -> Move slider ??????
		//Slider muss jetzt um die Distanz von Mitte Ausssparung bis rechte Aussparung fahren
		//Achtung, Kommentar richtig stellen
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			IF bAdditionalMoves THEN
				stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
				nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nTrayLength /2 - pTrayTransporter^.P_nHollowDistance;
				stActionData.aParams[1] := nTransferTrayPos;
				stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
				stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
				IF stError.ErrorId > 0 THEN
					nStateA_TransferTray := 99;
				ELSE
					nStateA_TransferTray := 7;
				END_IF
			ELSE
				nStateA_TransferTray := 11;
			END_IF
		END_IF
		
	7:	//Move ready? DrivingPinLeft vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 8;
			END_IF
		END_IF
		
	8:	//TurnDrivingPin ready? -> Move slider TransferPosLeft - DrivingPinGap
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nTransferPosLeft - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 9;
			END_IF
		END_IF
		
	9:	//Move ready? -> Move slider centre hollow (last pos + gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := nTransferTrayPos + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 10;
			END_IF
		END_IF		
		
	10:	//Move ready? DrivingPinLeft horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Left;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 11;
			END_IF
		END_IF
		
	11:	//TurnDrivingPin ready? -> Move slider SafePosLeft
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nSafePosLeft;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 12;
			END_IF
		END_IF
		
	12:	//TurnDrivingPin ready? -> Action ready
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			nStateA_TransferTray := 80;
		END_IF		
	
END_CASE

//Errorhandling
IF nStateA_TransferTray = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferTray;
	stError.POUAction := E_POUACT.POUACT_A_TransferTraySlotToLeft;
	fbErrorList.M_Add(stError);	
END_IF]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_TransferTraySlotToRight" Id="{7f183d0b-1960-405a-90c8-be7941ebb145}">
      <Implementation>
        <ST><![CDATA[CASE nStateA_TransferTray OF
	0:	//TransferStation ready for transfer?
		stError.ErrorId := pTrayTransporter^.M_GetStateForTransfer(E_TransferTrayCtrl.SlotToRight);
		IF stError.ErrorId = 0 THEN
			nStateA_TransferTray := 1;
		ELSE
			nStateA_TransferTray := 99;
		END_IF
		
	1:	//Move slider to slot (right hollow with right driving pin)
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		stActionData.aParams[1] := pTrayTransporter^.M_GetSliderPosTrayInSlot(E_DrivingPinSelection.Right, E_TrayHollowSelection.Right);
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 2;
		END_IF
		
	2:	//Move ready? DrivingPinLeft vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 3;
			END_IF
		END_IF
		
	3:	//Move slider TransferPosition right
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nTransferPosRight;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 4;
			END_IF		
		END_IF
		
	4:	//Move ready? -> Move slider centre hollow (last pos + gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos :=  nTransferTrayPos - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 5;
			END_IF
		END_IF
		
	5:	//Move ready? DrivingPinRight horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 6;
			END_IF
		END_IF
		
	6:	//Left hollow reachable?
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			IF bAdditionalMoves THEN
				IF nTransferTrayPos - pTrayTransporter^.P_nHollowToHollow / 2 >= pTrayTransporter^.P_nMinSliderPos THEN
					nStateA_TransferTray := 10;
				ELSE
					stError.ErrorId := E_ErrorIdCmd.ERRORID_CanNotTransferTrayCompletely;
					nStateA_TransferTray := 99; 
				END_IF
			ELSE
				IF nTransferTrayPos - pTrayTransporter^.P_nHollowToHollow >= pTrayTransporter^.P_nMinSliderPos  THEN
					nStateA_TransferTray := 10;
				ELSE
					nStateA_TransferTray := 7;
				END_IF
			END_IF
		END_IF
		
	7:	//Move slider to middle hollow
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		nTransferTrayPos := nTransferTrayPos - pTrayTransporter^.P_nTrayLength/2 + pTrayTransporter^.P_nHollowDistance;
		stActionData.aParams[1] := nTransferTrayPos;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 8;
		END_IF
		
	8:	//Move ready? DrivingPin right vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 9;
			END_IF
		END_IF
		
	9:	//TurnDrivingPin ready? -> Move TransferPosR
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nTransferPosRight;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				bAdditionalMoves := TRUE;
				nStateA_TransferTray := 4;
			END_IF
		END_IF
		
	10:	//TurnDrivingPin ready? -> Move slider at distance of both hollows (relative to previous position)
		stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
		IF bAdditionalMoves THEN //wird in State
			nTransferTrayPos := nTransferTrayPos - pTrayTransporter^.P_nHollowToHollow / 2;
		ELSE
			nTransferTrayPos := nTransferTrayPos - pTrayTransporter^.P_nHollowToHollow;	
		END_IF
		stActionData.aParams[1] := nTransferTrayPos;
		stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
		stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nStateA_TransferTray := 99;
		ELSE
			nStateA_TransferTray := 11;
		END_IF
		
	11:	//Move ready? DrivingPinRight vertical
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Vertical;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 12;
			END_IF
		END_IF
		
	12:	//TurnDrivingPin ready? -> Move TransferPosR + DrivingPinGap
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos := pTrayTransporter^.P_nTransferPosRight + pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := cMoveTraySpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 13;
			END_IF
		END_IF
		
	13:	//Move ready? -> Move slider centre hollow (last pos + gap)
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_MoveTrayTransporter;
			nTransferTrayPos :=  nTransferTrayPos - pTrayTransporter^.P_nDrivingPinGap;
			stActionData.aParams[1] := nTransferTrayPos;
			stActionData.aParams[2] := pTrayTransporter^.P_nMaxSliderSpeed;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 14;
			END_IF
		END_IF
		
	14:	//Move ready? DrivingPinRight horizontal
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_MoveTrayTransporter) THEN
			stActionData.eAction := E_Action.ACTION_TurnDrivingPin;
			stActionData.aParams[1] := E_DrivingPinSelection.Right;
			stActionData.aParams[2] := E_DrivingPinCtrl.Horizontal;
			stError.ErrorId := pTrayTransporter^.M_ExeAction(stActionData);
			IF stError.ErrorId > 0 THEN
				nStateA_TransferTray := 99;
			ELSE
				nStateA_TransferTray := 15;
			END_IF
		END_IF
		
	15:	//TurnDrivingPin ready? -> Action ready
		IF NOT pTrayTransporter^.M_GetActionBusy(E_Action.ACTION_TurnDrivingPin) THEN
			nStateA_TransferTray := 80;
		END_IF		
		
END_CASE

//Errorhandling
IF nStateA_TransferTray = 99 THEN
	stError.Cmd := E_Action.ACTION_TransferTray;
	stError.POUAction := E_POUACT.POUACT_A_TransferTraySlotToRight;
	fbErrorList.M_Add(stError);	
END_IF
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_WashTool" Id="{e67038f0-0cd2-40d8-8fd9-6c024fecd1d8}">
      <Implementation>
        <ST><![CDATA[stError.POUState := nActionState;

IF pMzTool^.P_bError THEN
	stError.ObjectId := pMzTool^.P_nObjectID;
	stError.ErrorId := pMzTool^.P_nErrorId;
	nActionState := 99;	
ELSIF pWashStation^.P_bError THEN
	stError.ObjectId := pWashStation^.P_nObjectID;
	stError.ErrorId := pWashStation^.P_nErrorId;
	nActionState := 99;
END_IF

CASE nActionState OF
	0:	//MoveToTarget "Washpoint"
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveToTarget;
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
			pTwinPiezoHolder := pMzTool;
 			stActionData.nObject := pTwinPiezoHolder^.P_pPiezoPipFirst^.P_nObjectID;
		ELSE
			stActionData.nObject := pMzTool^.P_nObjectID;
		END_IF
		
		stActionData.nTarget := pTarget^.P_nObjectID;
		stActionData.aParams[1] := E_TargetRef.TARGETREF_SpecPoint;
		stActionData.aParams[2] := nSpecPointSlotNr;
		stActionData.aParams[5] := -1;	//MaxSpeed X
		stActionData.aParams[6] := -1;	//MaxSpeed Y
		stActionData.aParams[7] := -1;	//Speed Z
		
		stError.ErrorId := fbMoveToTarget.M_SetAndCheckParams(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			fbMoveToTarget(bExecute:= TRUE);
			nActionState := 1;
		END_IF
		
	1:	//MoveToTarget ready?
		fbMoveToTarget(bExecute:= TRUE);
		IF NOT fbMoveToTarget.bBusy THEN
			IF fbMoveToTarget.bError THEN
				stError.ErrorId := fbMoveToTarget.nErrorId;
				nActionState := 99;
			ELSE
				nActionState := 2;
				//WastePumpe in jedem Fall einschalten
				IF eWashMode <> E_WashMode.MODE_DryOutside THEN
					MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
					stActionData.eAction := E_Action.ACTION_SwitchPump;
					stActionData.aParams[1] := 0; //WastePump
					stActionData.aParams[2] := 1; //On
					stError.ErrorId := pWashStation^.M_ExeAction(stActionData);
					IF stError.ErrorId > 0 THEN
						nActionState := 99;
					END_IF
				END_IF
			END_IF
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
	2:	//Abhängig vom Washmode Dispensen bzw. Washststation aktivieren
		nActionState := 3;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		CASE eWashMode OF
			E_WashMode.MODE_WashInside:
				//Tool dispensen
				//Für den Fall, dass Tool eine Piezo ist, dann soll diese auch Dispense Drops ausführen
				stActionData.eAction := E_Action.ACTION_Dispense;
				//überprüfen, ob bei nQuantity 0, ein Dauerdispensen erfolgt.
				//bisher noch nicht, es wurde nur beim HybridDispenser benutzt
				//es kann aber noch in M_ExeAction so umgebaut werden, dass es so funktioniert.
				stActionData.aParams[1] := nQuantity1;
				stActionData.aParams[2] := nFlow1;
				stActionData.aParams[3] := nDilInputNr;
				stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
				IF stError.ErrorId = 0 THEN
					//Für den Fall, dass Tool eine Piezo ist, dann soll diese auch Dispense Drops machen ausführen
					IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PiezoPip OR pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
						MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
						stActionData.eAction := E_Action.ACTION_DispenseDrops;
						stActionData.aParams[2] := 1; //DispCtrl = On
						stActionData.aParams[5] := 1; //Skip valve move
						stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					END_IF
				END_IF
				nActionState := 3;
			E_WashMode.MODE_WashInOutside:
				//Washstation spülen Ein
				stActionData.eAction := E_Action.ACTION_Rinse;
				stActionData.aParams[1] := nRinseChannel;
				stActionData.aParams[2] := 1; //Rinse "ON
				stActionData.aParams[3] := DWORD_TO_DINT(nTime); //Time
				stActionData.aParams[4] := 1; //KeepWastePumpOn
				stError.ErrorId := pWashStation^.M_ExeAction(stActionData);
				IF stError.ErrorId = 0 THEN
					stActionData.eAction := E_Action.ACTION_Dispense;
					stActionData.aParams[1] := nQuantity1;
					stActionData.aParams[2] := nFlow1;
					stActionData.aParams[3] := nDilInputNr;
					stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
					IF stError.ErrorId = 0 THEN
						//Für den Fall, dass Tool eine Piezo ist, dann soll diese auch Dispense Drops machen ausführen
						IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PiezoPip OR pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
							MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
							stActionData.eAction := E_Action.ACTION_DispenseDrops;
							stActionData.aParams[2] := 1; //DispCtrl = On
							stActionData.aParams[5] := 1; //Skip valve move
							stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
						END_IF
					END_IF
					nActionState := 3;
				END_IF
			E_WashMode.MODE_WashOutside:
				//Washstation spülen Ein
				stActionData.eAction := E_Action.ACTION_Rinse;
				stActionData.aParams[1] := nRinseChannel;
				stActionData.aParams[2] := 1; //Rinse "ON
				stActionData.aParams[3] := UDINT_TO_DINT(nTime); //Time
				stError.ErrorId := pWashStation^.M_ExeAction(stActionData);
				nActionState := 3;
			E_WashMode.MODE_DryOutside:
				//Luftdusche "Ein"
				stError.ErrorId := pWashStation^.M_SwitchAirShower(TRUE);
				nActionState := 10;
		END_CASE
		
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		END_IF					
		
	3:	//warten bis Dispensen bzw Time abgelaufen
		CASE eWashMode OF
			E_WashMode.MODE_WashInside:
				//Warten, bis Dispensen fertig
				IF NOT pMzTool^.M_GetActionBusy(E_ACTION.ACTION_Dispense) THEN
					pMzTool^.M_CancelAction(E_Action.ACTION_DispenseDrops);
					//WashStation leeren (dadurch wird aktivierte Wastepumpe auch abgeschalten)
					stActionData.eAction := E_Action.ACTION_EmptyWaste;
					pWashStation^.M_ExeAction(stActionData);
					nActionState := 4; //langsam heraus fahren
				END_IF
			E_WashMode.MODE_WashInOutside:
				//Für den Fall, dass Dispense auf Dauerdispensen eingestellt ist dann muss dieses abgebrochen werden wenn Rinse
				//fertig ist.
				IF nQuantity1 = 0 THEN //Dauerdispensen
					IF NOT pWashStation^.M_GetActionBusy(E_ACTION.ACTION_Rinse) THEN
						pMzTool^.M_CancelAction(E_Action.ACTION_Dispense);
						pMzTool^.M_CancelAction(E_Action.ACTION_DispenseDrops);
						//WashStation leeren (dadurch wird aktivierte Wastepumpe auch abgeschalten)
						stActionData.eAction := E_Action.ACTION_EmptyWaste;
						pWashStation^.M_ExeAction(stActionData);
						nActionState := 4; //langsam heraus fahren
					END_IF
				ELSE
					IF NOT (pMzTool^.M_GetActionBusy(E_ACTION.ACTION_Dispense) OR pWashStation^.M_GetActionBusy(E_ACTION.ACTION_Rinse)) THEN
						pMzTool^.M_CancelAction(E_Action.ACTION_DispenseDrops);
						//WashStation leeren (dadurch wird aktivierte Wastepumpe auch abgeschalten)
						stActionData.eAction := E_Action.ACTION_EmptyWaste;
						pWashStation^.M_ExeAction(stActionData);
						nActionState := 4; //langsam heraus fahren
					END_IF					
				END_IF
			E_WashMode.MODE_WashOutside:
				IF NOT pWashStation^.M_GetActionBusy(E_ACTION.ACTION_Rinse) THEN
					nActionState := 6; //Move free
				END_IF			
		END_CASE
		
	4:	//MoveZ bis OK WashStation langsam
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stPoint1 := pWashStation^.P_stAbsPosCenter;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint1.Z);
		stActionData.aParams[3] := 5000; //Speed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN
			nActionState := 99;
		ELSE
			nActionState := 5;
		END_IF
		
	5:	//MoveZ ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 6;
		END_IF
	
	6:	//MoveFree
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_Free;
		stActionData.aParams[3] := -1;	//MaxSpeed
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 7;
		END_IF
		
	7:	//MoveFree ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 80;
		END_IF

	10:	//Drying
		//MoveUp über Zeit
		//Distance berechnen aus aktueller Position minus Oberkante WashStation
		//Speed berechnen aus Distance und Time
		//Achtung! Begrenzung MaxSpeed
		stPoint1 := pMzTool^.P_stCurrentPosTotal;
		stPoint2 := pWashStation^.P_stAbsPosCenter;
		MEMSET(ADR(stActionData),0,SIZEOF(stActionData));
		stActionData.eAction := E_Action.ACTION_MoveZ;
		stActionData.aParams[1] := E_MoveMode.MODE_AbsWithOffset;
		stActionData.aParams[2] := REAL_TO_DINT(stPoint2.Z); //Oberkante Waschstation
		stActionData.aParams[3] :=  REAL_TO_DINT((stPoint2.Z - stPoint1.Z) / (UDINT_TO_REAL(nTime) / 1000.0)); //Speed berechnet aus Zeit und Weg
		stError.ErrorId := pMzTool^.M_ExeAction(stActionData);
		IF stError.ErrorId > 0 THEN	//Error
			nActionState := 99;
		ELSE
			nActionState := 11;
		END_IF
		
	11:	//MoveUp ready?
		IF NOT pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			pWashStation^.M_SwitchAirShower(FALSE);
			nActionState := 4;
		END_IF
	
	70:	//Abbrechen
		nActionState := 80;
		//Actionen der beteiligten Decvices abbrechen
		//MoveToTarget oder MoveZ vom MzTool abbrechen (schließen sich gegenseitig aus)
		IF fbMoveToTarget.bBusy THEN
			nActionState := 70;
			fbMoveToTarget(bStop:= TRUE);
		ELSIF pMzTool^.M_GetActionBusy(E_Action.ACTION_MoveZ) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_MoveZ);
		ELSE
			fbMoveToTarget(bExecute:= FALSE);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_Dispense) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_Dispense);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_DispenseDrops) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_DispenseDrops);
		END_IF

		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SetPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SetPressure);
		END_IF
		
		IF pMzTool^.M_GetActionBusy(E_Action.ACTION_SwitchPressure) THEN
			nActionState := 70;
			pMzTool^.M_CancelAction(E_Action.ACTION_SwitchPressure);
		END_IF
		
		pWashStation^.M_Stop();	
END_CASE

//Errorhandling
IF nActionState = 99 THEN
	pMzTool^.M_Stop();
	pWashStation^.M_Stop();
	fbMoveToTarget(bExecute:= FALSE);
	stError.Cmd := E_Action.ACTION_WashTool;
	stError.POUAction := E_POUACT.POUACT_A_WashTool;
	fbErrorList.M_Add(stError);	
END_IF]]></ST>
      </Implementation>
    </Action>
    <Method Name="FB_init" Id="{a87249a9-16e6-4a89-8244-de38d471c1da}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	bInitRetains : BOOL; // if TRUE, the retain variables are initialized (warm start / cold start)
	bInCopyCode : BOOL;  // if TRUE, the instance afterwards gets moved into the copy code (online change)
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[stError.POU := E_POU.POU_FB_ComplexAction;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Continue" Id="{06aa16b8-528c-4042-9e87-1adca7f253e9}">
      <Declaration><![CDATA[METHOD M_Continue
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eCurrentState = E_MachineState.MACHINESTATE_Pause THEN
	eCurrentState := E_MachineState.MACHINESTATE_Active;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ExeAction" Id="{2dfbeeb4-beee-4d31-a41a-4d7e5517d911}">
      <Declaration><![CDATA[METHOD M_ExeAction : ERRORID
VAR_INPUT
	refActionData : REFERENCE TO ST_ActionData;
END_VAR

VAR
	i			: UINT;
	nObjectId	: UINT;
END_VAR
VAR CONSTANT
	cHighVoltThreshold : DINT := 25;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Es kann immer nur eine ComplexAction aktiv werden
IF eCurrentState = E_MachineState.MACHINESTATE_Active THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_ComplexActionActive;
	RETURN;
END_IF

IF eCurrentState = E_MachineState.MACHINESTATE_PauseRequest OR eCurrentState = E_MachineState.MACHINESTATE_Pause THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_ComplexActionActive;
	RETURN;
END_IF

IF NOT eCurrentState = E_MachineState.MACHINESTATE_Idle THEN
	M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidState;
	RETURN;	
END_IF

//Es darf keine XY-Bewegung an einem Kopf stattfinden (mit Ausnahme)
//Welche Ausnahme soll denn das sein?
FOR i:= 1 TO fbObjectDirectory.nCntMZHead BY 1 DO 
	IF afbMzHead[i].P_bZIsMoving OR afbMzHead[i].P_bXYIsMoving THEN
		M_ExeAction := E_ErrorIdMultiZ.ERRORID_MultiZIsStillMoving;
		RETURN;
	END_IF
END_FOR

CASE refActionData.eAction OF
	E_Action.ACTION_ActionOnArray:
		//Object gültiges MzTool?
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		eActOnArrayOrder := DINT_TO_USINT(refActionData.aParams[1]);
		nActOnArraySpeedX := refActionData.aParams[2];
		nActOnArraySpeedY := refActionData.aParams[3];
		nActOnArraySpeedZ := refActionData.aParams[4];
		nActOnArraySpeedZRelease := refActionData.aParams[5];
		nZOffset1 := refActionData.aParams[6];	//ZOffsetAction
		nDistance1 := refActionData.aParams[7];	//ZDistanceRelease
		nZOffset2 := refActionData.aParams[8];	//ZOffsetXYMove
		
		bReleaseMoveInstantly := DINT_TO_BOOL(refActionData.aParams[9]);
		tReleaseMoveDelay := DINT_TO_TIME(refActionData.aParams[10]);
		
		//SubAction von stActionData auf stActionData2 übertragen
		
		MEMSET(ADR(stActionData2),0,SIZEOF(stActionData2));
		stActionData2.nObject := refActionData.nObject;
		stActionData2.eAction := DINT_TO_UINT(refActionData.aParams[11]);
		MEMCPY(ADR(stActionData2.aParams),ADR(refActionData.aParams[12]),32);
		
		
		//Action mit MzTool ausführbar?
		M_ExeAction := pMzTool^.M_CheckAction(stActionData2,0); 
		IF M_ExeAction > 0 THEN //Error
			RETURN;
		END_IF
		
		//Ist die Action im Allgemeinen geeignet?
		IF NOT(stActionData2.eAction = E_Action.ACTION_Aspirate OR
			stActionData2.eAction = E_Action.ACTION_Dispense OR
			stActionData2.eAction = E_Action.ACTION_DispenseDrops OR
			stActionData2.eAction = E_Action.ACTION_Expose OR
			stActionData2.eAction = E_Action.ACTION_Extrude OR
			stActionData2.eAction = E_Action.ACTION_PickPutPowder OR
			stActionData2.eAction = E_Action.ACTION_PulsePressure OR
			stActionData2.eAction = E_Action.ACTION_StampDemolding OR
			stActionData2.eAction = E_Action.ACTION_Mix OR
			stActionData2.eAction = E_Action.ACTION_SwitchPressure OR
			stActionData2.eAction = E_Action.ACTION_TakePicture) THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidAction;
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_SpotArray OR
			fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Mtp THEN
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			pArray := pTarget;
			nTargetCol := 0;
			nTargetRow := 0;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_CartDispenser OR 
									pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_CartDispStirrer THEN
				pCartDispenser := pMzTool;
			END_IF			
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold THEN
				IF NOT(pCartDispenser > 0 AND_THEN pCartDispenser^.P_bIsMESTool) THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
					RETURN;
				END_IF
			END_IF
		END_IF
		
	E_Action.ACTION_CalibrateZSensor:
		IF fbObjectDirectory.M_GetObjType(refActionData.nObject) = E_ObjectType.OBJECTTYPE_ZSensor THEN
			pZLevelSensor := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			//ZSensor montiert?
			IF NOT pZLevelSensor^.P_bSensorMounted THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_ZSensorNotMounted;  //Error
				RETURN;
			END_IF
			//ZSensor kann nur an einem "Point" kalibriert werden
			IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) <> E_ObjectType.OBJECTTYPE_Point THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget; //Error
				RETURN;	
			END_IF
			//Point darf keinen Offset haben
			IF pTarget^.P_rZOffset <> 0.0 THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_CalibrationPointHasAnOffset; //Error
				RETURN;	
			END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject; //Error
			RETURN;
		END_IF

		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
				RETURN;
			END_IF
		END_IF
	
	E_Action.ACTION_CleanTip:
		//Mit Object ausführbar?
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		IF pMzTool = 0 THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;
			RETURN;
		END_IF
		
		CASE pMzTool^.P_eObjectType OF
			E_ObjectType.OBJECTTYPE_CartDispenser,
			E_ObjectType.OBJECTTYPE_CartDispStirrer:
				pCartDispenser := pMzTool;
				iDispenser := pCartDispenser^;
			E_ObjectType.OBJECTTYPE_MultiCartHolder:
				pMultiCartHolder := pMzTool;
				iDispenser := pMultiCartHolder^;
			E_ObjectType.OBJECTTYPE_Extruder:
				pExtruder := pMzTool;
				iDispenser := pExtruder^;
			E_ObjectType.OBJECTTYPE_TwinExtruder:
				pTwinExtruder := pMzTool;
				iDispenser := pTwinExtruder^;
			E_ObjectType.OBJECTTYPE_HybridDispenser:
				pHybridDispenser := pMzTool;
				iDispenser := pHybridDispenser^;
			E_ObjectType.OBJECTTYPE_PassivPip:
				pPassivePip := pMzTool;
				iDispenser := pPassivePip^;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;
			RETURN;
		END_CASE
		
		pTipCleaner := 0;
		pTipCleanerGen2 := 0;
		//Ist Target ein TipCleaner?
		CASE fbObjectDirectory.M_GetObjType(refActionData.nTarget)OF
			E_ObjectType.OBJECTTYPE_TipCleaner:
				pTipCleaner := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			E_ObjectType.OBJECTTYPE_TipCleanerGen2:
				pTipCleaner := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
				pTipCleanerGen2 := pTipCleaner;
				pSlot := pTipCleanerGen2^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[1]));
				IF pSlot = 0 THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTargetSlot;
					RETURN;
				END_IF
				eCleaningMode := DINT_TO_USINT(refActionData.aParams[2]);
				tCleaningDispenseTime := DINT_TO_TIME(refActionData.aParams[3]);
				nCleaningWireSpeed := refActionData.aParams[4];
				IF nCleaningWireSpeed < 1 THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidCleaningWireSpeed;
					RETURN;
				END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		END_CASE
 		
		
	E_Action.ACTION_DispenseTest:
		IF (fbObjectDirectory.M_GetObjType(refActionData.nObject) <> E_ObjectType.OBJECTTYPE_PiezoPip) AND
			(fbObjectDirectory.M_GetObjType(refActionData.nObject) <> E_ObjectType.OBJECTTYPE_TwinPiezoHolder) THEN //Object gültiges MzTool?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;
			RETURN;
		END_IF

		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) <> E_ObjectType.OBJECTTYPE_Stroboscope THEN //Target gültig?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		END_IF	
		
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pPiezoPip := pMzTool;
		pStroboscope := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		nDispenseTestArg2 := refActionData.aParams[1];
		bInhibitDispenseTrials := DINT_TO_BOOL(refActionData.aParams[2]);
		
	E_Action.ACTION_DockTool:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Gültiges Target?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData,pTarget); //Ausführbar mit MzTool?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		M_ExeAction := pTarget^.M_CheckAction(refActionData,pMzTool); //Ausführbar mit Target?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
			pLuer := pMzTool;
			rSumDockOffset := pLuer^.P_rDockOffset;
		ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TriplePip THEN
			pTriplePip := pMzTool;
			rSumDockOffset := pTriplePip^.P_rDockOffset;
		ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_VacuumHandler THEN
			pVacuumHandler := pMzTool;
			rSumDockOffset := pVacuumHandler^.P_rDockOffset;
		ELSE
			rSumDockOffset := 0;
		END_IF
		
		IF (pTarget^.P_eObjectGroup AND E_ObjectGroup.OBJECTGROUP_Rack) = E_ObjectGroup.OBJECTGROUP_Rack THEN
			pRack := pTarget;
			pPieceSlot := pRack^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[2]));
		ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			pReactor := pTarget;
			pPieceSlot := pReactor^.M_GetSlot(1);
		END_IF
		
		IF pPieceSlot > 0 THEN
			IF pPieceSlot^.P_pPiece > 0 THEN
				rSumDockOffset := rSumDockOffset + pPieceSlot^.P_pPiece^.P_rDockOffset;
			END_IF
		END_IF
		
		nZOffset1 := refActionData.aParams[4];
		
	E_Action.ACTION_DryPip:
		//Object gültiges MzTool?
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF

		//Ist Target ein Drypad
		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) <> E_ObjectType.OBJECTTYPE_DryPad THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		END_IF
		
		pDryPad := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);

		CASE pMzTool^.P_eObjectType OF
			E_ObjectType.OBJECTTYPE_PassivPip:
				pPassivePip := pMzTool;
				iUsingDryPad := pPassivePip^;
			E_ObjectType.OBJECTTYPE_PiezoPip:
				pPiezoPip := pMzTool;
				iUsingDryPad := pPiezoPip^;
			E_ObjectType.OBJECTTYPE_SolenoidPip:
				pSolenoidPip := pMzTool;
				iUsingDryPad := pSolenoidPip^;
			E_ObjectType.OBJECTTYPE_TwinPiezoHolder:
				pTwinPiezoHolder := pMzTool;
				IF (pTwinPiezoHolder^.P_pPiezoPipFirst = 0) OR (pTwinPiezoHolder^.P_pPiezoPipSecond = 0) THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_NotAllPipettesConfigured;
					RETURN;
				ELSE
					iUsingDryPad := pTwinPiezoHolder^.P_pPiezoPipFirst^;
					pMzTool := pTwinPiezoHolder^.P_pPiezoPipFirst;
				END_IF
			E_ObjectType.OBJECTTYPE_Luer:
				//Luer kann derzeit nur mit Needle oder Tip auf dem DryPad trocknen (Kollision)
				IF pMzTool^.P_pPiece = 0 THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_NoPieceOnTool; //Error
					RETURN;
				END_IF
				pLuer :=  pMzTool;
				iUsingDryPad := pLuer^;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidAction;  //Error
			RETURN;
		END_CASE

		IF refActionData.aParams[1] > 0 THEN
			nTime := DINT_TO_UDINT(refActionData.aParams[1]);
		ELSE
			nTime := TIME_TO_UDINT(iUsingDryPad.P_tDryTime);
		END_IF
		nZOffset1 := refActionData.aParams[2];
		
	E_Action.ACTION_DryToolInside:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF	
		
		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) <> E_ObjectType.OBJECTTYPE_WashStation THEN //gültiges Target?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		ELSE
			pWashStation := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		END_IF
		
		//Kann Tool Action ausführen?
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pWashStation);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		//Kann WashStation Action ausführen?
		M_ExeAction := pWashStation^.M_CheckAction(refActionData, pMzTool);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		nSpecPointSlotNr := DINT_TO_UINT(refActionData.aParams[1]);
		nPressure1 := DINT_TO_INT(refActionData.aParams[2]);
		nTime := DINT_TO_DWORD(refActionData.aParams[3]);

	E_Action.ACTION_ExchangePiece:
		IF refActionData.aParams[2] = 0 THEN
			bTakePiece := FALSE;
		ELSIF refActionData.aParams[2] = 1 THEN
			bTakePiece := TRUE;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidCtrl;
			RETURN;
		END_IF
		
		eExchangeOption := DINT_TO_USINT(refActionData.aParams[3]);
		
		IF NOT (eExchangeOption = E_ExchangePieceOption.Slot OR eExchangeOption = E_ExchangePieceOption.NextSlotRespPiece) THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidExchangeOption;
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Object gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		CASE pMzTool^.P_eObjectType OF
			E_ObjectType.OBJECTTYPE_Luer:
				pLuer := pMzTool;
				rSumDockOffset := pLuer^.P_rDockOffset;
			E_ObjectType.OBJECTTYPE_TriplePip:
				pTriplePip := pMzTool;
				rSumDockOffset := pTriplePip^.P_rDockOffset;
			E_ObjectType.OBJECTTYPE_VacuumHandler:
				pVacuumHandler := pMzTool;
				rSumDockOffset := pVacuumHandler^.P_rDockOffset;			
			E_ObjectType.OBJECTTYPE_pHElectrode:
				ppHElectrode := pMzTool;
				//Dockoffset?
			E_ObjectType.OBJECTTYPE_StampSupport:
				pStampSupport := pMzTool;
			E_ObjectType.OBJECTTYPE_Gripper:
				pGripper := pMzTool;
		ELSE
			rSumDockOffset := 0;
		END_CASE
		
		pReactor := 0;
		pPowderStation :=0;
 
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Target gültig?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			//Slot ermitteln
			IF fbObjectDirectory.M_ObjIsRack(pTarget^.P_nObjectID) THEN //Target ein Rack?
				IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_VialRackClosed THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
					RETURN;
				END_IF
				pRack := pTarget;
				IF eExchangeOption = E_ExchangePieceOption.Slot THEN
					pPieceSlot := pRack^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[1]));
					IF pPieceSlot = 0 THEN //Error
						M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTargetSlot;
						RETURN;
					END_IF
				ELSIF eExchangeOption = E_ExchangePieceOption.NextSlotRespPiece THEN
					IF bTakePiece THEN
						pPieceSlot := pRack^.M_GetNextFreshPieceSlot(pMzTool^.M_GetXYRange());
						IF pPieceSlot = 0 THEN //Error
							M_ExeAction := E_ErrorIdCmd.ERRORID_NoFreshPieceAvailable;
							RETURN;
						END_IF
					ELSE
						pPieceSlot := pRack^.M_GetNextFreeSlot(pMzTool^.M_GetXYRange());
						IF pPieceSlot = 0 THEN //Error
							M_ExeAction := E_ErrorIdCmd.ERRORID_NoFreeSlotAvailable;
							RETURN;
						END_IF
					END_IF
					//Überprüfen, ob Tool das Slot erreichen kann.
					//Wenn nicht, dann nächsten Slot holen.
					//Oder lieber den Bereich mit übergeben, in dem ein freier Slot verfügbar ist
					//Tools haben Props, welche die Min/Max-Pos zurückgeben
					
					refActionData.aParams[1] := pPieceSlot^.nNr;
				END_IF
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN //Target ein Reaktor?
				pReactor := pTarget;
				IF eExchangeOption = E_ExchangePieceOption.Slot THEN
					pPieceSlot := pReactor^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[1]));
					IF pPieceSlot = 0 THEN //Error
						M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTargetSlot;
						RETURN;
					END_IF					
				ELSIF eExchangeOption = E_ExchangePieceOption.NextSlotRespPiece THEN
					pPieceSlot := pReactor^.M_GetSlot(1);
				END_IF
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_PowderStation THEN //Target eine PowderStation?
				pPowderStation := pTarget;
				IF eExchangeOption = E_ExchangePieceOption.Slot THEN
					pPieceSlot := pPowderStation^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[1]));
					IF pPieceSlot = 0 THEN //Error
						M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTargetSlot;
						RETURN;
					END_IF					
				ELSIF eExchangeOption = E_ExchangePieceOption.NextSlotRespPiece THEN
					pPieceSlot := pPowderStation^.M_GetSlot(1);
				END_IF				
			ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_SeptumWaste THEN //Target ein SeptumWaste?
				;
			END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		//Piece ermitteln
		pPiece := 0;
		IF bTakePiece THEN //Take, Piece wird vom Slot ermittelt
			IF pPieceSlot^.P_pPiece > 0 THEN
				pPiece := pPieceSlot^.P_pPiece^.P_pLatestChild;
			END_IF
		ELSE //Drop, Piece wird vom Tool ermittelt
			IF pMzTool^.P_pPiece > 0 THEN
				pPiece := pMzTool^.P_pPiece^.P_pLatestChild;
			END_IF
		END_IF
		
		IF pPiece = 0 THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_NoPieceDetermined;
			RETURN;
		END_IF
		
		rSumDockOffset := rSumDockOffset + pPiece^.P_rDockOffset;
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pPiece); //Action mit MzTool ausführbar?
		IF M_ExeAction > 0 THEN //Error
			RETURN;
		END_IF
		
		//Weitere Bedingungen des Targets checken		
		M_ExeAction := pTarget^.M_CheckAction(refActionData, pPiece); //Action mit Target ausführbar?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		bExchangeNeedle := FALSE;
		bExchangeSeptum := FALSE;
		bExchangeTip := FALSE;
		bExchangeStamp := FALSE;
		bExchangeVial := FALSE;
		bExchangepHCap := FALSE;
		
		CASE pPiece^.P_eObjectType OF
			E_ObjectType.OBJECTTYPE_Needle:
				bExchangeNeedle := TRUE;
			E_ObjectType.OBJECTTYPE_Septum:
				bExchangeSeptum := TRUE;
			E_ObjectType.OBJECTTYPE_Tip:
				bExchangeTip := TRUE;
			E_ObjectType.OBJECTTYPE_Stamp:
				pStampMagazine := pTarget;
				bExchangeStamp := TRUE;
			E_ObjectType.OBJECTTYPE_Vial:
				bExchangeVial := TRUE;
			E_ObjectType.OBJECTTYPE_pHElectrodeCap:
				ppHElectrCapRack := pTarget;
				bExchangepHCap := TRUE;
		ELSE
			RETURN;
		END_CASE
 
	E_Action.ACTION_GetPipSample:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Object gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Target gültig?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp THEN //derzeit nur mit Mtp ausführbar
				pMtp := pTarget;	
			ELSE
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
				RETURN;
			END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pTarget); //Action mit MzTool ausführbar?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		nCol := DINT_TO_UINT(refActionData.aParams[1]);
		nRow := DINT_TO_UINT(refActionData.aParams[2]);
		
		//pMzToolSpec := pMzTool;
		
		//Tool ein TwinPipHolder? -> FirstPip muss konfiguriert sein
		//-> SecondPip auch konfiguriert?
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
			//Mtp muss einen Wellabstand von 9mm haben 96er
			IF (pMtp^.P_rSpaceRows > 9500) OR (pMtp^.P_rSpaceRows < 8500) THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_MtpRowRiskOfCrash;
				RETURN;
			END_IF
			
			pTwinPiezoHolder := pMzTool;
			IF (pTwinPiezoHolder^.P_pPiezoPipFirst = 0) OR (pTwinPiezoHolder^.P_pPiezoPipSecond = 0) THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_NotAllPipettesConfigured;
				RETURN;
			ELSE
				//Checken, ob Zeile für Second gültig ist
				IF nRow < 3 THEN //SecondPip würde nicht mehr in Well treffen
					M_ExeAction := E_ErrorIdCmd.ERRORID_MtpRowRiskOfCrash;
					RETURN;
				END_IF
			END_IF
			//pMzTool := pTwinPiezoHolder^.P_pPiezoPipFirst;
		ELSIF pMzTool^.P_pParentMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
			//Kann eintreten, wenn GetPipSample auf eine einzelne Pipette des TwinPipHolders ausgeführt wird
			//Crash der CoPipette mit Mtp verhindern
			pTwinPiezoHolder := pMzTool^.P_pParentMzTool;
			IF pMzTool = pTwinPiezoHolder^.P_pPiezoPipFirst THEN
				IF nRow < 3 THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_MtpRowRiskOfCrash;
					RETURN;
				END_IF
			ELSIF pMzTool = pTwinPiezoHolder^.P_pPiezoPipSecond THEN
				IF (nRow + 2) > pMtp^.P_nRows THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_MtpRowRiskOfCrash;
					RETURN;
				END_IF
			END_IF
		END_IF

		nQuantity1 := refActionData.aParams[3];
		nFlow1 := refActionData.aParams[4];
		nTime := DINT_TO_DWORD(refActionData.aParams[5]);
		nQuantity2 := refActionData.aParams[6];	//Quantity Airgap
		bGetPipSample_SwitchBypass := DINT_TO_BOOL(refActionData.aParams[7]);
		IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PiezoPip OR pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TwinPiezoHolder THEN
			bGetPipSample_ActivatePiezo := DINT_TO_BOOL(refActionData.aParams[8]);
		ELSE
			bGetPipSample_ActivatePiezo := FALSE;
		END_IF
		
		(*IF bGetPipSample_SwitchBypass THEN
			nQuantity2 := 0; //Quantity Airgap auf "0"
		END_IF*)
		
	E_Action.ACTION_InsertTool:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Gültiges Target?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pTarget); //Ausführbar mit MzTool?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		M_ExeAction := pTarget^.M_CheckAction(refActionData, pMzTool); //Ausführbar mit Target?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		M_ExeAction := pMzTool^.M_AskSiblingForAction(E_Action.ACTION_MoveToTarget);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		
		eTargetRef := DINT_TO_USINT(refActionData.aParams[1]);
		nInsertLevel := DINT_TO_USINT(refActionData.aParams[4]);
		
		IF (pTarget^.P_eObjectGroup AND E_ObjectGroup.OBJECTGROUP_Rack) = E_ObjectGroup.OBJECTGROUP_Rack THEN
			pRack := pTarget;
			pPieceSlot := pRack^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[2]));
		ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Reactor THEN
			pReactor := pTarget;
			pPieceSlot := pReactor^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[2]));
		ELSIF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp THEN
			pMtp := pTarget;
		END_IF
		
		IF eTargetRef = E_TargetRef.TARGETREF_Slot THEN
			IF pPieceSlot = 0 THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTargetSlot;
				RETURN;
			ELSE
 				nTargetCol := UINT_TO_USINT(pPieceSlot^.nNr);
				nTargetRow := 0;
			END_IF
		ELSIF eTargetRef = E_TargetRef.TARGETREF_TwoDimArray THEN
			nTargetCol := DINT_TO_USINT(refActionData.aParams[2]);
			nTargetRow := DINT_TO_USINT(refActionData.aParams[3]);
		END_IF
	
	E_Action.ACTION_MeasureTool:
		bMeasureStamp := FALSE;
		bMeasureTarget := FALSE;
		bMeasureTip := FALSE;
		
		eMeasTipOption := DINT_TO_USINT(refActionData.aParams[2]);
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Gültiges Target?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF		
	
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		IF pMzTool = 0 THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_ObjectNotExists;
			RETURN;
		END_IF
		
		CASE pMzTool^.P_eObjectType OF
			E_ObjectType.OBJECTTYPE_CartDispenser,
			E_ObjectType.OBJECTTYPE_CartDispStirrer,
			E_ObjectType.OBJECTTYPE_MultiCartHolder,
			E_ObjectType.OBJECTTYPE_PassivPip,
			E_ObjectType.OBJECTTYPE_PiezoPip,
			E_ObjectType.OBJECTTYPE_SolenoidPip,
			E_ObjectType.OBJECTTYPE_PowderPip,
			E_ObjectType.OBJECTTYPE_Extruder,
			E_ObjectType.OBJECTTYPE_TwinExtruder,
			E_ObjectType.OBJECTTYPE_Luer,
			E_ObjectType.OBJECTTYPE_TitrationTool,
			E_ObjectType.OBJECTTYPE_PickPlacePip:
				bMeasureTip := TRUE;
			E_ObjectType.OBJECTTYPE_HybridDispenser:
				//Gemessen wird mit dem MasterTool des Dispensers
				pHybridDispenser := pMzTool;
				pMzTool := pHybridDispenser^.P_pMasterTool;
				bMeasureTip := TRUE;
			E_ObjectType.OBJECTTYPE_StampSupport:	//Vermessung Stamp
				pStampSupport := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
				IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_InkStation THEN
					pInkStation := pTarget;
					iTargetZSensor := pInkStation^;
				ELSIF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_StampMagazine THEN
					pStampMagazine := pTarget; 
					iTargetZSensor := pStampMagazine^;
				END_IF
				IF iTargetZSensor.P_bSensor THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_SensorAlreadySwitched;
					RETURN;
				END_IF
				bMeasureStamp := TRUE;
			E_ObjectType.OBJECTTYPE_ZSensor:	//Vermessung Target
				IF eMeasTipOption = E_MeasureOption.MEAS_OPTION_SlowApproach OR eMeasTipOption = E_MeasureOption.MEAS_OPTION_FastApproach THEN
					bMeasureTarget := TRUE;
				ELSE
					M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidMeasureOption;
					RETURN;				
				END_IF
			ELSE
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject; //Error
				RETURN;				
		END_CASE
		
		
		//Wenn bMeasureTip, dann muss Target ein TipCalibrator sein
		IF bMeasureTip OR bCalibrateTipCalibrator THEN
			IF NOT pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_TipCalibrator THEN
				bMeasureTip := FALSE;
				bCalibrateTipCalibrator := FALSE;
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
				RETURN;
			END_IF
			pTipCalibrator := pTarget;
			bMeasureTipLegacy := pTipCalibrator^.P_bLegacy;
			
			IF pMzTool^.P_pPiece = 0 THEN
				IF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PassivPip OR
				   pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_PiezoPip OR
				   pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_SolenoidPip OR
				   pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_Luer THEN
				   rMeasureDistance := 6000;
				ELSIF pMzTool^.P_eObjectType = E_ObjectType.OBJECTTYPE_TitrationTool THEN 
				   rMeasureDistance := 10000;
				ELSE
					M_ExeAction := E_ErrorIdCmd.ERRORID_NoPieceOnTool;
					RETURN;
				END_IF
			ELSE
				IF NOT(pMzTool^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_Nozzle OR
					pMzTool^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_Needle OR
					pMzTool^.P_pPiece^.P_eObjectType = E_ObjectType.OBJECTTYPE_Tip) THEN
					M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidPieceType;
					RETURN;
				ELSE
					rMeasureDistance := pMzTool^.P_pPiece^.P_rMeasureDistance;
				END_IF
			END_IF
		END_IF
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pTarget); //Action mit MzTool ausführbar?
		IF M_ExeAction > 0 THEN
			bMeasureTip := FALSE;
			RETURN;
		END_IF
		
		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold THEN //>20 da anloger Eingang etwas rauscht
				M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
				RETURN;
			END_IF
		END_IF
		
		
	E_Action.ACTION_MoveAllHome:
		;

	E_Action.ACTION_MoveToTarget:
		//Tool ermitteln
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF NOT (fbObjectDirectory.M_GetObjType(refActionData.nObject) = E_ObjectType.OBJECTTYPE_MZHead) THEN
			M_ExeAction := pMzTool^.M_AskSiblingForAction(E_Action.ACTION_MoveToTarget);
			IF M_ExeAction > 0 THEN
				RETURN;
			END_IF
		END_IF
		
		//Falls das Target sich auf dem HighVoltTray befindet und dieses auch angeschalten ist, dann ist ein MoveToTarget nur
		//mit einem MES-Tool möglich
		pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		IF pTarget = 0 THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
		END_IF
		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold AND NOT pMzTool^.P_bIsMESTool THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
				RETURN;
			END_IF
		END_IF
	
		M_ExeAction := fbMoveToTarget.M_SetAndCheckParams(refActionData);

		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
	E_Action.ACTION_OpenCloseFlipTube:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN //Gültiges Target?
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_FlipTubeRack THEN //Target ein FlipTubeRack?
				pFlipTubeRack := pTarget;
				pPieceSlot := pFlipTubeRack^.M_GetSlot(DINT_TO_UINT(refActionData.aParams[1]));
			ELSE
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error	
			END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pTarget); //Ausführbar mit Target?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		M_ExeAction := pTarget^.M_CheckAction(refActionData, pMzTool); //Ausführbar mit MzTool?
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		bOpen := NOT DINT_TO_BOOL(refActionData.aParams[2]); //Öffen
		
	E_Action.ACTION_StampDemolding:
		IF fbObjectDirectory.M_GetObjType(refActionData.nObject) <> E_ObjectType.OBJECTTYPE_StampSupport THEN //Gültiges MzTool?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;
			RETURN;
		END_IF
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pStampSupport := pMzTool;

		M_ExeAction := pStampSupport^.M_CheckAction(refActionData,0);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
 
		nDistance1 := refActionData.aParams[1];
		nSpeed1 := refActionData.aParams[2];
		nPressure1 := DINT_TO_INT(refActionData.aParams[3]);
		nPressure2 := DINT_TO_INT(refActionData.aParams[4]);
		nPeriode := refActionData.aParams[5];
		nDutycycle := refActionData.aParams[6];
		
	E_Action.ACTION_StampInking:
		IF fbObjectDirectory.M_GetObjType(refActionData.nObject) <> E_ObjectType.OBJECTTYPE_StampSupport THEN //Gültiges MzTool?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;
			RETURN;
		END_IF
		
		//Inking kann an einem Punkt oder an der InkStation stattfinden
		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_InkStation THEN
			pInkStation := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		ELSIF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Point THEN
			pInkStation := 0;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		END_IF
		
		//Wozu brauchen wir hier das Target?
		pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		pStampSupport := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		
		M_ExeAction := pStampSupport^.M_CheckAction(refActionData,pTarget);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		nDistance1 := refActionData.aParams[1];
		nPressure1 := DINT_TO_INT(refActionData.aParams[2]);
		nTime := DINT_TO_DWORD(refActionData.aParams[3]);
		
	E_Action.ACTION_TeachTarget:
		//Object gültig?
		IF NOT fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		
		IF fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			IF pTarget > 0 THEN
				M_ExeAction := pTarget^.M_CheckAction(refActionData, pMzTool);
				IF M_ExeAction > 0 THEN
					RETURN;
				END_IF
			ELSE
				M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
				RETURN;
			END_IF
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		//Target gültig? (derzeit nur Mtp impl.)
		
		//Hier macht es Sinn, beim Target selber zu fragen, ob es sich einteachen lässt
		
		(*IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Mtp THEN
			pMtp := aI_Object[refActionData.nTarget].P_pObject;
		ELSIF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Point THEN
			;
		ELSIF fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Stroboscope THEN
			;
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidTarget;  //Error
			RETURN;
		END_IF*)
		
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		IF pTarget^.P_eObjectType = E_ObjectType.OBJECTTYPE_Mtp THEN
			pMtp := pTarget;
		END_IF
		eTargetRef := DINT_TO_USINT(refActionData.aParams[1]);
		nSpecPointSlotNr := DINT_TO_UINT(refActionData.aParams[2]);
		nZOffset1 := refActionData.aParams[3];
		//refActionData.aParams[4] ist Reserve
		eTeachOption := DINT_TO_USINT(refActionData.aParams[5]);
		
		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
				RETURN;
			END_IF
		END_IF
		
	E_Action.ACTION_TeachTool:
		IF NOT fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		//Target gültig?
		IF NOT fbObjectDirectory.M_ObjIsTarget(refActionData.nTarget) THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		eTargetRef := DINT_TO_USINT(refActionData.aParams[1]);
		nCol := DINT_TO_USINT(refActionData.aParams[2]);
		nRow := DINT_TO_USINT(refActionData.aParams[2]);
		nZOffset1 := refActionData.aParams[4];

		pHighVoltTray := pTarget^.M_GetFirstParentOfType(E_ObjectType.OBJECTTYPE_HighVoltTray);
		IF pHighVoltTray > 0 THEN
			IF pHighVoltTray^.P_nCurrentVoltage > cHighVoltThreshold THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_RiskHighvoltFlashover;
				RETURN;
			END_IF
		END_IF

	E_Action.ACTION_TransferGas:
		//Beteiligte Luers checken
		IF NOT fbObjectDirectory.M_GetObjType(refActionData.nObject) = E_ObjectType.OBJECTTYPE_Luer THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF

		IF NOT fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Luer THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
		pLuer := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pLuer2 := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		nPressure1 := DINT_TO_INT(refActionData.aParams[1]);
		nTime := DINT_TO_DWORD(refActionData.aParams[2]);
		
	E_Action.ACTION_TransferLiquid:
		//Beteiligte Luers checken
		IF NOT fbObjectDirectory.M_GetObjType(refActionData.nObject) = E_ObjectType.OBJECTTYPE_Luer THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF

		IF NOT fbObjectDirectory.M_GetObjType(refActionData.nTarget) = E_ObjectType.OBJECTTYPE_Luer THEN
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;  //Error
			RETURN;
		END_IF
		pLuer := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		pLuer2 := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
		pDiluter1 := pLuer^.P_pDiluter;
		pDiluter2 := pLuer2^.P_pDiluter;
		
		nQuantity1 := refActionData.aParams[1];
		nFlow1 := refActionData.aParams[2];
		nQuantity2 := refActionData.aParams[3];
		nQuantity3 := refActionData.aParams[4];
		
	E_Action.ACTION_TransferTray:
		//Hier schon Bedingungen abfragen.
		IF fbObjectDirectory.M_GetObjType(refActionData.nObject) = E_ObjectType.OBJECTTYPE_TrayTransporter THEN
			pTrayTransporter := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF
 
		eTransferTrayCtrl :=  DINT_TO_USINT(refActionData.aParams[1]);

	E_Action.ACTION_WashTool:
		IF fbObjectDirectory.M_ObjIsMzTool(refActionData.nObject) THEN //Gültiges MzTool?
			pMzTool := fbObjectDirectory.M_GetObjPointer(refActionData.nObject);
		ELSE 
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableObject;  //Error
			RETURN;
		END_IF	
		
		IF fbObjectDirectory.M_GetObjType(refActionData.nTarget) <> E_ObjectType.OBJECTTYPE_WashStation THEN //gültiges Target?
			M_ExeAction := E_ErrorIdCmd.ERRORID_UnsuitableTarget;
			RETURN;
		ELSE
			pTarget := fbObjectDirectory.M_GetObjPointer(refActionData.nTarget);
			pWashStation := pTarget;
		END_IF
		
		//Kann Tool Action ausführen?
		M_ExeAction := pMzTool^.M_CheckAction(refActionData, pTarget);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		//Kann WashStation Action ausführen?
		M_ExeAction := pWashStation^.M_CheckAction(refActionData, pMzTool);
		IF M_ExeAction > 0 THEN
			RETURN;
		END_IF
		
		nSpecPointSlotNr := DINT_TO_UINT(refActionData.aParams[1]);
		//RinseChannel aus WashStation holen
		nRinseChannel := pWashStation^.M_GetRinseChannel(UINT_TO_USINT(nSpecPointSlotNr));
		eWashMode := DINT_TO_USINT(refActionData.aParams[2]);
		//passt WashMode zu RinseChannel?
		IF (eWashMode = E_WashMode.MODE_WashInOutside) OR (eWashMode = E_WashMode.MODE_WashOutside) THEN
			IF nRinseChannel = 0 THEN
				M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidRinseChannel;
				RETURN;
			END_IF
		END_IF
		
		nQuantity1 := refActionData.aParams[3];
		nFlow1 := refActionData.aParams[4];
		nTime := DINT_TO_DWORD(refActionData.aParams[5]);
		nDilInputNr := refActionData.aParams[6];

 	ELSE
		M_ExeAction := E_ErrorIdCmd.ERRORID_InvalidAction; //Error		
END_CASE
bBusy := TRUE;
eCurrentAction := refActionData.eAction;
eCurrentState := E_MachineState.MACHINESTATE_Active;]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Pause" Id="{6563408b-852e-4c0f-ab85-e23e7f438d63}">
      <Declaration><![CDATA[METHOD M_Pause
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//derzeit wird nur DispenseTest in Pause versetzt
IF eCurrentState = E_MachineState.MACHINESTATE_Active THEN
	IF eCurrentAction = E_Action.ACTION_DispenseTest THEN
		eCurrentState := E_MachineState.MACHINESTATE_PauseRequest;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Reset" Id="{79a03231-22de-4a6c-8a99-a05b6d451e8c}">
      <Declaration><![CDATA[METHOD M_Reset
VAR_INPUT
END_VAR
VAR
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eCurrentState = E_MachineState.MACHINESTATE_Error THEN
	bBusy := TRUE;
	eCurrentState := E_MachineState.MACHINESTATE_Reset;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_Stop" Id="{d71e9176-0c8e-4c84-b35a-b8300efb494a}">
      <Declaration><![CDATA[METHOD M_Stop
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eCurrentState = E_MachineState.MACHINESTATE_Active OR 
	eCurrentState = E_MachineState.MACHINESTATE_PauseRequest OR
	eCurrentState = E_MachineState.MACHINESTATE_Pause THEN
	
	bStop := TRUE;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_StopAction" Id="{9d3a68bd-8a16-4853-9fed-0c9fe0b25844}">
      <Declaration><![CDATA[METHOD M_StopAction
VAR_INPUT
	eAction : E_Action;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF eCurrentAction = eAction THEN
	M_Stop();
END_IF]]></ST>
      </Implementation>
    </Method>
