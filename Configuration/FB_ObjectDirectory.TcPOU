    <Method Name="M_GetObjIdStream" Id="{def79fe2-5491-4f76-bfe3-70310890afea}">
      <Declaration><![CDATA[METHOD M_GetObjIdStream : ERRORID
VAR_INPUT
	aData : REFERENCE TO ARRAY[0..999] OF UINT;
END_VAR

VAR
	iter : FB_ObjCollectIteratorDeep;
	i : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[objectList.M_GetIterator(iter);
WHILE iter.pNode > 0 AND_THEN iter.pNode^.P_pObject > 0 DO
	IF i > 999 THEN
		M_GetObjIdStream := 333;
		RETURN;	
	END_IF
	aData[i] := iter.pNode^.P_pObject^.P_nObjectID;
	i := i + 1;
	iter.M_Increment();
END_WHILE]]></ST>
      </Implementation>
    </Method>
