		IF nCntTipRack = cMaxTipRack THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntNeedleRackExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntTipRack := nCntTipRack + 1;
			a_pObjects[nObjectID] := ADR(afbTipRack[nCntTipRack]);
			afbTipRack[nCntTipRack].P_nObjectID := nObjectID;
		END_IF

	E_ObjectType.OBJECTTYPE_TitrationTool:
		IF nCntTitrationTool = cMaxTitrationTools THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntTitrationToolsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntTitrationTool := nCntTitrationTool + 1;
			a_pObjects[nObjectID] := ADR(afbTitrationTool[nCntTitrationTool]);
			afbTitrationTool[nCntTitrationTool].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbTitrationTool[nCntTitrationTool].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF

	E_ObjectType.OBJECTTYPE_TrayTransporter:
		IF nCntTrayTransporter = cMaxTrayTransporter THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntTrayTransporterExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntTrayTransporter := nCntTrayTransporter + 1;
			a_pObjects[nObjectID] := ADR(afbTrayTransporter[nCntTrayTransporter]);
			afbTrayTransporter[nCntTrayTransporter].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbTrayTransporter[nCntTrayTransporter].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
	
	E_ObjectType.OBJECTTYPE_TriplePip:
		IF nCntTriplePip = cMaxTriplePip THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntTriplePipExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntTriplePip := nCntTriplePip + 1;
			a_pObjects[nObjectID] := ADR(afbTriplePip[nCntTriplePip]);
			afbTriplePip[nCntTriplePip].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbTriplePip[nCntTriplePip].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_VacuumHandler:
		IF nCntVacuumHandler = cMaxVacuumHandler THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntVacuumHandlerExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntVacuumHandler := nCntVacuumHandler + 1;
			a_pObjects[nObjectID] := ADR(afbVacuumHandler[nCntVacuumHandler]);
			afbVacuumHandler[nCntVacuumHandler].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbVacuumHandler[nCntVacuumHandler].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF		
		
	E_ObjectType.OBJECTTYPE_VermesDisp:
		IF nCntVermesDisp = cMaxVermesDisp THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntVermesDispExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntVermesDisp := nCntVermesDisp + 1;
			a_pObjects[nObjectID] := ADR(afbVermesDisp[nCntVermesDisp]);
			afbVermesDisp[nCntVermesDisp].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbVermesDisp[nCntVermesDisp].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF

	E_ObjectType.OBJECTTYPE_Vial:
			pVial := __NEW(FB_Vial);
			pVial^.P_nObjectID := nObjectID;
			a_pObjects[nObjectID] := pVial;	
		
	E_ObjectType.OBJECTTYPE_VialClosed:
			pVialClosed := __NEW(FB_VialClosed);
			pVialClosed^.P_nObjectID := nObjectID;
			a_pObjects[nObjectID] := pVialClosed;	
		
	E_ObjectType.OBJECTTYPE_VialRack:
		IF nCntVialRack = cMaxVialRack THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntVialRackExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntVialRack := nCntVialRack + 1;
			a_pObjects[nObjectID] := ADR(afbVialRack[nCntVialRack]);
			afbVialRack[nCntVialRack].P_nObjectID := nObjectID;
		END_IF
		
	E_ObjectType.OBJECTTYPE_VialRackClosed:
		IF nCntVialRack = cMaxVialRack THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntVialRackExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntVialRack := nCntVialRack + 1;
			a_pObjects[nObjectID] := ADR(afbVialRack[nCntVialRack]);
			afbVialRack[nCntVialRack].P_nObjectID := nObjectID;
			afbVialRack[nCntVialRack].M_OverrideObjectType();
		END_IF		
		
	E_ObjectType.OBJECTTYPE_Wafer:
		pWafer := __NEW(FB_Wafer);
		pWafer^.P_nObjectID := nObjectID;
		a_pObjects[nObjectID] := pWafer;
		
	E_ObjectType.OBJECTTYPE_WashStation:
		IF nCntWashStation = cMaxWashStations THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntWashStationsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntWashStation := nCntWashStation + 1;
			a_pObjects[nObjectID] := ADR(afbWashStation[nCntWashStation]);
			afbWashStation[nCntWashStation].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbWashStation[nCntWashStation].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_Workplate:
		IF nCntWorkplate = cMaxWorkplates THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntWorkplatesExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntWorkplate := nCntWorkplate + 1;
			a_pObjects[nObjectID] := ADR(afbWorkplate[nCntWorkplate]);
			afbWorkplate[nCntWorkplate].P_nObjectID := nObjectID;
		END_IF
		
	E_ObjectType.OBJECTTYPE_WorkplateCamera:
		IF nCntWorkplateCamera = cMaxWorkplateCameras THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntWorkplateCameraExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntWorkplateCamera := nCntWorkplateCamera + 1;
			a_pObjects[nObjectID] := ADR(afbWorkplateCamera[nCntWorkplateCamera]);
			afbWorkplateCamera[nCntWorkplateCamera].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbWorkplateCamera[nCntWorkplateCamera].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;	
		END_IF		
		
	E_ObjectType.OBJECTTYPE_ZSensor:
		IF nCntZLevelSensor = cMaxZLevelSensors THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntZLevelSensorsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntZLevelSensor := nCntZLevelSensor + 1;
			a_pObjects[nObjectID] := ADR(afbZLevelSensor[nCntZLevelSensor]);
			afbZLevelSensor[nCntZLevelSensor].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbZLevelSensor[nCntZLevelSensor].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF
ELSE
	M_CreateObject := E_ErrorIdObjMgmt.ERRORID_InvalidObjectType;
	RETURN;
END_CASE
nCntObject := nCntObject + 1;

//ParentObject ermitteln aus data[0]
nParentObjectId := DINT_TO_UINT(refCmdData.n32Data[0]);
IF nParentObjectId = 0 THEN	//Soll kein Parent erhalten, nur für Diluter, Workplate und Head zulässig
	IF a_pObjects[nObjectID]^.P_eObjectType = E_ObjectType.OBJECTTYPE_Diluter OR
			a_pObjects[nObjectID]^.P_eObjectType = E_ObjectType.OBJECTTYPE_Diluter3Inputs OR
				a_pObjects[nObjectID]^.P_eObjectType = E_ObjectType.OBJECTTYPE_Workplate OR
					a_pObjects[nObjectID]^.P_eObjectType = E_ObjectType.OBJECTTYPE_MZHead OR
					a_pObjects[nObjectID]^.P_eObjectType = E_ObjectType.OBJECTTYPE_Stacker THEN
					
		a_pObjects[nObjectID]^.P_pObjCollectNode := objectList.M_AddNewNode(a_pObjects[nObjectID],nIndex);
	ELSE
		//Objekttyp muss zwingend an ein Parent
		M_CreateObject := E_ErrorIdObjMgmt.ERRORID_ObjectMustHaveAParent;
	END_IF
ELSIF nParentObjectId > 0 AND nParentObjectId <= cMaxObjects THEN
	pParentObject := a_pObjects[nParentObjectId];
	IF pParentObject > 0 THEN
		nParentSlotNr := DINT_TO_UINT(refCmdData.n32Data[1]);
		M_CreateObject := pParentObject^.M_AddChild(a_pObjects[nObjectID],nParentSlotNr,nIndex);
	ELSE
		M_CreateObject := E_ErrorIdObjMgmt.ERRORID_InvalidParentObject;
	END_IF
ELSE
	M_CreateObject := E_ErrorIdObjMgmt.ERRORID_InvalidParentObject;
END_IF

IF M_CreateObject > 0 THEN
	M_DeleteObject(nObjectID);
ELSE
	M_CreateObject := a_pObjects[nObjectID]^.M_SetAllProps(refCmdData);
	IF M_CreateObject > 0 THEN
		M_DeleteObject(nObjectID);
	ELSE
		refCmdData.aHeader[0] := nObjectID;	//zum Zurücklesen für den GUI-Kernel
		IF a_pObjects[nObjectID]^.M_bIsGroup(E_ObjectGroup.OBJECTGROUP_Device) THEN
			deviceList.M_AddNewNode(a_pObjects[nObjectID],nIndex);
		END_IF
		
		IF a_pObjects[nObjectID]^.M_bIsGroup(E_ObjectGroup.OBJECTGROUP_MzTool) THEN
			fbConfiguration.M_Deactivate();
		END_IF
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CustomUnitType2_Error" Id="{c02d379a-2255-4f73-b426-6e584fe2c516}">
      <Declaration><![CDATA[METHOD M_CustomUnitType2_Error : BOOL
VAR_INPUT
END_VAR

VAR
	i : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[FOR i := 1 TO nCntCustomUnitType2 DO
	 IF afbCustomUnitType2[i].P_bError THEN
		 M_CustomUnitType2_Error := TRUE;
	 END_IF
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_DeleteAllObj" Id="{be98f4e2-5ea6-44a3-b9c7-4ebe056082b6}">
      <Declaration><![CDATA[METHOD M_DeleteAllObj : E_ErrorIdObjMgmt
VAR_INPUT
END_VAR
VAR
	i		: UINT;
	iter 	: FB_ObjCollectIteratorDeep;
	pObject : POINTER TO FB_Object;
	id 		: UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Methode zum kompletten Löschen des Objektverzeichnisses

//Objektzählervariablen zurücksetzen
nCntCamera := 0;
nCntCartDispenser := 0;
nCntCartDispStirrer := 0;
nCntCartHolder := 0;
nCntCustomUnitType1 := 0;
nCntCustomUnitType2 := 0;
nCntMultiCartHolder := 0;
nCntHybridDispenser := 0;
nCntDeloDot := 0;	
nCntDiluter := 0;
nCntDiluter3Inputs := 0;
nCntDrayPad := 0;
nCntDummyTool := 0;
nCntExposure := 0;		
nCntFlipTubeHandler	:= 0;			
nCntFlipTubeRack := 0;
nCntGripper := 0;
nCntHighVoltTray := 0;		
nCntInkStation := 0;		
nCntLiquidReserve := 0;			
nCntLuer := 0; 	
nCntMtpHolder := 0;		
nCntMZHead := 0;	
nCntNeedleRack := 0;		
nCntNotifiIds := 0;		
nCntObject := 0;
nCntTwinExtruder := 0;	
nCntTwinPiezoHolder	:= 0;	
nCntPassivPip := 0;
nCntpHElectrode	:= 0;
nCntpHElectrodeCapRack := 0;
nCntPickPlacePip := 0;
nCntPiezoPip := 0;		
nCntPortRack := 0;		
nCntPowderPip := 0;		
nCntPowderStation := 0;			
nCntReactor := 0;	
nCntSampleScan := 0;		
nCntSeptumRack := 0;		
nCntSeptumWaste	:= 0;
nCntSinglePiezoHolder := 0;	
nCntStacker := 0;	
nCntSolenoidPip := 0;
nCntExtruder := 0;
nCntStampMagazine := 0;			
nCntStampSupport := 0;			
nCntStroboscope := 0;		
nCntSubstHolder := 0;
nCntSubstHolderUnistat := 0;
nCntTipCalibrator := 0;			
nCntTipCleaner := 0;
nCntTipCleanerGen2 := 0;
nCntTipRack := 0;
nCntTitrationTool := 0;
nCntTrayTransporter := 0;
nCntTriplePip := 0;		
nCntVacuumHandler := 0;
nCntVermesDisp := 0;			
nCntVialRack := 0;		
nCntWashStation	:= 0;		
nCntWorkplate := 0;
nCntWorkplateCamera := 0;
nCntZLevelSensor := 0;			

objectList.M_GetIterator(iter);
WHILE iter.pNode > 0 AND_THEN iter.pNode^.P_pObject > 0 DO
	pObject := iter.pNode^.P_pObject;
	id := pObject^.P_nObjectID;
	a_pObjects[id] := 0;
	pObject^.M_ClearAllProps(TRUE);
	CASE pObject^.P_eObjectType OF
		E_ObjectType.OBJECTTYPE_Cartridge:
			pCartridge := pObject;
			__DELETE(pCartridge);
		E_ObjectType.OBJECTTYPE_FlipTube:
			pFlipTube := pObject;
			__DELETE(pFlipTube);
		E_ObjectType.OBJECTTYPE_Mtp:
			pMtp := pObject;
			__DELETE(pMtp);
		E_ObjectType.OBJECTTYPE_Needle:
			pNeedle := pObject;
			__DELETE(pNeedle);
		E_ObjectType.OBJECTTYPE_Nozzle:
			pNozzle := pObject;
			__DELETE(pNozzle);		
		E_ObjectType.OBJECTTYPE_pHElectrodeCap:
			pPHElectrodeCap := pObject;
			__DELETE(pPHElectrodeCap);
		E_ObjectType.OBJECTTYPE_Point:
			pPoint := pObject;
			__DELETE(pPoint);
		E_ObjectType.OBJECTTYPE_Port:
			pPort := pObject;
			__DELETE(pPort);
		E_ObjectType.OBJECTTYPE_Septum:
			pSeptum := pObject;
			__DELETE(pSeptum);
		E_ObjectType.OBJECTTYPE_Slide:
			pSlide := pObject;
			__DELETE(pSlide);
		E_ObjectType.OBJECTTYPE_SpotArray:
			pSpotArray := pObject;
			__DELETE(pSpotArray);
		E_ObjectType.OBJECTTYPE_SpotPattern:
			pSpotPattern := pObject;
			__DELETE(pSpotPattern);
		E_ObjectType.OBJECTTYPE_Stamp:
			pStamp := pObject;
			__DELETE(pStamp);
		E_ObjectType.OBJECTTYPE_Tip:
			pTip := pObject;
			__DELETE(pTip);
		E_ObjectType.OBJECTTYPE_TargetTray:
			pTray := pObject;
			__DELETE(pTray);
		E_ObjectType.OBJECTTYPE_Vial:
			pVial := pObject;
			__DELETE(pVial);
		E_ObjectType.OBJECTTYPE_VialClosed:
			pVialClosed := pObject;
			__DELETE(pVialClosed);
		E_ObjectType.OBJECTTYPE_Wafer:
			pWafer := pObject;
			__DELETE(pWafer);	
	END_CASE
	iter.M_Increment();
END_WHILE

objectList.M_Clear();
fbIdPool.M_Reset();
deviceList.M_Clear();

fbConfiguration.M_Deactivate();

FOR i := 1 TO cMaxMzHeads BY 1 DO
	aFbMultiZRef[i].M_DelConfig();
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_DeleteObject" Id="{6958beb4-24fe-4972-a29b-b7d1f90c4555}">
      <Declaration><![CDATA[METHOD M_DeleteObject : E_ErrorIdObjMgmt
VAR_INPUT
	nObjectID		: UINT;
END_VAR
VAR
	pDeviceNode	: POINTER TO FB_ObjCollectionNode;
	iter : FB_ObjCollectIterator;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Existiert das Objekt ?
IF nObjectID > 0 AND nObjectID <= cMaxObjects THEN
	IF a_pObjects[nObjectId] > 0 THEN
		//Es können nur Objekte ohne Childs gelöscht werden
		IF NOT a_pObjects[nObjectId]^.P_bHasChilds THEN
			IF a_pObjects[nObjectId]^.M_bIsGroup(E_ObjectGroup.OBJECTGROUP_Device) THEN
				deviceList.M_GetIterator(iter);
				WHILE iter.pNode > 0 DO
					IF iter.pNode^.P_pObject = a_pObjects[nObjectId] THEN
						deviceList.M_ClearNode(iter.pNode);
						EXIT;
					END_IF
					iter.M_Increment();
				END_WHILE
			END_IF
		
			IF a_pObjects[nObjectId]^.P_nNotifyId > 0 THEN
				nCntNotifiIds := nCntNotifiIds - 1;
			END_IF
		
			IF a_pObjects[nObjectId]^.P_pParentObject > 0 THEN
				a_pObjects[nObjectId]^.P_pParentObject^.M_RemoveChild(a_pObjects[nObjectId]);
			ELSE
				IF a_pObjects[nObjectId]^.P_pObjCollectNode > 0 THEN
					a_pObjects[nObjectId]^.P_pObjCollectNode^.P_pOwnerColl^.M_ClearNode(a_pObjects[nObjectId]^.P_pObjCollectNode);
				END_IF
			END_IF
			
			IF a_pObjects[nObjectId]^.M_bIsGroup(E_ObjectGroup.OBJECTGROUP_MzTool) THEN
				fbConfiguration.M_Deactivate();
			END_IF
 			
			a_pObjects[nObjectId]^.M_ClearAllProps(FALSE);
		
			nCntObject := nCntObject - 1;
			
			CASE a_pObjects[nObjectId]^.P_eObjectType OF
				E_ObjectType.OBJECTTYPE_MZHead:
					nCntMZHead := nCntMZHead - 1;
				E_ObjectType.OBJECTTYPE_PiezoPip:
					nCntPiezoPip := nCntPiezoPip - 1;
				E_ObjectType.OBJECTTYPE_PassivPip:
					nCntPassivPip := nCntPassivPip - 1;
				E_ObjectType.OBJECTTYPE_pHElectrode:
					nCntpHElectrode := nCntpHElectrode - 1;
				E_ObjectType.OBJECTTYPE_pHElectrodeCap:
					pPHElectrodeCap := a_pObjects[nObjectId];
					__DELETE(pPHElectrodeCap);
				E_ObjectType.OBJECTTYPE_pHElectrodeCapRack:
					nCntpHElectrodeCapRack := nCntpHElectrodeCapRack - 1;
				E_ObjectType.OBJECTTYPE_PowderPip:
					nCntPowderPip := nCntPowderPip - 1;
				E_ObjectType.OBJECTTYPE_MultiCartHolder:
					nCntMultiCartHolder := nCntMultiCartHolder - 1;
				E_ObjectType.OBJECTTYPE_HybridDispenser:
					nCntHybridDispenser := nCntHybridDispenser - 1;
				E_ObjectType.OBJECTTYPE_CartDispenser:
					nCntCartDispenser := nCntCartDispenser - 1;
				E_ObjectType.OBJECTTYPE_CartDispStirrer:
					nCntCartDispStirrer := nCntCartDispStirrer - 1;
				E_ObjectType.OBJECTTYPE_CartHolder:
					nCntCartHolder := nCntCartHolder - 1;
				E_ObjectType.OBJECTTYPE_Camera:
					nCntCamera := nCntCamera - 1;
				E_ObjectType.OBJECTTYPE_ZSensor:
					nCntZLevelSensor := nCntZLevelSensor - 1;
				E_ObjectType.OBJECTTYPE_StampSupport:
					nCntStampSupport := nCntStampSupport - 1;
				E_ObjectType.OBJECTTYPE_Luer:
					nCntLuer := nCntLuer - 1;
				E_ObjectType.OBJECTTYPE_TrayTransporter:
					nCntTrayTransporter := nCntTrayTransporter - 1;
				E_ObjectType.OBJECTTYPE_TriplePip:
					nCntTriplePip := nCntTriplePip - 1;
				E_ObjectType.OBJECTTYPE_VacuumHandler:
					nCntVacuumHandler := nCntVacuumHandler - 1;
				E_ObjectType.OBJECTTYPE_Workplate:
					nCntWorkplate := nCntWorkplate - 1;
				E_ObjectType.OBJECTTYPE_TipCleaner:
					nCntTipCleaner := nCntTipCleaner - 1;
				E_ObjectType.OBJECTTYPE_TipCleanerGen2:
					nCntTipCleanerGen2 := nCntTipCleanerGen2 - 1;
				E_ObjectType.OBJECTTYPE_TipCalibrator:
					nCntTipCalibrator := nCntTipCalibrator - 1;
				E_ObjectType.OBJECTTYPE_TitrationTool:
					nCntTitrationTool := nCntTitrationTool - 1;
				E_ObjectType.OBJECTTYPE_WashStation:
					nCntWashStation := nCntWashStation - 1;
				E_ObjectType.OBJECTTYPE_LiquidReserve:
					nCntLiquidReserve := nCntLiquidReserve - 1;
				E_ObjectType.OBJECTTYPE_DryPad:
					nCntDrayPad := nCntDrayPad - 1;
				E_ObjectType.OBJECTTYPE_Stroboscope:
					nCntStroboscope := nCntStroboscope - 1;
				E_ObjectType.OBJECTTYPE_MtpHolder:
					nCntMtpHolder := nCntMtpHolder - 1;
				E_ObjectType.OBJECTTYPE_SubstHolder:
					nCntSubstHolder := nCntSubstHolder - 1;
				E_ObjectType.OBJECTTYPE_SubstHolderUnistat:
					nCntSubstHolderUnistat := nCntSubstHolderUnistat - 1;
				E_ObjectType.OBJECTTYPE_StampMagazine:
					nCntStampMagazine := nCntStampMagazine - 1;
				E_ObjectType.OBJECTTYPE_InkStation:
					nCntInkStation := nCntInkStation - 1;
				E_ObjectType.OBJECTTYPE_PowderStation:
					nCntPowderStation := nCntPowderStation - 1;
				E_ObjectType.OBJECTTYPE_Reactor:
					nCntReactor := nCntReactor - 1;
				E_ObjectType.OBJECTTYPE_TargetTray:
					pTray := a_pObjects[nObjectId];
					__DELETE(pTray);
				E_ObjectType.OBJECTTYPE_SpotArray:
					pSpotArray := a_pObjects[nObjectId];
					__DELETE(pSpotArray);
				E_ObjectType.OBJECTTYPE_Mtp:
					pMtp := a_pObjects[nObjectId];
					__DELETE(pMtp);
				E_ObjectType.OBJECTTYPE_Slide:
					pSlide := a_pObjects[nObjectId];
					__DELETE(pSlide);
				E_ObjectType.OBJECTTYPE_Wafer:
					pWafer := a_pObjects[nObjectId];
					__DELETE(pWafer);					
				E_ObjectType.OBJECTTYPE_Point:
					pPoint := a_pObjects[nObjectId];
					__DELETE(pPoint);
				E_ObjectType.OBJECTTYPE_Diluter:
					fbConfiguration.M_Deactivate();
					nCntDiluter := nCntDiluter - 1;
				E_ObjectType.OBJECTTYPE_Diluter3Inputs:
					fbConfiguration.M_Deactivate();
					nCntDiluter3Inputs := nCntDiluter3Inputs - 1;
				E_ObjectType.OBJECTTYPE_SpotPattern:
					pSpotPattern := a_pObjects[nObjectId];
					__DELETE(pSpotPattern);
				E_ObjectType.OBJECTTYPE_DeloDot:
					nCntDeloDot := nCntDeloDot - 1;
				E_ObjectType.OBJECTTYPE_Exposure:
					nCntExposure := nCntExposure - 1;
				E_ObjectType.OBJECTTYPE_Stamp:
					pStamp := a_pObjects[nObjectId];
					__DELETE(pStamp);
				E_ObjectType.OBJECTTYPE_Needle:
					pNeedle := a_pObjects[nObjectId];
					__DELETE(pNeedle);
				E_ObjectType.OBJECTTYPE_Tip:
					pTip := a_pObjects[nObjectId];
					__DELETE(pTip);
				E_ObjectType.OBJECTTYPE_Vial:
					pVial := a_pObjects[nObjectId];
					__DELETE(pVial);
				E_ObjectType.OBJECTTYPE_VialClosed:
					pVialClosed := a_pObjects[nObjectId];
					__DELETE(pVialClosed);
				E_ObjectType.OBJECTTYPE_Septum:
					pSeptum := a_pObjects[nObjectId];
					__DELETE(pSeptum);
				E_ObjectType.OBJECTTYPE_Cartridge:
					pCartridge := a_pObjects[nObjectId];
					__DELETE(pCartridge);
				E_ObjectType.OBJECTTYPE_Port:
					pPort := a_pObjects[nObjectId];
					__DELETE(pPort);
				E_ObjectType.OBJECTTYPE_FlipTube:
					pFlipTube := a_pObjects[nObjectId];
					__DELETE(pFlipTube);
				E_ObjectType.OBJECTTYPE_SeptumWaste:
					nCntSeptumWaste := nCntSeptumWaste - 1;
				E_ObjectType.OBJECTTYPE_NeedleRack:
					nCntNeedleRack := nCntNeedleRack - 1;
				E_ObjectType.OBJECTTYPE_TipRack:
					nCntTipRack := nCntTipRack - 1;
				E_ObjectType.OBJECTTYPE_FlipTubeRack:
					nCntFlipTubeRack := nCntFlipTubeRack - 1;
				E_ObjectType.OBJECTTYPE_SeptumRack:
					nCntSeptumRack := nCntSeptumRack - 1;
				E_ObjectType.OBJECTTYPE_VialRack:
					nCntVialRack := nCntVialRack - 1;
				E_ObjectType.OBJECTTYPE_PortRack:
					nCntPortRack := nCntPortRack - 1;
				E_ObjectType.OBJECTTYPE_Nozzle:
					fbConfiguration.M_Deactivate();
					pNozzle := a_pObjects[nObjectId];
					__DELETE(pNozzle);
				E_ObjectType.OBJECTTYPE_SinglePiezoHolder:
					nCntSinglePiezoHolder := nCntSinglePiezoHolder - 1;
				E_ObjectType.OBJECTTYPE_TwinPiezoHolder:
					nCntTwinPiezoHolder := nCntTwinPiezoHolder - 1;
				E_ObjectType.OBJECTTYPE_HighVoltTray:
					nCntHighVoltTray := nCntHighVoltTray - 1;
				E_ObjectType.OBJECTTYPE_SolenoidPip:
					nCntSolenoidPip := nCntSolenoidPip - 1;
				E_ObjectType.OBJECTTYPE_Extruder:
					nCntExtruder := nCntExtruder - 1;
				E_ObjectType.OBJECTTYPE_TwinExtruder:
					nCntTwinExtruder := nCntTwinExtruder - 1;
				E_ObjectType.OBJECTTYPE_VermesDisp:
					nCntVermesDisp := nCntVermesDisp - 1;
				E_ObjectType.OBJECTTYPE_WorkplateCamera:
					nCntWorkplateCamera := nCntWorkplateCamera - 1;
				E_ObjectType.OBJECTTYPE_DummyTool:
					nCntDummyTool := nCntDummyTool - 1;
				E_ObjectType.OBJECTTYPE_CustomUnitType1:
					nCntCustomUnitType1 := nCntCustomUnitType1 - 1;
				E_ObjectType.OBJECTTYPE_CustomUnitType2:
					nCntCustomUnitType2 := nCntCustomUnitType2 - 1;
				E_ObjectType.OBJECTTYPE_Gripper:
					nCntGripper := nCntGripper - 1;
				E_ObjectType.OBJECTTYPE_PickPlacePip:
					nCntPickPlacePip := nCntPickPlacePip - 1;
				E_ObjectType.OBJECTTYPE_Stacker:
					nCntStacker := nCntStacker - 1;
			END_CASE
			a_pObjects[nObjectId] := 0;
			//ObjectID wieder freigeben
			fbIdPool.M_ReleaseId(nObjectId);
		ELSE
			M_DeleteObject := E_ErrorIdObjMgmt.ERRORID_ObjectHasChilds;
		END_IF
	ELSE
		M_DeleteObject := E_ErrorIdObjMgmt.ERRORID_InvalidObjectId;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetChangedObjId" Id="{27335885-d38a-4b5f-a255-a76626d7cfd3}">
      <Declaration><![CDATA[METHOD M_GetChangedObjId : UINT
VAR_INPUT
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF hList.nCount > 0 THEN
	fbList.A_GetTail(hList:= hList);
	{IF hasvalue (RegisterSize, '32')}
	M_GetChangedObjId := UDINT_TO_UINT(fbList.getValue);
	{ELSE}
	M_GetChangedObjId := ULINT_TO_UINT(fbList.getValue);
	{END_IF}
	fbList.A_RemoveTailValue(hList:= hList);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetCoHead" Id="{e1836cd9-3959-43b5-802c-cd26497e48e2}">
      <Declaration><![CDATA[METHOD M_GetCoHead : POINTER TO FB_MzHead
VAR_INPUT
	pMzHead : POINTER TO FB_MzHead;
END_VAR

VAR
	i : UINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[FOR i:= 1 TO nCntMZHead BY 1 DO
	IF ADR(afbMzHead[i]) <> pMzHead THEN
		IF afbMzHead[i].P_eObjectType = E_ObjectType.OBJECTTYPE_MZHead THEN
			IF afbMzHead[i].P_pXDrive = pMzHead^.P_pXDrive THEN
				M_GetCoHead := ADR(afbMzHead[i]);
			END_IF
		END_IF
	END_IF
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetConfigCheckSum" Id="{38268fea-9da5-4910-a5a4-8e7797912e8f}">
      <Declaration><![CDATA[METHOD M_GetConfigCheckSum : UINT
VAR_INPUT
END_VAR

VAR
	nObjectCounter 	: UINT;
	wPrevious 		: WORD := 16#FFFF;
	iter			: FB_ObjCollectIteratorDeep;
	nLevel			: UINT;
	nObjType		: UINT;
	nNoOfProps		: UINT;
	nParentSlotNr	: UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[objectList.M_GetIterator(iter);
WHILE iter.pNode > 0 AND_THEN iter.pNode^.P_pObject > 0 DO
	
	nParentSlotNr := iter.pNode^.P_pObject^.P_nParentSlotNr;
	wPrevious := F_DATA_TO_CRC16_CCITT(ADR(nParentSlotNr),SIZEOF(nParentSlotNr),wPrevious);

	nLevel := iter.pNode^.M_GetLevel(0);
	wPrevious := F_DATA_TO_CRC16_CCITT(ADR(nLevel),SIZEOF(nLevel),wPrevious); 

	nObjType := iter.pNode^.P_pObject^.P_eObjectType;
	wPrevious := F_DATA_TO_CRC16_CCITT(ADR(nObjType),SIZEOF(nObjType),wPrevious);

	nNoOfProps := iter.pNode^.P_pObject^.P_nNoOfProps;
	wPrevious := F_DATA_TO_CRC16_CCITT(ADR(nNoOfProps),SIZEOF(nNoOfProps),wPrevious);

	iter.M_Increment();
END_WHILE
M_GetConfigCheckSum := WORD_TO_UINT(wPrevious);]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_GetDevice" Id="{a386ae1b-c49a-40d3-8532-254716a94494}">
