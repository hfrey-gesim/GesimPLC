	pMzToolBase	: POINTER TO FB_MzBase;
	pDiluter : POINTER TO FB_Diluter; 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF M_ObjIsDevice(nObjectId) THEN
	M_GetDevice := a_pObjects[nObjectId]^.M_GetDevice();
END_IF]]></ST>
