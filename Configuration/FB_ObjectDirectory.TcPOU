<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.11">
  <POU Name="FB_ObjectDirectory" Id="{d21e24d3-e574-403c-b3f5-9068019773ff}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_ObjectDirectory

VAR_OUTPUT
	bIsInitialized			: BOOL;

	//Anzahl der jeweiligen Objekttypen, welche ins Objektverzeichnis eingetragen sind (Objektzählervariablen)
	nCntCamera				:UINT;
	nCntCartDispenser		:UINT;
	nCntCartDispStirrer		:UINT;
	nCntCartHolder			:UINT;
	nCntCustomUnitType1		:UINT;
	nCntCustomUnitType2		:UINT;
	nCntMultiCartHolder		:UINT;
	nCntHybridDispenser		:UINT;
	nCntDeloDot				:UINT;
	nCntDiluter				:UINT;
	nCntDiluter3Inputs		:UINT;
	nCntDrayPad				:UINT;
	nCntDummyTool			:UINT;
	nCntExposure			:UINT;
	nCntExtruder			:UINT;
	nCntFlipTubeHandler		:UINT;
	nCntFlipTubeRack		:UINT;
	nCntGripper				:UINT;
	nCntHighVoltTray		:UINT;
	nCntInkStation			:UINT;
	nCntLiquidReserve		:UINT;
	nCntLuer				:UINT;
	nCntMtpHolder			:UINT;
	nCntMZHead				:UINT;
	nCntNeedleRack			:UINT;
	nCntPassivPip			:UINT;
	nCntpHElectrode			:UINT;
	nCntpHElectrodeCapRack	:UINT;
	nCntPickPlacePip		:UINT;
	nCntPiezoPip			:UINT;
	nCntPortRack			:UINT;
	nCntPowderPip			:UINT;
	nCntPowderStation		:UINT;
	nCntReactor				:UINT;
	nCntSampleScan			:UINT;
	nCntSeptumRack			:UINT;
	nCntSeptumWaste			:UINT;
	nCntSinglePiezoHolder	:UINT;
	nCntStacker				:UINT;
	nCntSolenoidPip			:UINT;
	nCntStampMagazine		:UINT;
	nCntStampSupport		:UINT;
	nCntStroboscope			:UINT;
	nCntSubstHolder			:UINT;
	nCntSubstHolderUnistat	:UINT;
	nCntTipCalibrator		:UINT;
	nCntTipCleaner			:UINT;
	nCntTipCleanerGen2		:UINT;
	nCntTipRack				:UINT;
	nCntTitrationTool		:UINT;
	nCntTrayTransporter		:UINT;
	nCntTriplePip			:UINT;
	nCntTwinExtruder		:UINT;
	nCntTwinPiezoHolder		:UINT;
	nCntVacuumHandler		:UINT;
	nCntVermesDisp			:UINT;
	nCntVialRack			:UINT;
	nCntWashStation			:UINT;
	nCntWorkplate			:UINT;
	nCntWorkplateCamera		:UINT;
	nCntZLevelSensor		:UINT;
	
	//Anzahl der jeweiligeb Objecttypen, welche in InterfaceArrays eingetragen sind
	nCntObject			: UINT;
	
	//Anzahl der aktuellen benutzen NotificationIds
	nCntNotifiIds		: UINT;

END_VAR

VAR
	fbIdPool 			: FB_IdPool;
	a_pObjects 			: ARRAY[1..cMaxObjects] OF POINTER TO FB_Object;
	objectList			: FB_ObjCollection(0);
	deviceList			: FB_ObjCollection(0);	

	//Für ObjectChange
	fbList				: FB_LinkedListCtrl;
	hList				: T_HLINKEDLIST;
	nodes				: ARRAY [0..20] OF T_LinkedListEntry;
	
	//Notification MoveObject
	stObjectHasMoved	: ST_ObjHasMoved;
	
	pCartridge			: POINTER TO FB_Cartridge;	
	pFlipTube			: POINTER TO FB_FlipTube;	
	pMtp				: POINTER TO FB_Mtp;
	pNeedle				: POINTER TO FB_Needle;
	pNozzle				: POINTER TO FB_Nozzle;
	pPHElectrodeCap		: POINTER TO FB_pHElectrodeCap;		
	pPoint				: POINTER TO FB_Point;
	pPort				: POINTER TO FB_Port;
	pSeptum				: POINTER TO FB_Septum;
	pSlide				: POINTER TO FB_Slide;
	pSpotArray			: POINTER TO FB_SpotArray;	
	pSpotPattern		: POINTER TO FB_SpotPattern;		
	pStamp				: POINTER TO FB_Stamp;
	pTip				: POINTER TO FB_Tip;
	pTray				: POINTER TO FB_TargetTray;
	pVial				: POINTER TO FB_Vial;
	pVialClosed			: POINTER TO FB_VialClosed;	
	pWafer				: POINTER TO FB_Wafer;
	pCleaningBrush		: POINTER TO FB_CleaningBrush;
END_VAR


]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="M_CheckCuboidCollision" Id="{080984b8-a7ad-4f68-813d-b026b022c3db}">
      <Declaration><![CDATA[METHOD M_CheckCuboidCollision : BOOL
VAR_INPUT
	Cuboid : REFERENCE TO FB_Cuboid;
END_VAR

VAR
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Überprüft den übergebenen Quader darauf, dass er mit keinem Target auf der Workplate oder
//mit einem Tool in HomePos kollidiert. Punkte werden dabei ausgeschlossen.
//Das erste Problem besteht darin, dass ein Point in einem Target vertieft befinden kann (MTP)
//oder z.B. ein Punkt, der vermessen wurde und sich dadurch unterhalb des Targets befindet
//in diesem Fall muss genau dieses Target als Kollisionsobjekt ausgeschlossen werden
//also das Target, auf dem sich der Punkt befindet. Wie sieht es mit einem Slide aus? Wenn dieses 
//durch Vermessung etwas tiefer sitzt als sein Parent, dann macht das eigentlich nichts.

//Alle Targets durchlaufen? Mit einem Durchlauf? was ist, wenn es tausende Points gibt?
//afbWorkplate[1].]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_CreateObject" Id="{3ff92fb3-8f2d-432e-9c8f-5f85b42f8b0f}">
      <Declaration><![CDATA[METHOD  M_CreateObject : ERRORID
VAR_INPUT
	nIndex			: INT;	//Index in der ObjCollection ("-1" -> wird am Ende eingefügt)
	refCmdData		: REFERENCE TO ST_CmdData;
END_VAR
VAR_OUTPUT
	nNotifyId		: DINT;
END_VAR
VAR
	nObjectID		: UINT;
	eObjectType 	: E_ObjectType;
	nParentObjectId : UINT;
	pParentObject	: POINTER TO FB_Object;
	nParentSlotNr	: UINT;
	nNewIndex		: UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Methode zum Hinzufügen von Objecten ins Objektverzeichnis

nObjectID := fbIdPool.M_GetId();
IF nObjectID = 0 THEN
	M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntObjectsExceeded;	//Rückgabe Error
	RETURN;	
END_IF

eObjectType := refCmdData.aHeader[0];

IF (nObjectID  > 0) AND (nObjectID <= cMaxObjects) THEN
	IF a_pObjects[nObjectID] <> 0 THEN	//ObjectID schon vorhanden
		M_CreateObject := E_ErrorIdObjMgmt.ERRORID_ObjectIDAlreadyExists;
		RETURN;
	END_IF
ELSE
	M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntObjectsExceeded;	//Rückgabe Error
	RETURN;
END_IF

CASE eObjectType OF

	E_ObjectType.OBJECTTYPE_Camera:	//Camera, Mikroskop, Scanner o.ä.
		IF nCntCamera = cMaxCameras THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCamerasExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntCamera := nCntCamera + 1;
			a_pObjects[nObjectID] := ADR(afbCamera[nCntCamera]);
			afbCamera[nCntCamera].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCamera[nCntCamera].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF

	E_ObjectType.OBJECTTYPE_Cartridge:	//Kartusche auf einem Rack
		pCartridge := __NEW(FB_Cartridge);
		pCartridge^.P_nObjectID := nObjectID;
		a_pObjects[nObjectID] := pCartridge;	
		
	E_ObjectType.OBJECTTYPE_CartDispenser:
		IF nCntCartDispenser = cMaxCartDisp THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCartridgeDispExceeded; //Rückgabe Error
			RETURN;
		ELSE
			nCntCartDispenser := nCntCartDispenser + 1;
			a_pObjects[nObjectID] := ADR(afbCartDisp[nCntCartDispenser]);
			afbCartDisp[nCntCartDispenser].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCartDisp[nCntCartDispenser].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF
	E_ObjectType.OBJECTTYPE_CartDispStirrer:
		IF nCntCartDispStirrer = cMaxCartDispStirrer THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCartridgeDispStirrerExceeded; //Rückgabe Error
			RETURN;
		ELSE
			nCntCartDispStirrer := nCntCartDispStirrer + 1;
			a_pObjects[nObjectID] := ADR(afbCartDispStirrer[nCntCartDispStirrer]);
			afbCartDispStirrer[nCntCartDispStirrer].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCartDispStirrer[nCntCartDispStirrer].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF
E_ObjectType.OBJECTTYPE_CartHolder:
		IF nCntCartHolder = cMaxCartHolder THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCartridgeHolderExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntCartHolder := nCntCartHolder + 1;
			a_pObjects[nObjectID] := ADR(afbCartHolder[nCntCartHolder]);
			afbCartHolder[nCntCartHolder].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCartHolder[nCntCartHolder].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF
		
	E_ObjectType.OBJECTTYPE_CleaningBrush:
		pCleaningBrush := __NEW(FB_CleaningBrush);
		pCleaningBrush^.P_nObjectID := nObjectID;
		a_pObjects[nObjectID] := pCleaningBrush;	
		
	E_ObjectType.OBJECTTYPE_CustomUnitType1:
		IF nCntCustomUnitType1 = cMaxCustomUnitTyp1 THEN //maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCustomUnitType1Exceeded; //Rückgabe Error
			RETURN;
		ELSE
			nCntCustomUnitType1 := nCntCustomUnitType1 + 1;
			a_pObjects[nObjectID] := ADR(afbCustomUnitType1[nCntCustomUnitType1]);
			afbCustomUnitType1[nCntCustomUnitType1].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCustomUnitType1[nCntCustomUnitType1].P_nNotifyId := nCntNotifiIds;			
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_CustomUnitType2:
		IF nCntCustomUnitType2 = cMaxCustomUnitTyp2 THEN //maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntCustomUnitType2Exceeded; //Rückgabe Error
			RETURN;
		ELSE
			nCntCustomUnitType2 := nCntCustomUnitType2 + 1;
			a_pObjects[nObjectID] := ADR(afbCustomUnitType2[nCntCustomUnitType2]);
			afbCustomUnitType2[nCntCustomUnitType2].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbCustomUnitType2[nCntCustomUnitType2].P_nNotifyId := nCntNotifiIds;			
			nNotifyId := nCntNotifiIds;
		END_IF

	E_ObjectType.OBJECTTYPE_MultiCartHolder:
		IF nCntMultiCartHolder = cMaxMultiCartHolder THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntMultiCartridgeHolderExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntMultiCartHolder := nCntMultiCartHolder + 1;
			a_pObjects[nObjectID] := ADR(afbMultiCartHolder[nCntMultiCartHolder]);
			afbMultiCartHolder[nCntMultiCartHolder].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbMultiCartHolder[nCntMultiCartHolder].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_HybridDispenser:
		IF nCntHybridDispenser = cMaxHybridDispenser THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntHybridDispenserExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntHybridDispenser := nCntHybridDispenser + 1;
			a_pObjects[nObjectID] := ADR(afbHybridDispenser[nCntHybridDispenser]);
			afbHybridDispenser[nCntHybridDispenser].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbHybridDispenser[nCntHybridDispenser].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_DeloDot:
		IF nCntDeloDot = cMaxDeloDots THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntDeloDotsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntDeloDot := nCntDeloDot + 1;
			a_pObjects[nObjectID] := ADR(afbDeloDot[nCntDeloDot]);
			afbDeloDot[nCntDeloDot].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbDeloDot[nCntDeloDot].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF

	E_ObjectType.OBJECTTYPE_Diluter:
		IF nCntDiluter = cMaxDiluters THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntDilutersExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntDiluter := nCntDiluter + 1;
			a_pObjects[nObjectID] := ADR(afbDiluter[nCntDiluter]);
			afbDiluter[nCntDiluter].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbDiluter[nCntDiluter].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_Diluter3Inputs:
		IF nCntDiluter3Inputs = cMaxDiluters3Inputs THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntDilutersExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntDiluter3Inputs := nCntDiluter3Inputs + 1;
			a_pObjects[nObjectID] := ADR(afbDiluter3Inputs[nCntDiluter3Inputs]);
			afbDiluter3Inputs[nCntDiluter3Inputs].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbDiluter3Inputs[nCntDiluter3Inputs].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_DryPad:
		IF nCntDrayPad = cMaxDrayPads THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntDrayPadsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntDrayPad := nCntDrayPad + 1;
			a_pObjects[nObjectID] := ADR(afbDryPad[nCntDrayPad]);
			afbDryPad[nCntDrayPad].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbDryPad[nCntDrayPad].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_DummyTool:
		IF nCntDummyTool = cMaxDummyTools THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntDummyToolExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntDummyTool := nCntDummyTool + 1;
			a_pObjects[nObjectID] := ADR(afbDummyTool[nCntDummyTool]);
			afbDummyTool[nCntDummyTool].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbDummyTool[nCntDummyTool].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
 		END_IF		
		
	E_ObjectType.OBJECTTYPE_Exposure:
		IF nCntExposure = cMaxExposure THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntExposureExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntExposure := nCntExposure + 1;
			a_pObjects[nObjectID] := ADR(afbExposure[nCntExposure]);
			afbExposure[nCntExposure].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbExposure[nCntExposure].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_Extruder:
		IF nCntExtruder = cMaxExtruder THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntExtruderExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntExtruder := nCntExtruder + 1;
			a_pObjects[nObjectID] := ADR(afbExtruder[nCntExtruder]);
			afbExtruder[nCntExtruder].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbExtruder[nCntExtruder].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF	
		
	E_ObjectType.OBJECTTYPE_FlipTube:
			pFlipTube := __NEW(FB_FlipTube);
			pFlipTube^.P_nObjectID := nObjectID;
			a_pObjects[nObjectID] := pFlipTube;	
		
	E_ObjectType.OBJECTTYPE_FlipTubeHandler:	//FlipTubeHandler
		IF nCntFlipTubeHandler = cMaxFlipTubeHandler THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntFlipTubePinExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntFlipTubeHandler := nCntFlipTubeHandler + 1;
			a_pObjects[nObjectID] := ADR(afbFlipTubeHandler[nCntFlipTubeHandler]);
			afbFlipTubeHandler[nCntFlipTubeHandler].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbFlipTubeHandler[nCntFlipTubeHandler].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_FlipTubeRack:
		IF nCntFlipTubeRack = cMaxFlipTubeRack THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntFlipTubeRackExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntFlipTubeRack := nCntFlipTubeRack + 1;
			a_pObjects[nObjectID] := ADR(afbFlipTubeRack[nCntFlipTubeRack]);
			afbFlipTubeRack[nCntFlipTubeRack].P_nObjectID := nObjectID;
		END_IF
		
	E_ObjectType.OBJECTTYPE_Gripper:
		IF nCntGripper = cMaxGripper THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntGripperExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntGripper := nCntGripper + 1;
			a_pObjects[nObjectID] := ADR(afbGripper[nCntGripper]);
			afbGripper[nCntGripper].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbGripper[nCntGripper].P_nNotifyId := nCntNotifiIds;
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_HighVoltTray:
		IF nCntHighVoltTray = cMaxHighVoltTray THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntHighVoltTrayExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntHighVoltTray := nCntHighVoltTray + 1;
			a_pObjects[nObjectID] := ADR(afbHighVoltTray[nCntHighVoltTray]);
			afbHighVoltTray[nCntHighVoltTray].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbHighVoltTray[nCntHighVoltTray].P_nNotifyId := nCntNotifiIds;			
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_InkStation:
		IF nCntInkStation = cMaxInkStations THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_CntInkStationsExceeded;	//Rückgabe Error
			RETURN;
		ELSE
			nCntInkStation := nCntInkStation + 1;
			a_pObjects[nObjectID] := ADR(afbInkStation[nCntInkStation]);
			afbInkStation[nCntInkStation].P_nObjectID := nObjectID;
			nCntNotifiIds := nCntNotifiIds + 1;
			afbInkStation[nCntInkStation].P_nNotifyId := nCntNotifiIds;			
			nNotifyId := nCntNotifiIds;
		END_IF
		
	E_ObjectType.OBJECTTYPE_LiquidReserve:
		IF nCntLiquidReserve = cMaxLiquidReserve THEN	//maximale Anzahl des spez.Objecttypes erreicht, Object kann nicht angelegt werden
			M_CreateObject := E_ErrorIdObjMgmt.ERRORID_Cnt4LiquidReserveExceeded;	//Rückgabe Error
			RETURN;
		ELSE
