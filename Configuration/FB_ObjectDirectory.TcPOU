    <Method Name="M_RemoveObjChange" Id="{79614ad8-3893-4bcc-a6c4-0beab649fa92}">
      <Declaration><![CDATA[METHOD M_RemoveObjChange
VAR_INPUT
	nObjectId : UINT;
END_VAR

VAR
	getPosPtr : POINTER TO T_LinkedListEntry;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[fbList.A_FindNext(hList:= hList, putPosPtr:= 0, putValue:= UINT_TO_UDINT(nObjectId), getPosPtr=> getPosPtr);
IF fbList.bOk THEN //Eintrag vorhanden
	fbList.A_RemoveValueAtPosPtr(hList:= hList, putPosPtr := getPosPtr);
END_IF]]></ST>
      </Implementation>
