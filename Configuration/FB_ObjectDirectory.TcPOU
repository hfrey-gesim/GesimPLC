    <Method Name="M_SetObjChange" Id="{50b26a62-d0ed-4393-b2b5-0940555eb488}">
      <Declaration><![CDATA[METHOD M_SetObjChange
VAR_INPUT
	nObjectId : UINT;
END_VAR

VAR
	putValue : UDINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[putValue := UINT_TO_UDINT(nObjectId);
//Checken, ob schon eingetragen
fbList.A_FindNext(hList:= hList, putPosPtr:= 0, putValue:= putValue);
IF NOT fbList.bOk THEN //Eintrag noch nicht vorhanden
	fbList.A_AddHeadValue(hList:= hList, putValue:= putValue);	
	nObjPropChangeCnt := nObjPropChangeCnt + 1;
END_IF]]></ST>
      </Implementation>
    </Method>
