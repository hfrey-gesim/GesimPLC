    <Method Name="M_MoveObject" Id="{2bca388a-ceae-4fd2-9159-839ab2ac382c}">
      <Declaration><![CDATA[METHOD M_MoveObject : ERRORID
VAR_INPUT
	pObject : POINTER TO FB_Object;
	pDestObject : POINTER TO FB_Object;
	nDestSlotNr	: UINT;
END_VAR

VAR
	pSlot : POINTER TO FB_Slot;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[//Verschiebt ein Objekt zu einem neuen Objekt oder zu einem anderen Slot.
IF pObject > 0 THEN
	IF pObject^.P_pParentObject > 0 AND_THEN pDestObject > 0 THEN
		IF nDestSlotNr > 0 THEN
			pSlot := pDestObject^.M_GetSlot(nDestSlotNr);
			IF pSlot > 0 THEN
				IF pSlot^.P_pChild > 0 THEN
					M_MoveObject := E_ErrorIdObjMgmt.ERRORID_DestinationSlotNotFree;
					RETURN;
				END_IF
			ELSE
				M_MoveObject := E_ErrorIdObjMgmt.ERRORID_InvalidDestinationSlot;
				RETURN;
			END_IF
		END_IF
		M_MoveObject := pObject^.P_pParentObject^.M_RemoveChild(pObject);
		IF M_MoveObject = 0 THEN
			M_MoveObject := pDestObject^.M_AddChild(pObject,nDestSlotNr,-1);
			//M_SetObjChange(pObject^.P_nObjectID);
			stObjectHasMoved.ObjectId := pObject^.P_nObjectID;
			stObjectHasMoved.DestObjId := pDestObject^.P_nObjectID;
			stObjectHasMoved.DestSlotNr := nDestSlotNr;
			stObjectHasMoved.ChangeCounter := stObjectHasMoved.ChangeCounter + 1;
		END_IF
	ELSE
		M_MoveObject := E_ErrorIdObjMgmt.ERRORID_InvalidObject;
	END_IF
ELSE
	M_MoveObject := E_ErrorIdObjMgmt.ERRORID_InvalidObject;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="M_ObjIsArray" Id="{af1a1a5d-6db0-48f9-9108-e4896b8c5c61}">
      <Declaration><![CDATA[METHOD M_ObjIsArray : BOOL
VAR_INPUT
	nObjectId	: UINT;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF nObjectId > 0 AND nObjectId <= cMaxObjects THEN
	IF (a_pObjects[nObjectId]^.P_eObjectGroup AND E_ObjectGroup.OBJECTGROUP_Array) = E_ObjectGroup.OBJECTGROUP_Array THEN
		M_ObjIsArray := TRUE;
	END_IF
END_IF]]></ST>
      </Implementation>
    </Method>
